REPORT_SOURCE=unfiltered
FILTERED_TARGET_URL=https://dashboard-tracking.punjab.gov.pk/user_wise_larva_report?district_id=18&date_range=0&dormant_users=true&line_listing=true&status=false&title=Dormant+Users
UNFILTERED_TARGET_URL=https://dashboard-tracking.punjab.gov.pk/user_wise_larva_report?district_id=18&date_range=0

PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO_MS=300
GENERATE_SCREENSHOT=false

NATS_URL=nats://localhost:4222
