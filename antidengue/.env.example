WA_WAIT_FOR_DELIVERY=true
WA_HEALTH_TIMEOUT_SECONDS=5
WA_DELIVERY_TIMEOUT_SECONDS=900
WA_ATTACHMENT_TEXT_MODE=separate
WA_INCLUDE_EXCEL_FOR_DDEO=true
