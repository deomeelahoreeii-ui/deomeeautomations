APP_NAME=Automation Platform
DATABASE_URL=postgresql+psycopg://automation:change-me@127.0.0.1:5432/automation_platform
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
# Job state is stored in PostgreSQL/SQLite, so a Celery result backend is optional.
CELERY_RESULT_BACKEND=
CELERY_FILESYSTEM_FOLDER=./data/celery-broker
DEOMEE_ROOT=/home/ahmad/code/deomeeautomations
CRM_PROJECT_ROOT=/home/ahmad/code/deomeeautomations/crm-management-system
# Native CRM sheet filtering uses Paperless directly. Prefer PAPERLESS_TOKEN when available.
PAPERLESS_URL=https://paperless.lab.internal/dashboard
PAPERLESS_USERNAME=
PAPERLESS_PASSWORD=
PAPERLESS_TOKEN=
PAPERLESS_VERIFY_SSL=true
# Preferred for an internal/self-signed Paperless certificate: path to the issuing CA PEM file.
PAPERLESS_CA_BUNDLE=
# Development fallback only: retry without certificate verification for trusted internal/private hosts.
PAPERLESS_ALLOW_INSECURE_FALLBACK=true
PAPERLESS_TIMEOUT_SECONDS=15
PAPERLESS_DOCUMENT_TYPE_COMPLAINT=Complaint
PAPERLESS_MAX_PAGES=10
ANTIDENGUE_PROJECT_ROOT=/home/ahmad/code/deomeeautomations/antidengue
ANTIDENGUE_PYTHON_BIN=/home/ahmad/code/deomeeautomations/antidengue/.venv/bin/python
ANTIDENGUE_POCKETBASE_DB_PATH=/home/ahmad/code/deomeeautomations/antidengue-pocketbase/pb_data/data.db
ARTIFACT_ROOT=./data/artifacts
SOURCE_FILE_MAX_BYTES=52428800
LEGACY_UV_BIN=/home/ahmad/.local/bin/uv
WHATSAPP_NATS_URL=nats://127.0.0.1:4222
WHATSAPP_COMMAND_SUBJECT=whatsapp.pending
WHATSAPP_HEALTH_SUBJECT=whatsapp.worker.health
WHATSAPP_QR_IMAGE_PATH=./data/whatsapp/login-qr.png
API_CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,http://localhost:5173,http://127.0.0.1:5173
