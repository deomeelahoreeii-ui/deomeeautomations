APP_NAME=Automation Platform
LOG_LEVEL=INFO
LOG_FORMAT=json

# Compose-only infrastructure credentials. Replace these before sharing a host
# with other users or exposing any service through a reverse proxy.
POSTGRES_PASSWORD=change-me
RABBITMQ_USER=automation
RABBITMQ_PASSWORD=change-me
FLOWER_BASIC_AUTH=automation:change-me
APP_UID=1000
APP_GID=1000

DATABASE_URL=postgresql+psycopg://automation:change-me@127.0.0.1:5432/automation_platform
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
# Job state is stored in PostgreSQL/SQLite, so a Celery result backend is optional.
CELERY_RESULT_BACKEND=
CELERY_FILESYSTEM_FOLDER=./data/celery-broker
DEOMEE_ROOT=..
CRM_PROJECT_ROOT=../crm-management-system
# Native CRM sheet filtering uses Paperless directly. Prefer PAPERLESS_TOKEN when available.
PAPERLESS_URL=https://paperless.lab.internal/dashboard
PAPERLESS_USERNAME=
PAPERLESS_PASSWORD=
PAPERLESS_TOKEN=
PAPERLESS_VERIFY_SSL=true
# Preferred for an internal/self-signed Paperless certificate: path to the issuing CA PEM file.
PAPERLESS_CA_BUNDLE=
# Development fallback only: retry without certificate verification for trusted internal/private hosts.
PAPERLESS_ALLOW_INSECURE_FALLBACK=true
PAPERLESS_TIMEOUT_SECONDS=15
PAPERLESS_DOCUMENT_TYPE_COMPLAINT=Complaint
PAPERLESS_DOCUMENT_TYPE_ATTACHMENT=Attachment
PAPERLESS_CORRESPONDENT_NAME=CEO, (DEA), Lahore
PAPERLESS_MAX_PAGES=10
# Active CRM jobs with no progress log for this long are closed as stale.
CRM_JOB_STALE_MINUTES=15
ANTIDENGUE_PROJECT_ROOT=../antidengue
ANTIDENGUE_PYTHON_BIN=../antidengue/.venv/bin/python
ARTIFACT_ROOT=./data/artifacts
SOURCE_FILE_MAX_BYTES=52428800
LEGACY_UV_BIN=uv
WHATSAPP_NATS_URL=nats://127.0.0.1:4222
WHATSAPP_COMMAND_SUBJECT=whatsapp.pending
WHATSAPP_HEALTH_SUBJECT=whatsapp.worker.health
WHATSAPP_QR_IMAGE_PATH=./data/whatsapp/login-qr.png
API_CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,http://localhost:5173,http://127.0.0.1:5173
API_ALLOWED_HOSTS=localhost,127.0.0.1,testserver,api
PUBLIC_API_BASE_URL=http://127.0.0.1:8020

# Shared secret used by the WhatsApp worker to mirror inbound metadata into FastAPI.
WHATSAPP_INBOUND_INGEST_TOKEN=replace-with-a-long-random-secret
# Worker request/reply subject used for on-demand inbound media archiving.
WHATSAPP_INBOUND_MEDIA_SUBJECT=whatsapp.worker.inbound.media
WHATSAPP_INBOUND_MEDIA_MAX_BYTES=78643200
WHATSAPP_INBOUND_MEDIA_TIMEOUT_SECONDS=180
# Historical provider. wwebjs is the default; baileys preserves the legacy implementation.
WHATSAPP_INBOUND_HISTORY_PROVIDER=wwebjs
# Legacy Baileys history subject, retained for optional future use.
WHATSAPP_INBOUND_HISTORY_SUBJECT=whatsapp.worker.inbound.history
# whatsapp-web.js bridge subject used by normal historical backfill.
WHATSAPP_WEB_HISTORY_SUBJECT=whatsapp.web.inbound.history
WHATSAPP_INBOUND_HISTORY_TIMEOUT_SECONDS=15

# S3-compatible durable archive for WhatsApp inbound files.
# Works with RustFS, SeaweedFS and other path-style S3 implementations.
OBJECT_STORAGE_ENABLED=false
OBJECT_STORAGE_PROVIDER=s3
# RustFS default: http://127.0.0.1:9000
# SeaweedFS weed mini default: http://127.0.0.1:8333
OBJECT_STORAGE_ENDPOINT_URL=http://127.0.0.1:9000
# Optional address used only by containers when the browser/host address above
# is not reachable inside Docker.
OBJECT_STORAGE_CONTAINER_ENDPOINT_URL=http://host.docker.internal:9000
OBJECT_STORAGE_ACCESS_KEY=change-me
OBJECT_STORAGE_SECRET_KEY=change-me
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PATH_STYLE=true
OBJECT_STORAGE_VERIFY_SSL=false
OBJECT_STORAGE_CA_BUNDLE=
OBJECT_STORAGE_AUTO_CREATE_BUCKETS=true
OBJECT_STORAGE_RAW_BUCKET=whatsapp-inbound-raw
OBJECT_STORAGE_MANIFEST_BUCKET=whatsapp-inbound-manifests
OBJECT_STORAGE_DERIVED_BUCKET=whatsapp-inbound-derived
# Shared platform buckets for AntiDengue and future modules. Existing WhatsApp/CRM
# inbound objects remain in the compatibility buckets above during migration.
PLATFORM_STORAGE_RAW_BUCKET=automation-raw
PLATFORM_STORAGE_MANIFEST_BUCKET=automation-manifests
PLATFORM_STORAGE_DERIVED_BUCKET=automation-derived
OBJECT_STORAGE_CONNECT_TIMEOUT_SECONDS=5
OBJECT_STORAGE_READ_TIMEOUT_SECONDS=120

# AntiDengue writes each run to a job-scoped local workspace, then RustFS becomes
# authoritative after checksum verification. Verified local files are cache only.
ANTIDENGUE_LOCAL_RETENTION_HOURS=24
ANTIDENGUE_FAILED_WORKSPACE_RETENTION_HOURS=168
ANTIDENGUE_RETENTION_ENABLED=true
ANTIDENGUE_RETENTION_INTERVAL_SECONDS=3600

# WhatsApp inbound CRM categorization (Bundle 4C)
CRM_COMPLAINT_PREFIXES=104
CRM_COMPLAINT_SUFFIX_DIGITS=7
WHATSAPP_PROCESSING_CLASSIFIER_VERSION=crm-classifier-v1
WHATSAPP_PROCESSING_CRM_RULE_VERSION=crm-104-v1
WHATSAPP_PROCESSING_TEXT_LIMIT=100000

ANTIDENGUE_SCHEDULER_ENABLED=true
ANTIDENGUE_SCHEDULER_INTERVAL_SECONDS=10

# Shared ntfy transport. Localhost is the secure first-stage default.
# For LAN access set NTFY_EXPOSURE_MODE=lan, NTFY_BIND_ADDRESS to the laptop's
# LAN IP, and NTFY_PUBLIC_BASE_URL to http://<laptop-lan-ip>:2586.
# Tailscale/Cloudflare will keep the local bind and only change the public URL.
NTFY_ENABLED=false
NTFY_EXPOSURE_MODE=local
NTFY_BIND_ADDRESS=127.0.0.1
NTFY_PORT=2586
NTFY_PUBLISH_URL=http://127.0.0.1:2586
NTFY_PUBLIC_BASE_URL=http://localhost:2586
NTFY_TOKEN=
NTFY_TIMEOUT_SECONDS=5
NTFY_CACHE_DURATION=72h
NTFY_KEEPALIVE_INTERVAL=45s

# Module-level route; browser sound preferences remain per device.
ANTIDENGUE_NTFY_ENABLED=false
ANTIDENGUE_NTFY_TOPIC=automation-antidengue

# Frappe Helpdesk complaint workflow integration (Bundle 1)
FRAPPE_HELPDESK_ENABLED=false
FRAPPE_HELPDESK_URL=http://127.0.0.1:8082
# Optional address used by API/worker containers for a host-native Frappe.
FRAPPE_HELPDESK_CONTAINER_URL=http://host.docker.internal:8082
FRAPPE_HELPDESK_PUBLIC_URL=http://localhost:8082
FRAPPE_HELPDESK_SITE=helpdesk.localhost
FRAPPE_HELPDESK_API_KEY=
FRAPPE_HELPDESK_API_SECRET=
FRAPPE_HELPDESK_TIMEOUT_SECONDS=15
FRAPPE_HELPDESK_PREVIEW_TOKEN_TTL_SECONDS=1800
FRAPPE_HELPDESK_VERIFY_SSL=true
FRAPPE_HELPDESK_CA_BUNDLE=
FRAPPE_HELPDESK_DEFAULT_RAISED_BY=complaints@deomee.local
FRAPPE_HELPDESK_DEFAULT_PRIORITY=Medium
FRAPPE_HELPDESK_DEFAULT_STATUS=New
# Comma-separated CRM states eligible for one-way ticket creation.
FRAPPE_HELPDESK_SYNC_STATES=published
FRAPPE_HELPDESK_CRM_PUBLIC_URL=http://localhost:4321
# Optional, e.g. {base_url}/documents/{document_id}/details
FRAPPE_HELPDESK_PAPERLESS_URL_TEMPLATE=
FRAPPE_HELPDESK_FALLBACK_AGENT_EMAIL=ahmadkakarr@gmail.com
FRAPPE_HELPDESK_TRIAGE_TEAM=Complaint Triage
FRAPPE_HELPDESK_TEAM_PREFIX=Complaints
FRAPPE_HELPDESK_APPROVED_REPLY_STATUSES=Approved,Issued
