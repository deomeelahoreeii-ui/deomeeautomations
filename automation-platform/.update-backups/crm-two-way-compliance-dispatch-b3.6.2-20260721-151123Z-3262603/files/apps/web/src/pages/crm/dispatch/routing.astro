---
import CrmLayout from "../../../layouts/CrmLayout.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="CRM Dispatch Routing" description="Manage controlled WhatsApp destinations, message templates and deterministic complaint routing rules." page="dispatch">
  <a class="btn btn-sm" href="/crm/dispatch/" slot="actions">← Dispatch Queue</a>
  <main id="crm-routing" class="crm32-page crm-routing-page" data-api-base={apiBase}>
    <nav class="dispatch-tabs" aria-label="CRM dispatch pages"><a href="/crm/dispatch/">Dispatch Queue</a><a href="/crm/dispatch/">Batches</a><a class="active" href="/crm/dispatch/routing/">Routing</a><a href="/crm/dispatch/">Delivery History</a></nav>
    <section class="master-card routing-intro"><header class="crm-card-heading"><div><p class="eyebrow">Controlled dispatch</p><h2>Separate destinations from routing rules</h2><p>A destination profile defines who receives the packet and how it is sent. Routing rules decide when a complaint should use that destination. WhatsApp contacts and groups always come from the synchronized directory.</p></div></header></section>
    <nav class="routing-workspace-tabs"><button class="active" type="button" data-view="profiles">Destination Profiles</button><button type="button" data-view="rules">Routing Rules</button><button type="button" data-view="test">Test Routing</button></nav>

    <section id="profiles-view" class="master-card routing-view active">
      <header class="crm-card-heading"><div><p class="eyebrow">Who and how</p><h2>Destination profiles</h2><p>Each profile owns a synchronized audience, message template, packet policy and approval safeguards.</p></div><button id="new-profile" class="btn btn-primary btn-sm" type="button">＋ New destination profile</button></header>
      <div id="profile-list" class="routing-profile-grid"><p class="crm-empty-state compact">Loading destination profiles…</p></div>
    </section>

    <section id="rules-view" class="master-card routing-view" hidden>
      <header class="crm-card-heading"><div><p class="eyebrow">When to route</p><h2>Deterministic routing rules</h2><p>Rules use category, subcategory, controlled tags, tehsil, district and source. Equal-priority conflicts are blocked for human review.</p></div><button id="new-rule" class="btn btn-primary btn-sm" type="button">＋ New routing rule</button></header>
      <div id="rule-list" class="routing-rule-list"><p class="crm-empty-state compact">Loading routing rules…</p></div>
    </section>

    <section id="test-view" class="master-card routing-view" hidden>
      <header class="crm-card-heading"><div><p class="eyebrow">Explainable routing</p><h2>Test Routing</h2><p>Enter a complaint case UUID to see matching rules, selected destination profiles, conflicts and fallback behavior without creating a dispatch batch.</p></div></header>
      <div class="dispatch-routing-test">
        <label class="crm-field"><span>Complaint case UUID</span><input id="routing-test-case" class="input input-bordered" placeholder="00000000-0000-0000-0000-000000000000" /></label>
        <button id="run-routing-test" class="btn btn-primary" type="button">Run routing test</button>
      </div>
      <div id="routing-test-result" class="dispatch-routing-test-result"><p class="crm-empty-state compact">No routing test has been run.</p></div>
    </section>

    <dialog id="profile-dialog" class="crm-modal"><form method="dialog" class="crm-modal-shell dispatch-profile-dialog" id="profile-form"><header class="crm-modal-header"><div><p class="eyebrow">CRM DESTINATION PROFILE</p><h2 id="profile-title">New destination profile</h2></div><button type="button" data-close-profile>×</button></header><div class="crm-modal-body">
      <input id="profile-id" type="hidden" />
      <div class="dispatch-profile-steps">
        <section><span>1</span><div><h3>Destinations</h3><p>Choose one recipient type and one or more synchronized targets.</p></div></section>
        <section><span>2</span><div><h3>Message and packet</h3><p>Configure the exact text and attachment policy.</p></div></section>
        <section><span>3</span><div><h3>Safety</h3><p>Approval, rate and retry safeguards.</p></div></section>
      </div>
      <div class="official-letter-form-grid">
        <label class="crm-field"><span>Profile name</span><input id="profile-name" class="input input-bordered" required placeholder="DDEO Model Town — CRM Complaints" /></label>
        <label class="crm-field"><span>Recipient type</span><select id="profile-target-type" class="select select-bordered"><option value="contact">Official contact(s)</option><option value="group">Official group(s)</option></select></label>
      </div>
      <div class="dispatch-directory-picker"><div class="dispatch-directory-toolbar"><label class="crm-field"><span>Search synchronized directory</span><input id="directory-search" class="input input-bordered" placeholder="Name, number or group…" /></label><button id="refresh-directory" class="btn btn-sm" type="button">↻ Refresh</button></div><div id="directory-results" class="dispatch-directory-results"><p>Search or refresh the directory.</p></div><div id="selected-destinations" class="dispatch-selected-chips"></div></div>
      <label class="crm-field full"><span>WhatsApp message template</span><textarea id="profile-template" class="textarea textarea-bordered" rows="7"></textarea><small>Supported variables: complaint_number, category, subcategory, letter_number, letter_date, packet_page_count, response_due_date, dispatch_purpose and instructions.</small></label>
      <div class="official-letter-form-grid">
        <label class="crm-field"><span>Packet policy</span><select id="profile-packet" class="select select-bordered"><option value="complete_pdf">Complete PDF required</option></select></label>
        <label class="crm-field"><span>Privacy policy</span><select id="profile-privacy" class="select select-bordered"><option value="full">Standard verified destination</option><option value="restricted">Restricted destination (allows confidential complaints)</option></select></label>
        <label class="crm-field"><span>Maximum packet size (MB)</span><input id="profile-max-size" class="input input-bordered" type="number" min="1" max="100" value="15" /></label>
        <label class="crm-field"><span>Messages per minute</span><input id="profile-rate" class="input input-bordered" type="number" min="1" max="120" value="20" /></label>
        <label class="crm-field"><span>Maximum retries</span><input id="profile-retries" class="input input-bordered" type="number" min="0" max="20" value="5" /></label>
      </div>
      <label class="crm-check-row"><input id="profile-approval" class="checkbox" type="checkbox" checked /><span><strong>Require explicit approval</strong><small>Freeze exact recipients, message and packet before queueing real WhatsApp deliveries.</small></span></label>
      <label class="crm-check-row"><input id="profile-enabled" class="checkbox" type="checkbox" checked /><span><strong>Profile active</strong><small>Inactive profiles cannot be selected by routing rules.</small></span></label>
      <p id="profile-message" class="form-message"></p>
    </div><footer class="crm-modal-footer"><button type="button" class="btn" data-close-profile>Cancel</button><button id="save-profile" class="btn btn-primary" type="submit">Save destination profile</button></footer></form></dialog>

    <dialog id="rule-dialog" class="crm-modal"><form method="dialog" class="crm-modal-shell dispatch-rule-dialog" id="rule-form"><header class="crm-modal-header"><div><p class="eyebrow">CRM ROUTING RULE</p><h2 id="rule-title">New routing rule</h2></div><button type="button" data-close-rule>×</button></header><div class="crm-modal-body">
      <input id="rule-id" type="hidden" />
      <div class="official-letter-form-grid"><label class="crm-field"><span>Rule name</span><input id="rule-name" class="input input-bordered" required /></label><label class="crm-field"><span>Priority</span><input id="rule-priority" class="input input-bordered" type="number" value="100" /></label><label class="crm-field"><span>Selection mode</span><select id="rule-mode" class="select select-bordered"><option value="suggested">Suggested automatically</option><option value="manual_only">Manual only</option><option value="fallback">Default fallback</option></select></label><label class="crm-field full"><span>Description</span><textarea id="rule-description" class="textarea textarea-bordered" rows="2"></textarea></label></div>
      <section class="routing-condition-builder"><h3>Conditions</h3><p>Leave a field blank to ignore it. Separate multiple values with commas.</p><div class="official-letter-form-grid"><label class="crm-field"><span>Categories</span><input id="rule-categories" class="input input-bordered" placeholder="Fee, Administrative" /></label><label class="crm-field"><span>Subcategories</span><input id="rule-subcategories" class="input input-bordered" placeholder="Summer Vacations" /></label><label class="crm-field"><span>Any tags</span><input id="rule-tags-any" class="input input-bordered" placeholder="private-school, advance-fee" /></label><label class="crm-field"><span>All tags</span><input id="rule-tags-all" class="input input-bordered" /></label><label class="crm-field"><span>Excluded tags</span><input id="rule-exclude-tags" class="input input-bordered" /></label><label class="crm-field"><span>Institution types</span><input id="rule-institutions" class="input input-bordered" placeholder="private-school" /></label><label class="crm-field"><span>Tehsils</span><input id="rule-tehsils" class="input input-bordered" /></label><label class="crm-field"><span>Districts</span><input id="rule-districts" class="input input-bordered" /></label><label class="crm-field"><span>Sources</span><input id="rule-sources" class="input input-bordered" placeholder="crm_portal" /></label></div></section>
      <section class="routing-profile-selector"><h3>Destination profiles</h3><div id="rule-profile-options" class="routing-profile-options"></div></section>
      <label class="crm-check-row"><input id="rule-stop" class="checkbox" type="checkbox" checked /><span><strong>Stop after this priority match</strong><small>Prevents lower-priority rules from adding unintended destinations.</small></span></label><label class="crm-check-row"><input id="rule-enabled" class="checkbox" type="checkbox" checked /><span><strong>Rule active</strong><small>Inactive rules remain in history but are ignored.</small></span></label>
      <p id="rule-message" class="form-message"></p>
    </div><footer class="crm-modal-footer"><button type="button" class="btn" data-close-rule>Cancel</button><button id="save-rule" class="btn btn-primary" type="submit">Save routing rule</button></footer></form></dialog>
    <div id="routing-toast" class="crm-toast" role="status" hidden></div>
  </main>
  <script>
    const root=document.getElementById('crm-routing') as HTMLElement;const API=root.dataset.apiBase||'';const $=(id:string)=>document.getElementById(id) as any;let profiles:any[]=[];let rules:any[]=[];let selectedTargets=new Map<string,any>();
    const DEFAULT=`Respected Sir/Madam,\n\nComplaint No. {{complaint_number}} is forwarded for necessary action in accordance with the attached official letter No. {{letter_number}} dated {{letter_date}}.\n\nThe complete complaint record is attached as a PDF.\n\nPlease process the matter in accordance with applicable rules and policy.`;
    function toast(m:string,e=false){const n=$('routing-toast');n.textContent=m;n.className=`crm-toast${e?' error':''}`;n.hidden=false;window.setTimeout(()=>n.hidden=true,5000)}
    async function api(path:string,init?:RequestInit){const h=new Headers(init?.headers||{});if(init?.body)h.set('Content-Type','application/json');const r=await fetch(`${API}${path}`,{...init,headers:h});const b=await r.json().catch(()=>({}));if(!r.ok)throw new Error(typeof b.detail==='string'?b.detail:r.statusText);return b}
    document.querySelectorAll<HTMLButtonElement>('[data-view]').forEach(b=>b.addEventListener('click',()=>{document.querySelectorAll('[data-view]').forEach(x=>x.classList.toggle('active',x===b));const view=b.dataset.view;['profiles','rules','test'].forEach(x=>$(x+'-view').hidden=x!==view)}));
    const close=(dialog:HTMLDialogElement)=>dialog.close();document.querySelectorAll('[data-close-profile]').forEach(x=>x.addEventListener('click',()=>close($('profile-dialog'))));document.querySelectorAll('[data-close-rule]').forEach(x=>x.addEventListener('click',()=>close($('rule-dialog'))));
    function profileCard(p:any){const a=document.createElement('article');a.className=`routing-profile-card${p.enabled?'':' inactive'}`;const h=document.createElement('header');const d=document.createElement('div');d.innerHTML=`<strong>${p.name}</strong><small>${p.targets.length} destination${p.targets.length===1?'':'s'} · ${p.account_name}</small>`;const status=document.createElement('span');status.className=`crm-status-badge ${p.enabled?'success':'warning'}`;status.textContent=p.enabled?'Active':'Inactive';h.append(d,status);const targets=document.createElement('div');targets.className='routing-target-chips';for(const t of p.targets){const s=document.createElement('span');s.textContent=`${t.target_type==='group'?'Group':'Contact'} · ${t.name}${t.available?'':' · unavailable'}`;targets.append(s)}const policy=document.createElement('p');policy.textContent=`${p.packet_policy.replaceAll('_',' ')} · ${p.privacy_policy} privacy · approval ${p.require_approval?'required':'optional'} · v${p.version}`;const footer=document.createElement('footer');const edit=document.createElement('button');edit.type='button';edit.className='btn btn-sm';edit.textContent='Edit profile';edit.addEventListener('click',()=>openProfile(p));const toggle=document.createElement('button');toggle.type='button';toggle.className='btn btn-sm';toggle.textContent=p.enabled?'Deactivate':'Activate';toggle.addEventListener('click',async()=>{await api(`/api/v1/crm/dispatch/profiles/${p.id}/enabled`,{method:'PATCH',body:JSON.stringify({enabled:!p.enabled})});await loadProfiles()});footer.append(edit,toggle);a.append(h,targets,policy,footer);return a}
    function renderProfiles(){$('profile-list').replaceChildren(...(profiles.length?profiles.map(profileCard):[Object.assign(document.createElement('p'),{className:'crm-empty-state compact',textContent:'No CRM destination profiles exist yet.'})]));renderRuleProfileOptions()}
    function ruleCard(r:any){const a=document.createElement('article');a.className=`routing-rule-card${r.enabled?'':' inactive'}`;const when=Object.entries(r.conditions||{}).map(([k,v]:any)=>`${k.replaceAll('_',' ')}: ${Array.isArray(v)?v.join(', '):v}`).join(' · ')||'Fallback / no conditions';const profilesText=r.profiles.map((p:any)=>p.name).join(', ');a.innerHTML=`<div><strong>${r.name}</strong><small>Priority ${r.priority} · ${r.selection_mode.replaceAll('_',' ')}</small><p><b>WHEN</b> ${when}</p><p><b>SEND TO</b> ${profilesText}</p></div>`;const actions=document.createElement('div');actions.className='table-actions';const edit=document.createElement('button');edit.className='btn btn-sm';edit.type='button';edit.textContent='Edit';edit.addEventListener('click',()=>openRule(r));const toggle=document.createElement('button');toggle.className='btn btn-sm';toggle.type='button';toggle.textContent=r.enabled?'Deactivate':'Activate';toggle.addEventListener('click',async()=>{await api('/api/v1/crm/dispatch/rules',{method:'POST',body:JSON.stringify({...r,id:r.id,conditions:r.conditions,profile_ids:r.profile_ids,enabled:!r.enabled})});await loadRules()});actions.append(edit,toggle);a.append(actions);return a}
    function renderRules(){$('rule-list').replaceChildren(...(rules.length?rules.map(ruleCard):[Object.assign(document.createElement('p'),{className:'crm-empty-state compact',textContent:'No routing rules exist yet. Complaints will require manual routing.'})]))}
    async function loadProfiles(){const r=await api('/api/v1/crm/dispatch/profiles?include_inactive=true');profiles=r.items||[];renderProfiles()}
    async function loadRules(){const r=await api('/api/v1/crm/dispatch/rules?include_inactive=true');rules=r.items||[];renderRules()}
    function renderSelected(){const chips=[...selectedTargets.values()].map(t=>{const s=document.createElement('span');s.className='dispatch-selected-chip';s.textContent=t.name;const b=document.createElement('button');b.type='button';b.textContent='×';b.addEventListener('click',()=>{selectedTargets.delete(t.id);renderSelected();loadDirectory()});s.append(b);return s});$('selected-destinations').replaceChildren(...chips)}
    async function loadDirectory(){const type=$('profile-target-type').value;const search=encodeURIComponent($('directory-search').value||'');const path=type==='group'?`/api/v1/whatsapp/directory/groups?availability=available&page_size=50&search=${search}`:`/api/v1/whatsapp/directory/contacts?page_size=50&search=${search}`;const r=await api(path);const rows=(r.items||[]).map((t:any)=>{const id=t.id;const label=document.createElement('label');label.className='dispatch-directory-option';const input=document.createElement('input');input.type='checkbox';input.className='checkbox checkbox-sm';input.checked=selectedTargets.has(id);input.addEventListener('change',()=>{input.checked?selectedTargets.set(id,{id,name:t.name||t.display_name||t.identifier,target_type:type}):selectedTargets.delete(id);renderSelected()});const body=document.createElement('span');body.innerHTML=`<strong>${t.name||t.display_name||'Unnamed'}</strong><small>${t.jid||t.phone_jid||t.identifier||''}${t.participant_count?` · ${t.participant_count} participants`:''}</small>`;label.append(input,body);return label});$('directory-results').replaceChildren(...(rows.length?rows:[Object.assign(document.createElement('p'),{textContent:'No synchronized destinations match.'})]));renderSelected()}
    function openProfile(p:any=null){$('profile-id').value=p?.id||'';$('profile-name').value=p?.name||'';$('profile-target-type').value=p?.recipient_channel==='group'?'group':'contact';$('profile-template').value=p?.template_body||DEFAULT;$('profile-packet').value=p?.packet_policy||'complete_pdf';$('profile-privacy').value=p?.privacy_policy||'full';$('profile-max-size').value=Math.round((p?.max_packet_bytes||15*1024*1024)/1024/1024);$('profile-rate').value=p?.messages_per_minute||20;$('profile-retries').value=p?.max_retries||5;$('profile-approval').checked=p?.require_approval!==false;$('profile-enabled').checked=p?.enabled!==false;selectedTargets=new Map((p?.targets||[]).map((t:any)=>[t.target_id,{id:t.target_id,name:t.name,target_type:t.target_type}]));$('profile-title').textContent=p?'Edit destination profile':'New destination profile';$('profile-message').textContent='';$('profile-dialog').showModal();void loadDirectory()}
    function split(id:string){return $('rule-'+id).value.split(',').map((x:string)=>x.trim()).filter(Boolean)}
    function renderRuleProfileOptions(selected:string[]=[]){const current=new Set(selected.length?selected:Array.from(document.querySelectorAll<HTMLInputElement>('[data-rule-profile]:checked')).map(x=>x.value));const nodes=profiles.filter(x=>x.enabled).map(p=>{const label=document.createElement('label');label.className='routing-profile-option';const input=document.createElement('input');input.type='checkbox';input.className='checkbox checkbox-sm';input.dataset.ruleProfile='1';input.value=p.id;input.checked=current.has(p.id);const span=document.createElement('span');span.innerHTML=`<strong>${p.name}</strong><small>${p.targets.length} destination${p.targets.length===1?'':'s'}</small>`;label.append(input,span);return label});$('rule-profile-options').replaceChildren(...nodes)}
    function openRule(r:any=null){$('rule-id').value=r?.id||'';$('rule-name').value=r?.name||'';$('rule-description').value=r?.description||'';$('rule-priority').value=r?.priority||100;$('rule-mode').value=r?.selection_mode||'suggested';const c=r?.conditions||{};$('rule-categories').value=(c.categories||[]).join(', ');$('rule-subcategories').value=(c.subcategories||[]).join(', ');$('rule-tags-any').value=(c.tags_any||[]).join(', ');$('rule-tags-all').value=(c.tags_all||[]).join(', ');$('rule-exclude-tags').value=(c.exclude_tags||[]).join(', ');$('rule-institutions').value=(c.institution_types||[]).join(', ');$('rule-tehsils').value=(c.tehsils||[]).join(', ');$('rule-districts').value=(c.districts||[]).join(', ');$('rule-sources').value=(c.sources||[]).join(', ');$('rule-stop').checked=r?.stop_after_match!==false;$('rule-enabled').checked=r?.enabled!==false;renderRuleProfileOptions(r?.profile_ids||[]);$('rule-title').textContent=r?'Edit routing rule':'New routing rule';$('rule-message').textContent='';$('rule-dialog').showModal()}
    $('new-profile').addEventListener('click',()=>openProfile());$('new-rule').addEventListener('click',()=>openRule());$('refresh-directory').addEventListener('click',()=>void loadDirectory());
    $('run-routing-test').addEventListener('click',async()=>{const caseId=$('routing-test-case').value.trim();const out=$('routing-test-result');if(!caseId){out.innerHTML='<p class="form-message error">Enter a complaint case UUID.</p>';return}out.innerHTML='<p class="crm-empty-state compact">Evaluating routing rules…</p>';try{const r=await api(`/api/v1/crm/dispatch/routing-test/${encodeURIComponent(caseId)}`);const matches=(r.matches||[]).map((m:any)=>`<li><strong>${m.name}</strong><small>Priority ${m.priority} · ${m.selection_mode.replaceAll('_',' ')} · ${m.profiles.map((p:any)=>p.name).join(', ')||'No destinations'}</small></li>`).join('');const selected=(r.selected_profiles||[]).map((x:any)=>`<span class="dispatch-selected-chip">${x.name}</span>`).join('');out.innerHTML=`<article class="routing-test-summary"><div><span class="crm-status-badge ${r.conflict?'danger':r.selected_profiles?.length?'success':'warning'}">${r.conflict?'Conflict':r.selected_profiles?.length?'Route resolved':'Needs manual route'}</span><h3>${r.complaint_number||caseId}</h3><p>${r.explanation||''}</p></div><section><h4>Selected destinations</h4><div class="dispatch-selected-chips">${selected||'<span>None</span>'}</div></section><section><h4>Matching rules</h4><ol>${matches||'<li>No rules matched.</li>'}</ol></section></article>`}catch(e){out.innerHTML=`<p class="form-message error">${e instanceof Error?e.message:String(e)}</p>`}});
    $('profile-target-type').addEventListener('change',()=>{selectedTargets.clear();void loadDirectory()});let timer=0;$('directory-search').addEventListener('input',()=>{clearTimeout(timer);timer=window.setTimeout(()=>void loadDirectory(),250)});
    $('profile-form').addEventListener('submit',async(e:Event)=>{e.preventDefault();const button=$('save-profile');button.disabled=true;try{await api('/api/v1/crm/dispatch/profiles',{method:'POST',body:JSON.stringify({id:$('profile-id').value||null,name:$('profile-name').value,target_type:$('profile-target-type').value,target_ids:[...selectedTargets.keys()],template_body:$('profile-template').value,packet_policy:$('profile-packet').value,privacy_policy:$('profile-privacy').value,max_packet_bytes:Number($('profile-max-size').value)*1024*1024,require_approval:$('profile-approval').checked,messages_per_minute:Number($('profile-rate').value),max_retries:Number($('profile-retries').value),enabled:$('profile-enabled').checked})});$('profile-dialog').close();await loadProfiles();toast('Destination profile saved.')}catch(err){$('profile-message').textContent=err instanceof Error?err.message:String(err)}finally{button.disabled=false}});
    $('rule-form').addEventListener('submit',async(e:Event)=>{e.preventDefault();const button=$('save-rule');button.disabled=true;try{const profileIds=Array.from(document.querySelectorAll<HTMLInputElement>('[data-rule-profile]:checked')).map(x=>x.value);await api('/api/v1/crm/dispatch/rules',{method:'POST',body:JSON.stringify({id:$('rule-id').value||null,name:$('rule-name').value,description:$('rule-description').value||null,priority:Number($('rule-priority').value),selection_mode:$('rule-mode').value,conditions:{categories:split('categories'),subcategories:split('subcategories'),tags_any:split('tags-any'),tags_all:split('tags-all'),exclude_tags:split('exclude-tags'),institution_types:split('institutions'),tehsils:split('tehsils'),districts:split('districts'),sources:split('sources')},profile_ids:profileIds,stop_after_match:$('rule-stop').checked,enabled:$('rule-enabled').checked})});$('rule-dialog').close();await loadRules();toast('Routing rule saved.')}catch(err){$('rule-message').textContent=err instanceof Error?err.message:String(err)}finally{button.disabled=false}});
    Promise.all([api('/api/v1/crm/dispatch/bootstrap'),loadProfiles(),loadRules()]).catch(e=>toast(e instanceof Error?e.message:String(e),true));
  </script>
</CrmLayout>
