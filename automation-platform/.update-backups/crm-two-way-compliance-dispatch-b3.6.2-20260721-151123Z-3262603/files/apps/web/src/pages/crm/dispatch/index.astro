---
import CrmLayout from "../../../layouts/CrmLayout.astro";
import DataTable from "../../../components/DataTable.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
const preselectedLetter = Astro.url.searchParams.get("letter_id") || "";
---
<CrmLayout title="CRM Dispatch" description="Route finalized complaint packets to controlled WhatsApp destinations with preview, approval and delivery history." page="dispatch">
  <a class="btn btn-sm" href="/crm/replies/official-letters/" slot="actions">Official Letters</a>
  <a class="btn btn-primary btn-sm" href="/crm/dispatch/routing/" slot="actions">Manage Routing</a>
  <main id="crm-dispatch" class="crm32-page crm-dispatch-page" data-api-base={apiBase} data-preselected-letter={preselectedLetter}>
    <nav class="dispatch-tabs" aria-label="CRM dispatch pages"><a class="active" href="/crm/dispatch/">Dispatch Queue</a><a href="#batch-history">Batches</a><a href="/crm/dispatch/routing/">Routing</a><a href="#batch-history">Delivery History</a></nav>
    <section class="crm-metric-grid dispatch-metrics">
      <article class="crm-metric-card"><span>Ready to dispatch</span><strong id="metric-ready">—</strong><small>Finalized official letters</small></article>
      <article class="crm-metric-card"><span>Needs routing</span><strong id="metric-routing">—</strong><small>Human route decision required</small></article>
      <article class="crm-metric-card"><span>Awaiting approval</span><strong id="metric-approval">—</strong><small>Frozen previews ready</small></article>
      <article class="crm-metric-card"><span>Sending</span><strong id="metric-sending">—</strong><small>Queued or awaiting confirmation</small></article>
      <article class="crm-metric-card"><span>Completed with errors</span><strong id="metric-errors">—</strong><small>Retry only failed targets</small></article>
    </section>

    <section class="master-card dispatch-create-card">
      <header class="crm-card-heading"><div><p class="eyebrow">Prepare dispatch</p><h2>Select finalized complaint packets</h2><p>Only complete PDFs are eligible. Routing rules suggest destinations; no WhatsApp message is sent until the exact frozen preview is approved.</p></div><a class="btn btn-sm" href="/crm/replies/official-letters/">Open letter register</a></header>
      <div class="dispatch-create-grid">
        <label class="crm-field"><span>Search finalized letters</span><input id="letter-search" class="input input-bordered" placeholder="Complaint or letter number…" /></label>
        <label class="crm-field"><span>Dispatch purpose</span><select id="dispatch-purpose" class="select select-bordered"><option value="complaint_forwarding">Complaint forwarding</option><option value="compliance_request">Compliance request</option><option value="information_only">For information</option></select></label>
        <label class="crm-field"><span>Response due date (optional)</span><input id="response-due" class="input input-bordered" type="datetime-local" /></label>
      </div>
      <div class="dispatch-letter-toolbar"><span id="selected-count">0 selected</span><button id="clear-selection" class="btn btn-sm" type="button">Clear</button><button id="create-batch" class="btn btn-primary btn-sm" type="button" disabled>Create Dispatch Batch</button></div>
      <div id="eligible-letters" class="dispatch-letter-grid"><p class="crm-empty-state compact">Loading finalized letters…</p></div>
    </section>

    <section id="batch-history" class="master-card dispatch-history-card">
      <header class="crm-card-heading"><div><p class="eyebrow">Dispatch history</p><h2>CRM complaint dispatch batches</h2><p>Track routing decisions, frozen previews, approvals, delivery acknowledgements and retries.</p></div><button id="refresh-batches" class="btn btn-sm" type="button">↻ Refresh</button></header>
      <div class="dispatch-history-toolbar"><label class="crm-field"><span>Search</span><input id="batch-search" class="input input-bordered" placeholder="Batch number or purpose…" /></label><label class="crm-field"><span>Status</span><select id="batch-status" class="select select-bordered"><option value="">All statuses</option><option value="review_required">Needs routing</option><option value="ready">Awaiting approval</option><option value="sending">Sending</option><option value="completed">Completed</option><option value="completed_with_errors">Completed with errors</option><option value="failed">Failed</option></select></label></div>
      <DataTable id="dispatch-batch-table" pageSize={25} pageSizeOptions={[25,50,100]} emptyText="No dispatch batches match the filters." ariaLabel="CRM dispatch batches" />
    </section>
    <div id="dispatch-toast" class="crm-toast" role="status" hidden></div>
  </main>
  <script>
    const root=document.getElementById('crm-dispatch') as HTMLElement; const API=root.dataset.apiBase||''; const table=document.getElementById('dispatch-batch-table') as any; const selected=new Set<string>(); let letters:any[]=[];
    const $=(id:string)=>document.getElementById(id) as any;
    function toast(message:string,error=false){const n=$('dispatch-toast');n.textContent=message;n.className=`crm-toast${error?' error':''}`;n.hidden=false;window.setTimeout(()=>n.hidden=true,5000)}
    async function api(path:string,init?:RequestInit){const h=new Headers(init?.headers||{});if(init?.body)h.set('Content-Type','application/json');const r=await fetch(`${API}${path}`,{...init,headers:h});const b=await r.json().catch(()=>({}));if(!r.ok)throw new Error(typeof b.detail==='string'?b.detail:r.statusText);return b}
    const stack=(a:string,b:string)=>{const d=document.createElement('div');d.className='table-stack';const x=document.createElement('strong');x.textContent=a;const y=document.createElement('small');y.textContent=b;d.append(x,y);return d};
    const badge=(v:string)=>{const s=document.createElement('span');s.className=`crm-status-badge ${['completed','delivered'].includes(v)?'success':['failed','completed_with_errors'].includes(v)?'danger':['ready','review_required'].includes(v)?'warning':''}`;s.textContent=v.replaceAll('_',' ');return s};
    function selection(){ $('selected-count').textContent=`${selected.size} selected`; $('create-batch').disabled=!selected.size; for(const input of document.querySelectorAll<HTMLInputElement>('[data-letter-check]'))input.checked=selected.has(input.value)}
    function renderLetters(){const query=$('letter-search').value.trim().toLowerCase();const visible=letters.filter(item=>`${item.letter_number} ${item.complaint_number}`.toLowerCase().includes(query));const cards=visible.map(item=>{const label=document.createElement('label');label.className='dispatch-letter-card';const input=document.createElement('input');input.type='checkbox';input.className='checkbox checkbox-sm';input.dataset.letterCheck='1';input.value=item.id;input.checked=selected.has(item.id);input.addEventListener('change',()=>{input.checked?selected.add(item.id):selected.delete(item.id);selection()});const body=document.createElement('div');const title=document.createElement('strong');title.textContent=item.complaint_number;const detail=document.createElement('span');detail.textContent=`${item.letter_number} · ${item.letter_date}`;const packet=document.createElement('small');const complete=item.artifacts?.find((x:any)=>x.kind==='complete_pdf');packet.textContent=complete?`Complete PDF · ${(complete.size_bytes/1024/1024).toFixed(1)} MB`:'Complete PDF missing';if(!complete){input.disabled=true;label.classList.add('blocked')}body.append(title,detail,packet);label.append(input,body);return label});$('eligible-letters').replaceChildren(...(cards.length?cards:[Object.assign(document.createElement('p'),{className:'crm-empty-state compact',textContent:'No finalized official letters match this search.'})]));selection()}
    async function loadLetters(){const result=await api('/api/v1/crm/official-letters/letters?status=finalized&page=1&page_size=200');letters=result.items||[];const pre=root.dataset.preselectedLetter;if(pre&&letters.some(x=>x.id===pre))selected.add(pre);renderLetters()}
    async function loadStats(){const s=await api('/api/v1/crm/dispatch/statistics');$('metric-ready').textContent=s.ready_to_dispatch;$('metric-routing').textContent=s.needs_routing;$('metric-approval').textContent=s.awaiting_approval;$('metric-sending').textContent=s.sending;$('metric-errors').textContent=s.completed_with_errors}
    async function loadPage(pageIndex:number,pageSize:number){const q=new URLSearchParams({page:String(pageIndex+1),page_size:String(pageSize),search:$('batch-search').value,status:$('batch-status').value});const r=await api(`/api/v1/crm/dispatch/batches?${q}`);await loadStats();return{rows:r.items,total:r.total}}
    void table.configure({manualPagination:true,getRowId:(r:any)=>r.id,columns:[
      {header:'BATCH',cell:({row}:any)=>stack(row.original.batch_number,new Date(row.original.created_at).toLocaleString())},
      {header:'STATUS',cell:({row}:any)=>badge(row.original.status)},
      {header:'PROGRESS',cell:({row}:any)=>stack(`${row.original.successful_items}/${row.original.total_items} delivered`,`${row.original.ready_items} ready · ${row.original.blocked_items} blocked · ${row.original.failed_items} failed`)},
      {header:'PURPOSE',cell:({row}:any)=>row.original.purpose.replaceAll('_',' ')},
      {header:'ACTIONS',cell:({row}:any)=>{const a=document.createElement('a');a.href=row.original.detail_url;a.className='btn btn-primary btn-xs';a.textContent='Open batch';return a}},
    ],loadPage}).catch((e:unknown)=>toast(e instanceof Error?e.message:String(e),true));
    $('letter-search').addEventListener('input',renderLetters);$('clear-selection').addEventListener('click',()=>{selected.clear();selection()});
    $('create-batch').addEventListener('click',async()=>{const button=$('create-batch');button.disabled=true;try{const due=$('response-due').value;const result=await api('/api/v1/crm/dispatch/batches',{method:'POST',body:JSON.stringify({official_letter_ids:[...selected],purpose:$('dispatch-purpose').value,response_due_at:due?new Date(due).toISOString():null})});window.location.href=result.batch.detail_url}catch(e){toast(e instanceof Error?e.message:String(e),true);button.disabled=false}});
    let timer=0;['batch-search','batch-status'].forEach(id=>$(id).addEventListener('input',()=>{clearTimeout(timer);timer=window.setTimeout(()=>table.refresh(true),250)}));$('refresh-batches').addEventListener('click',()=>table.refresh(false));
    Promise.all([api('/api/v1/crm/dispatch/bootstrap'),loadLetters(),loadStats()]).catch(e=>toast(e instanceof Error?e.message:String(e),true));
  </script>
</CrmLayout>
