  "summary": [
    "Include the complete B3.6 CRM complaint dispatch and routing implementation",
    "Preserve the original AntiDengue WhatsApp contract while validating the additive polymorphic preview source separately",
    "Enforce one active official-letter preview and one current finalized letter per complaint",
    "Reuse an existing preview instead of creating a new revision on every Generate Preview click or page reload",
    "Require explicit Create Revised Letter flow before replacing a finalized official letter",
    "Archive accidental duplicate previews and repair duplicate finalized records during migration",
    "Hide discarded transient previews from the official-letter register and automatically resume the active letter in the preparer",
    "Run the complete project suite and Astro build by default with database-first automatic rollback"
  ],
