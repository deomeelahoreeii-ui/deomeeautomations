---
import CrmLayout from "../../../../../layouts/CrmLayout.astro";
import DataTable from "../../../../../components/DataTable.astro";
import CheckboxField from "../../../../../components/ui/CheckboxField.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---

<CrmLayout title="Classification Review" description="Review only low-confidence matches and proposed taxonomy changes before they become authoritative." page="replies">
  <a class="btn btn-sm" href="/crm/replies/bulk/" slot="actions">← Bulk Operations</a>
  <a class="btn btn-sm" href="/crm/taxonomy/tags/" slot="actions">Manage Tags</a>
  <a class="btn btn-sm" href="/crm/taxonomy/" slot="actions">Manage Taxonomy</a>

  <main id="classification-review" data-api-base={apiBase} class="crm32-page classification-review-page">
    <nav class="reply-mode-tabs" aria-label="Reply workspace modes">
      <a href="/crm/replies/">Reply Queue</a>
      <a href="/crm/replies/bulk/">Bulk Operations</a>
      <a class="active" href="/crm/replies/bulk/classification/">Classification Review</a>
      <a href="/crm/replies/bulk/prompt-profiles/">Reply SOP</a>
    </nav>

    <section class="master-card classification-review-hero">
      <div><p class="eyebrow">Exception queue</p><h2>Human review is required only when confidence is low or taxonomy is uncertain</h2><p>Approve the suggested category, choose another controlled option, attach approved tags, or reject the proposal. ChatGPT never creates categories, subcategories or tags directly.</p></div>
      <div class="classification-review-summary"><span>Awaiting review</span><strong id="review-count">—</strong></div>
    </section>

    <section class="master-card classification-review-table-card">
      <header class="crm-card-heading">
        <div><p class="eyebrow">Pending decisions</p><h2>Classification exceptions</h2><p>High-confidence existing matches are handled automatically and do not appear here.</p></div>
        <div class="classification-review-tools"><input id="review-search" class="input input-bordered" type="search" placeholder="Search complaint number or text…" /><button id="refresh-review" class="btn" type="button">↻ Refresh</button></div>
      </header>
      <DataTable id="classification-review-table" pageSize={25} pageSizeOptions={[10,25,50,100]} emptyText="No classifications require manual review." ariaLabel="Complaint classification review queue" class="classification-review-table" />
    </section>

    <section id="taxonomy-suggestions" class="master-card taxonomy-suggestions-card">
      <header class="crm-card-heading">
        <div><p class="eyebrow">Controlled taxonomy proposals</p><h2>New category, subcategory and tag suggestions</h2><p>Map suggestions to an existing option, create an approved controlled tag, defer them, or reject them. Suggested values never become authoritative automatically.</p></div>
        <div class="table-action-row"><a class="btn" href="/crm/taxonomy/tags/">Manage Tags</a><a class="btn" href="/crm/taxonomy/">Manage Categories</a></div>
      </header>
      <DataTable id="taxonomy-suggestions-table" pageSize={10} pageSizeOptions={[10,25,50]} emptyText="No taxonomy suggestions are awaiting review." ariaLabel="AI taxonomy suggestions" class="taxonomy-suggestions-table" />
    </section>

    <dialog id="classification-dialog" class="modal crm-modal">
      <div class="modal-box crm-modal-box classification-review-dialog">
        <header class="crm-modal-header"><div><p class="eyebrow">Review classification</p><h2 id="review-dialog-number">Complaint</h2><p id="review-dialog-meta">—</p></div><button class="btn btn-sm" type="button" data-close-dialog aria-label="Close">×</button></header>
        <div class="crm-modal-body classification-review-layout">
          <aside class="classification-context-column">
            <section class="classification-review-complaint"><h3>Complaint</h3><p id="review-dialog-complaint">Loading…</p></section>
            <section class="classification-ai-explanation"><div><span>AI confidence</span><strong id="review-confidence">—</strong></div><div><span>Reason</span><p id="review-reason">—</p></div></section>
          </aside>
          <section class="classification-decision-column">
            <div class="form-grid-two">
              <label class="crm-field" for="review-category"><span>Category</span><select id="review-category" class="select select-bordered"></select></label>
              <label class="crm-field" for="review-subcategory"><span>Subcategory</span><select id="review-subcategory" class="select select-bordered"><option value="">No subcategory</option></select></label>
            </div>

            <section class="classification-tag-picker" aria-labelledby="tag-picker-heading">
              <header class="classification-tag-picker-heading"><div><h3 id="tag-picker-heading">Controlled tags</h3><p>One click selects or removes a tag. Categories remain broad while tags preserve institution, evidence, routing and secondary issues.</p></div><a class="text-link" href="/crm/taxonomy/tags/">Manage all tags →</a></header>
              <div id="selected-tags" class="selected-tag-chips" aria-live="polite"><span class="muted">No tags selected.</span></div>
              <div id="unresolved-recommended-tags" class="unresolved-tag-note" hidden></div>
              <div class="classification-tag-controls">
                <input id="tag-picker-search" class="input input-bordered" type="search" placeholder="Search name, alias or description…" />
                <select id="tag-picker-group" class="select select-bordered"><option value="">All groups</option></select>
                <select id="tag-picker-scope" class="select select-bordered"><option value="all">All tags</option><option value="recommended">AI recommended</option><option value="selected">Selected only</option></select>
              </div>
              <div id="tag-picker-results" class="classification-tag-results"><div class="crm-empty-state compact">Loading controlled tags…</div></div>
              <div id="tag-picker-summary" class="classification-tag-summary"></div>
              <footer class="classification-tag-picker-actions"><button id="create-controlled-tag" class="btn btn-sm" type="button">+ Create controlled tag</button><button id="suggest-controlled-tag" class="btn btn-sm" type="button">+ Suggest a new tag</button></footer>
            </section>
          </section>
        </div>
        <footer class="crm-modal-footer"><button id="reject-classification" class="btn btn-error" type="button">Reject suggestion</button><span class="modal-footer-spacer"></span><button class="btn" type="button" data-close-dialog>Cancel</button><button id="approve-classification" class="btn btn-primary" type="button">Approve classification</button></footer>
      </div>
      <form method="dialog" class="modal-backdrop"><button aria-label="Close">close</button></form>
    </dialog>

    <dialog id="quick-tag-dialog" class="modal crm-modal">
      <form id="quick-tag-form" class="modal-box crm-modal-box tag-editor-dialog">
        <header class="crm-modal-header"><div><p class="eyebrow">Controlled tag</p><h2 id="quick-tag-title">Create controlled tag</h2><p>Duplicate names and aliases are rejected. The new tag can be selected immediately.</p></div><button class="btn btn-sm" type="button" data-close-dialog aria-label="Close">×</button></header>
        <div class="crm-modal-body">
          <div class="form-grid-two">
            <label class="crm-field" for="quick-tag-name"><span>Display name</span><input id="quick-tag-name" class="input input-bordered" required maxlength="140" /></label>
            <label class="crm-field" for="quick-tag-slug"><span>System slug</span><input id="quick-tag-slug" class="input input-bordered" required maxlength="120" /></label>
          </div>
          <label class="crm-field" for="quick-tag-group"><span>Group</span><select id="quick-tag-group" class="select select-bordered" required></select></label>
          <label class="crm-field" for="quick-tag-description"><span>Description</span><textarea id="quick-tag-description" class="textarea textarea-bordered" rows="3" maxlength="4000"></textarea></label>
          <label class="crm-field" for="quick-tag-aliases"><span>Aliases</span><textarea id="quick-tag-aliases" class="textarea textarea-bordered" rows="2" placeholder="One alias per line"></textarea></label>
          <div class="tag-setting-grid"><CheckboxField id="quick-tag-active" label="Active" description="Available for human assignment." checked /><CheckboxField id="quick-tag-ai" label="Available to AI" description="Included in future classification packages." checked /></div>
        </div>
        <footer class="crm-modal-footer"><button class="btn" type="button" data-close-dialog>Cancel</button><button id="save-quick-tag" class="btn btn-primary" type="submit">Create and select tag</button></footer>
      </form>
      <form method="dialog" class="modal-backdrop"><button aria-label="Close">close</button></form>
    </dialog>

    <dialog id="suggest-tag-dialog" class="modal crm-modal">
      <form id="suggest-tag-form" class="modal-box crm-modal-box crm-confirm-dialog">
        <header class="crm-modal-header"><div><p class="eyebrow">Taxonomy suggestion</p><h2>Suggest a new controlled tag</h2><p>The complaint may be approved without this tag. A taxonomy administrator can review the suggestion later.</p></div><button class="btn btn-sm" type="button" data-close-dialog aria-label="Close">×</button></header>
        <div class="crm-modal-body">
          <label class="crm-field" for="suggest-tag-name"><span>Proposed name</span><input id="suggest-tag-name" class="input input-bordered" required maxlength="140" /></label>
          <label class="crm-field" for="suggest-tag-group"><span>Suggested group</span><select id="suggest-tag-group" class="select select-bordered" required></select></label>
          <label class="crm-field" for="suggest-tag-reason"><span>Why existing tags do not fit</span><textarea id="suggest-tag-reason" class="textarea textarea-bordered" rows="4" maxlength="4000" required></textarea></label>
        </div>
        <footer class="crm-modal-footer"><button class="btn" type="button" data-close-dialog>Cancel</button><button class="btn btn-primary" type="submit">Submit suggestion</button></footer>
      </form>
      <form method="dialog" class="modal-backdrop"><button aria-label="Close">close</button></form>
    </dialog>

    <div id="review-toast" class="crm-toast" role="status" aria-live="polite" hidden></div>
  </main>

  <script>
    import { badge, stack } from "../../../../../scripts/table-cells";
    type Review={id:string;case_id:string;complaint_number:string;complaint_preview:string;suggested_category_id?:string|null;suggested_subcategory_id?:string|null;suggested_category:string;suggested_subcategory:string;confidence:number;reason:string;tags:string[];status:string;created_at:string};
    type Category={id:string;name:string;subcategories:{id:string;name:string}[]};
    type Tag={id:string;name:string;display_name:string;group:string;description:string;aliases:string[];usage_count?:number;active?:boolean;ai_available?:boolean};
    type TagGroup={id:string;slug:string;name:string;description:string;display_order:number;active:boolean;tag_count:number};
    type Suggestion={id:string;classification_id:string;complaint_number:string;proposal_type:string;proposed_name:string;proposed_group_name?:string|null;reason:string;supporting_count:number;status:string;parent_category_id?:string|null;created_at:string};
    const root=document.getElementById("classification-review") as HTMLElement;
    const API=root.dataset.apiBase||"";
    const $=<T extends HTMLElement=HTMLElement>(id:string)=>document.getElementById(id) as T;
    const table=$("classification-review-table") as HTMLElement & {configure:(config:any)=>Promise<void>;refresh:(reset?:boolean)=>Promise<void>};
    const suggestionsTable=$("taxonomy-suggestions-table") as HTMLElement & {configure:(config:any)=>Promise<void>;refresh:(reset?:boolean)=>Promise<void>};
    const dialog=$("classification-dialog") as HTMLDialogElement;
    const quickTagDialog=$("quick-tag-dialog") as HTMLDialogElement;
    const suggestTagDialog=$("suggest-tag-dialog") as HTMLDialogElement;
    let options:{categories:Category[];tags:Tag[]}={categories:[],tags:[]};
    let groups:TagGroup[]=[];
    let current:Review|null=null;
    let selectedTagIds=new Set<string>();
    let recommendedNames=new Set<string>();
    let tagCache=new Map<string,Tag>();
    let quickTagSuggestionId="";
    let slugTouched=false;
    function toast(message:string,error=false){const node=$("review-toast");node.textContent=message;node.classList.toggle("error",error);node.hidden=false;setTimeout(()=>node.hidden=true,4500)}
    async function api(path:string,options?:RequestInit){const response=await fetch(`${API}${path}`,options);let body:any={};try{body=await response.json()}catch{}if(!response.ok)throw new Error(body.detail||`Request failed (${response.status})`);return body}
    function dt(value:string){return value?new Intl.DateTimeFormat(undefined,{dateStyle:"medium",timeStyle:"short"}).format(new Date(value)):"—"}
    function slug(value:string){return value.toLowerCase().replace(/[^a-z0-9]+/g,"-").replace(/^-|-$/g,"").slice(0,120)}
    function aliases(value:string){return Array.from(new Set(value.split(/[\n,;]+/).map(item=>item.trim()).filter(Boolean)))}
    function closeNearest(event:Event){const target=event.currentTarget as HTMLElement;const modal=target.closest("dialog") as HTMLDialogElement|null;if(modal?.open)modal.close()}
    document.querySelectorAll<HTMLElement>("[data-close-dialog]").forEach(button=>button.addEventListener("click",closeNearest));
    dialog.addEventListener("close",()=>{current=null;selectedTagIds.clear();recommendedNames.clear()});
    function populateCategories(selectedCategory?:string|null,selectedSubcategory?:string|null){const category=$("review-category") as HTMLSelectElement;category.replaceChildren();for(const item of options.categories){const option=document.createElement("option");option.value=item.id;option.textContent=item.name;category.append(option)}if(selectedCategory)category.value=selectedCategory;populateSubcategories(selectedSubcategory)}
    function populateSubcategories(selected?:string|null){const categoryId=($("review-category") as HTMLSelectElement).value;const sub=$("review-subcategory") as HTMLSelectElement;sub.replaceChildren();const empty=document.createElement("option");empty.value="";empty.textContent="No subcategory";sub.append(empty);const category=options.categories.find(row=>row.id===categoryId);for(const item of category?.subcategories||[]){const option=document.createElement("option");option.value=item.id;option.textContent=item.name;sub.append(option)}if(selected)sub.value=selected}
    $("review-category").addEventListener("change",()=>populateSubcategories());
    function groupName(slugValue:string){return groups.find(row=>row.slug===slugValue)?.name||slugValue.replaceAll("-"," ")}
    function fillGroupSelect(id:string,includeAll=false){const select=$(id) as HTMLSelectElement;const selected=select.value;select.innerHTML=(includeAll?'<option value="">All groups</option>':"")+groups.filter(row=>row.active).map(row=>`<option value="${row.slug}">${row.name}</option>`).join("");if(selected)select.value=selected}
    async function loadOptions(){const [taxonomy,groupData]=await Promise.all([api("/api/v1/crm/ai-pipeline/taxonomy-options"),api("/api/v1/crm/ai-pipeline/tag-groups")]);options=taxonomy;groups=groupData.items||[];tagCache=new Map((options.tags||[]).map((tag:Tag)=>[tag.id,tag]));fillGroupSelect("tag-picker-group",true);fillGroupSelect("quick-tag-group");fillGroupSelect("suggest-tag-group")}
    function selectedTags(){return Array.from(selectedTagIds).map(id=>tagCache.get(id)).filter(Boolean) as Tag[]}
    function renderSelected(){const node=$("selected-tags");const rows=selectedTags();if(!rows.length){node.innerHTML='<span class="muted">No tags selected.</span>';return}node.replaceChildren(...rows.map(tag=>{const chip=document.createElement("button");chip.type="button";chip.className="selected-tag-chip";chip.title=`Remove ${tag.display_name}`;chip.innerHTML=`<span>${tag.display_name}</span><small>${groupName(tag.group)}</small><b aria-hidden="true">×</b>`;chip.addEventListener("click",()=>{selectedTagIds.delete(tag.id);renderSelected();void renderTagResults()});return chip}))}
    function unresolvedRecommended(){const known=new Set(Array.from(tagCache.values()).map(tag=>tag.name));return Array.from(recommendedNames).filter(name=>!known.has(name))}
    function renderUnresolved(){const names=unresolvedRecommended();const node=$("unresolved-recommended-tags");node.hidden=!names.length;if(names.length)node.innerHTML=`<strong>AI proposed tags not yet controlled:</strong> ${names.map(name=>`<span>${name}</span>`).join(" ")} <small>Review these in Taxonomy Suggestions or create a controlled tag.</small>`}
    function tagRow(tag:Tag){const label=document.createElement("label");label.className="classification-tag-option";const input=document.createElement("input");input.type="checkbox";input.className="checkbox checkbox-sm";input.checked=selectedTagIds.has(tag.id);input.addEventListener("change",()=>{if(input.checked)selectedTagIds.add(tag.id);else selectedTagIds.delete(tag.id);renderSelected()});const copy=document.createElement("span");copy.className="classification-tag-option-copy";const recommendation=recommendedNames.has(tag.name)?'<span class="tag-recommended-badge">Recommended</span>':"";copy.innerHTML=`<strong>${tag.display_name}${recommendation}</strong><small>${tag.name}${tag.description?` · ${tag.description}`:""}${tag.aliases?.length?` · aliases: ${tag.aliases.join(", ")}`:""}</small>`;const count=document.createElement("span");count.className="classification-tag-usage";count.textContent=tag.usage_count?`${tag.usage_count} uses`:"";label.append(input,copy,count);return label}
    async function renderTagResults(){const node=$("tag-picker-results");const scope=($("tag-picker-scope") as HTMLSelectElement).value;const search=($("tag-picker-search") as HTMLInputElement).value.trim();const group=($("tag-picker-group") as HTMLSelectElement).value;node.innerHTML='<div class="crm-empty-state compact">Loading controlled tags…</div>';let rows:Tag[]=[];let total=0;if(scope==="selected"){rows=selectedTags().filter(tag=>(!group||tag.group===group)&&(!search||`${tag.display_name} ${tag.name} ${tag.description} ${(tag.aliases||[]).join(" ")}`.toLowerCase().includes(search.toLowerCase())));total=rows.length}else{const p=new URLSearchParams({status:"active",ai_available:"true",page_size:"100"});if(search)p.set("search",search);if(group)p.set("group",group);const data=await api(`/api/v1/crm/ai-pipeline/tags?${p}`);rows=data.items||[];total=data.total||0;for(const tag of rows)tagCache.set(tag.id,tag);if(scope==="recommended")rows=rows.filter(tag=>recommendedNames.has(tag.name))}if(!rows.length){node.innerHTML='<div class="crm-empty-state compact">No controlled tags match this view.</div>';$("tag-picker-summary").textContent=scope==="recommended"&&unresolvedRecommended().length?"Some AI-proposed tags are not yet controlled.":"";renderSelected();renderUnresolved();return}const byGroup=new Map<string,Tag[]>();for(const tag of rows){if(!byGroup.has(tag.group))byGroup.set(tag.group,[]);byGroup.get(tag.group)!.push(tag)}node.replaceChildren(...Array.from(byGroup.entries()).map(([groupSlug,items],index)=>{const details=document.createElement("details");details.className="classification-tag-group";details.open=Boolean(search)||scope!=="all"||index===0;const summary=document.createElement("summary");summary.innerHTML=`<span>${groupName(groupSlug)}</span><small>${items.length} tags</small>`;const list=document.createElement("div");list.className="classification-tag-group-list";list.replaceChildren(...items.map(tagRow));details.append(summary,list);return details}));$("tag-picker-summary").textContent=total>rows.length?`Showing ${rows.length} of ${total}. Refine search to find more tags.`:`${rows.length} controlled tags shown.`;renderSelected();renderUnresolved()}
    async function openReview(row:Review){current=row;$("review-dialog-number").textContent=`Complaint ${row.complaint_number}`;$("review-dialog-meta").textContent=`Suggested: ${row.suggested_category}${row.suggested_subcategory?` · ${row.suggested_subcategory}`:""}`;$("review-dialog-complaint").textContent=row.complaint_preview||"Loading complete complaint…";$("review-confidence").textContent=`${Math.round(row.confidence*100)}%`;$("review-reason").textContent=row.reason||"No reason supplied.";populateCategories(row.suggested_category_id,row.suggested_subcategory_id);recommendedNames=new Set(row.tags||[]);selectedTagIds.clear();for(const tag of tagCache.values())if(recommendedNames.has(tag.name))selectedTagIds.add(tag.id);($("tag-picker-search") as HTMLInputElement).value="";($("tag-picker-group") as HTMLSelectElement).value="";($("tag-picker-scope") as HTMLSelectElement).value="all";renderSelected();renderUnresolved();dialog.showModal();void renderTagResults();try{const detail=await api(`/api/v1/crm/reply-workspace/cases/${row.case_id}`);$("review-dialog-complaint").textContent=detail.case.complaint_text||row.complaint_preview||"No complaint text is stored."}catch(error){toast(error instanceof Error?error.message:String(error),true)}}
    async function resolve(decision:"approve"|"reject"){if(!current)return;const category=($("review-category") as HTMLSelectElement).value;if(decision==="approve"&&!category){toast("Select a category.",true);return}try{await api(`/api/v1/crm/ai-pipeline/classification-review/${current.id}/resolve`,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({category_id:decision==="approve"?category:null,subcategory_id:decision==="approve"?(($("review-subcategory") as HTMLSelectElement).value||null):null,tag_ids:decision==="approve"?Array.from(selectedTagIds):[],decision})});dialog.close();toast(decision==="approve"?"Classification approved.":"Classification suggestion rejected.");await Promise.all([table.refresh(false),suggestionsTable.refresh(false)])}catch(error){toast(error instanceof Error?error.message:String(error),true)}}
    $("approve-classification").addEventListener("click",()=>void resolve("approve"));$("reject-classification").addEventListener("click",()=>void resolve("reject"));
    function openQuickTag(prefill="",suggestionId=""){quickTagSuggestionId=suggestionId;slugTouched=false;$("quick-tag-title").textContent=suggestionId?"Create tag from suggestion":"Create controlled tag";($("quick-tag-name") as HTMLInputElement).value=prefill;($("quick-tag-slug") as HTMLInputElement).value=slug(prefill);($("quick-tag-description") as HTMLTextAreaElement).value="";($("quick-tag-aliases") as HTMLTextAreaElement).value="";($("quick-tag-active") as HTMLInputElement).checked=true;($("quick-tag-ai") as HTMLInputElement).checked=true;($("quick-tag-group") as HTMLSelectElement).value="issue";quickTagDialog.showModal();($("quick-tag-name") as HTMLInputElement).focus()}
    $("create-controlled-tag").addEventListener("click",()=>openQuickTag(($("tag-picker-search") as HTMLInputElement).value.trim()));
    $("quick-tag-name").addEventListener("input",()=>{if(!slugTouched)($("quick-tag-slug") as HTMLInputElement).value=slug(($("quick-tag-name") as HTMLInputElement).value)});$("quick-tag-slug").addEventListener("input",()=>{slugTouched=true});
    $("quick-tag-form").addEventListener("submit",async(event)=>{event.preventDefault();const payload={display_name:($("quick-tag-name") as HTMLInputElement).value.trim(),slug:($("quick-tag-slug") as HTMLInputElement).value.trim(),group_name:($("quick-tag-group") as HTMLSelectElement).value,description:($("quick-tag-description") as HTMLTextAreaElement).value,aliases:aliases(($("quick-tag-aliases") as HTMLTextAreaElement).value),active:($("quick-tag-active") as HTMLInputElement).checked,ai_available:($("quick-tag-ai") as HTMLInputElement).checked};const button=$("save-quick-tag") as HTMLButtonElement;button.disabled=true;try{const result=quickTagSuggestionId?await api(`/api/v1/crm/ai-pipeline/taxonomy-suggestions/${quickTagSuggestionId}/create-tag`,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(payload)}):await api("/api/v1/crm/ai-pipeline/tags",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(payload)});const tag=(result.tag||result) as Tag;tagCache.set(tag.id,tag);if(current)selectedTagIds.add(tag.id);quickTagDialog.close();toast("Controlled tag created.");await Promise.all([renderTagResults(),suggestionsTable.refresh(false)])}catch(error){toast(error instanceof Error?error.message:String(error),true)}finally{button.disabled=false}});
    $("suggest-controlled-tag").addEventListener("click",()=>{if(!current)return;($("suggest-tag-name") as HTMLInputElement).value=($("tag-picker-search") as HTMLInputElement).value.trim();($("suggest-tag-group") as HTMLSelectElement).value="issue";($("suggest-tag-reason") as HTMLTextAreaElement).value="";suggestTagDialog.showModal()});
    $("suggest-tag-form").addEventListener("submit",async(event)=>{event.preventDefault();if(!current)return;try{await api(`/api/v1/crm/ai-pipeline/classification-review/${current.id}/tag-suggestions`,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({display_name:($("suggest-tag-name") as HTMLInputElement).value.trim(),group_name:($("suggest-tag-group") as HTMLSelectElement).value,reason:($("suggest-tag-reason") as HTMLTextAreaElement).value})});suggestTagDialog.close();toast("New tag suggestion added for taxonomy review.");await suggestionsTable.refresh(false)}catch(error){toast(error instanceof Error?error.message:String(error),true)}});
    async function resolveSuggestion(row:Suggestion,status:"rejected"|"deferred"){try{await api(`/api/v1/crm/ai-pipeline/taxonomy-suggestions/${row.id}/resolve`,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({status})});toast(status==="rejected"?"Taxonomy suggestion rejected.":"Taxonomy suggestion deferred.");await suggestionsTable.refresh(false)}catch(error){toast(error instanceof Error?error.message:String(error),true)}}
    async function configure(){await loadOptions();await table.configure({columns:[
      {accessorKey:"complaint_number",header:"Complaint No.",meta:{minWidth:"145px"},cell:(c:any)=>{const row=c.row.original as Review;const a=document.createElement("a");a.className="table-primary-link";a.href=`/crm/replies/${row.case_id}/?return_to=${encodeURIComponent(location.pathname)}`;a.textContent=row.complaint_number;return a}},
      {accessorKey:"complaint_preview",header:"Complaint",meta:{minWidth:"280px",maxWidth:"520px"},cell:(c:any)=>{const row=c.row.original as Review;const wrap=document.createElement("div");wrap.className="table-preview-cell";const span=document.createElement("span");span.textContent=row.complaint_preview;const button=document.createElement("button");button.className="btn btn-xs";button.type="button";button.textContent="Review";button.addEventListener("click",()=>void openReview(row));wrap.append(span,button);return wrap}},
      {id:"suggestion",header:"Suggested classification",meta:{minWidth:"220px"},cell:(c:any)=>{const row=c.row.original as Review;return stack(row.suggested_category||"New taxonomy proposed",row.suggested_subcategory||row.tags.join(" · "))}},
      {accessorKey:"confidence",header:"Confidence",meta:{width:"110px",align:"right"},cell:(c:any)=>badge(`${Math.round(Number(c.getValue())*100)}%`,Number(c.getValue())>=.65?"warning":"danger")},
      {accessorKey:"reason",header:"Reason",meta:{minWidth:"220px"}},
      {accessorKey:"created_at",header:"Created",meta:{minWidth:"160px"},cell:(c:any)=>dt(c.getValue())}
    ],manualPagination:true,getRowId:(row:Review)=>row.id,loadPage:async(pageIndex:number,pageSize:number)=>{const p=new URLSearchParams({page:String(pageIndex+1),page_size:String(pageSize)});const search=($("review-search") as HTMLInputElement).value.trim();if(search)p.set("search",search);const data=await api(`/api/v1/crm/ai-pipeline/classification-review?${p}`);$("review-count").textContent=String(data.total||0);return{rows:data.items||[],total:data.total||0}}});
    await suggestionsTable.configure({columns:[
      {accessorKey:"proposed_name",header:"Proposed option",meta:{minWidth:"210px"},cell:(c:any)=>{const row=c.row.original as Suggestion;return stack(row.proposed_name,`${row.proposal_type.replaceAll("_"," ")}${row.proposed_group_name?` · ${groupName(row.proposed_group_name)}`:""}`)}},
      {accessorKey:"complaint_number",header:"Complaint No.",meta:{minWidth:"145px"}},
      {accessorKey:"reason",header:"Reason",meta:{minWidth:"260px"}},
      {accessorKey:"created_at",header:"Created",meta:{minWidth:"155px"},cell:(c:any)=>dt(c.getValue())},
      {id:"actions",header:"Actions",meta:{minWidth:"260px"},cell:(c:any)=>{const row=c.row.original as Suggestion;const wrap=document.createElement("div");wrap.className="table-action-row";if(row.proposal_type==="tag"){const create=document.createElement("button");create.type="button";create.className="btn btn-xs btn-primary";create.textContent="Create tag";create.addEventListener("click",()=>{openQuickTag(row.proposed_name,row.id);($("quick-tag-group") as HTMLSelectElement).value=row.proposed_group_name||"issue";($("quick-tag-description") as HTMLTextAreaElement).value=row.reason});wrap.append(create)}const defer=document.createElement("button");defer.type="button";defer.className="btn btn-xs";defer.textContent="Defer";defer.addEventListener("click",()=>void resolveSuggestion(row,"deferred"));const reject=document.createElement("button");reject.type="button";reject.className="btn btn-xs btn-error";reject.textContent="Reject";reject.addEventListener("click",()=>void resolveSuggestion(row,"rejected"));wrap.append(defer,reject);return wrap}}
    ],manualPagination:true,getRowId:(row:Suggestion)=>row.id,loadPage:async(pageIndex:number,pageSize:number)=>{const p=new URLSearchParams({status:"pending",page:String(pageIndex+1),page_size:String(pageSize)});const data=await api(`/api/v1/crm/ai-pipeline/taxonomy-suggestions?${p}`);return{rows:data.items||[],total:data.total||0}}})}
    let timer:number|undefined;$("review-search").addEventListener("input",()=>{clearTimeout(timer);timer=window.setTimeout(()=>void table.refresh(true),250)});$("refresh-review").addEventListener("click",()=>void Promise.all([table.refresh(false),suggestionsTable.refresh(false)]));let tagTimer:number|undefined;$("tag-picker-search").addEventListener("input",()=>{clearTimeout(tagTimer);tagTimer=window.setTimeout(()=>void renderTagResults(),220)});$("tag-picker-group").addEventListener("change",()=>void renderTagResults());$("tag-picker-scope").addEventListener("change",()=>void renderTagResults());
    void configure().catch(error=>toast(error instanceof Error?error.message:String(error),true));
  </script>
</CrmLayout>
