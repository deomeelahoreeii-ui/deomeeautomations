---
import CrmLayout from "../../../layouts/CrmLayout.astro";
---
<CrmLayout title="Helpdesk Synchronization" description="Keep Frappe workflow and approved replies synchronized with PostgreSQL. Team, tehsil and officer routing remains optional." page="helpdesk">
  <a class="btn btn-sm" href="/crm/replies/" slot="actions">Reply Workspace</a>
  <a class="btn btn-sm" href="http://localhost:8082/helpdesk/tickets" target="_blank" rel="noreferrer" slot="actions">Open Frappe Helpdesk ↗</a>

  <section class="workflow-callout master-card">
    <div><p class="eyebrow">Primary purpose</p><h2>Reply and workflow synchronization</h2><p>Classification and replies can now be edited from the Automation Portal. Use this page to pull external Helpdesk changes, retry failures and inspect the synchronization audit. Routing is not required for reply archiving.</p></div>
    <div class="workflow-callout-actions"><button class="btn btn-primary" id="pull-workflow">Preview and pull latest workflow</button><a class="btn" href="/crm/replies/">Open Reply Queue</a></div>
  </section>

  <section class="workflow-metrics">
    <article class="master-card"><span>Linked tickets</span><strong id="linked-count">—</strong><small>Complaint identity established</small></article>
    <article class="master-card"><span>Workflow synchronized</span><strong id="pulled-count">—</strong><small id="not-pulled-count">— waiting for first pull</small></article>
    <article class="master-card"><span>Draft / pending</span><strong id="draft-count">—</strong><small>Operational replies not in AI archive</small></article>
    <article class="master-card"><span>Approved / issued</span><strong id="reply-count">—</strong><small>Eligible for archive rules</small></article>
    <article class="master-card"><span>Synchronization failures</span><strong id="failure-count">—</strong><small>Require review or retry</small></article>
  </section>

  <section class="workflow-primary-grid">
    <article class="master-card workflow-card">
      <p class="eyebrow">Portal-first workflow</p><h2>Prepare and approve replies</h2><p>Use the dedicated editor to classify a complaint, write findings and approve a verified final reply. Every approved revision is preserved.</p><a class="btn btn-primary" href="/crm/replies/">Open Reply Workspace</a>
    </article>
    <article class="master-card workflow-card">
      <p class="eyebrow">External changes</p><h2>Pull from Helpdesk</h2><p>Copies ticket status, findings and only Approved or Issued final replies into PostgreSQL. Drafts and rejected replies remain outside the AI archive.</p><button class="btn btn-primary" id="pull-workflow-secondary">Preview and pull</button>
    </article>
    <article class="master-card workflow-card">
      <p class="eyebrow">Knowledge readiness</p><h2>Review approved archive</h2><p>Inspect category-wise approved complaint/reply pairs and export Excel, CSV, JSON, Markdown or text files for AI chat windows.</p><a class="btn btn-primary" href="/crm/knowledge/">Open AI Reply Archive</a>
    </article>
  </section>

  <details class="master-card optional-routing">
    <summary><span><b>Optional team, tehsil and officer routing</b><small>Expand only when you need automatic Helpdesk assignment. It is not required for complaint/reply storage or AI exports.</small></span><span id="routed-summary">0 routed</span></summary>
    <div class="routing-grid">
      <article><h3>Verify routing teams</h3><p>Creates or verifies triage and tehsil teams. It does not assign any ticket.</p><button class="btn" id="bootstrap-teams">Verify teams</button></article>
      <article><h3>Preview exact routing</h3><p>Shows proposed team/officer changes and preserves unrelated manual assignments.</p><button class="btn" id="route-tickets">Preview and route</button></article>
      <article><h3>Officer configuration</h3><p>Individual assignment is used only for officers explicitly linked to active Helpdesk agent emails.</p><a class="btn" href="/master-data/officers">Open officers</a></article>
    </div>
  </details>

  <section class="master-card workflow-audit">
    <div class="workflow-audit-heading"><div><p class="eyebrow">Synchronization audit</p><h2>Current complaint workflow</h2><p>Readable state labels with direct links to the reply editor and Helpdesk ticket.</p></div><button class="btn btn-sm" id="refresh-workflow">↻ Refresh</button></div>
    <div id="workflow-message" class="alert" hidden></div>
    <div class="workflow-table-wrap"><table class="table table-sm"><thead><tr><th>Complaint</th><th>Helpdesk</th><th>Workflow</th><th>Assignment</th><th>Reply archive</th><th>Last verified pull</th></tr></thead><tbody id="workflow-rows"></tbody></table></div>
  </section>

  <style>
    .workflow-callout{display:flex;align-items:center;justify-content:space-between;gap:1.5rem;border-left:4px solid #16879a}.workflow-callout h2,.workflow-card h2,.workflow-audit h2{margin:.1rem 0}.workflow-callout p,.workflow-card p,.workflow-audit p,.routing-grid p{color:#66758a}.workflow-callout-actions{display:flex;gap:.55rem;flex-wrap:wrap;justify-content:flex-end}.workflow-metrics{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:.8rem;margin:1rem 0}.workflow-metrics article{display:grid;gap:.2rem;padding:1rem}.workflow-metrics span,.workflow-metrics small{color:#6b7787}.workflow-metrics strong{font-size:1.65rem}.workflow-primary-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem}.workflow-card{display:flex;flex-direction:column;align-items:flex-start;padding:1.1rem}.workflow-card p:not(.eyebrow){flex:1;min-height:4.5rem}.optional-routing{margin-top:1rem}.optional-routing summary{display:flex;align-items:center;justify-content:space-between;gap:1rem;cursor:pointer;list-style:none}.optional-routing summary span:first-child{display:grid}.optional-routing summary small{color:#66758a;margin-top:.2rem}.optional-routing summary>span:last-child{border-radius:999px;background:#eef2f6;padding:.3rem .6rem;font-size:.72rem;font-weight:750}.routing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:1rem;border-top:1px solid #e2e8f0;padding-top:1rem}.routing-grid article{border:1px solid #e2e8f0;border-radius:.7rem;padding:.8rem}.routing-grid h3{margin:0}.workflow-audit{margin-top:1rem;padding:1.1rem}.workflow-audit-heading{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem}.workflow-table-wrap{overflow-x:auto;margin-top:1rem}.workflow-table-wrap table{min-width:68rem}.workflow-table-wrap td{vertical-align:top}.workflow-primary,.workflow-secondary{display:block}.workflow-primary{font-weight:750}.workflow-secondary{color:#7b8796;font-size:.7rem}.state-pill{display:inline-flex;border-radius:999px;background:#eef2f6;color:#475569;padding:.25rem .5rem;font-size:.7rem;font-weight:800}.state-pill.approved,.state-pill.issued,.state-pill.synchronized,.state-pill.pulled{background:#e7f8f1;color:#176b57}.state-pill.failed{background:#fff0f1;color:#a52630}.state-pill.draft,.state-pill.pending-approval{background:#fff3dc;color:#925b05}@media(max-width:1150px){.workflow-metrics{grid-template-columns:repeat(3,1fr)}.workflow-primary-grid,.routing-grid{grid-template-columns:1fr}}@media(max-width:700px){.workflow-callout,.workflow-audit-heading{align-items:flex-start;flex-direction:column}.workflow-callout-actions{justify-content:flex-start}.workflow-metrics{grid-template-columns:repeat(2,1fr)}}
  </style>
  <script>
    import { actions } from "astro:actions";
    const $=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;
    const esc=(v:unknown)=>String(v??"").replace(/[&<>'"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"}[c]!));
    const readable=(value:unknown,fallback="Not synchronized")=>String(value||fallback).replaceAll("_"," ").replace(/\b\w/g,c=>c.toUpperCase());
    const cls=(value:unknown)=>String(value||"").toLowerCase().replaceAll(" ","-").replaceAll("_","-");
    function message(text:string,error=false){const node=$("workflow-message");node.hidden=false;node.className=`alert ${error?"alert-error":"alert-success"}`;node.textContent=text}
    async function load(){
      const [stats,audit]=await Promise.all([actions.crm.helpdeskWorkflowStatistics({}),actions.crm.helpdeskWorkflowAudit({limit:300})]);
      if(stats.data){const d=stats.data as any,statuses=d.approval_statuses||{},workflows=d.workflow_statuses||{},routing=d.routing_statuses||{};$("linked-count").textContent=String(d.linked_cases||0);$("pulled-count").textContent=String(d.pulled_cases||0);$("not-pulled-count").textContent=`${workflows.not_pulled||0} waiting for first pull`;$("draft-count").textContent=String((statuses.Draft||0)+(statuses["Pending Approval"]||0));$("reply-count").textContent=String(d.approved_replies||0);$("failure-count").textContent=String((workflows.failed||0)+(routing.failed||0));$("routed-summary").textContent=`${routing.routed||0} routed`}
      if(audit.data){const rows=(audit.data as any).items||[];$("workflow-rows").innerHTML=rows.map((x:any)=>`<tr><td><a class="workflow-primary" href="/crm/replies/${esc(x.case_id)}/">${esc(x.complaint_number||x.case_id)}</a><a class="workflow-secondary" href="/crm/cases/${esc(x.case_id)}/">Open complaint record</a></td><td>${x.ticket_url?`<a class="workflow-primary" href="${esc(x.ticket_url)}" target="_blank" rel="noreferrer">Ticket ${esc(x.ticket_id)} ↗</a>`:`<span class="workflow-primary">Ticket ${esc(x.ticket_id)}</span>`}<span class="workflow-secondary">${esc(readable(x.routing_status,"Not routed"))}</span></td><td><span class="state-pill ${cls(x.workflow_status)}">${esc(readable(x.workflow_status,"Not pulled"))}</span><span class="workflow-secondary">${x.last_pull_at?"Verified":"Awaiting first pull"}</span></td><td><span class="workflow-primary">${esc(x.team||"Unassigned")}</span><span class="workflow-secondary">${esc(x.assigned_officer||x.assigned_users?.join(", ")||"No officer required")}</span></td><td><span class="state-pill ${cls(x.reply_approval_status)}">${esc(readable(x.reply_approval_status,"Not prepared"))}</span><span class="workflow-secondary">${x.reply_imported?"Approved revision archived":"Not in approved archive"}</span></td><td>${x.last_pull_at?new Date(x.last_pull_at).toLocaleString():"—"}</td></tr>`).join("")||`<tr><td colspan="6">No linked complaint tickets.</td></tr>`}
    }
    async function pull(){const p=await actions.crm.helpdeskWorkflowPreview({limit:500});if(p.error){message(p.error.message,true);return}const d=p.data as any;if(!confirm(`Pull the latest workflow for exactly ${d.selected_count||0} linked complaints? Draft and rejected replies will remain outside the approved archive.`))return;const r=await actions.crm.pullHelpdeskWorkflow({caseIds:d.selected_case_ids||[],limit:500});if(r.error){message(r.error.message,true);return}const c=(r.data as any).counts||{};message(`Workflow synchronization complete: ${c.pulled||0} pulled, ${c.failed||0} failed.`);await load()}
    $("bootstrap-teams").addEventListener("click",async()=>{const r=await actions.crm.bootstrapHelpdeskTeams({});if(r.error){message(r.error.message,true);return}const d=r.data as any;message(`Routing teams verified: ${d.teams?.created||0} created, ${d.teams?.unchanged||0} unchanged. This did not route any ticket.`);await load()});
    $("route-tickets").addEventListener("click",async()=>{const p=await actions.crm.helpdeskRoutingPreview({limit:500});if(p.error){message(p.error.message,true);return}const d=p.data as any;if(!d.batch_token){message("No linked tickets are available for routing.",true);return}const ready=d.counts?.ready||0,manual=d.counts?.manual_assignment_preserved||0;if(!confirm(`Optional routing only: route the exact ${d.selected_count} previewed tickets? ${ready} ready; ${manual} manual assignments preserved.`))return;const r=await actions.crm.applyHelpdeskRouting({previewToken:d.batch_token,force:false});if(r.error){message(r.error.message,true);return}const c=(r.data as any).counts||{};message(`Routing complete: ${c.routed||0} routed, ${c.manual_preserved||0} manual assignments preserved, ${c.failed||0} failed.`);await load()});
    $("pull-workflow").addEventListener("click",pull);$("pull-workflow-secondary").addEventListener("click",pull);$("refresh-workflow").addEventListener("click",load);await load();
  </script>
</CrmLayout>
