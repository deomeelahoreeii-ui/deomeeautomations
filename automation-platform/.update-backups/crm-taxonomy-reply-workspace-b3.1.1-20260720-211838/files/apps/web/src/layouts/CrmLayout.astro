---
import AppLayout from "./AppLayout.astro";

interface Props {
  title: string;
  description: string;
  page:
    | "intake"
    | "cases"
    | "replies"
    | "taxonomy"
    | "knowledge"
    | "helpdesk"
    | "sheet-filter"
    | "pdf-filter"
    | "sheet-to-pdf";
}

const { title, description, page } = Astro.props;
const links = [
  { ids: ["intake"], label: "Complaint Intake", href: "/crm/intake/" },
  { ids: ["cases"], label: "Complaint Cases", href: "/crm/cases/" },
  { ids: ["replies"], label: "Reply Workspace", href: "/crm/replies/" },
  { ids: ["taxonomy"], label: "Taxonomy", href: "/crm/taxonomy/" },
  { ids: ["knowledge"], label: "AI Reply Archive", href: "/crm/knowledge/" },
  { ids: ["helpdesk"], label: "Helpdesk Sync", href: "/crm/helpdesk/" },
  { ids: ["sheet-filter", "pdf-filter", "sheet-to-pdf"], label: "Bulk Tools", href: "/crm/" },
];
---

<AppLayout title={title} eyebrow="Operations / CRM" description={description} active="crm">
  <slot name="actions" slot="actions" />
  <nav class="section-tabs crm-lifecycle-tabs" aria-label="CRM pages">
    {links.map((item) => (
      <a class:list={{ active: item.ids.includes(page) }} href={item.href}>{item.label}</a>
    ))}
  </nav>
  <slot />
</AppLayout>

<style>
  .crm-lifecycle-tabs{overflow-x:auto;scrollbar-width:thin;white-space:nowrap}
</style>
