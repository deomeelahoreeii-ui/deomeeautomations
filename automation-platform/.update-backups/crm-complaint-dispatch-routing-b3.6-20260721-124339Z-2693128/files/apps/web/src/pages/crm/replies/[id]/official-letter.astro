---
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const { id } = Astro.params;
if (!id) return Astro.redirect('/crm/replies/');
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Prepare Official Letter" description="Create a legal-size DEO official letter from the immutable approved reply revision." page="replies">
  <a class="btn btn-sm" href={`/crm/replies/${id}/`} slot="actions">← Reply Editor</a>
  <a class="btn btn-sm" href="/crm/replies/official-letters/" slot="actions">Official Letters</a>
  <a class="btn btn-sm" href="/crm/replies/official-letters/settings/" slot="actions">Configuration</a>
  <main id="official-letter-preparer" data-api-base={apiBase} data-case-id={id} class="crm32-page official-letter-preparer">
    <nav class="reply-mode-tabs" aria-label="Reply workspace modes"><a href="/crm/replies/">Reply Queue</a><a href="/crm/replies/bulk/">Bulk Operations</a><a class="active" href="/crm/replies/official-letters/">Official Letters</a></nav>
    <section id="letter-warning" class="crm-warning-box" hidden></section>
    <section class="official-letter-workspace">
      <aside class="master-card official-letter-source-card">
        <header class="crm-card-heading"><div><p class="eyebrow">Immutable source</p><h2 id="source-title">Loading approved reply…</h2><p>The complaint and approved reply snapshots cannot be edited on this page.</p></div></header>
        <div class="source-tabs"><button class="active" type="button" data-source="complaint">Complaint</button><button type="button" data-source="reply">Approved Reply</button><button type="button" data-source="history">Letter History</button></div>
        <article id="source-complaint" class="official-source-panel active"></article>
        <article id="source-reply" class="official-source-panel" hidden></article>
        <div id="source-history" class="official-source-panel configuration-list" hidden></div>
      </aside>
      <section class="master-card official-letter-form-card">
        <header class="crm-card-heading"><div><p class="eyebrow">Letter details</p><h2>Number, date, recipient and signatory</h2><p>The number and date are shared defaults and stay the same across complaint letters. Changing them here and finalizing the letter makes the new values the defaults for subsequent letters. A complete PDF can then place the official letter before the original complaint and accepted attachments.</p></div><span id="letter-status" class="crm-status-badge warning">Draft configuration</span></header>
        <form id="letter-form" class="official-letter-form">
          <input id="reply-revision-id" type="hidden" />
          <input id="letter-id" type="hidden" /><input id="supersedes-letter-id" type="hidden" />
          <div class="official-letter-form-grid">
            <label class="crm-field"><span>Shared letter number</span><input id="letter-number" class="input input-bordered" required /><small>Reused for all new letters until changed.</small></label>
            <label class="crm-field"><span>Shared letter date</span><input id="letter-date" class="input input-bordered" type="date" required /><small>Reused for all new letters until changed.</small></label>
            <label class="crm-field"><span>Recipient</span><input id="recipient-name" class="input input-bordered" required /></label>
            <label class="crm-field"><span>Recipient location</span><input id="recipient-location" class="input input-bordered" required /></label>
            <label class="crm-field"><span>Subject prefix</span><input id="subject-prefix" class="input input-bordered" required /></label>
            <label class="crm-field"><span>Template version</span><select id="template-id" class="select select-bordered" required></select></label>
            <label class="crm-field"><span>Signature profile</span><select id="signature-id" class="select select-bordered" required></select></label>
            <label class="crm-field full"><span>CC entries, one per line</span><textarea id="cc-entries" class="textarea textarea-bordered" rows="3"></textarea></label>
          </div>
          <div class="official-letter-actions"><button id="preview-letter" class="btn" type="submit">Generate Preview</button><button id="create-revision" class="btn" type="button" hidden>Create Revised Letter</button><button id="finalize-letter" class="btn btn-primary" type="button" disabled>Finalize Official Letter</button></div>
        </form>
        <section id="letter-artifacts" class="official-letter-artifacts" hidden><div><strong id="artifact-heading">Preview generated</strong><small id="artifact-note"></small></div><div id="artifact-actions" class="table-actions"></div></section>
      </section>
    </section>
    <section id="preview-card" class="master-card official-letter-preview-card" hidden><header class="crm-card-heading"><div><p class="eyebrow">Browser preview</p><h2 id="preview-title">Official letter PDF</h2><p id="preview-description">Review the legal-size output before finalizing the official record.</p></div><button id="close-preview" class="btn btn-sm" type="button">Hide preview</button></header><iframe id="letter-preview-frame" title="Official letter PDF preview"></iframe></section>
    <div id="letter-toast" class="crm-toast" role="status" hidden></div>
  </main>
  <script>
    const root = document.getElementById('official-letter-preparer') as HTMLElement;
    const API = root.dataset.apiBase || '';
    const caseId = root.dataset.caseId || '';
    const $ = (id:string) => document.getElementById(id) as any;
    let data:any = null;
    let current:any = null;

    function toast(message:string, error=false) {
      const node = $('letter-toast');
      node.textContent = message;
      node.className = `crm-toast${error ? ' error' : ''}`;
      node.hidden = false;
      window.setTimeout(() => node.hidden = true, 5000);
    }

    async function api(path:string, init?:RequestInit) {
      const headers = new Headers(init?.headers || {});
      if (init?.body) headers.set('Content-Type', 'application/json');
      const response = await fetch(`${API}${path}`, {...init, headers});
      const body = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(typeof body.detail === 'string' ? body.detail : body.detail?.message || response.statusText);
      return body;
    }

    function action(label:string, href:string, primary=false) {
      const link = document.createElement('a');
      link.className = primary ? 'btn btn-primary btn-sm' : 'btn btn-sm';
      link.href = href;
      link.textContent = label;
      return link;
    }

    function command(label:string, handler:() => void, primary=false) {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = primary ? 'btn btn-primary btn-sm' : 'btn btn-sm';
      button.textContent = label;
      button.addEventListener('click', handler);
      return button;
    }

    function setFormDisabled(disabled:boolean) {
      for (const node of document.querySelectorAll<HTMLInputElement|HTMLTextAreaElement|HTMLSelectElement>('#letter-form input:not([type="hidden"]), #letter-form textarea, #letter-form select')) node.disabled = disabled;
      $('preview-letter').hidden = disabled;
    }

    function renderHistory() {
      const rows = data.letters || [];
      const content = rows.length ? rows.map((letter:any) => {
        const row = document.createElement('article');
        row.className = 'configuration-row';
        const copy = document.createElement('div');
        const title = document.createElement('strong');
        title.textContent = letter.letter_number;
        const detail = document.createElement('small');
        detail.textContent = `${letter.letter_date} · ${letter.status} · revision ${letter.revision}`;
        copy.append(title, detail);
        row.append(copy, action('Open', letter.letter_url));
        return row;
      }) : [Object.assign(document.createElement('div'), {className:'crm-empty-state compact', textContent:'No official letter has been created for this complaint.'})];
      $('source-history').replaceChildren(...content);
    }

    function populateDefaults() {
      const defaults = data.defaults;
      $('letter-id').value = '';
      $('supersedes-letter-id').value = '';
      $('letter-number').value = defaults.suggested_letter_number;
      $('letter-date').value = defaults.letter_date;
      $('recipient-name').value = defaults.default_recipient_name;
      $('recipient-location').value = defaults.default_recipient_location;
      $('subject-prefix').value = defaults.default_subject_prefix;
      $('cc-entries').value = defaults.default_cc_entries;
      $('template-id').value = defaults.default_template_id || '';
      $('signature-id').value = defaults.default_signature_id || '';
      current = null;
      $('letter-status').textContent = 'Draft configuration';
      $('letter-status').className = 'crm-status-badge warning';
      $('letter-artifacts').hidden = true;
      $('preview-card').hidden = true;
      $('finalize-letter').disabled = true;
      $('finalize-letter').hidden = false;
      $('create-revision').hidden = true;
      setFormDisabled(false);
    }

    function render() {
      const complaint = data.case;
      const revision = data.approved_revision;
      $('source-title').textContent = `Complaint ${complaint.complaint_number}`;
      $('source-complaint').textContent = complaint.complaint_text || 'No complaint text.';
      $('source-reply').textContent = revision.reply_text || 'No approved reply text.';
      $('reply-revision-id').value = revision.id;
      $('template-id').replaceChildren(...data.templates.map((item:any) => new Option(`${item.name} · v${item.version}`, item.id)));
      $('signature-id').replaceChildren(...data.signatures.map((item:any) => new Option(`${item.name} · ${item.designation}`, item.id)));
      populateDefaults();
      renderHistory();
    }

    function payload(finalize=false) {
      return {
        letter_number:$('letter-number').value,
        letter_date:$('letter-date').value,
        recipient_name:$('recipient-name').value,
        recipient_location:$('recipient-location').value,
        subject_prefix:$('subject-prefix').value,
        cc_entries:$('cc-entries').value,
        template_id:$('template-id').value,
        signature_profile_id:$('signature-id').value,
        reply_revision_id:$('reply-revision-id').value,
        letter_id:$('letter-id').value || null,
        supersedes_letter_id:$('supersedes-letter-id').value || null,
        finalize,
      };
    }

    function populateLetter(letter:any) {
      $('letter-id').value = letter.id;
      $('letter-number').value = letter.letter_number;
      $('letter-date').value = letter.letter_date;
      $('recipient-name').value = letter.recipient_name;
      $('recipient-location').value = letter.recipient_location;
      $('subject-prefix').value = letter.subject_prefix;
      $('cc-entries').value = letter.cc_entries;
      $('template-id').value = letter.template_id;
      $('signature-id').value = letter.signature_profile_id;
    }

    function showArtifacts(letter:any) {
      current = letter;
      populateLetter(letter);
      $('letter-status').textContent = letter.status;
      $('letter-status').className = `crm-status-badge ${letter.status === 'finalized' ? 'success' : letter.status === 'failed' ? 'danger' : 'warning'}`;
      $('letter-artifacts').hidden = false;
      $('artifact-heading').textContent = letter.status === 'finalized' ? 'Official letter finalized' : letter.status === 'superseded' ? 'Superseded official letter' : 'Preview generated';
      const warnings = letter.warnings || [];
      const sourceCount = data?.source_documents?.length || 0;
      $('artifact-note').textContent = `Letter ${letter.letter_number} · revision ${letter.revision}${sourceCount ? ` · ${sourceCount} accepted source document(s)` : ' · no accepted source documents'}${warnings.length ? ` · ${warnings.join(' ')}` : ''}`;
      const actions = $('artifact-actions');
      actions.replaceChildren();
      const pdf = letter.artifacts?.find((item:any) => item.kind === 'pdf');
      const complete = letter.artifacts?.find((item:any) => item.kind === 'complete_pdf');
      const odt = letter.artifacts?.find((item:any) => item.kind === 'odt');
      if (pdf) {
        actions.append(action('Preview Letter PDF', `${API}${pdf.preview_url}`, true), action('Download Letter PDF', `${API}${pdf.download_url}`));
        $('letter-preview-frame').src = `${API}${pdf.preview_url}`;
        $('preview-title').textContent = 'Official letter PDF';
        $('preview-description').textContent = 'Review the legal-size official letter output.';
        $('preview-card').hidden = false;
      }
      if (odt) actions.append(action('Download ODT', `${API}${odt.download_url}`));
      const immutable = ['finalized', 'superseded'].includes(letter.status);
      if (immutable) {
        if (complete) {
          actions.append(
            action('Preview Complete PDF', `${API}${complete.preview_url}`, true),
            action('Download Complete PDF', `${API}${complete.download_url}`),
            command('Rebuild Complete PDF', () => void buildCompletePdf())
          );
        } else {
          actions.append(command('Build Complete PDF', () => void buildCompletePdf(), true));
        }
      }
      setFormDisabled(immutable);
      $('finalize-letter').disabled = letter.status !== 'preview';
      $('finalize-letter').hidden = immutable;
      $('create-revision').hidden = letter.status !== 'finalized';
    }

    async function buildCompletePdf() {
      if (!current || !['finalized', 'superseded'].includes(current.status)) return;
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('#artifact-actions button'));
      buttons.forEach(button => button.disabled = true);
      try {
        const result = await api(`/api/v1/crm/official-letters/letters/${current.id}/complete-pdf`, {method:'POST', body:JSON.stringify({})});
        showArtifacts(result);
        const complete = result.artifacts?.find((item:any) => item.kind === 'complete_pdf');
        if (complete) {
          $('letter-preview-frame').src = `${API}${complete.preview_url}`;
          $('preview-title').textContent = 'Complete official record PDF';
          $('preview-description').textContent = 'Official letter first, followed by the original complaint and accepted attachments.';
          $('preview-card').hidden = false;
        }
        const skipped = result.complete_pdf?.skipped_documents?.length || 0;
        toast(skipped ? `Complete PDF created. ${skipped} source document(s) could not be included.` : 'Complete PDF created in official-letter, complaint and attachment order.');
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      } finally {
        buttons.forEach(button => button.disabled = false);
      }
    }

    async function load() {
      try {
        data = await api(`/api/v1/crm/official-letters/cases/${caseId}/prepare`);
        render();
        const requested = new URLSearchParams(location.search).get('letter');
        if (requested) showArtifacts(await api(`/api/v1/crm/official-letters/letters/${requested}`));
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error);
        $('letter-warning').hidden = false;
        $('letter-warning').textContent = message;
        toast(message, true);
      }
    }

    $('letter-form').addEventListener('submit', async (event:Event) => {
      event.preventDefault();
      const button = $('preview-letter');
      button.disabled = true;
      button.textContent = 'Generating preview…';
      try {
        const result = await api(`/api/v1/crm/official-letters/cases/${caseId}/generate`, {method:'POST', body:JSON.stringify(payload(false))});
        showArtifacts(result);
        toast(result.warnings?.length ? result.warnings.join(' ') : 'Preview generated. Review the PDF before finalizing.');
      } catch (error) { toast(error instanceof Error ? error.message : String(error), true); }
      finally { button.disabled = false; button.textContent = 'Generate Preview'; }
    });

    $('finalize-letter').addEventListener('click', async () => {
      if (!current || current.status !== 'preview') return;
      if (!confirm(`Finalize official letter ${current.letter_number}? The approved reply and artifacts will become immutable.`)) return;
      const button = $('finalize-letter');
      button.disabled = true;
      try {
        const result = await api(`/api/v1/crm/official-letters/letters/${current.id}/finalize`, {method:'POST', body:JSON.stringify({})});
        showArtifacts(result);
        toast('Official letter finalized. Its number and date are now the shared defaults for subsequent letters.');
        data = await api(`/api/v1/crm/official-letters/cases/${caseId}/prepare`);
        renderHistory();
      } catch (error) { toast(error instanceof Error ? error.message : String(error), true); }
      finally { button.disabled = false; }
    });

    $('create-revision').addEventListener('click', async () => {
      if (!current || current.status !== 'finalized') return;
      const supersededId = current.id;
      const previousNumber = current.letter_number;
      data = await api(`/api/v1/crm/official-letters/cases/${caseId}/prepare`);
      render();
      $('supersedes-letter-id').value = supersededId;
      $('letter-status').textContent = 'Revised letter configuration';
      toast(`Revised letter started. Finalizing it will supersede ${previousNumber}.`);
    });

    document.querySelectorAll('[data-source]').forEach((button:any) => button.addEventListener('click', () => {
      document.querySelectorAll('[data-source]').forEach((node:any) => node.classList.toggle('active', node === button));
      for (const name of ['complaint', 'reply', 'history']) $(`source-${name}`).hidden = button.dataset.source !== name;
    }));
    $('close-preview').addEventListener('click', () => $('preview-card').hidden = true);
    void load();
  </script>
</CrmLayout>
