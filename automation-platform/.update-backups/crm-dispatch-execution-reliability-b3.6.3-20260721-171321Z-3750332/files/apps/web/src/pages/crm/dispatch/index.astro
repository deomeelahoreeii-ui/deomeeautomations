---
import CrmLayout from "../../../layouts/CrmLayout.astro";
import DataTable from "../../../components/DataTable.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
const preselectedLetter = Astro.url.searchParams.get("letter_id") || "";
const preselectedCase = Astro.url.searchParams.get("case_id") || "";
---
<CrmLayout title="CRM Dispatch" description="Request compliance from lower offices and submit completed compliance to higher offices through controlled WhatsApp dispatch." page="dispatch">
  <a class="btn btn-sm" href="/crm/replies/official-letters/" slot="actions">Official Letters</a>
  <a class="btn btn-primary btn-sm" href="/crm/dispatch/routing/" slot="actions">Manage Routing</a>
  <main id="crm-dispatch" class="crm32-page crm-dispatch-page" data-api-base={apiBase} data-preselected-letter={preselectedLetter} data-preselected-case={preselectedCase}>
    <nav class="dispatch-tabs" aria-label="CRM dispatch pages"><a class="active" href="/crm/dispatch/">Dispatch Queue</a><a href="#batch-history">Batches</a><a href="/crm/dispatch/routing/">Routing</a><a href="#batch-history">Delivery History</a></nav>

    <section class="dispatch-direction-switch" aria-label="Dispatch direction">
      <button class="active" type="button" data-direction="downward"><strong>Request Compliance</strong><span>Send fresh or pending complaints to DDEOs, AEOs, schools or other lower offices for report, reply and evidence.</span></button>
      <button type="button" data-direction="upward"><strong>Submit Compliance</strong><span>Send the approved DEO reply, official letter, complaint and accepted evidence to the CEO or another higher office.</span></button>
    </section>

    <section class="crm-metric-grid dispatch-metrics">
      <article class="crm-metric-card" aria-label="Ready to dispatch complaints"><span>Pending assignment</span><strong id="metric-downward">—</strong><small>Fresh complaints without an approved reply</small></article>
      <article class="crm-metric-card"><span>Ready for submission</span><strong id="metric-upward">—</strong><small>Finalized official compliance packets</small></article>
      <article class="crm-metric-card"><span>Needs routing</span><strong id="metric-routing">—</strong><small>Human route decision required</small></article>
      <article class="crm-metric-card"><span>Awaiting approval</span><strong id="metric-approval">—</strong><small>Frozen WhatsApp previews ready</small></article>
      <article class="crm-metric-card"><span>Completed with errors</span><strong id="metric-errors">—</strong><small>Retry only failed destinations</small></article>
    </section>

    <section class="master-card dispatch-create-card">
      <header class="crm-card-heading"><div><p class="eyebrow" id="workflow-eyebrow">DOWNWARD ASSIGNMENT</p><h2 id="workflow-title">Select complaints requiring lower-office compliance</h2><p id="workflow-copy">The packet contains the original complaint and accepted attachments. No approved DEO reply or official letter is required at this stage.</p></div><a class="btn btn-sm" id="source-register-link" href="/crm/replies/">Open Reply Queue</a></header>
      <div class="dispatch-create-grid">
        <label class="crm-field"><span>Search complaints</span><input id="source-search" class="input input-bordered" placeholder="Complaint number or complaint text…" /></label>
        <label class="crm-field"><span>Dispatch purpose</span><select id="dispatch-purpose" class="select select-bordered"></select></label>
        <label class="crm-field"><span>Response due date (optional)</span><input id="response-due" class="input input-bordered" type="datetime-local" /></label>
      </div>
      <div class="dispatch-letter-toolbar dispatch-selection-toolbar">
        <div><strong id="selected-count">0 selected</strong><span id="available-count"></span></div>
        <div class="table-actions"><button id="select-all-visible" class="btn btn-sm" type="button">Select all</button><button id="clear-selection" class="btn btn-sm" type="button">Clear</button><button id="create-batch" class="btn btn-primary btn-sm" type="button" aria-label="Create Dispatch Batch" disabled>Create Compliance Request</button></div>
      </div>
      <div id="eligible-sources" class="dispatch-letter-grid"><p class="crm-empty-state compact">Loading eligible complaints…</p></div>
    </section>

    <section id="batch-history" class="master-card dispatch-history-card">
      <header class="crm-card-heading"><div><p class="eyebrow">Dispatch history</p><h2>CRM complaint dispatch batches</h2><p>Downward compliance requests and upward compliance submissions share one traceable preview, approval and delivery history.</p></div><button id="refresh-batches" class="btn btn-sm" type="button">↻ Refresh</button></header>
      <div class="dispatch-history-toolbar"><label class="crm-field"><span>Search</span><input id="batch-search" class="input input-bordered" placeholder="Batch number or purpose…" /></label><label class="crm-field"><span>Direction</span><select id="batch-direction" class="select select-bordered"><option value="">Both directions</option><option value="downward">Request compliance</option><option value="upward">Submit compliance</option></select></label><label class="crm-field"><span>Status</span><select id="batch-status" class="select select-bordered"><option value="">All statuses</option><option value="review_required">Needs routing</option><option value="ready">Awaiting approval</option><option value="sending">Sending</option><option value="completed">Completed</option><option value="completed_with_errors">Completed with errors</option><option value="failed">Failed</option></select></label></div>
      <DataTable id="dispatch-batch-table" pageSize={25} pageSizeOptions={[25,50,100]} emptyText="No dispatch batches match the filters." ariaLabel="CRM dispatch batches" />
    </section>
    <div id="dispatch-toast" class="crm-toast" role="status" hidden></div>
  </main>
  <script>
    const root=document.getElementById('crm-dispatch') as HTMLElement; const API=root.dataset.apiBase||''; const table=document.getElementById('dispatch-batch-table') as any;
    const selected=new Set<string>(); let sources:any[]=[]; let direction=(root.dataset.preselectedLetter?'upward':'downward');
    const $=(id:string)=>document.getElementById(id) as any;
    const purposeOptions={downward:[['compliance_request','Request complete compliance'],['report_request','Request field report'],['evidence_request','Request supporting evidence'],['clarification_request','Request clarification'],['information_only','For information']],upward:[['compliance_submission','Submit compliance to CEO/higher office'],['reply_submission','Submit approved reply'],['follow_up_submission','Submit follow-up compliance'],['information_only','For information']]};
    function toast(message:string,error=false){const n=$('dispatch-toast');n.textContent=message;n.className=`crm-toast${error?' error':''}`;n.hidden=false;window.setTimeout(()=>n.hidden=true,5000)}
    async function api(path:string,init?:RequestInit){const h=new Headers(init?.headers||{});if(init?.body)h.set('Content-Type','application/json');const r=await fetch(`${API}${path}`,{...init,headers:h});const b=await r.json().catch(()=>({}));if(!r.ok)throw new Error(typeof b.detail==='string'?b.detail:r.statusText);return b}
    const stack=(a:string,b:string)=>{const d=document.createElement('div');d.className='table-stack';const x=document.createElement('strong');x.textContent=a;const y=document.createElement('small');y.textContent=b;d.append(x,y);return d};
    const badge=(v:string)=>{const s=document.createElement('span');s.className=`crm-status-badge ${['completed','delivered'].includes(v)?'success':['failed','completed_with_errors'].includes(v)?'danger':['ready','review_required'].includes(v)?'warning':''}`;s.textContent=v.replaceAll('_',' ');return s};
    function updateWorkflow(){for(const b of document.querySelectorAll<HTMLButtonElement>('[data-direction]'))b.classList.toggle('active',b.dataset.direction===direction);const down=direction==='downward';$('workflow-eyebrow').textContent=down?'DOWNWARD ASSIGNMENT':'UPWARD SUBMISSION';$('workflow-title').textContent=down?'Select complaints requiring lower-office compliance':'Select finalized compliance packets for higher office';$('workflow-copy').textContent=down?'The packet contains the original complaint and accepted attachments. Reports and evidence received later can be uploaded in the Reply Editor.':'The packet contains the official letter, approved DEO reply, original complaint and all accepted reports/evidence.';$('source-register-link').href=down?'/crm/replies/':'/crm/replies/official-letters/';$('source-register-link').textContent=down?'Open Reply Queue':'Open Letter Register';$('source-search').placeholder=down?'Complaint number or complaint text…':'Complaint or letter number…';$('dispatch-purpose').replaceChildren(...purposeOptions[direction].map(([v,l])=>new Option(l,v)));$('create-batch').textContent=down?'Create Compliance Request':'Create Compliance Submission';selected.clear();void loadSources()}
    function selection(){ $('selected-count').textContent=`${selected.size} selected`; $('create-batch').disabled=!selected.size; for(const input of document.querySelectorAll<HTMLInputElement>('[data-source-check]'))input.checked=selected.has(input.value)}
    function renderSources(){const cards=sources.map(item=>{const label=document.createElement('label');label.className='dispatch-letter-card';const input=document.createElement('input');input.type='checkbox';input.className='checkbox checkbox-sm';input.dataset.sourceCheck='1';input.value=item.id;input.checked=selected.has(item.id);input.disabled=!item.ready;input.addEventListener('change',()=>{input.checked?selected.add(item.id):selected.delete(item.id);selection()});const body=document.createElement('div');const title=document.createElement('strong');title.textContent=item.complaint_number;const detail=document.createElement('span');detail.textContent=direction==='downward'?`${item.category||'Unclassified'}${item.subcategory?` · ${item.subcategory}`:''} · ${item.state}`:`${item.letter_number} · ${item.letter_date}`;const packet=document.createElement('small');packet.textContent=item.packet_label||'';body.append(title,detail,packet);label.append(input,body);if(!item.ready)label.classList.add('blocked');return label});$('eligible-sources').replaceChildren(...(cards.length?cards:[Object.assign(document.createElement('p'),{className:'crm-empty-state compact',textContent:direction==='downward'?'No pending complaints match this search.':'No finalized compliance packets match this search.'})]));$('available-count').textContent=`${sources.filter(x=>x.ready).length} available`;selection()}
    async function loadSources(){const q=new URLSearchParams({direction,search:$('source-search').value||'',page:'1',page_size:'500'});const result=await api(`/api/v1/crm/dispatch/eligible-sources?${q}`);sources=result.items||[];const pre=direction==='upward'?root.dataset.preselectedLetter:root.dataset.preselectedCase;if(pre&&sources.some(x=>x.id===pre))selected.add(pre);renderSources()}
    async function loadStats(){const s=await api('/api/v1/crm/dispatch/statistics');$('metric-downward').textContent=s.ready_downward||0;$('metric-upward').textContent=s.ready_upward||0;$('metric-routing').textContent=s.needs_routing;$('metric-approval').textContent=s.awaiting_approval;$('metric-errors').textContent=s.completed_with_errors}
    async function loadPage(pageIndex:number,pageSize:number){const q=new URLSearchParams({page:String(pageIndex+1),page_size:String(pageSize),search:$('batch-search').value||'',status:$('batch-status').value||'',direction:$('batch-direction').value||''});const r=await api(`/api/v1/crm/dispatch/batches?${q}`);const rows=r.items||[];return{rows,total:r.total,pageCount:Math.max(1,Math.ceil(r.total/pageSize))}}
    async function configureTable(){await table.configure({manualPagination:true,pageLoader:loadPage,columns:[{header:'Batch',accessorKey:'batch_number',cell:(c:any)=>stack(c.getValue(),new Date(c.row.original.created_at).toLocaleString())},{header:'Workflow',id:'workflow',cell:(c:any)=>stack(c.row.original.direction==='downward'?'Request compliance':'Submit compliance',c.row.original.purpose.replaceAll('_',' '))},{header:'Status',accessorKey:'status',cell:(c:any)=>badge(c.getValue())},{header:'Progress',id:'progress',cell:(c:any)=>stack(`${c.row.original.ready_items}/${c.row.original.total_items} ready`,`${c.row.original.successful_items} delivered · ${c.row.original.failed_items} failed`)},{header:'Actions',id:'actions',cell:(c:any)=>{const a=document.createElement('a');a.className='btn btn-primary btn-sm';a.href=c.row.original.detail_url;a.textContent='Review';return a},meta:{width:'100px',align:'right'}}]});await table.reload()}
    for(const b of document.querySelectorAll<HTMLButtonElement>('[data-direction]'))b.addEventListener('click',()=>{direction=b.dataset.direction||'downward';updateWorkflow()});
    $('select-all-visible').addEventListener('click',()=>{for(const item of sources)if(item.ready)selected.add(item.id);selection()});$('clear-selection').addEventListener('click',()=>{selected.clear();selection()});
    let sourceTimer=0;$('source-search').addEventListener('input',()=>{clearTimeout(sourceTimer);sourceTimer=window.setTimeout(()=>void loadSources(),250)});
    $('create-batch').addEventListener('click',async()=>{const b=$('create-batch');b.disabled=true;try{const payload={direction,purpose:$('dispatch-purpose').value,response_due_at:$('response-due').value?new Date($('response-due').value).toISOString():null,case_ids:direction==='downward'?[...selected]:[],official_letter_ids:direction==='upward'?[...selected]:[],actor:'web-operator'};const r=await api('/api/v1/crm/dispatch/batches',{method:'POST',body:JSON.stringify(payload)});location.href=`/crm/dispatch/batches/${r.batch.id}/`}catch(e){toast(e instanceof Error?e.message:String(e),true);b.disabled=false}});
    $('refresh-batches').addEventListener('click',()=>void table.reload());$('batch-search').addEventListener('input',()=>void table.setPageIndex(0));$('batch-status').addEventListener('change',()=>void table.setPageIndex(0));$('batch-direction').addEventListener('change',()=>void table.setPageIndex(0));
    Promise.all([loadStats(),configureTable()]).then(()=>updateWorkflow()).catch(e=>toast(e instanceof Error?e.message:String(e),true));
  </script>
</CrmLayout>
