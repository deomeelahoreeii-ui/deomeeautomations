---
import DataTable from "../../../components/DataTable.astro";
import WhatsAppLayout from "../../../layouts/WhatsAppLayout.astro";
---

<WhatsAppLayout title="Dispatch Previews" description="Frozen, exact WhatsApp delivery plans generated from completed module dry runs." page="previews">
  <button class="btn btn-sm btn-primary" id="create-preview" slot="actions">＋ Create preview</button>

  <div class="notice preview-notice">
    Preview compilation never publishes to NATS or records a delivery. It freezes the exact messages, recipients, routes and file checksums for review.
  </div>

  <nav class="preview-workflow-tabs" aria-label="Preview workflow">
    <button class="preview-workflow-tab active" type="button" data-view="pending">Pending review</button>
    <button class="preview-workflow-tab" type="button" data-view="sending">Approved & queued</button>
    <button class="preview-workflow-tab" type="button" data-view="history">Delivery history</button>
  </nav>

  <div class="toolbar directory-toolbar">
    <input class="input input-bordered input-sm search-input" id="preview-search" placeholder="Search batch, profile, audience or wing…" />
    <select class="select select-bordered select-sm" id="preview-status">
      <option value="">All states</option>
      <option value="ready">Ready</option>
      <option value="blocked">Blocked</option>
      <option value="stale">Stale</option>
    </select>
    <span class="toolbar-status" id="preview-total">Loading…</span>
  </div>
  <div class="bulk-preview-bar" id="bulk-preview-bar" hidden>
    <strong id="selected-preview-count">0 selected</strong>
    <button class="btn btn-xs" type="button" id="select-matching">Select all matching</button>
    <button class="btn btn-xs" type="button" id="clear-selection">Clear</button>
    <span class="bulk-spacer"></span>
    <button class="btn btn-xs btn-primary" type="button" id="bulk-approve">Approve & queue</button>
    <button class="btn btn-xs btn-error" type="button" id="bulk-delete">Delete permanently</button>
  </div>
  <article class="master-card"><DataTable id="previews-table" pageSize={10} emptyText="No dispatch previews have been created." /></article>

  <dialog class="modal" id="preview-dialog"><div class="modal-box master-modal wide-modal">
    <div class="modal-title"><div><p class="eyebrow">Preview only</p><h2>Compile dispatch previews</h2><small>Choose one report run, then select the routes you want to review together.</small></div><button type="button" id="close-preview">×</button></div>
    <form class="master-form preview-create-form" id="preview-form">
      <label class="full"><span>Completed dry run *</span><select class="select select-bordered select-sm" id="source-run" required></select><small id="source-run-help">Select a run containing an exact dispatch plan.</small></label>
      <div class="full profile-picker">
        <span class="field-label">Dispatch profiles *</span>
        <div class="profile-picker-toolbar">
          <select class="select select-bordered select-sm" id="profile-module" aria-label="Module"></select>
          <select class="select select-bordered select-sm" id="profile-wing"></select>
          <button class="btn btn-sm" type="button" id="select-visible-profiles">Select visible</button>
          <button class="btn btn-sm" type="button" id="clear-profiles">Clear</button>
          <strong id="selected-profile-count">0 selected</strong>
        </div>
        <div class="profile-options" id="dispatch-profiles"></div>
        <small id="profile-help">Select one or more routes from the same module.</small>
      </div>
      <div class="preview-compile-explainer full">
        <strong>What will happen</strong>
        <span>Resolve routes → validate wing isolation → hash attachments → render exact messages → freeze the review snapshot.</span>
      </div>
      <div class="form-actions"><button class="btn btn-sm" type="button" id="cancel-preview">Cancel</button><button class="btn btn-sm btn-primary" id="compile-preview" type="submit">Compile frozen preview</button></div>
    </form>
  </div><form method="dialog" class="modal-backdrop"><button>close</button></form></dialog>

  <style is:global>
    .preview-workflow-tabs{display:flex;gap:.4rem;margin:.8rem 0}.preview-workflow-tab{border:1px solid #d5deea;background:#fff;border-radius:.55rem;padding:.55rem .85rem;font-weight:700;color:#60708a}.preview-workflow-tab.active{background:#e4f4f7;border-color:#63b6c2;color:#086b78}.bulk-preview-bar,.profile-picker-toolbar{display:flex;align-items:center;gap:.55rem;flex-wrap:wrap}.bulk-preview-bar{padding:.65rem .8rem;border:1px solid #d5deea;border-radius:.65rem;background:#fff;margin:.6rem 0}.bulk-spacer{flex:1}.profile-picker-toolbar .select{width:auto;min-width:11rem;flex:0 1 15rem}.profile-options{border:1px solid #d5deea;border-radius:.65rem;max-height:18rem;overflow:auto;margin-top:.55rem;background:#fff}.profile-wing-heading{padding:.55rem .8rem;background:#f3f7fb;border-bottom:1px solid #d5deea;font-size:.72rem;letter-spacing:.07em;text-transform:uppercase;color:#60708a;font-weight:800}.profile-option{display:grid;grid-template-columns:auto minmax(0,1fr);align-items:start;gap:.75rem;padding:.75rem .8rem;border-bottom:1px solid #e5ebf2;cursor:pointer}.profile-option:hover{background:#f6fbfc}.profile-option:last-child{border-bottom:0}.profile-option strong,.profile-option small{display:block}.profile-option strong{font-size:.9rem}.profile-option small{color:#718198;margin-top:.2rem}.field-label{display:block;font-weight:700;font-size:.76rem;margin-bottom:.35rem}.profile-picker-toolbar strong{margin-left:auto;font-size:.78rem}.profile-selection-summary{padding:.55rem .7rem;background:#eef8fa;border-radius:.5rem;color:#176877;font-size:.78rem}
  </style>

  <script>
    import { actions } from "astro:actions";
    import { actionButtons, badge, stack } from "../../../scripts/table-cells";
    import { closeAlert, confirmAction, showError, showLoading, showSuccess } from "../../../scripts/alerts";

    await customElements.whenDefined("astro-data-table");
    const table = document.getElementById("previews-table") as any;
    const dialog = document.getElementById("preview-dialog") as HTMLDialogElement;
    const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    let timer: number | undefined;
    let options: any = { runs: [], profiles: [] };
    let currentRows: any[] = [];
    let activeView: "pending" | "sending" | "history" = "pending";
    const selectedPreviews = new Set<string>();
    const selectedProfiles = new Set<string>();

    const formatDate = (value: string) => new Date(value).toLocaleString();
    const tone = (status: string) => status === "blocked" || status === "ready_with_exclusions" ? "warning" : status === "stale" ? "inactive" : "";

    function updateBulkBar() {
      const count = selectedPreviews.size;
      el<HTMLDivElement>("bulk-preview-bar").hidden = count === 0;
      el("selected-preview-count").textContent = `${count} selected`;
    }

    function selectionBox(id?: string) {
      const input = document.createElement("input");
      input.type = "checkbox";
      input.className = "checkbox checkbox-sm";
      if (id) {
        input.disabled = activeView !== "pending";
        input.checked = selectedPreviews.has(id);
        input.setAttribute("aria-label", "Select preview");
        input.addEventListener("change", () => {
          input.checked ? selectedPreviews.add(id) : selectedPreviews.delete(id);
          updateBulkBar();
        });
      } else {
        input.disabled = activeView !== "pending";
        input.checked = currentRows.length > 0 && currentRows.every((row) => selectedPreviews.has(row.id));
        input.setAttribute("aria-label", "Select current page");
        input.addEventListener("change", () => {
          currentRows.forEach((row) => input.checked ? selectedPreviews.add(row.id) : selectedPreviews.delete(row.id));
          updateBulkBar();
          void table.refresh(false);
        });
      }
      return input;
    }

    async function loadPage(pageIndex: number, pageSize: number) {
      const result = await actions.whatsapp.previews({
        search: el<HTMLInputElement>("preview-search").value,
        status: el<HTMLSelectElement>("preview-status").value,
        view: activeView,
        page: pageIndex + 1,
        pageSize,
      });
      if (result.error) throw result.error;
      const data = result.data as any;
      currentRows = data.items;
      el("preview-total").textContent = `${data.total} preview${data.total === 1 ? "" : "s"}`;
      return { rows: data.items, total: data.total };
    }

    function visibleProfiles() {
      const moduleKey = el<HTMLSelectElement>("profile-module").value;
      const wing = el<HTMLSelectElement>("profile-wing").value;
      return options.profiles.filter((profile: any) =>
        (!moduleKey || (profile.application_key || "antidengue") === moduleKey) && (!wing || profile.wing_name === wing)
      );
    }

    function updateProfileSelection() {
      el("selected-profile-count").textContent = `${selectedProfiles.size} selected`;
      const button = el<HTMLButtonElement>("compile-preview");
      button.disabled = !options.runs.length || !selectedProfiles.size;
      button.textContent = selectedProfiles.size
        ? `Compile ${selectedProfiles.size} preview${selectedProfiles.size === 1 ? "" : "s"}`
        : "Select profiles to continue";
    }

    function renderProfiles() {
      const container = el("dispatch-profiles");
      const profiles = visibleProfiles().sort((a: any, b: any) => a.wing_name.localeCompare(b.wing_name) || a.name.localeCompare(b.name));
      container.innerHTML = "";
      let currentWing = "";
      profiles.forEach((profile: any) => {
        if (profile.wing_name !== currentWing) {
          currentWing = profile.wing_name;
          const heading = document.createElement("div");
          heading.className = "profile-wing-heading";
          heading.textContent = currentWing;
          container.append(heading);
        }
        const label = document.createElement("label");
        label.className = "profile-option";
        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.className = "checkbox checkbox-sm";
        checkbox.checked = selectedProfiles.has(profile.id);
        checkbox.addEventListener("change", () => {
          checkbox.checked ? selectedProfiles.add(profile.id) : selectedProfiles.delete(profile.id);
          updateProfileSelection();
        });
        const detail = document.createElement("div");
        const title = document.createElement("strong");
        title.textContent = profile.name;
        const meta = document.createElement("small");
        meta.textContent = `${profile.report_type_name} → ${profile.recipient_scope_name} · ${profile.target_count} target${profile.target_count === 1 ? "" : "s"} · v${profile.version}`;
        detail.append(title, meta);
        label.append(checkbox, detail);
        container.append(label);
      });
      if (!profiles.length) container.textContent = "No profiles match these filters.";
      updateProfileSelection();
    }

    function populateDialog() {
      const runSelect = el<HTMLSelectElement>("source-run");
      runSelect.innerHTML = options.runs.length
        ? options.runs.map((run: any) => `<option value="${run.id}">${formatDate(run.created_at)} · ${run.planned_delivery_count ? `${run.planned_delivery_count} planned` : "nothing to dispatch"} · ${run.quality_warning_count} warnings</option>`).join("")
        : '<option value="">No completed AntiDengue dry run with a frozen plan</option>';
      const modules = [...new Map(options.profiles.map((profile: any) => [profile.application_key || "antidengue", profile.application_name || "AntiDengue"])).entries()];
      el<HTMLSelectElement>("profile-module").innerHTML = modules.map(([key, name]) => `<option value="${key}">${name}</option>`).join("");
      const wings = [...new Set(options.profiles.map((profile: any) => profile.wing_name))];
      el<HTMLSelectElement>("profile-wing").innerHTML = '<option value="">All wings</option>' + wings.map((wing) => `<option value="${wing}">${wing}</option>`).join("");
      selectedProfiles.clear();
      renderProfiles();
      el("source-run-help").textContent = options.runs.length
        ? "Only successful dry runs are eligible. Report-generation warnings remain visible in the preview."
        : "Run AntiDengue in dry-run mode first.";
      el("profile-help").textContent = options.profiles.length
        ? "Every route is checked against this profile and its wing-scoped audience."
        : "Configure an audience and enabled AntiDengue dispatch profile first.";
    }

    async function openCreate() {
      try {
        const result = await actions.whatsapp.previewOptions();
        if (result.error) throw result.error;
        options = result.data;
        populateDialog();
        const requestedRun = new URLSearchParams(window.location.search).get("source_job_id");
        if (requestedRun && options.runs.some((run: any) => run.id === requestedRun)) el<HTMLSelectElement>("source-run").value = requestedRun;
        dialog.showModal();
      } catch (error) { await showError(error); }
    }

    try {
      await table.configure({ manualPagination: true, loadPage, columns: [
        { id: "select", header: () => selectionBox(), enableSorting: false, cell: ({row}: any) => selectionBox(row.original.id) },
        { accessorKey: "preview_key", header: "Preview", enableSorting: false, cell: ({row}: any) => stack(row.original.preview_key, formatDate(row.original.created_at)) },
        { accessorKey: "profile_name", header: "Routing", enableSorting: false, cell: ({row}: any) => stack(row.original.profile_name, `${row.original.audience_name} · v${row.original.profile_version}`) },
        { accessorKey: "wing_name", header: "Wing / report", enableSorting: false, cell: ({row}: any) => stack(row.original.wing_name, row.original.report_type_name) },
        { accessorKey: "delivery_count", header: "Deliveries", enableSorting: false, cell: ({row}: any) => stack(
          `${row.original.delivery_count} planned`,
          `${row.original.ready_count} ready · ${row.original.warning_count} warning-state · ${row.original.blocked_count} blocked${row.original.warning_issue_count ? ` · ${row.original.warning_issue_count} warning issue(s)` : ""}${row.original.blocked_issue_count ? ` · ${row.original.blocked_issue_count} blocker issue(s)` : ""}`
        ) },
        { accessorKey: "status", header: "State", enableSorting: false, cell: ({row}: any) => badge((row.original.display_status || row.original.status).replaceAll("_", " "), tone(row.original.display_status || row.original.status)) },
        { id: "actions", header: "", enableSorting: false, cell: ({row}: any) => actionButtons(row.original.approved ? [
          { label: "View delivery audit", onClick: () => { window.location.href = `/whatsapp/previews/${row.original.id}`; } },
        ] : [
          { label: "Review", onClick: () => { window.location.href = `/whatsapp/previews/${row.original.id}`; } },
          {label:"Delete permanently",tone:"danger",onClick:async()=>{if(!await confirmAction("Permanently delete this preview?","Frozen deliveries and managed attachment copies will be removed.","Delete permanently"))return;const result=await actions.whatsapp.hardDeletePreview({id:row.original.id});if(result.error)await showError(result.error);else{await showSuccess("Preview deleted","The frozen batch was removed.");await table.refresh(true);}}},
        ]) },
      ]});
    } catch (error) { await showError(error); }

    el("create-preview").addEventListener("click", () => void openCreate());
    el("close-preview").addEventListener("click", () => dialog.close());
    el("cancel-preview").addEventListener("click", () => dialog.close());
    el("profile-module").addEventListener("change", renderProfiles);
    el("profile-wing").addEventListener("change", renderProfiles);
    el("select-visible-profiles").addEventListener("click", () => { visibleProfiles().forEach((profile: any) => selectedProfiles.add(profile.id)); renderProfiles(); });
    el("clear-profiles").addEventListener("click", () => { selectedProfiles.clear(); renderProfiles(); });
    el("clear-selection").addEventListener("click", () => { selectedPreviews.clear(); updateBulkBar(); void table.refresh(false); });
    el("select-matching").addEventListener("click", async () => {
      try {
        const result = await actions.whatsapp.previewSelection({search: el<HTMLInputElement>("preview-search").value, status: el<HTMLSelectElement>("preview-status").value, view: activeView});
        if (result.error) throw result.error;
        (result.data as any).ids.forEach((id: string) => selectedPreviews.add(id));
        updateBulkBar(); await table.refresh(false);
      } catch (error) { await showError(error); }
    });
    el("preview-status").addEventListener("change", () => { selectedPreviews.clear(); updateBulkBar(); void table.refresh(true); });
    el("preview-search").addEventListener("input", () => { selectedPreviews.clear(); updateBulkBar(); window.clearTimeout(timer); timer = window.setTimeout(() => void table.refresh(true), 250); });
    document.querySelectorAll<HTMLButtonElement>(".preview-workflow-tab").forEach((button) => button.addEventListener("click", () => {
      activeView = button.dataset.view as typeof activeView;
      document.querySelectorAll(".preview-workflow-tab").forEach((item) => item.classList.toggle("active", item === button));
      selectedPreviews.clear(); updateBulkBar(); void table.refresh(true);
    }));
    el("bulk-delete").addEventListener("click", async () => {
      const ids = [...selectedPreviews];
      if (!await confirmAction(`Delete ${ids.length} previews permanently?`, "Approved audit records are protected. Frozen deliveries and managed attachment copies will be removed.", "Delete selected")) return;
      const result = await actions.whatsapp.bulkDeletePreviews({preview_ids: ids});
      if (result.error) return void await showError(result.error);
      selectedPreviews.clear(); updateBulkBar(); await showSuccess("Previews deleted", `${ids.length} frozen batches were removed.`); await table.refresh(true);
    });
    el("bulk-approve").addEventListener("click", async () => {
      const ids = [...selectedPreviews];
      if (!await confirmAction(`Approve and queue ${ids.length} previews?`, "This acknowledges warnings and explicitly excludes any delivery-scoped blockers. Batch-blocked previews are still rejected.", "Approve & queue")) return;
      try {
        showLoading("Approving selected previews", "Checking gateway readiness and freezing delivery audit records…");
        const result = await actions.whatsapp.bulkApprovePreviews({preview_ids: ids, acknowledge_warnings: true, acknowledge_exclusions: true, approved_by: "web-operator"});
        if (result.error) throw result.error;
        closeAlert(); selectedPreviews.clear(); updateBulkBar(); await showSuccess("Deliveries queued", `${ids.length} previews were approved and queued.`); await table.refresh(true);
      } catch (error) { closeAlert(); await showError(error); }
    });
    el<HTMLFormElement>("preview-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      try {
        const profileIds = [...selectedProfiles];
        showLoading(`Compiling ${profileIds.length} dispatch preview${profileIds.length === 1 ? "" : "s"}`, "Resolving routes and hashing exact report attachments…");
        const result = await actions.whatsapp.createPreviewsBulk({
          source_job_id: el<HTMLSelectElement>("source-run").value,
          dispatch_profile_ids: profileIds,
        });
        if (result.error) throw result.error;
        const jobs = (result.data as any).jobs;
        const completed = new Map<string, any>();
        for (let attempt = 0; attempt < 150 && completed.size < jobs.length; attempt += 1) {
          await new Promise((resolve) => window.setTimeout(resolve, 800));
          for (const job of jobs.filter((item: any) => !completed.has(item.id))) {
            const polled = await actions.whatsapp.job({id: job.id});
            if (polled.error) throw polled.error;
            const state = polled.data as any;
            if (state.status === "succeeded" || state.status === "failed") completed.set(job.id, state);
          }
        }
        const failed = [...completed.values()].find((item: any) => item.status === "failed");
        if (failed) throw new Error(failed.error || "One preview compilation failed");
        if (completed.size !== jobs.length) throw new Error("Preview compilation is still running. Refresh this page shortly.");
        closeAlert();
        dialog.close();
        if (jobs.length === 1) window.location.href = `/whatsapp/previews/${[...completed.values()][0].result.preview_id}`;
        else { await showSuccess("Previews compiled", `${jobs.length} frozen previews are ready for review.`); await table.refresh(true); }
      } catch (error) { closeAlert(); await showError(error); }
    });
    if (new URLSearchParams(window.location.search).has("source_job_id")) void openCreate();
  </script>
</WhatsAppLayout>
