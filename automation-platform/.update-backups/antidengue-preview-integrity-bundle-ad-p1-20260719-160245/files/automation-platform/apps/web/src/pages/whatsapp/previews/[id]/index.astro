---
import DispatchPreviewNav from "../../../../components/DispatchPreviewNav.astro";
import WhatsAppLayout from "../../../../layouts/WhatsAppLayout.astro";

const { id = "" } = Astro.params;
---

<WhatsAppLayout title="Dispatch Preview" description="Immutable AntiDengue routing snapshot and preflight summary." page="previews">
  <a class="btn btn-sm" href="/whatsapp/previews" slot="actions">← All previews</a>
  <span id="preview-context" data-preview-id={id} hidden></span>
  <div class="preview-identity">
    <div><span>Frozen batch</span><strong id="preview-key">Loading…</strong><small id="preview-created">—</small></div>
    <span class="preview-state" id="preview-state">Loading</span>
  </div>
  <DispatchPreviewNav id={id} active="overview" />

  <section class="preview-metrics">
    <article class="ready"><span>Ready</span><strong id="ready-count">—</strong><small id="ready-detail">Safe planned deliveries</small></article>
    <article class="warning"><span>Warnings</span><strong id="warning-count">—</strong><small>Review recommended</small></article>
    <article class="blocked"><span>Blocked</span><strong id="blocked-count">—</strong><small>Cannot be approved</small></article>
    <article><span>Attachments</span><strong id="artifact-count">—</strong><small>Files used by planned deliveries</small></article>
  </section>

  <div class="preview-overview-grid">
    <article class="wa-panel preview-route-card">
      <div class="panel-heading compact"><div><p class="eyebrow">Resolved route</p><h2>Dispatch configuration</h2></div></div>
      <dl class="preview-facts">
        <div><dt>Module</dt><dd id="application-name">—</dd></div>
        <div><dt>Report type</dt><dd id="report-type">—</dd></div>
        <div><dt>Wing</dt><dd id="wing-name">—</dd></div>
        <div><dt>Profile</dt><dd id="profile-name">—</dd></div>
        <div><dt>Audience</dt><dd id="audience-name">—</dd></div>
        <div><dt>Connection</dt><dd id="account-name">—</dd></div>
        <div><dt>Template</dt><dd id="template-name">—</dd></div>
        <div><dt>Source dry run</dt><dd><a id="source-job" href="/">—</a></dd></div>
      </dl>
    </article>

    <article class="wa-panel preview-integrity-card">
      <div class="panel-heading compact"><div><p class="eyebrow">Snapshot integrity</p><h2>Frozen content</h2></div></div>
      <p>The delivery targets, rendered messages, routing metadata and attachment checksums are stored together. Nothing on this page sends a message.</p>
      <dl class="preview-facts compact-facts">
        <div><dt>Profile version</dt><dd id="profile-version">—</dd></div>
        <div><dt>Content SHA-256</dt><dd><code id="content-hash">—</code></dd></div>
        <div><dt>Frozen at</dt><dd id="frozen-at">—</dd></div>
      </dl>
      <div class="preview-stale-warning" id="stale-warning" hidden><strong>Preview is stale</strong><span>The route configuration or a delivery file changed. Create a new preview before any future approval.</span></div>
    </article>
  </div>

  <article class="wa-panel preview-next-card">
    <div><p class="eyebrow">Review and approval</p><h2>Send the frozen payloads</h2><p>Inspect the exact messages and attachments, then explicitly approve this immutable batch for live delivery.</p></div>
    <div class="preview-next-actions"><a class="btn btn-sm" href={`/whatsapp/previews/${id}/deliveries`}>Review deliveries</a><a class="btn btn-sm" href={`/whatsapp/previews/${id}/issues`}>Review issues</a><a class="btn btn-sm" href={`/whatsapp/previews/${id}/artifacts`}>View attachments</a><button class="btn btn-sm btn-primary" id="approve-preview" type="button" hidden>Approve & queue</button><a class="btn btn-sm btn-primary" id="view-queued" href="/whatsapp/deliveries" hidden>View queued deliveries</a></div>
  </article>

  <script>
    import { actions } from "astro:actions";
    import { confirmAction, showError, showSuccess } from "../../../../scripts/alerts";
    const id = document.getElementById("preview-context")!.dataset.previewId!;
    const el = (key) => document.getElementById(key);
    const formatDate = (value) => value ? new Date(value).toLocaleString() : "—";
    try {
      const result = await actions.whatsapp.preview({ id });
      if (result.error) throw result.error;
      const data = result.data;
      el("preview-key").textContent = data.preview_key;
      el("preview-created").textContent = `Created ${formatDate(data.created_at)}`;
      el("preview-state").textContent = data.status;
      el("preview-state").className = `preview-state ${data.status}`;
      for (const [key, value] of [["ready-count", data.ready_count], ["warning-count", data.warning_count], ["blocked-count", data.blocked_count], ["artifact-count", data.artifact_count]]) el(key).textContent = String(value);
      el("ready-detail").textContent = data.jurisdiction_count ? `${data.jurisdiction_count} jurisdictions · ${data.unique_recipient_count} recipients${data.additional_charge_route_count ? ` · ${data.additional_charge_route_count} additional-charge routes` : ""}` : `${data.unique_recipient_count} unique recipients`;
      for (const [key, value] of [["application-name", data.application_name], ["report-type", data.report_type_name], ["wing-name", data.wing_name], ["profile-name", `${data.profile_name} · v${data.profile_version}`], ["audience-name", data.audience_name], ["account-name", data.account_name], ["template-name", data.template_name], ["profile-version", `Version ${data.profile_version}`], ["frozen-at", formatDate(data.frozen_at)]]) el(key).textContent = value;
      el("content-hash").textContent = data.content_sha256;
      const source = el("source-job"); source.textContent = data.source_job_id.slice(0, 8); source.href = `/?job_id=${data.source_job_id}`;
      el("stale-warning").hidden = !data.stale;
      const approve = el("approve-preview");
      const queued = el("view-queued");
      if (data.approval) {
        queued.hidden = false;
        queued.textContent = data.approval.status === "completed" ? "View delivery results" : `Dispatch ${data.approval.status}`;
      } else if (data.status === "ready" && !data.stale && data.delivery_count > 0) {
        approve.hidden = false;
        approve.textContent = `Approve & queue ${data.delivery_count} deliver${data.delivery_count === 1 ? "y" : "ies"}`;
        approve.addEventListener("click", async () => {
          const warningText = data.warning_count
            ? `You are approving ${data.delivery_count} exact frozen deliveries with ${data.warning_count} warning(s). This sends real WhatsApp messages and cannot be undone.`
            : `You are approving ${data.delivery_count} exact frozen deliveries. This sends real WhatsApp messages and cannot be undone.`;
          if (!await confirmAction("Approve live WhatsApp dispatch?", warningText, "Approve & queue")) return;
          approve.disabled = true;
          try {
            const result = await actions.whatsapp.approvePreview({ id, acknowledge_warnings: data.warning_count > 0, approved_by: "web-operator" });
            if (result.error) throw result.error;
            await showSuccess("Dispatch approved", "The exact reviewed payloads were queued. Delivery results will update on the Deliveries page.");
            window.location.href = "/whatsapp/deliveries";
          } catch (error) { approve.disabled = false; await showError(error); }
        });
      }
    } catch (error) { await showError(error); }
  </script>
</WhatsAppLayout>
