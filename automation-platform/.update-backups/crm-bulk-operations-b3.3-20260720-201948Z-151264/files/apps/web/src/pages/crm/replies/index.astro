---
import CrmLayout from "../../../layouts/CrmLayout.astro";
import DataTable from "../../../components/DataTable.astro";
import CheckboxField from "../../../components/ui/CheckboxField.astro";
import ModalDialog from "../../../components/ui/ModalDialog.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---

<CrmLayout
  title="Reply Workspace"
  description="Classify complaints, prepare replies, approve verified outcomes and preserve every approved revision for AI reuse."
  page="replies"
>
  <a class="btn btn-sm" href="/crm/taxonomy/" slot="actions">Manage Taxonomy</a>
  <a class="btn btn-sm" href="/crm/knowledge/" slot="actions">AI Reply Archive</a>

  <main id="reply-workspace" data-api-base={apiBase} class="crm32-page reply-workspace-page">
    <nav class="reply-mode-tabs" aria-label="Reply workspace modes">
      <button class="active" data-tab="queue" type="button">Reply Queue</button>
      <button data-tab="csv" type="button">Bulk CSV</button>
      <button data-tab="letters" type="button">Formal Letters</button>
    </nav>

    <section id="tab-queue" data-tab-panel="queue" class="reply-tab-panel">
      <section class="crm-metric-grid reply-summary" aria-label="Reply workflow summary">
        <article class="crm-metric-card"><span>Awaiting classification</span><strong id="stat-unclassified">—</strong><small>Choose category and subcategory</small></article>
        <article class="crm-metric-card"><span>Awaiting reply</span><strong id="stat-awaiting">—</strong><small>No saved reply yet</small></article>
        <article class="crm-metric-card"><span>Draft / pending</span><strong id="stat-drafts">—</strong><small id="stat-pending">— pending approval</small></article>
        <article class="crm-metric-card"><span>Approved / issued</span><strong id="stat-approved">—</strong><small id="stat-issued">— issued</small></article>
        <article class="crm-metric-card"><span>AI ready</span><strong id="stat-ai-ready">—</strong><small>Verified approved archive records</small></article>
      </section>

      <section class="master-card reply-filter-card">
        <header class="crm-card-heading reply-filter-heading">
          <div>
            <p class="eyebrow">Primary workflow</p>
            <h2>Complaint reply queue</h2>
            <p>Complaint numbers, text previews, classifications, workflow state and connections are arranged in dedicated columns.</p>
          </div>
          <div class="reply-filter-actions">
            <button id="refresh-queue" class="btn btn-sm" type="button">↻ Refresh</button>
            <a class="btn btn-primary btn-sm" href="/crm/knowledge/">Open AI archive</a>
          </div>
        </header>

        <div class="reply-primary-filters">
          <label class="crm-field reply-search-filter" for="filter-search"><span>Search</span><input id="filter-search" class="input input-bordered" placeholder="Complaint number, complaint text or reply…" /></label>
          <label class="crm-field" for="filter-category"><span>Category</span><select id="filter-category" class="select select-bordered"><option value="">All categories</option></select></label>
          <label class="crm-field" for="filter-status"><span>Reply status</span><select id="filter-status" class="select select-bordered"><option value="">All statuses</option><option>Not Prepared</option><option>Draft</option><option>Pending Approval</option><option>Approved</option><option>Issued</option><option>Rejected</option></select></label>
          <label class="crm-field" for="filter-source"><span>Source</span><select id="filter-source" class="select select-bordered"><option value="">All sources</option><option value="crm_portal">CRM portal</option><option value="pm_portal">PM portal</option><option value="whatsapp">WhatsApp</option></select></label>
          <button id="toggle-more-filters" class="btn" type="button" aria-expanded="false" aria-controls="advanced-filters">More filters</button>
          <button id="clear-filters" class="btn btn-ghost" type="button">Clear</button>
        </div>

        <div id="advanced-filters" class="reply-advanced-filters" hidden>
          <label class="crm-field" for="filter-subcategory"><span>Subcategory</span><select id="filter-subcategory" class="select select-bordered"><option value="">All subcategories</option></select></label>
          <label class="crm-field" for="filter-ai"><span>AI eligibility</span><select id="filter-ai" class="select select-bordered"><option value="">All</option><option value="true">Eligible</option><option value="false">Not eligible</option></select></label>
          <label class="crm-field" for="filter-from"><span>Created from</span><input id="filter-from" class="input input-bordered" type="date" /></label>
          <label class="crm-field" for="filter-to"><span>Created to</span><input id="filter-to" class="input input-bordered" type="date" /></label>
        </div>
      </section>

      <section id="bulk-classification" class="master-card bulk-classification" hidden>
        <div class="bulk-selection-copy"><strong><span id="selected-count">0</span> complaints selected</strong><small>Apply one controlled category and optional subcategory to every selected complaint.</small></div>
        <label class="crm-field" for="bulk-category"><span>Category</span><select id="bulk-category" class="select select-bordered"></select></label>
        <label class="crm-field" for="bulk-subcategory"><span>Subcategory</span><select id="bulk-subcategory" class="select select-bordered"><option value="">No subcategory</option></select></label>
        <CheckboxField id="bulk-sync" label="Sync Helpdesk" description="Write and verify linked tickets." checked compact />
        <button id="apply-bulk-classification" class="btn btn-primary" type="button">Apply classification</button>
        <button id="clear-selection" class="btn" type="button">Clear selection</button>
      </section>

      <section class="master-card reply-table-card">
        <header class="reply-table-heading">
          <div>
            <h2>Pending complaint replies</h2>
            <p id="queue-count">Loading complaints…</p>
          </div>
          <span class="reply-table-hint">Complaint text is kept to one line. Use <b>View</b> for the complete record.</span>
        </header>
        <DataTable
          id="reply-queue-table"
          pageSize={25}
          pageSizeOptions={[25, 50, 100]}
          emptyText="No complaints match the current filters."
          ariaLabel="Complaint reply queue"
          class="reply-queue-table"
        />
      </section>
    </section>

    <section id="tab-csv" data-tab-panel="csv" class="reply-tab-panel" hidden>
      <section class="legacy-intro master-card"><div><p class="eyebrow">Compatible bulk workflow</p><h2>ChatGPT CSV exchange</h2><p>The existing two-column export/import workflow remains available. Imported replies are preserved and can still generate formal letters.</p></div></section>
      <section class="legacy-grid">
        <article class="master-card legacy-step"><span class="step-number">1</span><div><h2>Export complaint remarks</h2><p>Downloads exactly <b>Complaint Number</b> and <b>Complaint Remarks</b>.</p><div class="button-row"><a id="download-awaiting" class="btn btn-primary" href="#">Download awaiting replies</a><a id="download-all" class="btn" href="#">Download all published</a></div></div></article>
        <article class="master-card legacy-step"><span class="step-number">2</span><div><h2>Import ChatGPT reply CSV</h2><p>The file must contain exactly <b>Complaint Number</b> and <b>Reply</b>.</p><form id="reply-import-form" class="legacy-form"><input id="reply-file" class="file-input file-input-bordered" type="file" accept=".csv,text/csv" required /><button id="import-replies" class="btn btn-primary" type="submit">Validate and import</button></form><div id="reply-import-result" class="reply-message" hidden></div></div></article>
      </section>
      <section class="crm-metric-grid legacy-summary"><article class="crm-metric-card"><span>Published complaints</span><strong id="legacy-published">—</strong></article><article class="crm-metric-card"><span>Awaiting reply</span><strong id="legacy-awaiting">—</strong></article><article class="crm-metric-card"><span>Replies imported</span><strong id="legacy-imported">—</strong></article><article class="crm-metric-card"><span>Letters generated</span><strong id="legacy-generated">—</strong></article></section>
      <section class="master-card legacy-register"><div class="crm-card-heading"><div><p class="eyebrow">Legacy register</p><h2>CSV reply coverage</h2></div><button id="refresh-legacy" class="btn btn-sm" type="button">↻ Refresh</button></div><div id="legacy-list" class="legacy-list"></div></section>
    </section>

    <section id="tab-letters" data-tab-panel="letters" class="reply-tab-panel" hidden>
      <section class="formal-letter-panel master-card">
        <div><p class="eyebrow">Native formal documents</p><h2>Generate DEO Report package</h2><p>Creates a ZIP with one complaint folder and formal ODT letter per imported reply, plus a traceable manifest. Existing document-generation behaviour is unchanged.</p></div>
        <button id="download-letters" class="btn btn-primary" type="button">Generate and download letters</button>
        <div id="letter-result" class="reply-message" hidden></div>
      </section>
    </section>

    <div id="reply-toast" class="crm-toast" role="status" aria-live="polite" hidden></div>
  </main>

  <ModalDialog
    id="complaint-preview-dialog"
    formId="complaint-preview-form"
    title="Complaint details"
    eyebrow="Queue preview"
    description="Read the complete complaint without losing filters, pagination or selected rows."
    size="xl"
  >
    <div id="complaint-preview-loading" class="crm-empty-state compact">Loading complaint…</div>
    <div id="complaint-preview-content" class="complaint-preview-content" hidden>
      <div id="complaint-preview-meta" class="crm-chip-row"></div>
      <section class="complaint-preview-grid">
        <article><span>Classification</span><strong id="complaint-preview-classification">—</strong><small id="complaint-preview-sync">—</small></article>
        <article><span>Reply workflow</span><strong id="complaint-preview-status">—</strong><small id="complaint-preview-ai">—</small></article>
        <article><span>Connections</span><strong id="complaint-preview-connections">—</strong><small>Helpdesk and Paperless</small></article>
      </section>
      <article id="complaint-preview-text" class="complaint-preview-text"></article>
    </div>

    <Fragment slot="footer">
      <button class="btn" type="button" data-dialog-close>Close</button>
      <a id="preview-full-case" class="btn" href="#">Open complete case</a>
      <a id="preview-open-editor" class="btn btn-primary" href="#">Open reply editor</a>
    </Fragment>
  </ModalDialog>

  <script>
    import { badge, stack } from "../../../scripts/table-cells";
    import { openDialog, wireDialogs } from "../../../scripts/dialogs";

    type Category = {
      id: string;
      name: string;
      active: boolean;
      merged_into_id?: string | null;
      subcategories: { id: string; name: string; active: boolean; merged_into_id?: string | null }[];
    };
    type QueueItem = {
      case_id: string;
      complaint_number: string;
      complaint_preview: string;
      source_system: string;
      category_id?: string | null;
      category: string;
      subcategory_id?: string | null;
      subcategory: string;
      reply_preview: string;
      reply_status: string;
      ai_eligible: boolean;
      archive_ready: boolean;
      classification_sync_status: string;
      helpdesk_ticket_id?: string | null;
      helpdesk_ticket_url?: string | null;
      paperless_document_id?: string | null;
      updated_at: string;
    };

    const root = document.getElementById("reply-workspace") as HTMLElement;
    const API = root.dataset.apiBase || "";
    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const table = $("reply-queue-table") as any;
    const esc = (value: unknown) => String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
    const selectedIds = new Set<string>();
    let categories: Category[] = [];
    let visibleIds: string[] = [];
    let filterTimer = 0;

    async function api(path: string, init?: RequestInit) {
      const response = await fetch(`${API}${path}`, init);
      const body = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(typeof body.detail === "string" ? body.detail : body.detail?.message || response.statusText);
      return body;
    }

    function toast(message: string, error = false) {
      const node = $("reply-toast");
      node.textContent = message;
      node.className = `crm-toast${error ? " error" : ""}`;
      node.hidden = false;
      window.setTimeout(() => node.hidden = true, 4500);
    }

    function statusTone(value: string) {
      const normalized = value.toLowerCase();
      if (["approved", "issued", "synchronized"].includes(normalized)) return "";
      if (["draft", "pending approval", "pending", "not_synced"].includes(normalized)) return "warning";
      if (["rejected", "failed"].includes(normalized)) return "error";
      return "inactive";
    }

    function formatDate(value: unknown) {
      return value ? new Date(String(value)).toLocaleString() : "—";
    }

    function sourceLabel(value: string) {
      return ({ crm_portal: "CRM portal", pm_portal: "PM portal", whatsapp: "WhatsApp" } as Record<string, string>)[value] || value || "Unknown";
    }

    function currentReturnUrl() {
      return `${window.location.pathname}${window.location.search}`;
    }

    function editorUrl(item: QueueItem) {
      return `/crm/replies/${item.case_id}/?return=${encodeURIComponent(currentReturnUrl())}`;
    }

    function hydrateFiltersFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const mappings: Array<[string, string]> = [
        ["search", "filter-search"],
        ["category_id", "filter-category"],
        ["subcategory_id", "filter-subcategory"],
        ["reply_status", "filter-status"],
        ["ai_eligible", "filter-ai"],
        ["source_system", "filter-source"],
        ["date_from", "filter-from"],
        ["date_to", "filter-to"],
      ];
      for (const [param, id] of mappings) {
        const value = params.get(param);
        if (value !== null) ($(id) as HTMLInputElement | HTMLSelectElement).value = value;
      }
      const advanced = ["subcategory_id", "ai_eligible", "date_from", "date_to"].some((key) => params.has(key));
      setAdvancedFilters(advanced);
      return {
        pageIndex: Math.max(0, Number(params.get("page") || 1) - 1),
        pageSize: [25, 50, 100].includes(Number(params.get("page_size"))) ? Number(params.get("page_size")) : 25,
      };
    }

    function filterParams(pageIndex: number, pageSize: number) {
      const params = new URLSearchParams({
        category_id: ($("filter-category") as HTMLSelectElement).value,
        subcategory_id: ($("filter-subcategory") as HTMLSelectElement).value,
        reply_status: ($("filter-status") as HTMLSelectElement).value,
        source_system: ($("filter-source") as HTMLSelectElement).value,
        search: ($("filter-search") as HTMLInputElement).value.trim(),
        ai_eligible: ($("filter-ai") as HTMLSelectElement).value,
        date_from: ($("filter-from") as HTMLInputElement).value,
        date_to: ($("filter-to") as HTMLInputElement).value,
        page: String(pageIndex + 1),
        page_size: String(pageSize),
      });
      for (const [key, value] of [...params]) if (!value) params.delete(key);
      return params;
    }

    function syncUrl(pageIndex: number, pageSize: number) {
      const params = filterParams(pageIndex, pageSize);
      history.replaceState(null, "", `${window.location.pathname}?${params.toString()}`);
    }

    function populateCategories() {
      const active = categories.filter((item) => item.active && !item.merged_into_id);
      const options = active.map((item) => `<option value="${item.id}">${esc(item.name)}</option>`).join("");
      const filter = $("filter-category") as HTMLSelectElement;
      const bulk = $("bulk-category") as HTMLSelectElement;
      const filterValue = filter.value;
      const bulkValue = bulk.value;
      filter.innerHTML = `<option value="">All categories</option>${options}`;
      bulk.innerHTML = `<option value="">Choose category</option>${options}`;
      if (active.some((item) => item.id === filterValue)) filter.value = filterValue;
      if (active.some((item) => item.id === bulkValue)) bulk.value = bulkValue;
      updateSubcategoryOptions("filter");
      updateSubcategoryOptions("bulk");
    }

    function updateSubcategoryOptions(kind: "filter" | "bulk", preferred = "") {
      const categoryId = ($(kind === "filter" ? "filter-category" : "bulk-category") as HTMLSelectElement).value;
      const select = $(kind === "filter" ? "filter-subcategory" : "bulk-subcategory") as HTMLSelectElement;
      const current = preferred || select.value;
      const category = categories.find((item) => item.id === categoryId);
      const items = (category?.subcategories || []).filter((item) => item.active && !item.merged_into_id);
      select.innerHTML = `<option value="">${kind === "filter" ? "All subcategories" : "No subcategory"}</option>${items.map((item) => `<option value="${item.id}">${esc(item.name)}</option>`).join("")}`;
      if (items.some((item) => item.id === current)) select.value = current;
    }

    async function loadTaxonomy() {
      const requestedCategory = new URLSearchParams(window.location.search).get("category_id") || "";
      const requestedSubcategory = new URLSearchParams(window.location.search).get("subcategory_id") || "";
      const data = await api("/api/v1/crm/taxonomy?include_inactive=false");
      categories = data.categories || [];
      populateCategories();
      if (requestedCategory && categories.some((item) => item.id === requestedCategory)) {
        ($("filter-category") as HTMLSelectElement).value = requestedCategory;
        updateSubcategoryOptions("filter", requestedSubcategory);
      }
    }

    async function loadStats() {
      const stats = await api("/api/v1/crm/reply-workspace/statistics");
      $("stat-unclassified").textContent = String(stats.awaiting_classification ?? 0);
      $("stat-awaiting").textContent = String(stats.awaiting_reply ?? 0);
      $("stat-drafts").textContent = String((stats.draft_replies ?? 0) + (stats.pending_approval ?? 0));
      $("stat-pending").textContent = `${stats.pending_approval ?? 0} pending approval`;
      $("stat-approved").textContent = String((stats.approved ?? 0) + (stats.issued ?? 0));
      $("stat-issued").textContent = `${stats.issued ?? 0} issued`;
      $("stat-ai-ready").textContent = String(stats.ai_ready ?? 0);
    }

    function selectionHeader(): HTMLInputElement {
      const input = document.createElement("input");
      input.type = "checkbox";
      input.className = "checkbox checkbox-sm";
      input.setAttribute("aria-label", "Select every complaint on this page");
      input.dataset.selectVisible = "true";
      const selectedVisible = visibleIds.filter((id) => selectedIds.has(id)).length;
      input.checked = visibleIds.length > 0 && selectedVisible === visibleIds.length;
      input.indeterminate = selectedVisible > 0 && selectedVisible < visibleIds.length;
      input.addEventListener("change", () => {
        visibleIds.forEach((id) => input.checked ? selectedIds.add(id) : selectedIds.delete(id));
        updateSelection();
      });
      return input;
    }

    function selectionCell(item: QueueItem): HTMLInputElement {
      const input = document.createElement("input");
      input.type = "checkbox";
      input.className = "checkbox checkbox-sm";
      input.dataset.selectCase = item.case_id;
      input.checked = selectedIds.has(item.case_id);
      input.setAttribute("aria-label", `Select complaint ${item.complaint_number || item.case_id}`);
      input.addEventListener("change", () => {
        input.checked ? selectedIds.add(item.case_id) : selectedIds.delete(item.case_id);
        updateSelection();
      });
      return input;
    }

    function complaintNumberCell(item: QueueItem): DocumentFragment {
      const fragment = document.createDocumentFragment();
      const link = document.createElement("a");
      link.className = "table-link complaint-number-link";
      link.href = editorUrl(item);
      link.textContent = item.complaint_number || item.case_id;
      fragment.append(link);
      if (item.archive_ready) {
        const small = document.createElement("small");
        small.textContent = "Approved revision archived";
        fragment.append(small);
      }
      return fragment;
    }

    function complaintTextCell(item: QueueItem): HTMLElement {
      const container = document.createElement("div");
      container.className = "complaint-snippet-cell";
      const text = document.createElement("span");
      text.textContent = item.complaint_preview || "No complaint text";
      text.title = item.complaint_preview || "No complaint text";
      const button = document.createElement("button");
      button.type = "button";
      button.className = "table-inline-link";
      button.textContent = "View";
      button.addEventListener("click", () => void openComplaintPreview(item));
      container.append(text, button);
      return container;
    }

    function classificationCell(item: QueueItem): DocumentFragment {
      const fragment = document.createDocumentFragment();
      fragment.append(badge(item.category || "Unclassified", item.category_id ? "" : "warning"));
      const small = document.createElement("small");
      small.textContent = `${item.subcategory || "No subcategory"} · ${item.classification_sync_status || "not_synced"}`;
      fragment.append(small);
      return fragment;
    }

    function workflowCell(item: QueueItem): DocumentFragment {
      const fragment = document.createDocumentFragment();
      fragment.append(badge(item.reply_status || "Not Prepared", statusTone(item.reply_status || "Not Prepared")));
      const small = document.createElement("small");
      small.textContent = `${item.ai_eligible ? "AI eligible" : "Not AI eligible"}${item.archive_ready ? " · archived" : ""}`;
      fragment.append(small);
      return fragment;
    }

    function connectionsCell(item: QueueItem): HTMLElement {
      const container = document.createElement("div");
      container.className = "connection-links compact";
      if (item.helpdesk_ticket_url) {
        const link = document.createElement("a");
        link.className = "connection-chip";
        link.href = item.helpdesk_ticket_url;
        link.target = "_blank";
        link.rel = "noreferrer";
        link.textContent = `Helpdesk #${item.helpdesk_ticket_id || "—"}`;
        container.append(link);
      }
      if (item.paperless_document_id) {
        const span = document.createElement("span");
        span.className = "connection-chip";
        span.textContent = `Paperless #${item.paperless_document_id}`;
        container.append(span);
      }
      if (!container.childElementCount) container.textContent = "—";
      return container;
    }

    function actionsCell(item: QueueItem): HTMLElement {
      const container = document.createElement("div");
      container.className = "reply-row-actions";
      const editor = document.createElement("a");
      editor.className = "btn btn-primary btn-xs";
      editor.href = editorUrl(item);
      editor.textContent = item.reply_status === "Not Prepared" ? "Write reply" : "Open editor";
      const caseLink = document.createElement("a");
      caseLink.className = "btn btn-xs";
      caseLink.href = `/crm/cases/${item.case_id}/`;
      caseLink.textContent = "Case";
      container.append(editor, caseLink);
      return container;
    }

    function updateSelection() {
      $("selected-count").textContent = String(selectedIds.size);
      $("bulk-classification").hidden = selectedIds.size === 0;
      document.querySelectorAll<HTMLInputElement>("[data-select-case]").forEach((input) => {
        input.checked = selectedIds.has(input.dataset.selectCase || "");
      });
      document.querySelectorAll<HTMLInputElement>("[data-select-visible]").forEach((input) => {
        const selectedVisible = visibleIds.filter((id) => selectedIds.has(id)).length;
        input.checked = visibleIds.length > 0 && selectedVisible === visibleIds.length;
        input.indeterminate = selectedVisible > 0 && selectedVisible < visibleIds.length;
      });
    }

    async function loadQueuePage(pageIndex: number, pageSize: number) {
      const params = filterParams(pageIndex, pageSize);
      syncUrl(pageIndex, pageSize);
      const data = await api(`/api/v1/crm/reply-workspace/cases?${params}`);
      const rows = (data.items || []) as QueueItem[];
      visibleIds = rows.map((item) => item.case_id);
      $("queue-count").textContent = `${data.total} complaint${data.total === 1 ? "" : "s"} · page ${data.page} of ${data.pages}`;
      window.queueMicrotask(updateSelection);
      return { rows, total: Number(data.total || 0) };
    }

    async function configureQueue(initialPageIndex: number, initialPageSize: number) {
      await table.configure({
        manualPagination: true,
        initialPageIndex,
        initialPageSize,
        getRowId: (row: QueueItem) => row.case_id,
        loadPage: loadQueuePage,
        onRender: () => updateSelection(),
        columns: [
          { id: "select", header: selectionHeader, enableSorting: false, meta: { width: "48px", align: "center", className: "selection-cell", headerClassName: "selection-cell" }, cell: ({ row }: any) => selectionCell(row.original) },
          { accessorKey: "complaint_number", header: "Complaint No.", enableSorting: false, meta: { width: "150px", minWidth: "150px" }, cell: ({ row }: any) => complaintNumberCell(row.original) },
          { accessorKey: "complaint_preview", header: "Complaint text", enableSorting: false, meta: { minWidth: "310px", maxWidth: "520px" }, cell: ({ row }: any) => complaintTextCell(row.original) },
          { id: "classification", header: "Classification", enableSorting: false, meta: { width: "190px", minWidth: "180px" }, cell: ({ row }: any) => classificationCell(row.original) },
          { id: "workflow", header: "Reply status", enableSorting: false, meta: { width: "155px", minWidth: "145px" }, cell: ({ row }: any) => workflowCell(row.original) },
          { id: "source", header: "Source / updated", enableSorting: false, meta: { width: "165px", minWidth: "150px" }, cell: ({ row }: any) => stack(sourceLabel(row.original.source_system), formatDate(row.original.updated_at)) },
          { id: "connections", header: "Connections", enableSorting: false, meta: { width: "155px", minWidth: "145px" }, cell: ({ row }: any) => connectionsCell(row.original) },
          { id: "actions", header: "", enableSorting: false, meta: { width: "145px", minWidth: "140px", align: "right" }, cell: ({ row }: any) => actionsCell(row.original) },
        ],
      });
    }

    async function refreshAll(resetPage = false) {
      await Promise.all([loadStats(), table.refresh(resetPage)]);
    }

    function scheduleLoad() {
      window.clearTimeout(filterTimer);
      filterTimer = window.setTimeout(() => void refreshAll(true), 300);
    }

    function setAdvancedFilters(open: boolean) {
      $("advanced-filters").hidden = !open;
      $("toggle-more-filters").setAttribute("aria-expanded", String(open));
      $("toggle-more-filters").textContent = open ? "Fewer filters" : "More filters";
    }

    function clearFilters() {
      ["filter-search", "filter-category", "filter-subcategory", "filter-status", "filter-ai", "filter-source", "filter-from", "filter-to"].forEach((id) => {
        ($(id) as HTMLInputElement | HTMLSelectElement).value = "";
      });
      updateSubcategoryOptions("filter");
      setAdvancedFilters(false);
      void refreshAll(true);
    }

    async function applyBulk() {
      const categoryId = ($("bulk-category") as HTMLSelectElement).value;
      if (!categoryId) {
        toast("Choose a category first.", true);
        return;
      }
      const button = $("apply-bulk-classification") as HTMLButtonElement;
      button.disabled = true;
      button.textContent = "Applying…";
      try {
        const result = await api("/api/v1/crm/reply-workspace/classifications/bulk", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            case_ids: [...selectedIds],
            category_id: categoryId,
            subcategory_id: ($("bulk-subcategory") as HTMLSelectElement).value || null,
            synchronize: ($("bulk-sync") as HTMLInputElement).checked,
          }),
        });
        const failed = result.counts?.failed ?? 0;
        toast(`Classification applied to ${result.requested - failed} complaint(s).${failed ? ` ${failed} failed and remain selected.` : ""}`, Boolean(failed));
        if (!failed) selectedIds.clear();
        await refreshAll(false);
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      } finally {
        button.disabled = false;
        button.textContent = "Apply classification";
      }
    }

    async function openComplaintPreview(item: QueueItem) {
      $("complaint-preview-dialog-title").textContent = `Complaint ${item.complaint_number || item.case_id}`;
      $("complaint-preview-loading").hidden = false;
      $("complaint-preview-content").hidden = true;
      $("preview-full-case").setAttribute("href", `/crm/cases/${item.case_id}/`);
      $("preview-open-editor").setAttribute("href", editorUrl(item));
      openDialog("complaint-preview-dialog");
      try {
        const data = await api(`/api/v1/crm/reply-workspace/cases/${item.case_id}`);
        const complaint = data.case;
        const reply = data.reply;
        $("complaint-preview-meta").innerHTML = `
          <span>${esc(sourceLabel(complaint.source_system))}</span>
          <span>Created ${esc(formatDate(complaint.created_at))}</span>
          <span>Updated ${esc(formatDate(complaint.updated_at))}</span>
          ${complaint.paperless_document_id ? `<span>Paperless #${esc(complaint.paperless_document_id)}</span>` : ""}`;
        $("complaint-preview-classification").textContent = `${complaint.category || "Unclassified"}${complaint.subcategory ? ` · ${complaint.subcategory}` : ""}`;
        $("complaint-preview-sync").textContent = `Sync: ${complaint.classification_sync_status || "not_synced"}`;
        $("complaint-preview-status").textContent = reply.reply_status || "Not Prepared";
        $("complaint-preview-ai").textContent = reply.ai_eligible ? "Eligible for AI archive after approval" : "Not AI eligible";
        $("complaint-preview-connections").textContent = `${complaint.helpdesk_ticket_id ? `Helpdesk #${complaint.helpdesk_ticket_id}` : "No Helpdesk ticket"}${complaint.paperless_document_id ? ` · Paperless #${complaint.paperless_document_id}` : ""}`;
        $("complaint-preview-text").textContent = complaint.complaint_text || "No complaint text is stored.";
        $("complaint-preview-loading").hidden = true;
        $("complaint-preview-content").hidden = false;
      } catch (error) {
        $("complaint-preview-loading").textContent = error instanceof Error ? error.message : String(error);
      }
    }

    function activateTab(name: string) {
      document.querySelectorAll<HTMLElement>("[data-tab-panel]").forEach((panel) => panel.hidden = panel.dataset.tabPanel !== name);
      document.querySelectorAll<HTMLButtonElement>("[data-tab]").forEach((button) => button.classList.toggle("active", button.dataset.tab === name));
      if (name === "csv") void loadLegacy();
    }

    async function loadLegacy() {
      try {
        const [stats, data] = await Promise.all([api("/api/v1/crm/replies/statistics"), api("/api/v1/crm/replies")]);
        $("legacy-published").textContent = String(stats.published_cases ?? 0);
        $("legacy-awaiting").textContent = String(stats.awaiting_reply ?? 0);
        $("legacy-imported").textContent = String(stats.replies_imported ?? 0);
        $("legacy-generated").textContent = String(stats.letters_generated ?? 0);
        $("legacy-list").innerHTML = (data.items || []).map((item: any) => `<article class="legacy-row"><div><strong>${esc(item.complaint_number)}</strong><small>Paperless #${esc(item.paperless_document_id || "—")}</small></div><div><strong>${item.reply ? "Reply imported" : "Awaiting reply"}</strong><small>${item.reply ? `${esc(item.source_filename)} · version ${esc(item.reply_version)} · ${esc(formatDate(item.imported_at))}` : "Available in the awaiting-replies CSV"}</small></div><span class="status-chip ${item.generated_at ? "" : item.reply ? "" : "warning"}">${item.generated_at ? "Letter generated" : item.reply ? "Ready for letter" : "Needs reply"}</span></article>`).join("") || '<div class="crm-empty-state compact">No published complaints yet.</div>';
      } catch (error) {
        $("legacy-list").innerHTML = `<div class="crm-empty-state compact">${esc(error instanceof Error ? error.message : String(error))}</div>`;
      }
    }

    $("download-awaiting").setAttribute("href", `${API}/api/v1/crm/replies/complaints.csv?scope=awaiting`);
    $("download-all").setAttribute("href", `${API}/api/v1/crm/replies/complaints.csv?scope=all`);

    $("reply-import-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      const input = $("reply-file") as HTMLInputElement;
      const file = input.files?.[0];
      const button = $("import-replies") as HTMLButtonElement;
      const message = $("reply-import-result");
      if (!file) return;
      button.disabled = true;
      button.textContent = "Validating and importing…";
      message.hidden = true;
      const body = new FormData();
      body.append("file", file);
      try {
        const result = await api("/api/v1/crm/replies/imports", { method: "POST", body });
        message.className = "reply-message";
        message.textContent = `Imported ${result.imported}, updated ${result.updated}; ${result.letters_ready} formal letter(s) ready.`;
        message.hidden = false;
        input.value = "";
        await Promise.all([loadLegacy(), refreshAll(false)]);
      } catch (error) {
        message.className = "reply-message error";
        message.textContent = error instanceof Error ? error.message : String(error);
        message.hidden = false;
      } finally {
        button.disabled = false;
        button.textContent = "Validate and import";
      }
    });

    $("download-letters").addEventListener("click", async () => {
      const button = $("download-letters") as HTMLButtonElement;
      const message = $("letter-result");
      button.disabled = true;
      button.textContent = "Generating…";
      message.hidden = true;
      try {
        const response = await fetch(`${API}/api/v1/crm/replies/letter-packages`, { method: "POST" });
        if (!response.ok) {
          const body = await response.json().catch(() => ({}));
          throw new Error(body.detail?.message || body.detail || response.statusText);
        }
        const blob = await response.blob();
        const url = URL.createObjectURL(blob);
        const anchor = document.createElement("a");
        anchor.href = url;
        anchor.download = "crm-formal-replies.zip";
        document.body.appendChild(anchor);
        anchor.click();
        anchor.remove();
        URL.revokeObjectURL(url);
        message.className = "reply-message";
        message.textContent = "Formal letter package generated and downloaded.";
        message.hidden = false;
        await loadLegacy();
      } catch (error) {
        message.className = "reply-message error";
        message.textContent = error instanceof Error ? error.message : String(error);
        message.hidden = false;
      } finally {
        button.disabled = false;
        button.textContent = "Generate and download letters";
      }
    });

    wireDialogs();
    document.querySelectorAll<HTMLButtonElement>("[data-tab]").forEach((button) => button.addEventListener("click", () => activateTab(button.dataset.tab || "queue")));
    ["filter-category", "filter-subcategory", "filter-status", "filter-ai", "filter-source", "filter-from", "filter-to"].forEach((id) => $(id).addEventListener("change", () => {
      if (id === "filter-category") updateSubcategoryOptions("filter");
      void refreshAll(true);
    }));
    $("filter-search").addEventListener("input", scheduleLoad);
    $("bulk-category").addEventListener("change", () => updateSubcategoryOptions("bulk"));
    $("refresh-queue").addEventListener("click", () => void refreshAll(false));
    $("toggle-more-filters").addEventListener("click", () => setAdvancedFilters($("advanced-filters").hidden));
    $("clear-filters").addEventListener("click", clearFilters);
    $("apply-bulk-classification").addEventListener("click", () => void applyBulk());
    $("clear-selection").addEventListener("click", () => { selectedIds.clear(); updateSelection(); });
    $("refresh-legacy").addEventListener("click", () => void loadLegacy());

    void (async () => {
      const requested = new URLSearchParams(window.location.search);
      await loadTaxonomy();
      const initial = hydrateFiltersFromUrl();
      if (requested.get("category_id")) {
        ($("filter-category") as HTMLSelectElement).value = requested.get("category_id") || "";
        updateSubcategoryOptions("filter", requested.get("subcategory_id") || "");
      }
      await configureQueue(initial.pageIndex, initial.pageSize);
      await loadStats();
    })().catch((error) => toast(error instanceof Error ? error.message : String(error), true));
  </script>
</CrmLayout>
