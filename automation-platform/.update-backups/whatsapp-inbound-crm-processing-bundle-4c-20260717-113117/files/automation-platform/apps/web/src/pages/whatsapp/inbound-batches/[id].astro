---
import WhatsAppInboundNav from "../../../components/WhatsAppInboundNav.astro";
import WhatsAppLayout from "../../../layouts/WhatsAppLayout.astro";
const batchId = Astro.params.id || "";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<WhatsAppLayout title="Inbound Batch Details" description="Inspect files, object-storage outcomes and the complete server-side activity trail for one fetch run." page="inbound-files">
  <a class="btn btn-sm" href="/whatsapp/inbound-batches" slot="actions">← Batches</a>
  <WhatsAppInboundNav active="batches" />

  <section class="master-card inbound-batch-header" data-batch-id={batchId} data-api-base={apiBase} id="batch-detail-root">
    <div class="inbound-card-heading"><div><p class="eyebrow">Inbound batch</p><h2 id="detail-batch-code">Loading…</h2><p id="detail-contact">—</p></div><div class="inbound-detail-actions"><span class="badge" id="detail-status">Loading</span><button class="btn btn-xs" id="retry-storage" hidden>Retry storage</button></div></div>
    <div class="inbound-detail-facts"><div><span>Started</span><strong id="detail-started">—</strong></div><div><span>Anchor</span><strong id="detail-anchor">—</strong></div><div><span>Provider</span><strong id="detail-provider">—</strong></div><div><span>Object storage</span><strong id="detail-storage">—</strong></div></div>
  </section>

  <section class="inbound-summary-grid inbound-detail-summary"><article class="master-card"><span>Messages</span><strong id="detail-messages">—</strong></article><article class="master-card"><span>Files discovered</span><strong id="detail-files">—</strong></article><article class="master-card"><span>Stored / reused</span><strong id="detail-stored">—</strong></article><article class="master-card"><span>Failed</span><strong id="detail-failed">—</strong></article></section>

  <section class="inbound-detail-grid">
    <article class="master-card"><div class="inbound-card-heading"><div><p class="eyebrow">Persisted activity</p><h2>Live server log</h2></div><span class="badge" id="detail-log-state">Polling</span></div><pre class="inbound-log inbound-batch-log" id="detail-log">Loading batch activity…</pre></article>
    <article class="master-card"><p class="eyebrow">Manifest</p><h2>Storage record</h2><dl class="inbound-definition-list"><div><dt>Raw bucket</dt><dd id="detail-raw-bucket">—</dd></div><div><dt>Manifest bucket</dt><dd id="detail-manifest-bucket">—</dd></div><div><dt>Manifest key</dt><dd id="detail-manifest-key">—</dd></div><div><dt>Error</dt><dd id="detail-error">None</dd></div></dl></article>
  </section>

  <section class="master-card"><div class="inbound-card-heading"><div><p class="eyebrow">Batch items</p><h2>Files in this run</h2></div><span id="detail-item-count">0 files</span></div><div class="table-wrap"><table class="table table-sm inbound-file-table"><thead><tr><th>Received</th><th>File</th><th>Type</th><th>Size</th><th>Storage status</th><th>Object key</th><th></th></tr></thead><tbody id="detail-items"><tr><td colspan="7" class="empty-cell">Loading files…</td></tr></tbody></table></div></section>

  <script>
    import { actions } from "astro:actions";
    const root=document.getElementById("batch-detail-root") as HTMLElement,batchId=root.dataset.batchId||"",apiBase=root.dataset.apiBase||"";const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;let timer:number|undefined;
    const escapeHtml=(v:unknown)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");const formatDate=(v:any)=>{if(!v)return"—";const d=new Date(v);return Number.isNaN(d.getTime())?String(v):d.toLocaleString();};const formatBytes=(v:any)=>{const n=Number(v||0);if(!n)return"0 B";const u=["B","KB","MB","GB"];const i=Math.min(Math.floor(Math.log(n)/Math.log(1024)),3);return`${(n/1024**i).toFixed(i?1:0)} ${u[i]}`;};
    function render(b:any){el("detail-batch-code").textContent=b.batch_code;el("detail-contact").textContent=`${b.contact_name} · ${b.contact_identity||""}`;el("detail-status").textContent=b.status;el("detail-started").textContent=formatDate(b.started_at||b.created_at);el("detail-anchor").textContent=formatDate(b.anchor_timestamp);el("detail-provider").textContent=b.provider;el("detail-storage").textContent=b.storage_backend;el("detail-messages").textContent=`${b.messages_discovered}/${b.requested_count}`;el("detail-files").textContent=String(b.files_discovered);el("detail-stored").textContent=`${b.files_stored} / ${b.files_reused}`;el("detail-failed").textContent=String(b.files_failed);el("detail-raw-bucket").textContent=b.raw_bucket||"Local only";el("detail-manifest-bucket").textContent=b.manifest_bucket||"—";el("detail-manifest-key").textContent=b.manifest_object_key||"Not written yet";el("detail-error").textContent=b.error||b.history_error||"None";el("detail-item-count").textContent=`${(b.items||[]).length} files`;el<HTMLButtonElement>("retry-storage").hidden=!(b.files_failed||(b.items||[]).some((x:any)=>x.status==="storage_pending"));el("detail-items").innerHTML=(b.items||[]).length?(b.items||[]).map((x:any)=>`<tr><td>${escapeHtml(formatDate(x.message_timestamp))}</td><td><strong>${escapeHtml(x.original_filename||"Unnamed attachment")}</strong><small>${escapeHtml(x.sha256||"")}</small></td><td>${escapeHtml(x.mime_type||"—")}</td><td>${formatBytes(x.size_bytes)}</td><td><span class="badge">${escapeHtml(x.status)}</span><small>${escapeHtml(x.error||"")}</small></td><td><small>${escapeHtml(x.object_key||"—")}</small></td><td><a class="btn btn-xs" href="${apiBase}/api/v1/whatsapp/inbound/batches/${batchId}/items/${escapeHtml(x.id)}/download">Download</a></td></tr>`).join(""):'<tr><td colspan="7" class="empty-cell">No files were discovered in this batch.</td></tr>';}
    async function load(){const [b,e]=await Promise.all([actions.whatsapp.inboundBatch({id:batchId}),actions.whatsapp.inboundBatchEvents({id:batchId,limit:1000})]);if(b.error){el("detail-batch-code").textContent="Batch unavailable";el("detail-log").textContent=b.error.message;return;}render(b.data);if(e.data){const rows=(e.data as any).items||[];el("detail-log").textContent=rows.length?rows.map((x:any)=>`[${formatDate(x.created_at)}] ${String(x.level).toUpperCase().padEnd(7)} ${x.message}`).join("\n"):"No activity has been recorded.";el<HTMLPreElement>("detail-log").scrollTop=el<HTMLPreElement>("detail-log").scrollHeight;}const status=(b.data as any).status;el("detail-log-state").textContent=["created","fetching","storing"].includes(status)?"Live":"Complete";}
    el("retry-storage").addEventListener("click",async()=>{const button=el<HTMLButtonElement>("retry-storage");button.disabled=true;button.textContent="Retrying…";const r=await actions.whatsapp.retryInboundBatchStorage({id:batchId});button.disabled=false;button.textContent="Retry storage";if(r.error)alert(r.error.message);await load();});void load();timer=window.setInterval(()=>{if(!document.hidden)void load();},2500);window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer);});
  </script>
</WhatsAppLayout>
