---
import WhatsAppLayout from "../../layouts/WhatsAppLayout.astro";
---

<WhatsAppLayout
  title="WhatsApp Inbound Files"
  description="Find and archive images, PDFs and spreadsheets received from a selected WhatsApp contact."
  page="inbound-files"
>
  <button class="btn btn-sm" id="refresh-page" slot="actions">↻ Refresh</button>

  <div class="notice inbound-coverage-notice">
    Exports are complete for messages captured by this worker. Older WhatsApp history may be partial, and expired media is reported rather than silently omitted.
  </div>

  <section class="inbound-files-grid">
    <article class="master-card inbound-filter-card">
      <p class="eyebrow">Contact and scope</p>
      <h2>Choose inbound files</h2>

      <div class="inbound-contact-picker">
        <label>
          <span>WhatsApp contact</span>
          <input
            class="input input-bordered"
            id="inbound-contact-search"
            autocomplete="off"
            placeholder="Search name, phone JID or LID…"
          />
        </label>
        <input type="hidden" id="inbound-contact-id" />
        <div class="inbound-contact-results" id="inbound-contact-results" hidden></div>
        <div class="inbound-selected-contact" id="inbound-selected-contact" hidden>
          <div>
            <strong id="inbound-selected-name"></strong>
            <small id="inbound-selected-identity"></small>
          </div>
          <button class="btn btn-xs" type="button" id="clear-inbound-contact">Change</button>
        </div>
      </div>

      <div class="wa-form-grid inbound-filter-grid">
        <label>
          <span>Date range</span>
          <select class="select select-bordered" id="inbound-date-preset">
            <option value="7">Last 7 days</option>
            <option value="30" selected>Last 30 days</option>
            <option value="today">Today</option>
            <option value="all">All captured messages</option>
            <option value="custom">Custom range</option>
          </select>
        </label>
        <label>
          <span>Message scope</span>
          <select class="select select-bordered" id="inbound-chat-scope">
            <option value="direct">Direct chat only</option>
            <option value="direct_and_groups">Direct chat and files sent in groups</option>
          </select>
        </label>
        <label class="custom-date-field" hidden>
          <span>From</span>
          <input class="input input-bordered" id="inbound-date-from" type="date" />
        </label>
        <label class="custom-date-field" hidden>
          <span>To</span>
          <input class="input input-bordered" id="inbound-date-to" type="date" />
        </label>
      </div>

      <fieldset class="inbound-type-options">
        <legend>File types</legend>
        <label><input type="checkbox" value="image" checked /> Images</label>
        <label><input type="checkbox" value="pdf" checked /> PDFs</label>
        <label><input type="checkbox" value="spreadsheet" checked /> Excel / CSV / ODS</label>
      </fieldset>

      <div class="inbound-primary-actions">
        <button class="btn btn-primary" id="scan-inbound-files" type="button">Scan available files</button>
        <button class="btn" id="build-inbound-export" type="button" disabled>Build download package</button>
      </div>
      <p class="inbound-form-status" id="inbound-form-status"></p>
    </article>

    <article class="master-card inbound-preview-card">
      <div class="inbound-card-heading">
        <div>
          <p class="eyebrow">Scan preview</p>
          <h2>Available files</h2>
        </div>
        <span class="badge" id="inbound-preview-state">Not scanned</span>
      </div>
      <div class="inbound-metrics">
        <article><span>All files</span><strong id="metric-all">—</strong></article>
        <article><span>Images</span><strong id="metric-images">—</strong></article>
        <article><span>PDFs</span><strong id="metric-pdfs">—</strong></article>
        <article><span>Spreadsheets</span><strong id="metric-sheets">—</strong></article>
        <article><span>Estimated size</span><strong id="metric-size">—</strong></article>
        <article><span>Already archived</span><strong id="metric-archived">—</strong></article>
      </div>
      <div class="inbound-coverage" id="inbound-coverage">
        Select a contact and scan to see captured history coverage.
      </div>
    </article>
  </section>

  <section class="master-card inbound-preview-list-card">
    <div class="inbound-card-heading">
      <div><p class="eyebrow">Matched attachments</p><h2>Review before export</h2></div>
      <span id="inbound-preview-total">0 files</span>
    </div>
    <div class="table-wrap">
      <table class="table table-sm inbound-file-table">
        <thead><tr><th>Received</th><th>File</th><th>Type</th><th>Chat</th><th>Archive state</th></tr></thead>
        <tbody id="inbound-preview-items"><tr><td colspan="5" class="empty-cell">No scan has been run.</td></tr></tbody>
      </table>
    </div>
  </section>

  <section class="inbound-files-grid inbound-job-section">
    <article class="master-card">
      <div class="inbound-card-heading">
        <div><p class="eyebrow">Live activity</p><h2>Export progress</h2></div>
        <span class="badge" id="inbound-job-state">Idle</span>
      </div>
      <pre class="inbound-log" id="inbound-job-log">Choose filters, scan, then build a package.</pre>
    </article>
    <article class="master-card">
      <p class="eyebrow">Generated files</p>
      <h2>Downloads</h2>
      <div class="inbound-downloads" id="inbound-downloads">
        <p>ZIP and audit manifests will appear after processing.</p>
      </div>
    </article>
  </section>

  <section class="master-card inbound-history-card">
    <div class="inbound-card-heading">
      <div><p class="eyebrow">Export history</p><h2>Recent packages</h2></div>
      <button class="btn btn-xs" id="refresh-inbound-history" type="button">Refresh</button>
    </div>
    <div class="table-wrap">
      <table class="table table-sm inbound-file-table">
        <thead><tr><th>Created</th><th>Contact</th><th>Filters</th><th>Files</th><th>Status</th><th></th></tr></thead>
        <tbody id="inbound-history-items"><tr><td colspan="6" class="empty-cell">Loading export history…</td></tr></tbody>
      </table>
    </div>
  </section>

  <script>
    import { actions } from "astro:actions";

    const API_BASE = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
    const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const contactSearch = el<HTMLInputElement>("inbound-contact-search");
    const contactId = el<HTMLInputElement>("inbound-contact-id");
    const contactResults = el<HTMLDivElement>("inbound-contact-results");
    const selectedContact = el<HTMLDivElement>("inbound-selected-contact");
    const formStatus = el<HTMLParagraphElement>("inbound-form-status");
    const scanButton = el<HTMLButtonElement>("scan-inbound-files");
    const buildButton = el<HTMLButtonElement>("build-inbound-export");
    const previewItems = el<HTMLTableSectionElement>("inbound-preview-items");
    const historyItems = el<HTMLTableSectionElement>("inbound-history-items");
    const jobLog = el<HTMLPreElement>("inbound-job-log");
    const downloads = el<HTMLDivElement>("inbound-downloads");
    let selectedContactData: any = null;
    let latestPreview: any = null;
    let currentJobId = "";
    let currentExportId = "";
    let pollTimer: number | undefined;
    let searchTimer: number | undefined;

    function escapeHtml(value: unknown) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function formatBytes(value: number | null | undefined) {
      const bytes = Number(value || 0);
      if (!bytes) return "0 B";
      const units = ["B", "KB", "MB", "GB"];
      const index = Math.min(Math.floor(Math.log(bytes) / Math.log(1024)), units.length - 1);
      return `${(bytes / 1024 ** index).toFixed(index ? 1 : 0)} ${units[index]}`;
    }

    function formatDate(value: string | null | undefined) {
      if (!value) return "—";
      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? String(value) : date.toLocaleString();
    }

    function setStatus(message: string, kind: "" | "error" | "success" = "") {
      formStatus.textContent = message;
      formStatus.className = `inbound-form-status ${kind}`;
    }

    async function searchContacts() {
      const query = contactSearch.value.trim();
      if (query.length < 2) {
        contactResults.hidden = true;
        return;
      }
      const result = await actions.whatsapp.directoryContacts({ search: query, tokenStatus: "", page: 1, pageSize: 20 });
      if (result.error) {
        setStatus(result.error.message, "error");
        return;
      }
      const items = (result.data as any).items || [];
      contactResults.innerHTML = items.length
        ? items.map((item: any) => `<button type="button" data-contact='${escapeHtml(JSON.stringify(item))}'><strong>${escapeHtml(item.display_name || "Unnamed contact")}</strong><small>${escapeHtml(item.phone_jid || item.primary_lid_jid || item.canonical_key || "No phone JID")}</small></button>`).join("")
        : '<p class="empty-cell">No directory contacts matched.</p>';
      contactResults.hidden = false;
    }

    function chooseContact(item: any) {
      selectedContactData = item;
      contactId.value = item.id;
      el<HTMLElement>("inbound-selected-name").textContent = item.display_name || "Unnamed contact";
      el<HTMLElement>("inbound-selected-identity").textContent = item.phone_jid || item.primary_lid_jid || "No phone identity";
      selectedContact.hidden = false;
      contactSearch.hidden = true;
      contactResults.hidden = true;
      latestPreview = null;
      buildButton.disabled = true;
      setStatus("Contact selected. Scan to review available files.");
    }

    function clearContact() {
      selectedContactData = null;
      contactId.value = "";
      contactSearch.value = "";
      contactSearch.hidden = false;
      selectedContact.hidden = true;
      latestPreview = null;
      buildButton.disabled = true;
      contactSearch.focus();
    }

    function selectedMediaTypes() {
      return Array.from(document.querySelectorAll<HTMLInputElement>(".inbound-type-options input:checked")).map((item) => item.value);
    }

    function dateFilters() {
      const preset = el<HTMLSelectElement>("inbound-date-preset").value;
      if (preset === "all") return { date_from: null, date_to: null };
      const now = new Date();
      if (preset === "today") {
        const start = new Date(now); start.setHours(0, 0, 0, 0);
        const end = new Date(now); end.setHours(23, 59, 59, 999);
        return { date_from: start.toISOString(), date_to: end.toISOString() };
      }
      if (preset === "custom") {
        const from = el<HTMLInputElement>("inbound-date-from").value;
        const to = el<HTMLInputElement>("inbound-date-to").value;
        return {
          date_from: from ? new Date(`${from}T00:00:00`).toISOString() : null,
          date_to: to ? new Date(`${to}T23:59:59.999`).toISOString() : null,
        };
      }
      const days = Number(preset || 30);
      const start = new Date(now.getTime() - days * 86400000);
      return { date_from: start.toISOString(), date_to: now.toISOString() };
    }

    function filterPayload() {
      if (!contactId.value) throw new Error("Select a WhatsApp contact first.");
      const mediaTypes = selectedMediaTypes();
      if (!mediaTypes.length) throw new Error("Select at least one file type.");
      return {
        contact_id: contactId.value,
        ...dateFilters(),
        chat_scope: el<HTMLSelectElement>("inbound-chat-scope").value as "direct" | "direct_and_groups",
        media_types: mediaTypes as ("image" | "pdf" | "spreadsheet")[],
      };
    }

    function renderPreview(data: any) {
      latestPreview = data;
      const counts = data.category_counts || {};
      const statuses = data.download_status_counts || {};
      el<HTMLElement>("metric-all").textContent = String(data.files_found || 0);
      el<HTMLElement>("metric-images").textContent = String(counts.image || 0);
      el<HTMLElement>("metric-pdfs").textContent = String(counts.pdf || 0);
      el<HTMLElement>("metric-sheets").textContent = String(counts.spreadsheet || 0);
      el<HTMLElement>("metric-size").textContent = formatBytes(data.declared_bytes);
      el<HTMLElement>("metric-archived").textContent = String(statuses.archived || 0);
      el<HTMLElement>("inbound-preview-state").textContent = data.files_found ? "Ready" : "No matches";
      el<HTMLElement>("inbound-preview-total").textContent = `${data.files_found || 0} files`;
      const coverage = data.coverage || {};
      el<HTMLElement>("inbound-coverage").innerHTML = `<strong>Captured coverage:</strong> ${escapeHtml(formatDate(coverage.earliest_message_at))} to ${escapeHtml(formatDate(coverage.latest_message_at))}<br><small>${escapeHtml(coverage.note || "Historical coverage may be partial.")}</small>`;
      const items = data.items || [];
      previewItems.innerHTML = items.length
        ? items.map((item: any) => `<tr><td>${escapeHtml(formatDate(item.timestamp))}</td><td><strong>${escapeHtml(item.filename)}</strong><small>${escapeHtml(item.caption || "")}</small></td><td><span class="badge">${escapeHtml(item.category)}</span><small>${escapeHtml(item.mime_type || "")}</small></td><td>${escapeHtml(item.chat_scope)}</td><td>${escapeHtml(item.download_status || "metadata_only")}</td></tr>`).join("")
        : '<tr><td colspan="5" class="empty-cell">No supported files matched these filters.</td></tr>';
      buildButton.disabled = !data.files_found;
    }

    async function scanFiles() {
      try {
        scanButton.disabled = true;
        buildButton.disabled = true;
        setStatus("Scanning captured inbound message metadata…");
        const result = await actions.whatsapp.inboundExportPreview(filterPayload());
        if (result.error) throw new Error(result.error.message);
        renderPreview(result.data);
        setStatus(`Scan complete: ${(result.data as any).files_found} matching file(s).`, "success");
      } catch (error: any) {
        setStatus(error.message || String(error), "error");
      } finally {
        scanButton.disabled = false;
      }
    }

    async function buildExport() {
      try {
        buildButton.disabled = true;
        scanButton.disabled = true;
        setStatus("Queueing inbound file export…");
        const result = await actions.whatsapp.createInboundExport({ ...filterPayload(), requested_by: "web-operator" });
        if (result.error) throw new Error(result.error.message);
        const data = result.data as any;
        currentJobId = data.job_id;
        currentExportId = data.export.id;
        el<HTMLElement>("inbound-job-state").textContent = "Queued";
        jobLog.textContent = "Export queued. Waiting for the WhatsApp worker…";
        downloads.innerHTML = "<p>Files will appear after processing.</p>";
        setStatus("Export queued. Live progress is shown below.", "success");
        startPolling();
        await loadHistory();
      } catch (error: any) {
        setStatus(error.message || String(error), "error");
        buildButton.disabled = !latestPreview?.files_found;
      } finally {
        scanButton.disabled = false;
      }
    }

    async function pollJob() {
      if (!currentJobId) return;
      const [jobResult, logResult, artifactResult] = await Promise.all([
        actions.whatsapp.job({ id: currentJobId }),
        actions.whatsapp.jobLogs({ id: currentJobId }),
        actions.whatsapp.jobArtifacts({ id: currentJobId }),
      ]);
      if (jobResult.data) {
        const job = jobResult.data as any;
        el<HTMLElement>("inbound-job-state").textContent = job.status;
        if (["succeeded", "failed", "cancelled"].includes(job.status)) {
          if (pollTimer) window.clearInterval(pollTimer);
          pollTimer = undefined;
          buildButton.disabled = !latestPreview?.files_found;
          await loadHistory();
        }
      }
      if (logResult.data) {
        const logs = logResult.data as any[];
        jobLog.textContent = logs.map((item) => `[${formatDate(item.created_at)}] ${item.message}`).join("\n") || "Waiting for worker activity…";
        jobLog.scrollTop = jobLog.scrollHeight;
      }
      if (artifactResult.data) {
        const artifacts = artifactResult.data as any[];
        downloads.innerHTML = artifacts.length
          ? artifacts.map((item) => `<a class="inbound-download-link" href="${API_BASE}/api/v1/artifacts/${item.id}/download"><strong>${escapeHtml(item.name)}</strong><small>${escapeHtml(item.kind)} · ${formatBytes(item.size_bytes)}</small></a>`).join("")
          : "<p>Files will appear after processing.</p>";
      }
    }

    function startPolling() {
      if (pollTimer) window.clearInterval(pollTimer);
      void pollJob();
      pollTimer = window.setInterval(() => void pollJob(), 1000);
    }

    async function loadHistory() {
      const result = await actions.whatsapp.inboundExports({ page: 1, pageSize: 10 });
      if (result.error) {
        historyItems.innerHTML = `<tr><td colspan="6" class="empty-cell">${escapeHtml(result.error.message)}</td></tr>`;
        return;
      }
      const items = (result.data as any).items || [];
      historyItems.innerHTML = items.length
        ? items.map((item: any) => `<tr><td>${escapeHtml(formatDate(item.created_at))}</td><td><strong>${escapeHtml(item.contact_name)}</strong></td><td>${escapeHtml(item.chat_scope)}<small>${escapeHtml((item.media_types || []).join(", "))}</small></td><td>${item.files_downloaded + item.files_reused}/${item.files_matched}<small>${item.files_unavailable} unavailable</small></td><td><span class="badge">${escapeHtml(item.status)}</span></td><td><button class="btn btn-xs" data-open-export="${escapeHtml(item.id)}" data-job-id="${escapeHtml(item.job_id)}">Open</button></td></tr>`).join("")
        : '<tr><td colspan="6" class="empty-cell">No inbound exports have been created.</td></tr>';
    }

    contactSearch.addEventListener("input", () => {
      if (searchTimer) window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => void searchContacts(), 250);
    });
    contactResults.addEventListener("click", (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>("button[data-contact]");
      if (!button) return;
      chooseContact(JSON.parse(button.dataset.contact || "{}"));
    });
    el<HTMLButtonElement>("clear-inbound-contact").addEventListener("click", clearContact);
    el<HTMLSelectElement>("inbound-date-preset").addEventListener("change", (event) => {
      const custom = (event.target as HTMLSelectElement).value === "custom";
      document.querySelectorAll<HTMLElement>(".custom-date-field").forEach((item) => { item.hidden = !custom; });
    });
    scanButton.addEventListener("click", () => void scanFiles());
    buildButton.addEventListener("click", () => void buildExport());
    el<HTMLButtonElement>("refresh-inbound-history").addEventListener("click", () => void loadHistory());
    el<HTMLButtonElement>("refresh-page").addEventListener("click", () => { void loadHistory(); if (currentJobId) void pollJob(); });
    historyItems.addEventListener("click", (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>("button[data-open-export]");
      if (!button) return;
      currentExportId = button.dataset.openExport || "";
      currentJobId = button.dataset.jobId || "";
      startPolling();
      document.querySelector(".inbound-job-section")?.scrollIntoView({ behavior: "smooth" });
    });
    document.addEventListener("click", (event) => {
      if (!(event.target as HTMLElement).closest(".inbound-contact-picker")) contactResults.hidden = true;
    });
    void loadHistory();
  </script>
</WhatsAppLayout>
