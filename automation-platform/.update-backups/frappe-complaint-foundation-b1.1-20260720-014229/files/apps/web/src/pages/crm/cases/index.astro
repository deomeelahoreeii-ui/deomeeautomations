---
import CrmIntakeNav from "../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";
---
<CrmLayout title="Complaint Review" description="Turn captured WhatsApp evidence into reviewed CRM complaints, then publish only approved cases." page="cases">
  <button class="btn btn-sm" id="refresh-cases" slot="actions">↻ Refresh</button>
  <CrmIntakeNav active="review" />

  <section class="crm-review-hero">
    <div><p class="eyebrow">CRM complaint workflow</p><h2>Captured evidence → complaint cases → Paperless</h2><p>Start with an existing WhatsApp intake below. Classification extracts complaint numbers and text, checks Paperless for duplicates, and creates reviewable cases. Nothing is uploaded until you explicitly approve a case.</p></div>
    <div class="crm-review-steps"><span><b>1</b> Process evidence</span><span><b>2</b> Review cases</span><span><b>3</b> Approve & publish</span></div>
  </section>

  <section class="inbound-summary-grid crm-case-summary">
    <article class="master-card"><span>Captured runs ready</span><strong id="ready-source-count">—</strong><small>Already fetched; not classified</small></article>
    <article class="master-card"><span>Processing now</span><strong id="active-source-count">—</strong><small>Extraction and duplicate checks</small></article>
    <article class="master-card"><span>Unique complaint cases</span><strong id="unique-case-count">—</strong><small>One case per complaint number</small></article>
    <article class="master-card"><span>Ready for Paperless</span><strong id="ready-publication-count">—</strong><small>Verified and publishable</small></article>
  </section>

  <section class="master-card crm-paperless-center">
    <div class="crm-paperless-center-copy"><p class="eyebrow">Publication workspace</p><h2>Paperless publication center</h2><p>Approvals are counted per intake run, but this workspace keeps one durable case per complaint number. Repeated approvals are merged before publication.</p></div>
    <div class="crm-paperless-center-stats"><div><span>Approved unique cases</span><strong id="center-approved-count">—</strong></div><div><span>Ready now</span><strong id="center-ready-count">—</strong></div><div><span>Need verification</span><strong id="center-blocked-count">—</strong></div><div><span>Publishing</span><strong id="center-publishing-count">—</strong></div><div><span>Published</span><strong id="center-published-count">—</strong></div></div>
    <button class="btn btn-primary" id="open-publication-center" type="button">View approved cases →</button>
  </section>

  <section class="master-card crm-helpdesk-center" id="helpdesk-center">
    <div class="crm-helpdesk-copy"><p class="eyebrow">Complaint operations</p><h2>Frappe Helpdesk synchronization</h2><p>Paperless remains the document archive. Helpdesk receives approved complaint cases for assignment, status tracking, findings and final replies.</p></div>
    <div class="crm-helpdesk-stats"><div><span>Connection</span><strong id="helpdesk-health">Checking…</strong></div><div><span>Eligible CRM cases</span><strong id="helpdesk-eligible">—</strong></div><div><span>Linked tickets</span><strong id="helpdesk-linked">—</strong></div><div><span>Failed sync</span><strong id="helpdesk-failed">—</strong></div></div>
    <div class="crm-helpdesk-actions"><button class="btn btn-sm" id="preview-helpdesk" type="button">Preview import</button><button class="btn btn-sm" id="bootstrap-helpdesk" type="button">Verify fields & categories</button><button class="btn btn-sm btn-primary" id="sync-helpdesk" type="button">Sync eligible complaints</button><a class="btn btn-sm" id="open-helpdesk" href="http://localhost:8082/helpdesk/tickets" target="_blank" rel="noreferrer">Open Helpdesk ↗</a></div>
    <div class="crm-helpdesk-message" id="helpdesk-message" hidden></div>
  </section>

  <section class="master-card crm-source-queue" id="captured-evidence">
    <div class="inbound-card-heading"><div><p class="eyebrow">Start here</p><h2>Captured WhatsApp evidence</h2><p>These are permanent intake runs that already contain files. Process a run to create complaint candidates—there is no need to fetch Faheem's history again.</p></div><a class="btn btn-sm" href="/crm/intake/batches">All intake runs</a></div>
    <div id="source-list" class="crm-run-list"><div class="crm-intake-empty"><h3>Loading captured evidence…</h3></div></div>
  </section>

  <section class="master-card crm-case-registry" id="complaint-cases">
    <div class="inbound-card-heading"><div><p class="eyebrow">Review queue</p><h2>Complaint cases</h2><p>One durable case per complaint number. Confirm the main complaint, complete remarks, attachments and duplicate decision before publication.</p></div><button class="btn btn-sm" id="backfill-paperless">Import existing Paperless cases</button></div>
    <nav class="crm-case-views"><button data-case-view="">All unique cases</button><button data-case-view="review_required">Needs review</button><button data-case-view="fresh">Approved</button><button data-case-view="existing">Already exists</button><button data-case-view="publishing">Publishing</button><button data-case-view="published">Published</button><button data-case-view="rejected">Rejected</button></nav>
    <div class="toolbar crm-case-toolbar"><input class="input input-bordered input-sm" id="case-search" placeholder="Search complaint number, name, mobile or CNIC"/><select class="select select-bordered select-sm" id="case-state"><option value="">All case states</option><option value="candidate">Candidate</option><option value="review_required">Needs review</option><option value="fresh">Approved</option><option value="existing">Already exists</option><option value="publishing">Publishing</option><option value="published">Published</option><option value="rejected">Rejected</option></select><span id="case-count">Loading…</span></div>
    <div class="crm-publication-toolbar" id="publication-toolbar" hidden><label><input type="checkbox" id="select-all-publishable"/><span id="publication-selection-label">Select approved cases</span></label><div><small>Uploads canonical evidence with Source: CRM Portal and Status: Pending.</small><button class="btn btn-sm btn-primary" id="publish-selected" type="button" disabled>Publish selected to Paperless</button></div></div>
    <div class="crm-run-list" id="case-list"></div>
  </section>

  <style>
    .crm-paperless-center{display:grid;grid-template-columns:minmax(18rem,1.15fr) minmax(32rem,2fr) auto;gap:1rem;align-items:center;margin-top:1rem;border-color:#9bcdd4;border-left:5px solid #16879a;background:linear-gradient(120deg,#effafb,#fff)}.crm-paperless-center h2{margin:.15rem 0 .35rem}.crm-paperless-center p{margin:0;color:#64748b}.crm-paperless-center-stats{display:grid;grid-template-columns:repeat(5,1fr);gap:.5rem}.crm-paperless-center-stats div{padding:.65rem;border:1px solid #d8e7eb;border-radius:.6rem;background:#fff}.crm-paperless-center-stats span{display:block;color:#718096;font-size:.65rem;line-height:1.3}.crm-paperless-center-stats strong{display:block;margin-top:.15rem;font-size:1.25rem}
    .crm-helpdesk-center{display:grid;grid-template-columns:minmax(18rem,1.2fr) minmax(28rem,1.6fr);gap:1rem;align-items:center;margin-top:1rem;border-color:#d8e7eb}.crm-helpdesk-copy h2{margin:.15rem 0 .35rem}.crm-helpdesk-copy p{margin:0;color:#64748b}.crm-helpdesk-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:.5rem}.crm-helpdesk-stats div{padding:.65rem;border:1px solid #d8e7eb;border-radius:.6rem;background:#fff}.crm-helpdesk-stats span{display:block;color:#718096;font-size:.65rem}.crm-helpdesk-stats strong{display:block;margin-top:.15rem;font-size:1rem}.crm-helpdesk-actions{grid-column:1/-1;display:flex;gap:.55rem;flex-wrap:wrap}.crm-helpdesk-message{grid-column:1/-1;border-radius:.6rem;background:#eef8fa;color:#155e6c;padding:.7rem}.crm-helpdesk-message.error{background:#fff0f1;color:#a52630}.crm-helpdesk-link{display:inline-flex;align-items:center;gap:.25rem;margin-left:.45rem;color:#0d7788;font-weight:700}.crm-helpdesk-state{display:inline-flex;padding:.2rem .45rem;border-radius:1rem;background:#edf3f6;color:#526476;font-size:.66rem;font-weight:750}.crm-helpdesk-state.synchronized{background:#e7f8f1;color:#176b57}.crm-helpdesk-state.failed{background:#fff0f1;color:#a52630}.crm-helpdesk-state.pending,.crm-helpdesk-state.update_pending{background:#fff3dc;color:#925b05}.    .crm-review-hero{display:flex;justify-content:space-between;gap:2rem;align-items:center;padding:1.25rem 1.4rem;margin:1rem 0;border:1px solid #b9dce2;border-left:5px solid #16879a;border-radius:.9rem;background:linear-gradient(120deg,#f1fbfc,#fff)}.crm-review-hero h2{margin:.15rem 0 .35rem}.crm-review-hero p{max-width:58rem;margin:0;color:#64748b}.crm-review-steps{display:grid;gap:.45rem;min-width:15rem}.crm-review-steps span{display:flex;align-items:center;gap:.55rem;font-weight:700}.crm-review-steps b{display:grid;place-items:center;width:1.65rem;height:1.65rem;border-radius:50%;background:#16879a;color:#fff}.crm-case-summary{margin:1rem 0}.crm-case-summary small{display:block;color:#718096;margin-top:.2rem}.crm-source-queue,.crm-case-registry{margin-top:1rem}.crm-source-card .crm-run-metrics{grid-template-columns:repeat(3,1fr)}.crm-source-action{display:flex;align-items:center;gap:.65rem}.crm-source-action small{max-width:22rem;color:#64748b}.crm-case-views{display:flex;gap:.35rem;overflow:auto;margin:.8rem 0;padding:.25rem;background:#edf3f6;border-radius:.7rem}.crm-case-views button{border:0;background:transparent;padding:.55rem .8rem;border-radius:.5rem;white-space:nowrap;font-weight:700;color:#5e6d7e}.crm-case-views button.active{background:#fff;color:#0d7788;box-shadow:0 1px 4px #0f172a1a}.crm-case-toolbar{display:grid;grid-template-columns:minmax(18rem,1fr) 13rem auto;gap:.65rem;align-items:center}.crm-publication-toolbar{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin:.75rem 0;border:1px solid #b9dce2;border-radius:.7rem;background:#f2fafb;padding:.7rem .8rem}.crm-publication-toolbar label,.crm-publication-toolbar>div{display:flex;align-items:center;gap:.55rem}.crm-publication-toolbar small{color:#64748b}.crm-publish-selector{display:flex;align-items:center;gap:.6rem}.crm-publish-selector input{accent-color:#16879a}.crm-publication-blocker{display:block;margin-top:.25rem;color:#9a5b16;font-size:.7rem}@media(max-width:1100px){.crm-paperless-center,.crm-helpdesk-center{grid-template-columns:1fr}.crm-helpdesk-stats{grid-template-columns:repeat(2,1fr)}.crm-paperless-center-stats{grid-template-columns:repeat(3,1fr)}}@media(max-width:900px){.crm-review-hero{align-items:flex-start;flex-direction:column}.crm-review-steps{grid-template-columns:1fr;min-width:0}.crm-case-toolbar{grid-template-columns:1fr}.crm-source-card .crm-run-metrics{grid-template-columns:1fr}.crm-publication-toolbar,.crm-publication-toolbar>div{align-items:stretch;flex-direction:column}}@media(max-width:560px){.crm-paperless-center-stats,.crm-helpdesk-stats{grid-template-columns:1fr}}
  </style>

  <script>
    import { actions } from "astro:actions";
    const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;
    const esc=(v:any)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;");
    const formatDate=(v:any)=>{const d=new Date(v);return Number.isNaN(d.getTime())?"—":d.toLocaleString()};
    const terminal=new Set(["completed","completed_with_errors","failed","cancelled"]);let timer:number|undefined,publicationTimer:number|undefined,currentCases:any[]=[];const selectedCases=new Set<string>();
    function sourceAction(x:any){if(x.processing_run_id&&!terminal.has(x.processing_status))return`<div class="crm-source-action"><small>Classification is running now.</small><a class="btn btn-sm btn-primary" href="/crm/intake/review/${esc(x.processing_run_id)}">Watch progress →</a></div>`;if(x.processing_run_id&&["completed","completed_with_errors"].includes(x.processing_status))return`<div class="crm-source-action"><small>Processed ${x.processing_processed_items||0}/${x.processing_total_items||0}; ${x.processing_review_items||0} need review.</small><a class="btn btn-sm btn-primary" href="/crm/intake/review/${esc(x.processing_run_id)}">Open result →</a></div>`;return`<div class="crm-source-action"><small>Reads captured files and Paperless index only. It does not upload.</small><button class="btn btn-sm btn-primary" data-process-batch="${esc(x.id)}">Process evidence →</button></div>`}
    function renderSource(x:any){const ready=!x.processing_run_id||["failed","cancelled"].includes(x.processing_status);const label=ready?"Ready to process":String(x.processing_status).replaceAll("_"," ");return`<article class="crm-run-card crm-source-card"><header><div><span class="crm-run-state ${esc(x.processing_status||"not_started")}">${esc(label)}</span><h3>${esc(x.contact_name||"Unnamed contact")}</h3><p>${esc(x.contact_identity||"")} · ${esc(x.batch_code)}</p></div><time>${esc(formatDate(x.created_at))}</time></header><div class="crm-run-metrics"><div><span>Captured files</span><strong>${Number(x.files_discovered||0)}</strong><small>from this intake</small></div><div><span>Durable files</span><strong>${Number(x.files_stored||0)+Number(x.files_reused||0)}</strong><small>${Number(x.files_failed||0)} storage issue(s)</small></div><div><span>Processing</span><strong>${esc(label)}</strong><small>${x.processing_run_code?esc(x.processing_run_code):"Not started"}</small></div></div><footer><a href="/crm/intake/batches/${esc(x.id)}">Inspect captured run</a>${sourceAction(x)}</footer></article>`}
    function renderCase(x:any){const selectable=x.state==="fresh"&&x.publication_ready,blockers=(x.publication_blockers||[]).join(" · "),selector=selectable?`<label class="crm-publish-selector"><input type="checkbox" data-publish-case="${esc(x.id)}" ${selectedCases.has(x.id)?"checked":""}/><span>Select for Paperless</span></label>`:"",progress=x.state==="publishing",published=x.state==="published",status=x.paperless_document_id?`Paperless #${esc(x.paperless_document_id)}`:progress?"Uploading to Paperless…":x.publication_ready?"Ready for CRM Pending":"Paperless publication blocked",action=progress?"View progress":published?"Open case":x.publication_ready?"Verify case":"Review case",helpdesk=x.frappe_ticket_id?`<a class="crm-helpdesk-link" href="${esc(x.frappe_ticket_url)}" target="_blank" rel="noreferrer">Helpdesk #${esc(x.frappe_ticket_id)} ↗</a>`:`<span class="crm-helpdesk-state ${esc(x.frappe_sync_status)}">${esc(String(x.frappe_sync_status||"not_synced").replaceAll("_"," "))}</span>`;return`<article class="crm-run-card"><header><div>${selector}<span class="crm-run-state ${esc(x.state)}">${esc(x.state.replaceAll("_"," "))}</span><h3><a href="/crm/cases/${x.id}">${esc(x.complaint_number||"Number needs review")}</a></h3><p>${esc(x.complainant_name||"Complainant not confirmed")} · ${esc(x.district||"District unknown")}</p>${x.frappe_last_error?`<small class="crm-publication-blocker">Helpdesk sync failed: ${esc(x.frappe_last_error)}</small>`:x.publication_error&&x.state==="fresh"?`<small class="crm-publication-blocker">Last publication attempt failed: ${esc(x.publication_error)}</small>`:x.state==="fresh"&&!x.publication_ready?`<small class="crm-publication-blocker">Before publishing: ${esc(blockers||"Complete case verification")}</small>`:""}</div><strong>${x.document_count} evidence item(s)</strong></header><footer><span>${status}${helpdesk}</span><a class="btn btn-sm btn-primary" href="/crm/cases/${x.id}">${action} →</a></footer></article>`}
    function syncPublicationControls(){const publishable=currentCases.filter(x=>x.state==="fresh"&&x.publication_ready),visible=el<HTMLSelectElement>("case-state").value==="fresh",selectAll=el<HTMLInputElement>("select-all-publishable"),button=el<HTMLButtonElement>("publish-selected");el("publication-toolbar").hidden=!visible;for(const id of selectedCases)if(!publishable.some(x=>x.id===id))selectedCases.delete(id);selectAll.checked=publishable.length>0&&selectedCases.size===publishable.length;selectAll.indeterminate=selectedCases.size>0&&selectedCases.size<publishable.length;button.disabled=selectedCases.size===0;button.textContent=selectedCases.size?`Publish ${selectedCases.size} selected to Paperless`:"Publish selected to Paperless";el("publication-selection-label").textContent=`${selectedCases.size} of ${publishable.length} ready selected`}
    async function load(){
      const search=el<HTMLInputElement>("case-search").value;
      const state=el<HTMLSelectElement>("case-state").value;
      document.querySelectorAll<HTMLButtonElement>("[data-case-view]").forEach(button=>button.classList.toggle("active",button.dataset.caseView===state));
      const [caseResult,batchResult,statsResult,helpdeskStatsResult,helpdeskHealthResult]=await Promise.all([
        actions.crm.cases({search,state,limit:100}),
        actions.whatsapp.inboundBatches({limit:100}),
        actions.crm.caseStatistics({}),
        actions.crm.helpdeskStatistics({}),
        actions.crm.helpdeskHealth({}),
      ]);
      if(caseResult.error){
        el("case-list").innerHTML=`<p class="alert alert-error">${esc(caseResult.error.message)}</p>`;
      }else{
        const d=caseResult.data as any,items=d.items||[];
        currentCases=items;
        syncPublicationControls();
        el("case-count").textContent=`${d.total} unique complaint case${d.total===1?"":"s"}`;
        el("case-list").innerHTML=items.length?items.map(renderCase).join(""):`<div class="crm-intake-empty"><h3>No cases in this view</h3><p>Choose another status or process captured evidence above.</p></div>`;
      }
      if(statsResult.data){
        const s=statsResult.data as any;
        el("unique-case-count").textContent=String(s.unique_cases);
        el("ready-publication-count").textContent=String(s.ready_to_publish);
        el("center-approved-count").textContent=String(s.approved_cases);
        el("center-ready-count").textContent=String(s.ready_to_publish);
        el("center-blocked-count").textContent=String(s.blocked_from_publication);
        el("center-publishing-count").textContent=String(s.publishing);
        el("center-published-count").textContent=String(s.published);
        if(publicationTimer)clearTimeout(publicationTimer);
        publicationTimer=Number(s.publishing)>0?window.setTimeout(()=>void load(),3000):undefined;
      }
      if(helpdeskStatsResult.data){
        const hs=helpdeskStatsResult.data as any;
        el("helpdesk-eligible").textContent=String(hs.eligible_cases||0);
        el("helpdesk-linked").textContent=String(hs.linked_cases||0);
        el("helpdesk-failed").textContent=String(hs.statuses?.failed||0);
      }
      if(helpdeskHealthResult.data){
        const hh=helpdeskHealthResult.data as any;
        el("helpdesk-health").textContent=hh.status==="ok"?"Connected":hh.status==="not_configured"?"Not configured":String(hh.status||"Unknown");
        const open=el<HTMLAnchorElement>("open-helpdesk");
        if(hh.base_url)open.href=`${String(hh.base_url).replace(/\/$/,"")}/helpdesk/tickets`;
      }else if(helpdeskHealthResult.error){
        el("helpdesk-health").textContent="Unavailable";
      }
      if(batchResult.error){
        el("source-list").innerHTML=`<p class="alert alert-error">${esc(batchResult.error.message)}</p>`;
        return;
      }
      const all=(batchResult.data as any).items||[];
      const sources=all.filter((x:any)=>Number(x.files_discovered||0)>0&&["completed","completed_with_errors"].includes(x.status));
      el("ready-source-count").textContent=String(sources.filter((x:any)=>!x.processing_run_id||["failed","cancelled"].includes(x.processing_status)).length);
      el("active-source-count").textContent=String(sources.filter((x:any)=>x.processing_run_id&&!terminal.has(x.processing_status)).length);
      el("source-list").innerHTML=sources.length?sources.map(renderSource).join(""):`<div class="crm-intake-empty"><h3>No captured files are ready</h3><p>Start a WhatsApp complaint intake, or inspect runs with storage errors.</p><a class="btn btn-sm btn-primary" href="/crm/intake/">Start new intake</a></div>`;
    }
    el("source-list").addEventListener("click",async event=>{const button=(event.target as HTMLElement).closest<HTMLButtonElement>("[data-process-batch]");if(!button)return;if(!confirm("Classify this run's captured files and check for Paperless duplicates? Nothing will be uploaded."))return;button.disabled=true;button.textContent="Starting…";const r=await actions.whatsapp.createInboundProcessingRun({batch_id:button.dataset.processBatch!,paperless_check:true});if(r.error){alert(r.error.message);button.disabled=false;button.textContent="Process evidence →";return}const run=(r.data as any).processing_run;if(run?.id)window.location.assign(`/crm/intake/review/${run.id}`);else void load()});
    el("case-list").addEventListener("change",event=>{const input=(event.target as HTMLElement).closest<HTMLInputElement>("[data-publish-case]");if(!input)return;if(input.checked)selectedCases.add(input.dataset.publishCase!);else selectedCases.delete(input.dataset.publishCase!);syncPublicationControls()});
    el<HTMLInputElement>("select-all-publishable").addEventListener("change",event=>{const checked=(event.currentTarget as HTMLInputElement).checked;for(const x of currentCases.filter(x=>x.state==="fresh"&&x.publication_ready)){if(checked)selectedCases.add(x.id);else selectedCases.delete(x.id)}el("case-list").querySelectorAll<HTMLInputElement>("[data-publish-case]").forEach(input=>input.checked=checked);syncPublicationControls()});
    el<HTMLButtonElement>("publish-selected").addEventListener("click",async()=>{const caseIds=[...selectedCases];if(!caseIds.length)return;if(!confirm(`Publish ${caseIds.length} verified complaint${caseIds.length===1?"":"s"} and accepted evidence to Paperless as CRM Pending?`))return;const button=el<HTMLButtonElement>("publish-selected");button.disabled=true;button.textContent=`Queuing ${caseIds.length}…`;const result=await actions.crm.publishComplaintBatch({caseIds});if(result.error){alert(result.error.message);syncPublicationControls();return}selectedCases.clear();alert(`${(result.data as any).queued_count} complaint${(result.data as any).queued_count===1?"":"s"} queued for CRM Pending publication.`);await load()});
    const initialState=new URLSearchParams(location.search).get("state")||"";el<HTMLSelectElement>("case-state").value=initialState;document.querySelectorAll<HTMLButtonElement>("[data-case-view]").forEach(button=>button.addEventListener("click",()=>{el<HTMLSelectElement>("case-state").value=button.dataset.caseView||"";const url=new URL(location.href);if(button.dataset.caseView)url.searchParams.set("state",button.dataset.caseView);else url.searchParams.delete("state");history.replaceState({},"",url);void load()}));el("open-publication-center").addEventListener("click",()=>{el<HTMLSelectElement>("case-state").value="fresh";const url=new URL(location.href);url.searchParams.set("state","fresh");url.hash="complaint-cases";history.replaceState({},"",url);void load();el("complaint-cases").scrollIntoView({behavior:"smooth",block:"start"})});el("refresh-cases").addEventListener("click",load);el("case-state").addEventListener("change",()=>{const url=new URL(location.href),state=el<HTMLSelectElement>("case-state").value;if(state)url.searchParams.set("state",state);else url.searchParams.delete("state");history.replaceState({},"",url);void load()});el("case-search").addEventListener("input",()=>{clearTimeout(timer);timer=window.setTimeout(load,250)});el("backfill-paperless").addEventListener("click",async()=>{if(!confirm("Import the existing Paperless complaint index into this registry? This is read-only and uploads nothing."))return;const r=await actions.crm.backfillPaperlessCases({});alert(r.error?r.error.message:"Paperless import queued. Refresh shortly to see imported cases.")});
    const helpdeskMessage=el("helpdesk-message");function showHelpdeskMessage(text:string,error=false){helpdeskMessage.textContent=text;helpdeskMessage.className=`crm-helpdesk-message${error?" error":""}`;helpdeskMessage.hidden=false}
    el("preview-helpdesk").addEventListener("click",async()=>{const button=el<HTMLButtonElement>("preview-helpdesk");button.disabled=true;button.textContent="Checking…";const result=await actions.crm.helpdeskPreview({limit:200});button.disabled=false;button.textContent="Preview import";if(result.error){showHelpdeskMessage(result.error.message,true);return}const counts=(result.data as any).counts||{};showHelpdeskMessage(`${counts.ready||0} ready, ${counts.linked||0} already linked, ${counts.blocked||0} blocked. No ticket was changed.`)});
    el("bootstrap-helpdesk").addEventListener("click",async()=>{if(!confirm("Verify and update the complaint fields, statuses and categories in Frappe Helpdesk?"))return;const button=el<HTMLButtonElement>("bootstrap-helpdesk");button.disabled=true;button.textContent="Verifying…";const result=await actions.crm.bootstrapHelpdesk({});button.disabled=false;button.textContent="Verify fields & categories";if(result.error){showHelpdeskMessage(result.error.message,true);return}showHelpdeskMessage("Helpdesk complaint fields, statuses and category types are ready.");await load()});
    el("sync-helpdesk").addEventListener("click",async()=>{if(!confirm("Create or update Helpdesk tickets for all eligible published complaints? Existing linked tickets will not be duplicated."))return;const button=el<HTMLButtonElement>("sync-helpdesk");button.disabled=true;button.textContent="Synchronizing…";const result=await actions.crm.syncHelpdeskBatch({caseIds:[],limit:100,force:false});button.disabled=false;button.textContent="Sync eligible complaints";if(result.error){showHelpdeskMessage(result.error.message,true);return}const counts=(result.data as any).counts||{};showHelpdeskMessage(`${counts.created||0} created, ${counts.updated||0} updated, ${counts.unchanged||0} unchanged, ${counts.blocked||0} blocked, ${counts.failed||0} failed.`);await load()});
    window.addEventListener("beforeunload",()=>{if(publicationTimer)clearTimeout(publicationTimer)});void load();
  </script>
</CrmLayout>
