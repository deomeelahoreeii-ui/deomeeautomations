---
import DataTable from "../../../components/DataTable.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";
---

<CrmLayout
  title="CRM PDF Duplicate Filter"
  description="Upload complaint PDFs, compare their numbers and content with Paperless, and download safely separated result bundles."
  page="pdf-filter"
>
  <button class="btn btn-sm btn-ghost" id="refresh-crm-pdfs" type="button" slot="actions">↻ Refresh</button>

  <div class="notice crm-safety">
    Exact duplicates, uncertain matches, missing complaint numbers, and extraction failures are isolated instead of being silently treated as fresh.
  </div>

  <section class="crm-grid">
    <article class="master-card crm-upload-card">
      <div class="panel-heading compact">
        <div><p class="eyebrow">Immutable intake</p><h2>Upload CRM PDFs</h2></div>
        <span class="environment-pill">Combined maximum 50 MB</span>
      </div>
      <form id="crm-pdf-upload-form">
        <label class="crm-upload-drop" id="crm-pdf-upload-drop">
          <input id="crm-pdf-files" type="file" accept="application/pdf,.pdf" multiple required />
          <span class="crm-upload-icon">⇧</span>
          <strong id="crm-pdf-upload-title">Choose or drop complaint PDFs</strong>
          <small id="crm-pdf-upload-detail">Multiple PDF files are supported</small>
        </label>
        <div class="crm-upload-options">
          <label class="form-control">
            <span class="label-text">Batch label <small>optional</small></span>
            <input class="input input-bordered input-sm" id="crm-pdf-label" maxlength="120" placeholder="For example: CRM intake 15 July" />
          </label>
          <label class="form-control">
            <span class="label-text">Paperless index limit <small>optional</small></span>
            <input class="input input-bordered input-sm" id="crm-pdf-limit" type="number" min="1" max="10000" placeholder="All complaints" />
          </label>
        </div>
        <button class="btn btn-primary w-full" id="crm-pdf-upload-button" type="submit">Validate &amp; filter PDFs</button>
      </form>
    </article>

    <article class="master-card crm-preflight-card">
      <div class="panel-heading compact">
        <div><p class="eyebrow">Preflight</p><h2>Detected PDF batch</h2></div>
        <span class="status-chip inactive" id="paperless-status">Checking Paperless…</span>
      </div>
      <div id="crm-pdf-preflight-empty" class="empty-state">
        Upload PDFs to inspect file count, exact duplicates, combined size, and local OCR readiness.
      </div>
      <div id="crm-pdf-preflight-result" hidden>
        <div class="crm-preflight-metrics">
          <div><span>PDF files</span><strong id="crm-pdf-preflight-count">—</strong></div>
          <div><span>Combined size</span><strong id="crm-pdf-preflight-size">—</strong></div>
          <div><span>Exact duplicates</span><strong id="crm-pdf-preflight-duplicates">—</strong></div>
          <div><span>OCR tools</span><strong id="crm-pdf-preflight-ocr">—</strong></div>
        </div>
        <div id="crm-pdf-preflight-messages" class="crm-preflight-messages"></div>
      </div>
    </article>
  </section>

  <section class="crm-job-section" id="crm-pdf-job-section" hidden>
    <div class="section-title-row">
      <div><p class="eyebrow">Processing activity</p><h2 id="crm-pdf-job-title">CRM PDF filter run</h2></div>
      <span class="status-chip inactive" id="crm-pdf-job-status">Loading</span>
    </div>
    <div class="crm-result-grid crm-result-grid-seven">
      <article class="master-card crm-result-card"><span>Fresh</span><strong data-pdf-count="fresh">—</strong></article>
      <article class="master-card crm-result-card"><span>Uploaded / Pending</span><strong data-pdf-count="uploaded_pending">—</strong></article>
      <article class="master-card crm-result-card"><span>Not Relevant</span><strong data-pdf-count="uploaded_not_relevant">—</strong></article>
      <article class="master-card crm-result-card"><span>Submitted</span><strong data-pdf-count="submitted">—</strong></article>
      <article class="master-card crm-result-card duplicate"><span>Duplicate in Batch</span><strong data-pdf-count="duplicate_in_batch">—</strong></article>
      <article class="master-card crm-result-card review"><span>Manual Review</span><strong data-pdf-count="manual_review">—</strong></article>
      <article class="master-card crm-result-card error"><span>OCR Failed</span><strong data-pdf-count="ocr_failed">—</strong></article>
    </div>
    <div class="crm-job-grid">
      <article class="master-card crm-log-card">
        <div class="panel-heading compact"><div><p class="eyebrow">Live worker log</p><h2>Activity</h2></div></div>
        <pre id="crm-pdf-job-log">Waiting for worker output…</pre>
      </article>
      <article class="master-card crm-artifact-card">
        <div class="panel-heading compact"><div><p class="eyebrow">Generated files</p><h2>Downloads</h2></div></div>
        <div id="crm-pdf-artifacts" class="crm-artifacts"><p class="empty-state">Files will appear after processing.</p></div>
      </article>
    </div>
  </section>

  <section class="crm-history">
    <div class="section-title-row"><div><p class="eyebrow">Source history</p><h2>CRM PDF batch intake</h2></div></div>
    <div class="toolbar directory-toolbar">
      <input class="input input-bordered input-sm search-input" id="crm-pdf-search" placeholder="Search batch name or checksum…" />
      <select class="select select-bordered select-sm" id="crm-pdf-validation-status">
        <option value="">All validation states</option>
        <option value="valid">Valid</option>
        <option value="invalid">Invalid</option>
      </select>
      <span class="toolbar-status" id="crm-pdf-total">Loading…</span>
    </div>
    <article class="master-card"><DataTable id="crm-pdf-batches-table" pageSize={10} emptyText="No CRM PDF batches have been uploaded." /></article>
  </section>

  <script>
    import { actions } from "astro:actions";
    import { actionButtons, badge, stack } from "../../../scripts/table-cells";
    import { closeAlert, confirmAction, showError, showLoading, showSuccess } from "../../../scripts/alerts";

    const API = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
    const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const table = el("crm-pdf-batches-table") as any;
    const fileInput = el<HTMLInputElement>("crm-pdf-files");
    const selectedJobId = new URLSearchParams(window.location.search).get("job_id");
    let hasActiveJobs = false;
    let tablePollTimer: number | undefined;
    let jobPollTimer: number | undefined;

    function bytes(value: number) {
      if (!Number.isFinite(value)) return "—";
      if (value < 1024) return `${value} B`;
      if (value < 1024 * 1024) return `${(value / 1024).toFixed(1)} KB`;
      return `${(value / 1024 / 1024).toFixed(1)} MB`;
    }

    function selectedFiles(): File[] {
      return Array.from(fileInput.files || []).filter((file) => file.name.toLowerCase().endsWith(".pdf"));
    }

    async function apiJson(path: string) {
      const response = await fetch(`${API}${path}`);
      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        const detail = typeof data.detail === "object" ? data.detail?.message : data.detail;
        throw new Error(detail || response.statusText || "Request failed");
      }
      return data;
    }

    function updateSelectedFiles() {
      const files = selectedFiles();
      const total = files.reduce((sum, file) => sum + file.size, 0);
      el("crm-pdf-upload-title").textContent = files.length
        ? `${files.length} PDF${files.length === 1 ? "" : "s"} selected`
        : "Choose or drop complaint PDFs";
      el("crm-pdf-upload-detail").textContent = files.length
        ? `${bytes(total)} combined · ready for validation`
        : "Multiple PDF files are supported";
    }

    function showPreflight(source: any) {
      const meta = source.detected_metadata || {};
      const tools = meta.ocr_tools || {};
      const readyTools = [tools.pdftotext, tools.pdftoppm, tools.tesseract].filter(Boolean).length;
      el("crm-pdf-preflight-empty").hidden = true;
      el("crm-pdf-preflight-result").hidden = false;
      el("crm-pdf-preflight-count").textContent = String(meta.file_count ?? "—");
      el("crm-pdf-preflight-size").textContent = bytes(Number(meta.total_uncompressed_bytes || 0));
      el("crm-pdf-preflight-duplicates").textContent = String(meta.duplicate_file_count ?? 0);
      el("crm-pdf-preflight-ocr").textContent = `${readyTools}/3 ready`;
      const messages = el("crm-pdf-preflight-messages");
      messages.replaceChildren();
      const entries: Array<[string, string]> = [
        ...(source.validation_errors || []).map((message: string) => ["error", message] as [string, string]),
        ...(source.validation_warnings || []).map((message: string) => ["warning", message] as [string, string]),
      ];
      if (!entries.length) entries.push(["valid", "The PDF batch is valid and ready for Paperless duplicate filtering."]);
      for (const [tone, message] of entries) {
        const row = document.createElement("p");
        row.className = `crm-preflight-message ${tone}`;
        row.textContent = message;
        messages.append(row);
      }
    }

    async function loadOverview() {
      const result = await actions.crm.overview();
      if (result.error) return;
      const overview = result.data as any;
      const status = el("paperless-status");
      status.textContent = overview.paperless.configured ? "Paperless configured" : "Paperless setup required";
      status.className = `status-chip ${overview.paperless.configured ? "" : "error"}`;
      const verification = overview.paperless.ca_bundle
        ? `Custom CA: ${overview.paperless.ca_bundle}`
        : overview.paperless.verify_ssl
          ? "TLS verification enabled"
          : "TLS verification disabled";
      status.title = `${overview.paperless.url || "PAPERLESS_URL is not configured"} · ${verification}`;
    }

    async function loadPage(pageIndex: number, pageSize: number) {
      const result = await actions.crm.pdfBatches({
        search: el<HTMLInputElement>("crm-pdf-search").value,
        status: el<HTMLSelectElement>("crm-pdf-validation-status").value,
        page: pageIndex + 1,
        pageSize,
      });
      if (result.error) throw result.error;
      const data = result.data as any;
      hasActiveJobs = data.items.some((item: any) => ["queued", "running"].includes(item.latest_job?.status));
      el("crm-pdf-total").textContent = `${data.total} batches`;
      return { rows: data.items, total: data.total };
    }

    function configuredPaperlessLimit(): number | undefined {
      const raw = el<HTMLInputElement>("crm-pdf-limit").value.trim();
      if (!raw) return undefined;
      const parsed = Number(raw);
      return Number.isInteger(parsed) && parsed > 0 ? parsed : undefined;
    }

    async function processSource(source: any) {
      if (source.latest_job && !await confirmAction(
        "Reprocess this immutable CRM PDF batch?",
        "A new extraction and Paperless comparison run will be created. The uploaded batch remains unchanged.",
        "Reprocess",
      )) return;
      showLoading("Queueing CRM PDF filter", "The batch will be processed by the crm worker.");
      const result = await actions.crm.processPdfBatch({ id: source.id, paperlessLimit: configuredPaperlessLimit() });
      if (result.error) { closeAlert(); await showError(result.error); return; }
      closeAlert();
      const job = result.data as any;
      window.location.href = `/crm/pdfs/?job_id=${job.id}`;
    }

    async function hardDeleteSource(source: any) {
      if (!await confirmAction(
        "Permanently delete this CRM PDF batch?",
        "The immutable ZIP, all processing attempts, logs, categorized PDFs, and generated reports will be removed. This cannot be undone.",
        "Delete permanently",
      )) return;
      const result = await actions.crm.hardDeletePdfBatch({ id: source.id });
      if (result.error) { await showError(result.error); return; }
      await showSuccess("CRM PDF batch deleted", "The source batch and its managed outputs were removed.");
      await table.refresh(true);
    }

    function statusTone(status: string) {
      if (status === "succeeded") return "";
      if (status === "failed") return "error";
      if (["queued", "running"].includes(status)) return "warning";
      return "inactive";
    }

    async function loadJob(jobId: string) {
      el("crm-pdf-job-section").hidden = false;
      try {
        const [job, logs, artifacts] = await Promise.all([
          apiJson(`/api/v1/jobs/${jobId}`),
          apiJson(`/api/v1/jobs/${jobId}/logs`),
          apiJson(`/api/v1/jobs/${jobId}/artifacts`),
        ]);
        el("crm-pdf-job-title").textContent = job.title;
        const status = el("crm-pdf-job-status");
        status.textContent = job.status;
        status.className = `status-chip ${statusTone(job.status)}`;
        const counts = job.result?.counts || {};
        document.querySelectorAll<HTMLElement>("[data-pdf-count]").forEach((node) => {
          node.textContent = String(counts[node.dataset.pdfCount || ""] ?? "—");
        });
        el("crm-pdf-job-log").textContent = logs.length
          ? logs.map((entry: any) => `[${new Date(entry.created_at).toLocaleTimeString()}] ${entry.message}`).join("\n")
          : "Waiting for worker output…";
        const artifactBox = el("crm-pdf-artifacts");
        artifactBox.replaceChildren();
        if (!artifacts.length) {
          const empty = document.createElement("p");
          empty.className = "empty-state";
          empty.textContent = job.status === "failed" ? (job.error || "The job failed before generating files.") : "Files will appear after processing.";
          artifactBox.append(empty);
        } else {
          for (const artifact of artifacts) {
            const link = document.createElement("a");
            link.className = `crm-artifact-link ${artifact.kind}`;
            link.href = `${API}/api/v1/artifacts/${artifact.id}/download`;
            link.target = "_blank";
            const title = document.createElement("strong");
            title.textContent = artifact.name;
            const detail = document.createElement("small");
            detail.textContent = `${artifact.kind} · ${bytes(artifact.size_bytes)}`;
            link.append(title, detail);
            artifactBox.append(link);
          }
        }
        if (["queued", "running"].includes(job.status)) {
          jobPollTimer = window.setTimeout(() => void loadJob(jobId), 2500);
        }
      } catch (error) {
        await showError(error);
      }
    }

    await customElements.whenDefined("astro-data-table");
    try {
      await table.configure({
        manualPagination: true,
        loadPage,
        columns: [
          { accessorKey: "original_name", header: "Batch", enableSorting: false, cell: ({ row }: any) => stack(row.original.original_name, `${bytes(row.original.size_bytes)} · ${row.original.sha256.slice(0, 12)}…`) },
          { id: "detected", header: "Detected", enableSorting: false, cell: ({ row }: any) => stack(`${row.original.detected_metadata?.file_count ?? 0} PDFs`, `${row.original.detected_metadata?.duplicate_file_count ?? 0} exact duplicates`) },
          { accessorKey: "validation_status", header: "Validation", enableSorting: false, cell: ({ row }: any) => badge(row.original.validation_status, row.original.validation_status === "valid" ? "" : "error") },
          { id: "processing", header: "Latest run", enableSorting: false, cell: ({ row }: any) => row.original.latest_job ? stack(row.original.latest_job.status, new Date(row.original.latest_job.created_at).toLocaleString()) : badge("Not processed", "inactive") },
          { accessorKey: "created_at", header: "Uploaded", enableSorting: false, cell: ({ row }: any) => new Date(row.original.created_at).toLocaleString() },
          { id: "actions", header: "", enableSorting: false, cell: ({ row }: any) => actionButtons([
            { label: "Source ZIP", onClick: () => window.open(`${API}/api/v1/crm/pdf-batches/${row.original.id}/download`, "_blank") },
            ...(row.original.latest_job ? [{ label: "Activity", onClick: () => { window.location.href = `/crm/pdfs/?job_id=${row.original.latest_job.id}`; } }] : []),
            ...(row.original.validation_status === "valid" && !["queued", "running"].includes(row.original.latest_job?.status)
              ? [{ label: row.original.latest_job ? "Reprocess" : "Filter", onClick: () => void processSource(row.original) }]
              : []),
            ...(!["queued", "running"].includes(row.original.latest_job?.status)
              ? [{ label: "Delete permanently", tone: "danger", onClick: () => void hardDeleteSource(row.original) }]
              : []),
          ]) },
        ],
      });
    } catch (error) { await showError(error); }

    fileInput.addEventListener("change", updateSelectedFiles);
    const drop = el("crm-pdf-upload-drop");
    for (const eventName of ["dragenter", "dragover"]) drop.addEventListener(eventName, (event) => { event.preventDefault(); drop.classList.add("dragging"); });
    for (const eventName of ["dragleave", "drop"]) drop.addEventListener(eventName, (event) => { event.preventDefault(); drop.classList.remove("dragging"); });
    drop.addEventListener("drop", (event) => {
      const files = Array.from((event as DragEvent).dataTransfer?.files || []).filter((file) => file.name.toLowerCase().endsWith(".pdf"));
      if (!files.length) return;
      const transfer = new DataTransfer();
      for (const file of files) transfer.items.add(file);
      fileInput.files = transfer.files;
      updateSelectedFiles();
    });

    el<HTMLFormElement>("crm-pdf-upload-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      const files = selectedFiles();
      if (!files.length) return;
      const button = el<HTMLButtonElement>("crm-pdf-upload-button");
      button.disabled = true;
      showLoading("Validating CRM PDFs", "Uploading an immutable batch and checking file integrity and OCR readiness.");
      try {
        const body = new FormData();
        for (const file of files) body.append("files", file);
        const label = el<HTMLInputElement>("crm-pdf-label").value.trim();
        if (label) body.append("label", label);
        const response = await fetch(`${API}/api/v1/crm/pdf-batches/uploads`, { method: "POST", body });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          const detail = typeof data.detail === "object" ? (data.detail.message || (data.detail.errors || []).join(" ")) : data.detail;
          throw new Error(detail || "The CRM PDF batch could not be uploaded.");
        }
        showPreflight(data);
        await table.refresh(true);
        if (data.validation_status !== "valid") {
          closeAlert();
          await showError(new Error((data.validation_errors || []).join(" ") || "The CRM PDF batch is invalid."));
          return;
        }
        const queued = await actions.crm.processPdfBatch({ id: data.id, paperlessLimit: configuredPaperlessLimit() });
        if (queued.error) throw queued.error;
        closeAlert();
        const job = queued.data as any;
        window.location.href = `/crm/pdfs/?job_id=${job.id}`;
      } catch (error) {
        closeAlert();
        await showError(error);
      } finally {
        button.disabled = false;
      }
    });

    el("crm-pdf-search").addEventListener("input", () => void table.refresh(true));
    el("crm-pdf-validation-status").addEventListener("change", () => void table.refresh(true));
    el("refresh-crm-pdfs").addEventListener("click", () => {
      void table.refresh(false);
      void loadOverview();
      if (selectedJobId) void loadJob(selectedJobId);
    });

    async function pollTableWhileActive() {
      if (!hasActiveJobs) return;
      await table.refresh(false);
      if (hasActiveJobs) tablePollTimer = window.setTimeout(() => void pollTableWhileActive(), 4000);
    }

    await loadOverview();
    if (selectedJobId) await loadJob(selectedJobId);
    if (hasActiveJobs) tablePollTimer = window.setTimeout(() => void pollTableWhileActive(), 4000);
    window.addEventListener("beforeunload", () => {
      window.clearTimeout(tablePollTimer);
      window.clearTimeout(jobPollTimer);
    });
  </script>
</CrmLayout>
