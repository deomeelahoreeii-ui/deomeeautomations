---
import CrmLayout from "../../../layouts/CrmLayout.astro";
import DataTable from "../../../components/DataTable.astro";
import CheckboxField from "../../../components/ui/CheckboxField.astro";
import ModalDialog from "../../../components/ui/ModalDialog.astro";
import StatusBadge from "../../../components/ui/StatusBadge.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---

<CrmLayout
  title="Complaint Taxonomy"
  description="Manage the authoritative category and subcategory structure used by complaints, Helpdesk and AI exports."
  page="taxonomy"
>
  <a class="btn btn-sm" href="/crm/replies/" slot="actions">Open Reply Workspace</a>

  <main id="taxonomy-root" data-api-base={apiBase} class="crm32-page taxonomy-page">
    <section class="crm-metric-grid taxonomy-summary" aria-label="Taxonomy summary">
      <article class="crm-metric-card"><span>Categories</span><strong id="metric-categories">—</strong><small id="metric-active-categories">— active</small></article>
      <article class="crm-metric-card"><span>Subcategories</span><strong id="metric-subcategories">—</strong><small id="metric-active-subcategories">— active</small></article>
      <article class="crm-metric-card"><span>Classified complaints</span><strong id="metric-classified">—</strong><small id="metric-unclassified">— unclassified</small></article>
      <article class="crm-metric-card"><span>Helpdesk sync</span><strong id="metric-synced">—</strong><small id="metric-sync-errors">— errors</small></article>
    </section>

    <section class="master-card crm-page-toolbar taxonomy-toolbar">
      <div class="crm-page-toolbar-copy">
        <p class="eyebrow">Authoritative classification</p>
        <h2>Categories and subcategories</h2>
        <p>PostgreSQL remains authoritative. Category names are mirrored to Frappe Ticket Types, then linked complaints are verified after synchronization.</p>
      </div>
      <div class="crm-page-toolbar-actions taxonomy-toolbar-actions">
        <label class="crm-field crm-search-field" for="taxonomy-search">
          <span class="sr-only">Search taxonomy</span>
          <input id="taxonomy-search" class="input input-bordered" placeholder="Search names, guidance or policy…" />
        </label>
        <CheckboxField id="show-inactive" label="Show inactive" checked compact />
        <button id="refresh-taxonomy" class="btn btn-sm" type="button">↻ Refresh</button>
        <button id="new-category" class="btn btn-primary" type="button">+ New category</button>
      </div>
    </section>

    <section class="taxonomy-workspace">
      <aside class="master-card taxonomy-tree-card" aria-label="Complaint categories">
        <header class="crm-card-heading taxonomy-tree-heading">
          <div>
            <p class="eyebrow">Categories</p>
            <h2>Classification tree</h2>
            <p>Choose a category to manage its guidance and controlled options.</p>
          </div>
          <span id="category-visible-count" class="crm-count-badge">0</span>
        </header>
        <div id="category-list" class="taxonomy-tree-list" aria-live="polite">
          <div class="crm-empty-state">Loading taxonomy…</div>
        </div>
      </aside>

      <section class="master-card taxonomy-detail-card" aria-live="polite">
        <div id="category-empty" class="crm-empty-state taxonomy-detail-empty">
          <span class="crm-empty-icon" aria-hidden="true">◇</span>
          <h2>Select a category</h2>
          <p>Choose a category from the classification tree to manage details, subcategories, guidance and Helpdesk synchronization.</p>
        </div>

        <div id="category-detail" hidden>
          <header class="taxonomy-detail-header">
            <div class="taxonomy-detail-copy">
              <div class="taxonomy-title-line">
                <h2 id="detail-name">—</h2>
                <StatusBadge id="detail-status" label="—" />
              </div>
              <p id="detail-description">—</p>
              <div id="detail-meta" class="crm-chip-row"></div>
            </div>
            <div class="taxonomy-detail-actions">
              <button id="edit-category" class="btn btn-primary btn-sm" type="button">Edit category</button>
              <details id="category-action-menu" class="crm-action-menu">
                <summary class="btn btn-sm">More actions</summary>
                <div class="crm-action-menu-popover">
                  <button id="sync-category" type="button">Sync to Helpdesk</button>
                  <button id="toggle-category" type="button">Deactivate</button>
                  <button id="merge-category" type="button">Merge category</button>
                </div>
              </details>
            </div>
          </header>

          <div class="taxonomy-guidance-grid">
            <article>
              <span>Reply guidance</span>
              <p id="detail-guidance">No category-level reply guidance.</p>
            </article>
            <article>
              <span>Policy notes</span>
              <p id="detail-policy">No category-level policy notes.</p>
            </article>
          </div>

          <section class="taxonomy-subcategory-section">
            <header class="crm-card-heading taxonomy-subcategory-heading">
              <div>
                <p class="eyebrow">Controlled options</p>
                <h3>Subcategories</h3>
                <p>Complaint count, order, status and actions are separated into predictable columns.</p>
              </div>
              <button id="new-subcategory" class="btn btn-primary btn-sm" type="button">+ New subcategory</button>
            </header>
            <DataTable
              id="subcategory-table"
              pageSize={10}
              pageSizeOptions={[10, 25, 50]}
              emptyText="No subcategories yet. Create the first controlled option for this category."
              ariaLabel="Subcategories"
              class="taxonomy-subcategory-table"
            />
          </section>
        </div>
      </section>
    </section>

    <details class="master-card crm-audit-panel taxonomy-audit">
      <summary>
        <span><b>Recent taxonomy activity</b><small>Creates, edits, merges, activation changes and synchronization outcomes</small></span>
        <span aria-hidden="true">⌄</span>
      </summary>
      <div id="taxonomy-audit-list" class="crm-audit-list"><div class="crm-empty-state compact">Open to load recent activity.</div></div>
    </details>

    <div id="taxonomy-toast" class="crm-toast" role="status" aria-live="polite" hidden></div>
  </main>

  <ModalDialog
    id="category-dialog"
    formId="category-form"
    title="New category"
    eyebrow="Complaint taxonomy"
    description="Define the category identity, reusable reply knowledge and synchronization behaviour."
    size="lg"
  >
    <input id="category-id" type="hidden" />
    <section class="crm-form-section">
      <div class="crm-form-section-heading"><h3>Identity</h3><p>Name, description and display order used across CRM and Helpdesk.</p></div>
      <div class="crm-form-grid two-columns">
        <label class="crm-field wide" for="category-name"><span>Category name</span><input id="category-name" class="input input-bordered" maxlength="140" required /></label>
        <label class="crm-field" for="category-description"><span>Description</span><textarea id="category-description" class="textarea textarea-bordered" rows="4"></textarea></label>
        <label class="crm-field" for="category-order"><span>Display order</span><input id="category-order" class="input input-bordered" type="number" min="0" max="100000" value="100" /></label>
      </div>
    </section>

    <section class="crm-form-section">
      <div class="crm-form-section-heading"><h3>Reply knowledge</h3><p>Reusable instructions shown to staff while preparing replies.</p></div>
      <div class="crm-form-grid two-columns">
        <label class="crm-field" for="category-guidance"><span>Reply guidance</span><textarea id="category-guidance" class="textarea textarea-bordered" rows="6" placeholder="Reusable instructions for drafting replies in this category"></textarea></label>
        <label class="crm-field" for="category-policy"><span>Policy notes</span><textarea id="category-policy" class="textarea textarea-bordered" rows="6" placeholder="Rules, circulars, constraints and safe wording"></textarea></label>
      </div>
    </section>

    <section class="crm-form-section">
      <div class="crm-form-section-heading"><h3>Behaviour</h3><p>Control availability, AI eligibility and immediate synchronization.</p></div>
      <div class="crm-setting-grid">
        <CheckboxField id="category-active" label="Active" description="Available for new and updated complaint classifications." checked />
        <CheckboxField id="category-ai" label="AI eligible by default after approval" description="Approved replies can enter the AI archive unless staff opt out." />
        <CheckboxField id="category-sync-cases" label="Synchronize affected linked complaints to Helpdesk now" description="Write and verify the category on linked Helpdesk tickets immediately." checked wide />
      </div>
    </section>

    <Fragment slot="footer">
      <button class="btn" type="button" data-dialog-close>Cancel</button>
      <button id="save-category" class="btn btn-primary" type="submit">Save category</button>
    </Fragment>
  </ModalDialog>

  <ModalDialog
    id="subcategory-dialog"
    formId="subcategory-form"
    title="New subcategory"
    eyebrow="Controlled option"
    description="Add a precise controlled option under an active parent category."
    size="lg"
  >
    <input id="subcategory-id" type="hidden" />
    <section class="crm-form-section">
      <div class="crm-form-section-heading"><h3>Identity</h3><p>Parent category, name, description and display order.</p></div>
      <div class="crm-form-grid two-columns">
        <label class="crm-field wide" for="subcategory-category"><span>Parent category</span><select id="subcategory-category" class="select select-bordered" required></select></label>
        <label class="crm-field wide" for="subcategory-name"><span>Subcategory name</span><input id="subcategory-name" class="input input-bordered" maxlength="140" required /></label>
        <label class="crm-field" for="subcategory-description"><span>Description</span><textarea id="subcategory-description" class="textarea textarea-bordered" rows="4"></textarea></label>
        <label class="crm-field" for="subcategory-order"><span>Display order</span><input id="subcategory-order" class="input input-bordered" type="number" min="0" max="100000" value="100" /></label>
      </div>
    </section>

    <section class="crm-form-section">
      <div class="crm-form-section-heading"><h3>Reply knowledge</h3><p>Optional wording that supplements the parent category guidance.</p></div>
      <div class="crm-form-grid two-columns">
        <label class="crm-field" for="subcategory-guidance"><span>Reply guidance</span><textarea id="subcategory-guidance" class="textarea textarea-bordered" rows="6"></textarea></label>
        <label class="crm-field" for="subcategory-policy"><span>Policy notes</span><textarea id="subcategory-policy" class="textarea textarea-bordered" rows="6"></textarea></label>
      </div>
    </section>

    <section class="crm-form-section">
      <div class="crm-form-section-heading"><h3>Behaviour</h3><p>Control availability and linked-ticket synchronization.</p></div>
      <div class="crm-setting-grid">
        <CheckboxField id="subcategory-active" label="Active" description="Available under the selected parent category." checked />
        <CheckboxField id="subcategory-sync-cases" label="Synchronize affected linked complaints to Helpdesk now" description="Write and verify the new classification immediately." checked wide />
      </div>
    </section>

    <Fragment slot="footer">
      <button class="btn" type="button" data-dialog-close>Cancel</button>
      <button id="save-subcategory" class="btn btn-primary" type="submit">Save subcategory</button>
    </Fragment>
  </ModalDialog>

  <ModalDialog
    id="merge-dialog"
    formId="merge-form"
    title="Merge category"
    eyebrow="Safe consolidation"
    description="Move complaint references to another active record while preserving the source in audit history."
    size="sm"
  >
    <input id="merge-source-id" type="hidden" />
    <input id="merge-kind" type="hidden" />
    <p id="merge-explanation" class="crm-warning-box"></p>
    <label class="crm-field" for="merge-target"><span>Merge into</span><select id="merge-target" class="select select-bordered" required></select></label>
    <CheckboxField id="merge-sync-cases" label="Synchronize affected linked complaints to Helpdesk now" checked />

    <Fragment slot="footer">
      <button class="btn" type="button" data-dialog-close>Cancel</button>
      <button id="confirm-merge" class="btn btn-primary" type="submit">Merge records</button>
    </Fragment>
  </ModalDialog>

  <script>
    import { confirmAction } from "../../../scripts/alerts";
    import { closeDialog, openDialog, setDialogBusy, wireDialogs } from "../../../scripts/dialogs";
    import { badge, stack } from "../../../scripts/table-cells";

    type Subcategory = {
      id: string;
      category_id: string;
      name: string;
      description: string;
      display_order: number;
      active: boolean;
      reply_guidance: string;
      policy_notes: string;
      complaint_count: number;
      merged_into_id?: string | null;
    };
    type Category = {
      id: string;
      name: string;
      description: string;
      display_order: number;
      active: boolean;
      default_ai_eligible: boolean;
      reply_guidance: string;
      policy_notes: string;
      frappe_sync_status: string;
      frappe_last_error?: string;
      complaint_count: number;
      merged_into_id?: string | null;
      subcategories: Subcategory[];
    };

    const root = document.getElementById("taxonomy-root") as HTMLElement;
    const API = root.dataset.apiBase || "";
    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const esc = (value: unknown) => String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
    const subcategoryTable = $("subcategory-table") as any;
    let categories: Category[] = [];
    let selectedId = "";
    let auditLoaded = false;

    async function api(path: string, init?: RequestInit) {
      const response = await fetch(`${API}${path}`, {
        ...init,
        headers: { "Content-Type": "application/json", ...(init?.headers || {}) },
      });
      const body = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(typeof body.detail === "string" ? body.detail : body.detail?.message || response.statusText);
      return body;
    }

    function toast(message: string, error = false) {
      const node = $("taxonomy-toast");
      node.textContent = message;
      node.className = `crm-toast${error ? " error" : ""}`;
      node.hidden = false;
      window.setTimeout(() => node.hidden = true, 4500);
    }

    function selected() {
      return categories.find((item) => item.id === selectedId) || null;
    }

    function activeCategories() {
      return categories.filter((item) => item.active && !item.merged_into_id);
    }

    function statusTone(value: string) {
      if (["synchronized", "active"].includes(value)) return "success";
      if (["failed", "inactive"].includes(value)) return "danger";
      if (["pending", "not_synced"].includes(value)) return "warning";
      return "neutral";
    }

    function filteredCategories() {
      const term = ($("taxonomy-search") as HTMLInputElement).value.trim().toLowerCase();
      const showInactive = ($("show-inactive") as HTMLInputElement).checked;
      return categories.filter((category) => {
        if (!showInactive && (!category.active || category.merged_into_id)) return false;
        if (!term) return true;
        return [
          category.name,
          category.description,
          category.reply_guidance,
          category.policy_notes,
          ...category.subcategories.flatMap((item) => [item.name, item.description, item.reply_guidance, item.policy_notes]),
        ].join(" ").toLowerCase().includes(term);
      });
    }

    function renderMetrics(stats: any) {
      $("metric-categories").textContent = String(stats.categories ?? 0);
      $("metric-active-categories").textContent = `${stats.active_categories ?? 0} active`;
      $("metric-subcategories").textContent = String(stats.subcategories ?? 0);
      $("metric-active-subcategories").textContent = `${stats.active_subcategories ?? 0} active`;
      $("metric-classified").textContent = String(stats.classified_cases ?? 0);
      $("metric-unclassified").textContent = `${stats.unclassified_cases ?? 0} unclassified`;
      const sync = stats.sync_statuses || {};
      $("metric-synced").textContent = String(sync.synchronized ?? 0);
      $("metric-sync-errors").textContent = `${sync.failed ?? 0} errors`;
    }

    function renderCategories() {
      const items = filteredCategories();
      $("category-visible-count").textContent = String(items.length);
      $("category-list").innerHTML = items.length
        ? items.map((category) => {
          const inactive = !category.active || Boolean(category.merged_into_id);
          const label = category.merged_into_id ? "Merged" : category.active ? "Active" : "Inactive";
          return `<button type="button" class="taxonomy-tree-item ${category.id === selectedId ? "active" : ""} ${inactive ? "inactive" : ""}" data-category-id="${category.id}">
            <span class="taxonomy-tree-copy">
              <strong>${esc(category.name)}</strong>
              <span>${category.subcategories.length} subcategories · ${category.complaint_count} complaints</span>
            </span>
            <span class="taxonomy-tree-state">
              <span class="crm-status-badge ${statusTone(inactive ? "inactive" : category.frappe_sync_status)}">${esc(label)}</span>
              ${category.frappe_sync_status === "failed" ? '<span class="taxonomy-sync-warning">Sync issue</span>' : ""}
            </span>
          </button>`;
        }).join("")
        : '<div class="crm-empty-state compact">No categories match the current filters.</div>';
      document.querySelectorAll<HTMLElement>("[data-category-id]").forEach((button) => button.addEventListener("click", () => {
        selectedId = button.dataset.categoryId || "";
        renderCategories();
        renderDetail();
      }));
    }

    function rowActionMenu(item: Subcategory): HTMLElement {
      const container = document.createElement("div");
      container.className = "taxonomy-row-actions";
      const edit = document.createElement("button");
      edit.type = "button";
      edit.className = "table-action";
      edit.textContent = "Edit";
      edit.disabled = Boolean(item.merged_into_id);
      edit.addEventListener("click", () => openSubcategory(item.id));
      container.append(edit);

      const details = document.createElement("details");
      details.className = "crm-inline-menu";
      const summary = document.createElement("summary");
      summary.className = "table-action";
      summary.textContent = "More";
      const menu = document.createElement("div");
      menu.className = "crm-inline-menu-popover";

      const toggle = document.createElement("button");
      toggle.type = "button";
      toggle.textContent = item.active ? "Deactivate" : "Reactivate";
      toggle.disabled = Boolean(item.merged_into_id);
      toggle.addEventListener("click", () => void toggleSubcategory(item.id));

      const merge = document.createElement("button");
      merge.type = "button";
      merge.textContent = "Merge";
      merge.disabled = Boolean(item.merged_into_id || !item.active);
      merge.addEventListener("click", () => openMerge("subcategory", item.id));

      menu.append(toggle, merge);
      details.append(summary, menu);
      container.append(details);
      return container;
    }

    async function configureSubcategoryTable() {
      await subcategoryTable.configure({
        data: [],
        getRowId: (row: Subcategory) => row.id,
        rowClassName: (row: Subcategory) => !row.active || row.merged_into_id ? "is-inactive" : "",
        columns: [
          {
            accessorKey: "name",
            header: "Subcategory",
            enableSorting: true,
            meta: { minWidth: "250px" },
            cell: ({ row }: any) => stack(row.original.name, row.original.description || "No description"),
          },
          {
            accessorKey: "complaint_count",
            header: "Complaints",
            meta: { width: "100px", align: "right", className: "numeric-cell", headerClassName: "numeric-cell" },
          },
          {
            accessorKey: "display_order",
            header: "Order",
            meta: { width: "80px", align: "right", className: "numeric-cell", headerClassName: "numeric-cell" },
          },
          {
            id: "status",
            header: "Status",
            enableSorting: false,
            meta: { width: "115px" },
            cell: ({ row }: any) => badge(row.original.merged_into_id ? "Merged" : row.original.active ? "Active" : "Inactive", row.original.active && !row.original.merged_into_id ? "" : "inactive"),
          },
          {
            id: "actions",
            header: "",
            enableSorting: false,
            meta: { width: "130px", align: "right" },
            cell: ({ row }: any) => rowActionMenu(row.original),
          },
        ],
      });
    }

    function renderDetail() {
      const category = selected();
      $("category-empty").hidden = Boolean(category);
      $("category-detail").hidden = !category;
      if (!category) {
        void subcategoryTable.setData([]);
        return;
      }

      $("detail-name").textContent = category.name;
      const status = $("detail-status");
      const statusValue = category.active
        ? category.frappe_sync_status === "synchronized" ? "Synchronized" : category.frappe_sync_status || "Active"
        : "Inactive";
      status.textContent = statusValue;
      status.className = `crm-status-badge ${statusTone(category.active ? category.frappe_sync_status : "inactive")}`;
      $("detail-description").textContent = category.description || "No description provided.";
      $("detail-meta").innerHTML = `
        <span>Order ${category.display_order}</span>
        <span>${category.complaint_count} complaints</span>
        <span>${category.subcategories.length} subcategories</span>
        <span>AI default: ${category.default_ai_eligible ? "Yes" : "No"}</span>
        ${category.frappe_last_error ? `<span class="danger">Sync error: ${esc(category.frappe_last_error)}</span>` : ""}`;
      $("detail-guidance").textContent = category.reply_guidance || "No category-level reply guidance.";
      $("detail-policy").textContent = category.policy_notes || "No category-level policy notes.";

      $("toggle-category").textContent = category.active ? "Deactivate" : "Reactivate";
      ($("toggle-category") as HTMLButtonElement).disabled = Boolean(category.merged_into_id);
      ($("edit-category") as HTMLButtonElement).disabled = Boolean(category.merged_into_id);
      ($("merge-category") as HTMLButtonElement).disabled = Boolean(category.merged_into_id || !category.active);
      ($("new-subcategory") as HTMLButtonElement).disabled = !category.active || Boolean(category.merged_into_id);
      ($("sync-category") as HTMLButtonElement).disabled = Boolean(category.merged_into_id);

      const showInactive = ($("show-inactive") as HTMLInputElement).checked;
      const subcategories = category.subcategories.filter((item) => showInactive || item.active);
      void subcategoryTable.setData(subcategories);
    }

    function populateCategoryOptions(select: HTMLSelectElement, selectedValue = "") {
      select.innerHTML = activeCategories().map((item) => `<option value="${item.id}" ${item.id === selectedValue ? "selected" : ""}>${esc(item.name)}</option>`).join("");
    }

    async function load(preserve = true) {
      try {
        const data = await api("/api/v1/crm/taxonomy?include_inactive=true");
        categories = data.categories || [];
        renderMetrics(data.statistics || {});
        if (!preserve || !categories.some((item) => item.id === selectedId)) {
          selectedId = categories.find((item) => item.active && !item.merged_into_id)?.id || categories[0]?.id || "";
        }
        renderCategories();
        renderDetail();
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      }
    }

    function categoryPayload() {
      return {
        name: ($("category-name") as HTMLInputElement).value.trim(),
        description: ($("category-description") as HTMLTextAreaElement).value,
        display_order: Number(($("category-order") as HTMLInputElement).value || 100),
        active: ($("category-active") as HTMLInputElement).checked,
        default_ai_eligible: ($("category-ai") as HTMLInputElement).checked,
        reply_guidance: ($("category-guidance") as HTMLTextAreaElement).value,
        policy_notes: ($("category-policy") as HTMLTextAreaElement).value,
        synchronize_cases: ($("category-sync-cases") as HTMLInputElement).checked,
      };
    }

    function openCategory(id = "") {
      const category = categories.find((item) => item.id === id);
      $("category-dialog-title").textContent = category ? "Edit category" : "New category";
      ($("category-id") as HTMLInputElement).value = category?.id || "";
      ($("category-name") as HTMLInputElement).value = category?.name || "";
      ($("category-description") as HTMLTextAreaElement).value = category?.description || "";
      ($("category-order") as HTMLInputElement).value = String(category?.display_order ?? 100);
      ($("category-active") as HTMLInputElement).checked = category?.active ?? true;
      ($("category-ai") as HTMLInputElement).checked = category?.default_ai_eligible ?? false;
      ($("category-guidance") as HTMLTextAreaElement).value = category?.reply_guidance || "";
      ($("category-policy") as HTMLTextAreaElement).value = category?.policy_notes || "";
      ($("category-sync-cases") as HTMLInputElement).checked = true;
      openDialog("category-dialog");
    }

    async function saveCategory() {
      const button = $("save-category") as HTMLButtonElement;
      const id = ($("category-id") as HTMLInputElement).value;
      button.disabled = true;
      button.textContent = "Saving…";
      setDialogBusy("category-dialog", true);
      try {
        const result = await api(id ? `/api/v1/crm/taxonomy/categories/${id}` : "/api/v1/crm/taxonomy/categories", {
          method: id ? "PUT" : "POST",
          body: JSON.stringify(categoryPayload()),
        });
        selectedId = result.entity?.id || id;
        closeDialog("category-dialog", "saved");
        toast(`Category ${id ? "updated" : "created"}. ${result.frappe_category_sync?.status === "failed" ? "Helpdesk synchronization needs attention." : "Helpdesk synchronization checked."}`);
        await load();
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      } finally {
        setDialogBusy("category-dialog", false);
        button.disabled = false;
        button.textContent = "Save category";
      }
    }

    function findSubcategory(id: string) {
      for (const category of categories) {
        const item = category.subcategories.find((row) => row.id === id);
        if (item) return { category, item };
      }
      return null;
    }

    function openSubcategory(id = "") {
      const found = findSubcategory(id);
      const category = found?.category || selected();
      if (!category) return;
      $("subcategory-dialog-title").textContent = found ? "Edit subcategory" : "New subcategory";
      ($("subcategory-id") as HTMLInputElement).value = found?.item.id || "";
      populateCategoryOptions($("subcategory-category") as HTMLSelectElement, found?.item.category_id || category.id);
      ($("subcategory-name") as HTMLInputElement).value = found?.item.name || "";
      ($("subcategory-description") as HTMLTextAreaElement).value = found?.item.description || "";
      ($("subcategory-order") as HTMLInputElement).value = String(found?.item.display_order ?? 100);
      ($("subcategory-active") as HTMLInputElement).checked = found?.item.active ?? true;
      ($("subcategory-guidance") as HTMLTextAreaElement).value = found?.item.reply_guidance || "";
      ($("subcategory-policy") as HTMLTextAreaElement).value = found?.item.policy_notes || "";
      ($("subcategory-sync-cases") as HTMLInputElement).checked = true;
      openDialog("subcategory-dialog");
    }

    function subcategoryPayload() {
      return {
        category_id: ($("subcategory-category") as HTMLSelectElement).value,
        name: ($("subcategory-name") as HTMLInputElement).value.trim(),
        description: ($("subcategory-description") as HTMLTextAreaElement).value,
        display_order: Number(($("subcategory-order") as HTMLInputElement).value || 100),
        active: ($("subcategory-active") as HTMLInputElement).checked,
        reply_guidance: ($("subcategory-guidance") as HTMLTextAreaElement).value,
        policy_notes: ($("subcategory-policy") as HTMLTextAreaElement).value,
        synchronize_cases: ($("subcategory-sync-cases") as HTMLInputElement).checked,
      };
    }

    async function saveSubcategory() {
      const button = $("save-subcategory") as HTMLButtonElement;
      const id = ($("subcategory-id") as HTMLInputElement).value;
      button.disabled = true;
      button.textContent = "Saving…";
      setDialogBusy("subcategory-dialog", true);
      try {
        await api(id ? `/api/v1/crm/taxonomy/subcategories/${id}` : "/api/v1/crm/taxonomy/subcategories", {
          method: id ? "PUT" : "POST",
          body: JSON.stringify(subcategoryPayload()),
        });
        closeDialog("subcategory-dialog", "saved");
        toast(`Subcategory ${id ? "updated" : "created"}.`);
        await load();
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      } finally {
        setDialogBusy("subcategory-dialog", false);
        button.disabled = false;
        button.textContent = "Save subcategory";
      }
    }

    async function toggleCategory() {
      const category = selected();
      if (!category) return;
      const action = category.active ? "Deactivate" : "Reactivate";
      if (!await confirmAction(`${action} ${category.name}?`, "Complaint history is preserved. Linked complaints can be synchronized with the new state.", action)) return;
      try {
        await api(`/api/v1/crm/taxonomy/categories/${category.id}/active`, {
          method: "PATCH",
          body: JSON.stringify({ active: !category.active, synchronize_cases: true }),
        });
        toast(`Category ${category.active ? "deactivated" : "reactivated"}.`);
        await load();
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      }
    }

    async function toggleSubcategory(id: string) {
      const found = findSubcategory(id);
      if (!found) return;
      const action = found.item.active ? "Deactivate" : "Reactivate";
      if (!await confirmAction(`${action} ${found.item.name}?`, "Complaint history remains available and no record is hard-deleted.", action)) return;
      try {
        await api(`/api/v1/crm/taxonomy/subcategories/${id}/active`, {
          method: "PATCH",
          body: JSON.stringify({ active: !found.item.active, synchronize_cases: true }),
        });
        toast(`Subcategory ${found.item.active ? "deactivated" : "reactivated"}.`);
        await load();
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      }
    }

    async function syncCategory() {
      const category = selected();
      if (!category) return;
      const button = $("sync-category") as HTMLButtonElement;
      button.disabled = true;
      button.textContent = "Synchronizing…";
      try {
        const result = await api(`/api/v1/crm/taxonomy/categories/${category.id}/sync`, { method: "POST" });
        toast(result.status === "failed" ? result.error : `${category.name} synchronized with Helpdesk.`, result.status === "failed");
        await load();
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      } finally {
        button.disabled = false;
        button.textContent = "Sync to Helpdesk";
        ($("category-action-menu") as HTMLDetailsElement).open = false;
      }
    }

    function openMerge(kind: "category" | "subcategory", sourceId: string) {
      const category = selected();
      if (!category) return;
      ($("merge-kind") as HTMLInputElement).value = kind;
      ($("merge-source-id") as HTMLInputElement).value = sourceId;
      ($("merge-sync-cases") as HTMLInputElement).checked = true;
      const select = $("merge-target") as HTMLSelectElement;

      if (kind === "category") {
        const source = categories.find((item) => item.id === sourceId);
        $("merge-dialog-title").textContent = "Merge category";
        $("merge-explanation").textContent = `All complaints and compatible subcategories from “${source?.name}” will move to the selected active category. The source remains in audit history as inactive.`;
        select.innerHTML = activeCategories().filter((item) => item.id !== sourceId).map((item) => `<option value="${item.id}">${esc(item.name)}</option>`).join("");
      } else {
        const found = findSubcategory(sourceId);
        $("merge-dialog-title").textContent = "Merge subcategory";
        $("merge-explanation").textContent = `All complaints using “${found?.item.name}” will move to the selected active subcategory. Cross-category merging updates the parent category safely.`;
        select.innerHTML = categories.flatMap((item) => item.subcategories
          .filter((sub) => sub.active && !sub.merged_into_id && sub.id !== sourceId)
          .map((sub) => `<option value="${sub.id}">${esc(item.name)} → ${esc(sub.name)}</option>`)).join("");
      }

      if (!select.options.length) {
        toast("Create another active target before merging.", true);
        return;
      }
      ($("category-action-menu") as HTMLDetailsElement).open = false;
      openDialog("merge-dialog");
    }

    async function confirmMerge() {
      const kind = ($("merge-kind") as HTMLInputElement).value;
      const source = ($("merge-source-id") as HTMLInputElement).value;
      const target = ($("merge-target") as HTMLSelectElement).value;
      const button = $("confirm-merge") as HTMLButtonElement;
      if (!source || !target) return;
      button.disabled = true;
      button.textContent = "Merging…";
      setDialogBusy("merge-dialog", true);
      try {
        await api(`/api/v1/crm/taxonomy/${kind === "category" ? "categories" : "subcategories"}/${source}/merge`, {
          method: "POST",
          body: JSON.stringify({ target_id: target, synchronize_cases: ($("merge-sync-cases") as HTMLInputElement).checked }),
        });
        selectedId = kind === "category" ? target : selectedId;
        closeDialog("merge-dialog", "merged");
        toast("Merge completed and complaint references were preserved.");
        await load();
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      } finally {
        setDialogBusy("merge-dialog", false);
        button.disabled = false;
        button.textContent = "Merge records";
      }
    }

    async function loadAudit() {
      if (auditLoaded) return;
      auditLoaded = true;
      try {
        const data = await api("/api/v1/crm/taxonomy/audit?limit=100");
        $("taxonomy-audit-list").innerHTML = (data.items || []).map((item: any) => `<article class="crm-audit-row"><div><strong>${esc(item.event_type.replaceAll("_", " "))}</strong><small>${esc(item.entity_type)}</small></div><div><span>${esc(item.actor)}</span>${item.error ? `<small class="danger">${esc(item.error)}</small>` : ""}</div><small>${new Date(item.created_at).toLocaleString()}</small></article>`).join("") || '<div class="crm-empty-state compact">No taxonomy activity yet.</div>';
      } catch (error) {
        $("taxonomy-audit-list").innerHTML = `<div class="crm-empty-state compact">${esc(error instanceof Error ? error.message : String(error))}</div>`;
      }
    }

    wireDialogs();
    $("category-form").addEventListener("submit", (event) => { event.preventDefault(); void saveCategory(); });
    $("subcategory-form").addEventListener("submit", (event) => { event.preventDefault(); void saveSubcategory(); });
    $("merge-form").addEventListener("submit", (event) => { event.preventDefault(); void confirmMerge(); });
    $("new-category").addEventListener("click", () => openCategory());
    $("edit-category").addEventListener("click", () => openCategory(selectedId));
    $("new-subcategory").addEventListener("click", () => openSubcategory());
    $("refresh-taxonomy").addEventListener("click", () => void load());
    $("toggle-category").addEventListener("click", () => void toggleCategory());
    $("sync-category").addEventListener("click", () => void syncCategory());
    $("merge-category").addEventListener("click", () => openMerge("category", selectedId));
    $("taxonomy-search").addEventListener("input", () => { renderCategories(); renderDetail(); });
    $("show-inactive").addEventListener("change", () => { renderCategories(); renderDetail(); });
    document.querySelector(".taxonomy-audit")?.addEventListener("toggle", (event) => {
      if ((event.currentTarget as HTMLDetailsElement).open) void loadAudit();
    });

    void (async () => {
      await configureSubcategoryTable();
      await load(false);
    })();
  </script>
</CrmLayout>
