---
import CrmLayout from "../../../../../layouts/CrmLayout.astro";
import DataTable from "../../../../../components/DataTable.astro";
import ModalDialog from "../../../../../components/ui/ModalDialog.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
const batchId = Astro.params.id || "";
---
<CrmLayout title="Bulk Batch Details" description="Inspect batch lineage, complaint-level outcomes, validation errors and downloadable artifacts." page="replies">
  <a class="btn btn-sm" href="/crm/replies/bulk/batches/" slot="actions">← All Batches</a>
  <a class="btn btn-sm" href="/crm/replies/bulk/" slot="actions">Bulk Operations</a>
  <main id="batch-detail-page" data-api-base={apiBase} data-batch-id={batchId} class="crm32-page bulk-batch-detail-page">
    <nav class="reply-mode-tabs" aria-label="Reply workspace modes"><a href="/crm/replies/">Reply Queue</a><a class="active" href="/crm/replies/bulk/">Bulk Operations</a></nav>
    <section class="master-card batch-detail-header">
      <div><p class="eyebrow" id="batch-operation-label">Bulk operation</p><h2 id="batch-number">Loading batch…</h2><p id="batch-description">Please wait while the batch record is loaded.</p></div>
      <div class="batch-detail-actions"><button id="retry-batch" class="btn" type="button" hidden>Retry failed letters</button><button id="cancel-batch" class="btn btn-error" type="button" hidden>Cancel batch</button></div>
    </section>
    <section class="batch-detail-metrics">
      <article class="crm-metric-card"><span>Status</span><strong id="batch-status">—</strong><small id="batch-created">—</small></article>
      <article class="crm-metric-card"><span>Total items</span><strong id="batch-total">—</strong><small id="batch-valid">— valid</small></article>
      <article class="crm-metric-card"><span>Successful</span><strong id="batch-success">—</strong><small id="batch-skipped">— skipped</small></article>
      <article class="crm-metric-card"><span>Failed</span><strong id="batch-failed">—</strong><small id="batch-duplicates">— duplicates</small></article>
    </section>
    <section class="batch-detail-grid">
      <article class="master-card batch-lineage-card"><p class="eyebrow">Lineage</p><h2>Related batches</h2><div id="batch-lineage" class="batch-lineage-list"><span>Loading…</span></div></article>
      <article class="master-card batch-artifacts-card"><p class="eyebrow">Artifacts</p><h2>Downloads</h2><div id="batch-artifacts" class="batch-artifact-list"><span>Loading…</span></div></article>
      <article class="master-card batch-settings-card"><p class="eyebrow">Execution details</p><h2>Scope and settings</h2><dl id="batch-settings" class="batch-settings-list"></dl></article>
    </section>
    <section class="master-card batch-items-card">
      <header class="crm-card-heading"><div><p class="eyebrow">Complaint-level results</p><h2>Batch items</h2><p>Each row preserves the complaint number, source row, result, reply version and generated output identity.</p></div><button id="refresh-items" class="btn btn-sm" type="button">↻ Refresh</button></header>
      <div class="reply-primary-filters batch-item-filters"><label class="crm-field reply-search-filter"><span>Search complaint</span><input id="item-search" class="input input-bordered" placeholder="Complaint number…" /></label><label class="crm-field"><span>Result</span><select id="item-status-filter" class="select select-bordered"><option value="">All results</option><option value="exported">Exported</option><option value="valid">Valid</option><option value="invalid">Invalid</option><option value="missing">Missing</option><option value="imported">Imported</option><option value="updated">Updated</option><option value="unchanged">Unchanged</option><option value="generated">Generated</option><option value="classified">Classified</option><option value="review_required">Review required</option><option value="approved">Approved</option><option value="rejected">Rejected</option><option value="suggested">Suggested</option><option value="failed">Failed</option></select></label></div>
      <DataTable id="batch-items-table" pageSize={50} pageSizeOptions={[25,50,100]} emptyText="This batch has no item records." ariaLabel="CRM bulk batch items" class="batch-items-table" />
    </section>
    <div id="batch-detail-toast" class="crm-toast" role="status" aria-live="polite" hidden></div>
  </main>
  <ModalDialog id="batch-complaint-dialog" title="Complaint details" eyebrow="Batch item" description="Read the full complaint while keeping this batch open." size="xl">
    <div id="batch-complaint-loading" class="crm-empty-state compact">Loading complaint…</div>
    <div id="batch-complaint-content" class="complaint-preview-content" hidden><div id="batch-complaint-meta" class="crm-chip-row"></div><article id="batch-complaint-text" class="complaint-preview-text"></article></div>
    <Fragment slot="footer"><button class="btn" type="button" data-dialog-close>Close</button><a id="batch-open-case" class="btn" href="#">Open complete case</a><a id="batch-open-reply" class="btn btn-primary" href="#">Open reply editor</a></Fragment>
  </ModalDialog>
  <script>
    import { badge, stack } from "../../../../../scripts/table-cells"; import { openDialog, wireDialogs } from "../../../../../scripts/dialogs";
    type Artifact={id:string;kind:string;name:string;download_url:string;size_bytes:number;sha256:string}; type Batch={id:string;batch_number:string;operation_type:string;status:string;parent?:Batch|null;children:Batch[];artifacts:Artifact[];scope:any;settings:any;source_filename?:string|null;total_items:number;valid_items:number;successful_items:number;failed_items:number;skipped_items:number;duplicate_items:number;created_by:string;created_at:string;completed_at?:string|null;error_summary?:string|null}; type Item={id:string;case_id?:string|null;complaint_number:string;complaint_preview:string;paperless_document_id?:number|null;source_row?:number|null;status:string;error_code?:string|null;error_message?:string|null;reply_version_before?:number|null;reply_version_after?:number|null;current_reply_version?:number|null;output_filename?:string|null;processed_at?:string|null;details?:Record<string,any>};
    const root=document.getElementById("batch-detail-page") as HTMLElement,API=root.dataset.apiBase||"",batchId=root.dataset.batchId||"";const $=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;const table=$("batch-items-table") as any;let batch:Batch|null=null;const label=(v:string)=>({classification_export:"Classification export",classification_import:"Classification import",reply_context_export:"Reply context package",reply_export:"Basic reply export",reply_import:"Reply import",formal_letters:"Formal letters"}[v]||v.replaceAll("_"," "));const tone=(v:string)=>["completed","generated","imported","updated","exported","classified","approved"].includes(v)?"success":["ready","completed_with_errors","valid","unchanged","missing","review_required","suggested"].includes(v)?"warning":["failed","invalid","cancelled","rejected"].includes(v)?"danger":"info";const dt=(v?:string|null)=>v?new Date(v).toLocaleString():"—";const size=(n:number)=>n<1024?`${n} B`:n<1048576?`${(n/1024).toFixed(1)} KB`:`${(n/1048576).toFixed(1)} MB`;
    async function api(path:string,init:RequestInit={}){const r=await fetch(`${API}${path}`,init);const b=await r.json().catch(()=>({}));if(!r.ok)throw new Error(b.detail?.message||b.detail||r.statusText);return b}function toast(m:string,e=false){const n=$("batch-detail-toast");n.textContent=m;n.className=`crm-toast${e?" error":""}`;n.hidden=false;setTimeout(()=>n.hidden=true,5000)}
    function linkBatch(value:Batch,prefix:string){const a=document.createElement("a");a.className="batch-lineage-item";a.href=`/crm/replies/bulk/batches/${value.id}/`;a.innerHTML=`<span>${prefix}</span><strong>${value.batch_number}</strong><small>${label(value.operation_type)} · ${value.status.replaceAll("_"," ")}</small>`;return a}
    function renderBatch(value:Batch){batch=value;$("batch-operation-label").textContent=label(value.operation_type);$("batch-number").textContent=value.batch_number;$("batch-description").textContent=value.error_summary||`${value.source_filename||"No source filename"} · created by ${value.created_by}`;$("batch-status").textContent=value.status.replaceAll("_"," ");$("batch-created").textContent=`Created ${dt(value.created_at)}`;$("batch-total").textContent=String(value.total_items);$("batch-valid").textContent=`${value.valid_items} valid`;$("batch-success").textContent=String(value.successful_items);$("batch-skipped").textContent=`${value.skipped_items} skipped`;$("batch-failed").textContent=String(value.failed_items);$("batch-duplicates").textContent=`${value.duplicate_items} duplicates`;
      const lineage=$("batch-lineage");lineage.replaceChildren();if(value.parent)lineage.append(linkBatch(value.parent,"Parent"));for(const child of value.children||[])lineage.append(linkBatch(child,"Child"));if(!value.parent&&!(value.children||[]).length)lineage.innerHTML='<div class="crm-empty-state compact">This batch has no linked parent or child batch.</div>';
      const artifacts=$("batch-artifacts");artifacts.replaceChildren();for(const item of value.artifacts||[]){const a=document.createElement("a");a.className="batch-artifact-item";a.href=`${API}${item.download_url}`;a.innerHTML=`<span>${item.kind.replaceAll("_"," ")}</span><strong>${item.name}</strong><small>${size(item.size_bytes)} · SHA-256 ${item.sha256.slice(0,12)}…</small>`;artifacts.append(a)}if(!(value.artifacts||[]).length)artifacts.innerHTML='<div class="crm-empty-state compact">No downloadable artifact is available for this batch.</div>';
      const dl=$("batch-settings");dl.replaceChildren();for(const [k,v] of Object.entries({...value.scope,...value.settings})){const dtEl=document.createElement("dt"),dd=document.createElement("dd");dtEl.textContent=k.replaceAll("_"," ");dd.textContent=typeof v==="object"?JSON.stringify(v):String(v??"—");dl.append(dtEl,dd)}if(!dl.children.length)dl.innerHTML='<dt>Settings</dt><dd>No additional settings were recorded.</dd>';
      $("cancel-batch").hidden=!["draft","validating","ready"].includes(value.status);$("retry-batch").hidden=!(value.operation_type==="formal_letters"&&value.failed_items>0);
    }
    async function loadBatch(){renderBatch(await api(`/api/v1/crm/bulk-operations/batches/${batchId}`))}
    async function openComplaint(item:Item){if(!item.case_id)return;$("batch-complaint-loading").hidden=false;$("batch-complaint-content").hidden=true;$("batch-open-case").setAttribute("href",`/crm/cases/${item.case_id}/`);$("batch-open-reply").setAttribute("href",`/crm/replies/${item.case_id}/?return_to=${encodeURIComponent(location.pathname)}`);openDialog("batch-complaint-dialog");try{const d=await api(`/api/v1/crm/reply-workspace/cases/${item.case_id}`);$("batch-complaint-meta").textContent=`${d.case.complaint_number||item.complaint_number} · ${d.case.category||"Unclassified"}${d.case.subcategory?` · ${d.case.subcategory}`:""}`;$("batch-complaint-text").textContent=d.case.complaint_text||"No complaint text is stored.";$("batch-complaint-loading").hidden=true;$("batch-complaint-content").hidden=false}catch(e){$("batch-complaint-loading").textContent=e instanceof Error?e.message:String(e)}}
    async function configure(){await table.configure({columns:[
      {accessorKey:"complaint_number",header:"Complaint No.",meta:{minWidth:"145px"},cell:(c:any)=>{const i=c.row.original as Item;if(!i.case_id)return i.complaint_number;const a=document.createElement("a");a.className="table-primary-link";a.href=`/crm/replies/${i.case_id}/?return_to=${encodeURIComponent(location.pathname)}`;a.textContent=i.complaint_number;return a}},
      {accessorKey:"complaint_preview",header:"Complaint",meta:{minWidth:"260px",maxWidth:"460px"},cell:(c:any)=>{const i=c.row.original as Item,w=document.createElement("div");w.className="table-preview-cell";const s=document.createElement("span");s.textContent=i.complaint_preview||i.error_message||"No complaint preview";w.append(s);if(i.case_id){const b=document.createElement("button");b.type="button";b.className="btn btn-xs";b.textContent="View";b.addEventListener("click",()=>void openComplaint(i));w.append(b)}return w}},
      {accessorKey:"source_row",header:"Source row",meta:{width:"95px",align:"right"},cell:(c:any)=>c.getValue()||"—"},
      {accessorKey:"status",header:"Result",meta:{minWidth:"125px"},cell:(c:any)=>badge(String(c.getValue()).replaceAll("_"," "),tone(c.getValue()))},
      {id:"versions",header:"Reply version",meta:{minWidth:"135px"},cell:(c:any)=>{const i=c.row.original as Item;return stack(i.reply_version_after?`Version ${i.reply_version_after}`:"—",i.reply_version_before&&i.reply_version_before!==i.reply_version_after?`was ${i.reply_version_before}`:"")}},
      {id:"output",header:"Classification / output",meta:{minWidth:"250px"},cell:(c:any)=>{const i=c.row.original as Item,d=i.details||{};const primary=i.output_filename||i.error_message||[d.category,d.subcategory].filter(Boolean).join(" · ")||"—";const secondary=i.error_code||((d.tags||[]).join(" · "))||(d.prompt_profile_version?`SOP ${d.prompt_profile_version}`:"");return stack(primary,secondary)}},
      {accessorKey:"processed_at",header:"Processed",meta:{minWidth:"160px"},cell:(c:any)=>dt(c.getValue())}
    ],manualPagination:true,getRowId:(r:Item)=>r.id,loadPage:async(i:number,s:number)=>{const p=new URLSearchParams({page:String(i+1),page_size:String(s)}),status=($("item-status-filter") as HTMLSelectElement).value,search=($("item-search") as HTMLInputElement).value.trim();if(status)p.set("status",status);if(search)p.set("search",search);const d=await api(`/api/v1/crm/bulk-operations/batches/${batchId}/items?${p}`);return{rows:d.items||[],total:d.total||0}}})}
    let timer:number|undefined;($("item-search") as HTMLInputElement).addEventListener("input",()=>{clearTimeout(timer);timer=window.setTimeout(()=>void table.refresh(true),250)});$("item-status-filter").addEventListener("change",()=>void table.refresh(true));$("refresh-items").addEventListener("click",()=>void Promise.all([loadBatch(),table.refresh(false)]));$("cancel-batch").addEventListener("click",async()=>{try{renderBatch(await api(`/api/v1/crm/bulk-operations/batches/${batchId}/cancel`,{method:"POST",headers:{"Content-Type":"application/json"},body:"{}"}));toast("Batch cancelled.")}catch(e){toast(e instanceof Error?e.message:String(e),true)}});$("retry-batch").addEventListener("click",async()=>{try{const r=await api(`/api/v1/crm/bulk-operations/batches/${batchId}/retry`,{method:"POST",headers:{"Content-Type":"application/json"},body:"{}"});location.href=`/crm/replies/bulk/batches/${r.id}/`}catch(e){toast(e instanceof Error?e.message:String(e),true)}});wireDialogs();void (async()=>{await loadBatch();await configure()})().catch(e=>toast(e instanceof Error?e.message:String(e),true));
  </script>
</CrmLayout>
