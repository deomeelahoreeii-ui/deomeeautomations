---
import AntiDengueLayout from "../layouts/AntiDengueLayout.astro";
---

<AntiDengueLayout
  title="AntiDengue reporting"
  description="Build the proven dry-run plan, freeze the exact WhatsApp preview, then review or send it safely."
  page="dashboard"
>
  <button class="btn btn-sm btn-ghost" id="refresh-button" type="button" slot="actions">↻ Refresh</button>

  <div class="notice antidengue-safety-notice">
    Direct legacy live-send is disabled. Both actions below always run the proven dry-run filtering first and send only the exact frozen preview.
  </div>

  <section class="metric-grid" aria-label="AntiDengue overview">
    <article class="metric-card"><span>Raw files</span><strong id="raw-files">—</strong><small>Waiting or downloaded</small></article>
    <article class="metric-card"><span>Output files</span><strong id="output-files">—</strong><small>Generated reports</small></article>
    <article class="metric-card"><span>Active executions</span><strong id="active-executions">—</strong><small>Dry run, preview or dispatch</small></article>
    <article class="metric-card warning-card"><span>Next scheduled run</span><strong id="next-run">—</strong><small id="next-schedule-name">No enabled schedule</small></article>
  </section>

  <section class="workspace-grid antidengue-orchestration-grid">
    <div class="left-column">
      <article class="panel run-panel">
        <div class="panel-heading">
          <div><p class="eyebrow">Safe orchestration</p><h2>Run AntiDengue</h2></div>
          <span class="environment-pill">Dry-run planner</span>
        </div>
        <form id="run-form">
          <label class="field-label" for="login-mode">Portal login</label>
          <select class="select select-bordered w-full" id="login-mode">
            <option value="auto">Auto sign in</option>
            <option value="manual">Manual sign in</option>
            <option value="remote_approve">Remote approval</option>
          </select>

          <label class="field-label" for="dispatch-profile">Dispatch profile</label>
          <select class="select select-bordered w-full" id="dispatch-profile" required>
            <option value="">Loading enabled profiles…</option>
          </select>
          <p class="field-help" id="profile-help">The selected profile freezes the audience, routing and report type.</p>

          <div class="safe-run-actions">
            <button class="btn btn-outline" id="preview-button" type="button">
              <span>Build preview now</span>
              <small>Generate and stop for review</small>
            </button>
            <button class="btn btn-primary" id="send-button" type="button">
              <span>Build and send now</span>
              <small>Auto-send only when clean</small>
            </button>
          </div>
          <div class="form-message" id="form-message" role="status"></div>
        </form>
      </article>

      <article class="panel history-panel">
        <div class="panel-heading compact">
          <div><p class="eyebrow">Recent activity</p><h2>Orchestrated runs</h2></div>
          <a class="btn btn-xs btn-ghost" href="/antidengue/run-history">View all</a>
        </div>
        <div class="history-list" id="execution-list"><p class="empty-state">Loading runs…</p></div>
      </article>
    </div>

    <article class="panel activity-panel">
      <div class="activity-header">
        <div>
          <p class="eyebrow">Selected execution</p>
          <h2 id="selected-title">Activity</h2>
          <p id="selected-meta">Select or start a run to inspect its stages.</p>
        </div>
        <span class="job-status neutral" id="selected-status">No run</span>
      </div>

      <div class="orchestration-stages" id="stage-list">
        <div class="orchestration-stage pending"><span>1</span><div><strong>Report generation</strong><small>Pending</small></div></div>
        <div class="orchestration-stage pending"><span>2</span><div><strong>Frozen dispatch preview</strong><small>Pending</small></div></div>
        <div class="orchestration-stage pending"><span>3</span><div><strong>WhatsApp dispatch</strong><small>Pending</small></div></div>
      </div>

      <div class="run-result" id="run-result" hidden></div>

      <div class="terminal-toolbar">
        <span><i></i> Combined orchestration output</span>
        <button type="button" id="copy-logs">Copy logs</button>
      </div>
      <div class="terminal" id="terminal" aria-live="polite"><p class="terminal-empty">Run activity will appear here.</p></div>

      <div class="execution-actions" id="execution-actions" hidden>
        <a class="btn btn-sm btn-primary" id="open-preview" href="/whatsapp/previews">Open frozen preview</a>
        <a class="btn btn-sm btn-ghost" id="open-details" href="/antidengue/run-history">Full execution details</a>
      </div>
    </article>
  </section>

  <script>
    const API = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
    const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    let selectedExecutionId = new URLSearchParams(location.search).get("execution_id");
    let selectedStatus = "";
    let pollTimer: number | undefined;
    let executions: any[] = [];

    async function api(path: string, init?: RequestInit) {
      const response = await fetch(`${API}${path}`, {
        headers: { "Content-Type": "application/json", ...(init?.headers || {}) },
        ...init,
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(typeof data.detail === "string" ? data.detail : JSON.stringify(data.detail || data));
      return data;
    }

    const terminalStatuses = new Set(["preview_ready", "completed", "completed_with_delivery_errors", "blocked", "failed", "skipped", "cancelled"]);
    const formatDate = (value?: string | null) => value ? new Date(value).toLocaleString() : "—";
    const statusLabel = (value: string) => value.replaceAll("_", " ").replace(/^./, (c) => c.toUpperCase());

    async function loadOverview() {
      const [overview, scheduler] = await Promise.all([
        api("/api/v1/antidengue/overview"),
        api("/api/v1/antidengue/schedules/status"),
      ]);
      el("raw-files").textContent = String(overview.counts.raw_files);
      el("output-files").textContent = String(overview.counts.output_files);
      el("active-executions").textContent = String(scheduler.active_executions);
      el("next-run").textContent = scheduler.next_run_at ? new Date(scheduler.next_run_at).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) : "—";
      el("next-schedule-name").textContent = scheduler.next_run_at ? `${scheduler.next_schedule_name} · ${new Date(scheduler.next_run_at).toLocaleDateString()}` : "No enabled schedule";
    }

    async function loadProfiles() {
      const data = await api("/api/v1/whatsapp/previews/options");
      const select = el<HTMLSelectElement>("dispatch-profile");
      const previous = select.value;
      select.replaceChildren();
      if (!data.profiles.length) {
        const option = document.createElement("option");
        option.value = "";
        option.textContent = "No enabled AntiDengue dispatch profile";
        select.append(option);
        el("profile-help").textContent = "Configure an enabled AntiDengue dispatch profile under WhatsApp Routing first.";
        return;
      }
      for (const profile of data.profiles) {
        const option = document.createElement("option");
        option.value = profile.id;
        option.textContent = `${profile.name} · ${profile.audience_name} · ${profile.target_count} target(s)`;
        select.append(option);
      }
      if (previous && data.profiles.some((item: any) => item.id === previous)) select.value = previous;
    }

    function renderExecutionList() {
      const container = el("execution-list");
      container.replaceChildren();
      if (!executions.length) {
        container.innerHTML = '<p class="empty-state">No orchestrated runs yet.</p>';
        return;
      }
      for (const item of executions.slice(0, 10)) {
        const button = document.createElement("button");
        button.type = "button";
        button.className = `history-item ${item.id === selectedExecutionId ? "selected" : ""}`;
        const title = item.trigger_type === "manual_send" ? "Build and send" : item.trigger_type === "manual_preview" ? "Build preview" : item.schedule_name || "Scheduled run";
        button.innerHTML = `<span class="history-status ${item.status}"></span><span class="history-copy"><strong></strong><small></small></span><span class="job-status ${item.status}"></span>`;
        button.querySelector("strong")!.textContent = title;
        button.querySelector("small")!.textContent = `${item.execution_code} · ${formatDate(item.created_at)}`;
        button.querySelector(".job-status")!.textContent = statusLabel(item.status);
        button.addEventListener("click", () => { selectedExecutionId = item.id; renderExecutionList(); void loadSelected(); });
        container.append(button);
      }
    }

    async function loadExecutions() {
      const data = await api("/api/v1/antidengue/executions?limit=30");
      executions = data.items;
      if (selectedExecutionId && !executions.some((item) => item.id === selectedExecutionId)) selectedExecutionId = null;
      if (!selectedExecutionId && executions.length) selectedExecutionId = executions[0].id;
      renderExecutionList();
      await loadSelected();
    }

    function renderStages(stages: any[]) {
      const container = el("stage-list");
      container.replaceChildren();
      stages.forEach((stage, index) => {
        const row = document.createElement("div");
        const tone = ["succeeded", "not_requested"].includes(stage.status) ? "succeeded" : stage.status === "failed" ? "failed" : ["queued", "running"].includes(stage.status) ? "running" : "pending";
        row.className = `orchestration-stage ${tone}`;
        row.innerHTML = `<span>${index + 1}</span><div><strong></strong><small></small></div>`;
        row.querySelector("strong")!.textContent = stage.label;
        row.querySelector("small")!.textContent = statusLabel(stage.status);
        container.append(row);
      });
    }

    function renderLogs(logs: any[]) {
      const terminal = el("terminal");
      terminal.replaceChildren();
      if (!logs.length) {
        terminal.innerHTML = '<p class="terminal-empty">Waiting for orchestration activity…</p>';
        return;
      }
      for (const log of logs) {
        const row = document.createElement("div");
        row.className = `log-row ${String(log.level).toLowerCase()}`;
        row.innerHTML = `<time></time><b></b><span></span>`;
        row.querySelector("time")!.textContent = new Date(log.created_at).toLocaleTimeString([], { hour12: false });
        row.querySelector("b")!.textContent = String(log.source || log.level).toUpperCase();
        row.querySelector("span")!.textContent = log.message;
        terminal.append(row);
      }
      terminal.scrollTop = terminal.scrollHeight;
    }

    function renderResult(item: any) {
      const result = el("run-result");
      const preview = item.preview_summary || {};
      const dispatch = item.dispatch_summary || {};
      if (!item.error && !Object.keys(preview).length && !Object.keys(dispatch).length) {
        result.hidden = true;
        return;
      }
      result.hidden = false;
      result.innerHTML = item.error
        ? `<strong>${statusLabel(item.status)}</strong><span></span>`
        : `<div><span>Preview deliveries</span><strong>${preview.delivery_count ?? "—"}</strong></div><div><span>Warnings / blocked</span><strong>${preview.warning_count ?? 0} / ${preview.blocked_count ?? 0}</strong></div><div><span>Delivered / failed</span><strong>${dispatch.delivered ?? "—"} / ${dispatch.failed ?? "—"}</strong></div>`;
      if (item.error) result.querySelector("span")!.textContent = item.error;
    }

    async function loadSelected() {
      if (!selectedExecutionId) return;
      const item = await api(`/api/v1/antidengue/executions/${selectedExecutionId}`);
      selectedStatus = item.status;
      el("selected-title").textContent = item.schedule_name || (item.trigger_type === "manual_send" ? "Build and send" : "Build preview");
      el("selected-meta").textContent = `${item.execution_code} · ${formatDate(item.scheduled_for)}`;
      const badge = el("selected-status");
      badge.className = `job-status ${item.status}`;
      badge.textContent = statusLabel(item.status);
      renderStages(item.stages || []);
      renderLogs(item.logs || []);
      renderResult(item);
      const actions = el("execution-actions");
      actions.hidden = !item.preview_id;
      el<HTMLAnchorElement>("open-preview").href = item.preview_id ? `/whatsapp/previews/${item.preview_id}` : "/whatsapp/previews";
      el<HTMLAnchorElement>("open-details").href = `/antidengue/run-history?execution_id=${item.id}`;
    }

    async function startExecution(policy: "preview_only" | "auto_send_when_clean") {
      const profile = el<HTMLSelectElement>("dispatch-profile").value;
      const message = el("form-message");
      if (!profile) { message.textContent = "Select an enabled AntiDengue dispatch profile."; return; }
      if (policy === "auto_send_when_clean" && !confirm("This will send only if the dry run succeeds and the frozen preview has zero warnings and zero blocking issues. Continue?")) return;
      const buttons = [el<HTMLButtonElement>("preview-button"), el<HTMLButtonElement>("send-button")];
      buttons.forEach((button) => button.disabled = true);
      message.textContent = policy === "preview_only" ? "Queueing safe preview…" : "Queueing guarded build-and-send…";
      try {
        const item = await api("/api/v1/antidengue/executions", {
          method: "POST",
          body: JSON.stringify({
            login_mode: el<HTMLSelectElement>("login-mode").value,
            dispatch_policy: policy,
            dispatch_profile_id: profile,
            created_by: "web-operator",
          }),
        });
        selectedExecutionId = item.id;
        message.textContent = `${item.execution_code} created. The proven dry-run planner is first.`;
        await refreshAll();
      } catch (error) {
        message.textContent = error instanceof Error ? error.message : "Could not create the execution";
      } finally {
        buttons.forEach((button) => button.disabled = false);
      }
    }

    async function refreshAll() {
      window.clearTimeout(pollTimer);
      try {
        await Promise.all([loadOverview(), loadProfiles(), loadExecutions()]);
      } catch (error) {
        el("form-message").textContent = error instanceof Error ? error.message : "Platform API unavailable";
      } finally {
        pollTimer = window.setTimeout(refreshAll, selectedExecutionId && !terminalStatuses.has(selectedStatus) ? 2500 : 10000);
      }
    }

    el("preview-button").addEventListener("click", () => void startExecution("preview_only"));
    el("send-button").addEventListener("click", () => void startExecution("auto_send_when_clean"));
    el("refresh-button").addEventListener("click", () => void refreshAll());
    el("copy-logs").addEventListener("click", async () => {
      await navigator.clipboard.writeText(el("terminal").innerText);
      el("copy-logs").textContent = "Copied";
      setTimeout(() => el("copy-logs").textContent = "Copy logs", 1200);
    });
    void refreshAll();
    addEventListener("beforeunload", () => clearTimeout(pollTimer));
  </script>
</AntiDengueLayout>
