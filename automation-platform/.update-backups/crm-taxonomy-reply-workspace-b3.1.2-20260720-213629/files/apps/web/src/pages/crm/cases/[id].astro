---
import DataTable from "../../../components/DataTable.astro";
import CrmIntakeNav from "../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";

const caseId = Astro.params.id || "";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---

<CrmLayout title="Complaint Case" description="Review the complaint record, its evidence and extraction trail before publication." page="cases">
  <a class="btn btn-sm" href="/crm/cases/" slot="actions">← All cases</a>
  <CrmIntakeNav active="review" />

  <main id="case-workspace" data-case-id={caseId} data-api-base={apiBase}>
    <div id="case-error"></div>

    <section class="master-card crm-case-hero" id="case-header">
      <div class="crm-intake-empty"><h3>Loading complaint case…</h3></div>
    </section>

    <section class="crm-case-overview">
      <article class="master-card crm-case-summary-card">
        <div class="inbound-card-heading">
          <div>
            <p class="eyebrow">Canonical record</p>
            <h2>Case snapshot</h2>
            <p>Confirmed working values. The original extraction remains unchanged.</p>
          </div>
          <button class="btn btn-sm btn-primary" id="open-case-editor" type="button">Edit confirmed fields</button>
        </div>
        <div class="crm-case-facts" id="case-facts"></div>
        <div class="crm-case-remarks" id="case-remarks"></div>
      </article>

      <article class="master-card crm-case-evidence-card">
        <div class="inbound-card-heading">
          <div>
            <p class="eyebrow">Evidence</p>
            <h2>Documents and attachments</h2>
            <p>Open the source first, then confirm its role in this complaint.</p>
          </div>
          <span class="badge" id="case-document-count">—</span>
        </div>
        <div id="case-documents" class="crm-case-documents"></div>
      </article>
    </section>


    <section class="master-card crm-classification-card" id="classification-card">
      <div>
        <p class="eyebrow">Authoritative classification</p>
        <h2>Category and subcategory</h2>
        <p>Choose controlled values from PostgreSQL taxonomy. Saving updates this complaint and verifies the linked Helpdesk ticket when available.</p>
        <div id="classification-guidance" class="crm-classification-guidance"></div>
      </div>
      <div class="crm-classification-controls">
        <label>Category<select class="select select-bordered" id="case-category-select"><option value="">Choose category</option></select></label>
        <label>Subcategory<select class="select select-bordered" id="case-subcategory-select"><option value="">No subcategory</option></select></label>
        <div class="crm-classification-actions">
          <span class="crm-helpdesk-case-state" id="classification-sync-state">not synchronized</span>
          <button class="btn btn-primary" id="save-classification" type="button">Save and sync</button>
          <a class="btn" href="/crm/taxonomy/">Manage taxonomy</a>
          <a class="btn" id="write-case-reply" href={`/crm/replies/${caseId}/`}>Write reply</a>
        </div>
      </div>
    </section>

    <section class="master-card crm-helpdesk-case-card" id="helpdesk-case-card">
      <div>
        <p class="eyebrow">Operational workflow</p>
        <h2>Frappe Helpdesk</h2>
        <p id="helpdesk-case-summary">This complaint has not been synchronized yet.</p>
        <div class="crm-helpdesk-workflow-facts" id="helpdesk-workflow-facts"></div>
        <p class="crm-helpdesk-case-error" id="helpdesk-case-error" hidden></p>
      </div>
      <div class="crm-helpdesk-case-actions">
        <span class="crm-helpdesk-case-state" id="helpdesk-case-state">not synchronized</span>
        <a class="btn" id="open-helpdesk-ticket" href="#" target="_blank" rel="noreferrer" hidden>Open ticket ↗</a>
        <button class="btn" id="pull-helpdesk-case" type="button">Pull workflow</button>
        <button class="btn btn-primary" id="sync-helpdesk-case" type="button">Sync to Helpdesk</button>
      </div>
    </section>

    <section class="master-card crm-case-audit-card">
      <div class="inbound-card-heading">
        <div>
          <p class="eyebrow">Extraction audit</p>
          <h2>Observed fields</h2>
          <p>Sortable, traceable observations from selectable PDF text, OCR and structured rows.</p>
        </div>
        <label class="crm-audit-search">
          <span class="sr-only">Search observations</span>
          <input class="input input-bordered input-sm" id="observation-search" placeholder="Search field, value or source…" />
        </label>
      </div>
      <DataTable id="case-observations-table" pageSize={10} emptyText="No structured observations were extracted." />
      <details class="crm-extraction-sources">
        <summary>Extraction source text and versions</summary>
        <div id="case-extractions"></div>
      </details>
    </section>

    <section class="master-card crm-case-decision-card">
      <div>
        <p class="eyebrow">Final decision</p>
        <h2>Paperless publication</h2>
        <p>Review duplicate results, then explicitly approve or publish this exact evidence package.</p>
        <p id="publication-readiness"></p>
        <div id="case-matches" class="crm-case-matches"></div>
      </div>
      <div class="crm-case-decision-actions">
        <button class="btn" id="approve-fresh" type="button">Approve as fresh</button>
        <button class="btn btn-primary" id="publish-case" type="button">Publish approved package</button>
      </div>
    </section>
  </main>

  <dialog class="modal" id="case-editor-dialog">
    <div class="modal-box master-modal crm-case-editor-modal">
      <div class="modal-title">
        <div><span class="eyebrow">Canonical record</span><h2>Edit confirmed fields</h2></div>
        <button type="button" id="close-case-editor" aria-label="Close">×</button>
      </div>
      <p class="crm-modal-help">These values drive the final Paperless metadata. Saving never rewrites OCR or extracted source text.</p>
      <form id="case-form" class="crm-case-form"></form>
      <div class="form-actions">
        <button class="btn" id="cancel-case-editor" type="button">Cancel</button>
        <button class="btn btn-primary" id="save-case" type="button">Save confirmed fields</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <style>
    .crm-case-hero{margin-top:1rem;padding:1.1rem 1.25rem}.crm-case-hero .inbound-card-heading{align-items:center}.crm-case-hero h2{margin:.15rem 0;font-size:1.45rem}.crm-case-hero-meta{display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;color:#64748b;font-size:.8rem}.crm-case-overview{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1.05fr);gap:1rem;margin:1rem 0}.crm-case-summary-card,.crm-case-evidence-card,.crm-case-audit-card,.crm-case-decision-card{padding:1.1rem 1.25rem}.crm-case-overview h2,.crm-case-audit-card h2,.crm-case-decision-card h2{margin:0;font-size:1rem}.crm-case-facts{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.55rem;margin-top:1rem}.crm-case-fact{min-width:0;border:1px solid #e1e8ee;border-radius:.65rem;background:#f9fbfc;padding:.65rem .75rem}.crm-case-fact span,.crm-case-fact strong{display:block}.crm-case-fact span{color:#7b8899;font-size:.67rem;text-transform:uppercase;letter-spacing:.04em}.crm-case-fact strong{margin-top:.2rem;overflow-wrap:anywhere;color:#29384d;font-size:.85rem}.crm-case-fact.empty strong{color:#9aa5b3;font-weight:500}.crm-case-remarks{margin-top:.7rem;border-left:3px solid #77b8c1;background:#f4fafb;padding:.75rem .85rem}.crm-case-remarks span{display:block;color:#718096;font-size:.67rem;text-transform:uppercase}.crm-case-remarks p{margin:.3rem 0 0;color:#405066;font-size:.8rem;line-height:1.55}.crm-case-documents{display:grid;gap:.65rem;margin-top:1rem}.crm-evidence-item{border:1px solid #dfe7ed;border-radius:.7rem;padding:.8rem}.crm-evidence-item header{display:flex;justify-content:space-between;gap:1rem}.crm-evidence-item strong,.crm-evidence-item small{display:block}.crm-evidence-item strong{overflow-wrap:anywhere;color:#29384d;font-size:.82rem}.crm-evidence-item small{margin-top:.2rem;color:#7b8798;font-size:.68rem}.crm-evidence-item p{margin:.55rem 0;color:#64748b;font-size:.72rem}.crm-evidence-actions{display:flex;gap:.4rem;flex-wrap:wrap;border-top:1px solid #edf1f4;padding-top:.6rem}.crm-duplicate-captures{margin:.6rem 0;border-radius:.55rem;background:#f5f8fa;padding:.55rem .65rem}.crm-duplicate-captures summary{cursor:pointer;color:#536176;font-size:.7rem;font-weight:750}.crm-duplicate-links{display:flex;gap:.35rem;flex-wrap:wrap;margin-top:.5rem}.crm-case-audit-card{margin-top:1rem}.crm-audit-search{width:min(22rem,100%)}.crm-audit-search input{width:100%}.crm-observation-value{max-width:42rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.crm-extraction-sources{margin-top:1rem;border-top:1px solid #e2e8f0;padding-top:.8rem}.crm-extraction-sources>summary{cursor:pointer;color:#526276;font-size:.8rem;font-weight:700}.crm-extraction-version{margin-top:.65rem;border:1px solid #dfe7ed;border-radius:.65rem;padding:.7rem}.crm-extraction-version summary{cursor:pointer;font-size:.75rem}.crm-extracted-text{max-height:22rem;overflow:auto;white-space:pre-wrap;overflow-wrap:anywhere;background:#17212b;color:#d9e4ee;border-radius:.55rem;padding:1rem;font-size:.72rem;line-height:1.5}.crm-case-decision-card{display:flex;align-items:center;justify-content:space-between;gap:1.5rem;margin-top:1rem}.crm-case-decision-card>div:first-child{min-width:0}.crm-case-decision-card p{margin:.3rem 0;color:#66758a;font-size:.75rem}.crm-case-matches{display:flex;gap:.45rem;flex-wrap:wrap;margin-top:.65rem}.crm-case-match{border-radius:1rem;background:#f0f5f7;padding:.35rem .6rem;color:#536176;font-size:.67rem}.crm-case-decision-actions{display:flex;gap:.5rem;flex:0 0 auto}.crm-case-editor-modal{width:min(780px,calc(100vw - 2rem));max-width:780px;max-height:calc(100vh - 2rem);overflow:auto}.crm-modal-help{margin:.5rem 0 1rem;color:#718096;font-size:.75rem;line-height:1.5}.crm-case-form{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}.crm-case-form label{display:grid;gap:.3rem;color:#46556a;font-size:.75rem;font-weight:700}.crm-case-form label.wide{grid-column:1/-1}.crm-case-form textarea{min-height:6rem}.form-actions{display:flex;justify-content:flex-end;gap:.5rem;margin-top:1rem;border-top:1px solid #e2e8f0;padding-top:1rem}@media(max-width:900px){.crm-case-overview{grid-template-columns:1fr}.crm-case-decision-card{align-items:flex-start;flex-direction:column}.crm-case-decision-actions{width:100%;flex-wrap:wrap}}@media(max-width:620px){.crm-case-facts,.crm-case-form{grid-template-columns:1fr}.crm-case-form label.wide{grid-column:auto}.crm-case-hero .inbound-card-heading,.crm-case-audit-card .inbound-card-heading{align-items:flex-start;flex-direction:column}.crm-audit-search{width:100%}}
    .crm-publication-blocker{display:inline-block;border-radius:.45rem;background:#fff6e5;padding:.4rem .55rem;color:#8a5419;font-size:.72rem;font-weight:700}.crm-helpdesk-case-card{display:flex;align-items:center;justify-content:space-between;gap:1.5rem;margin-top:1rem;padding:1.1rem 1.25rem;border-left:5px solid #16879a}.crm-helpdesk-case-card h2{margin:0;font-size:1rem}.crm-helpdesk-case-card p{margin:.3rem 0 0;color:#66758a;font-size:.75rem}.crm-helpdesk-case-actions{display:flex;align-items:center;justify-content:flex-end;gap:.5rem;flex-wrap:wrap}.crm-helpdesk-case-state{display:inline-flex;border-radius:1rem;background:#edf3f6;padding:.3rem .6rem;color:#526476;font-size:.7rem;font-weight:750}.crm-helpdesk-case-state.synchronized{background:#e7f8f1;color:#176b57}.crm-helpdesk-case-state.failed{background:#fff0f1;color:#a52630}.crm-helpdesk-case-state.pending,.crm-helpdesk-case-state.update_pending{background:#fff3dc;color:#925b05}.crm-helpdesk-workflow-facts{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.55rem}.crm-helpdesk-workflow-facts span{border-radius:1rem;background:#f1f5f7;padding:.25rem .5rem;color:#536274;font-size:.68rem;font-weight:700}.crm-helpdesk-case-error{border-radius:.45rem;background:#fff0f1!important;padding:.4rem .55rem!important;color:#a52630!important;font-weight:700}@media(max-width:900px){.crm-helpdesk-case-card{align-items:flex-start;flex-direction:column}.crm-helpdesk-case-actions{justify-content:flex-start;width:100%}}
.crm-classification-card{display:grid;grid-template-columns:minmax(0,1fr) minmax(26rem,1fr);gap:1.5rem;align-items:center;margin-top:1rem;padding:1.1rem 1.25rem;border-left:5px solid #16879a}.crm-classification-card h2{margin:0;font-size:1rem}.crm-classification-card p{margin:.3rem 0;color:#66758a;font-size:.75rem}.crm-classification-controls{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;align-items:end}.crm-classification-controls label{display:grid;gap:.3rem;color:#46556a;font-size:.75rem;font-weight:700}.crm-classification-actions{grid-column:1/-1;display:flex;align-items:center;justify-content:flex-end;gap:.45rem;flex-wrap:wrap}.crm-classification-guidance{display:grid;gap:.25rem;margin-top:.55rem;color:#536274;font-size:.7rem}.crm-classification-guidance span{border-radius:.5rem;background:#effafb;padding:.4rem .55rem}@media(max-width:900px){.crm-classification-card{grid-template-columns:1fr}.crm-classification-actions{justify-content:flex-start}}@media(max-width:600px){.crm-classification-controls{grid-template-columns:1fr}.crm-classification-actions{grid-column:auto}}
  </style>

  <script>
    import { actions } from "astro:actions";

    await customElements.whenDefined("astro-data-table");
    const root=document.getElementById("case-workspace") as HTMLElement,id=root.dataset.caseId!,apiBase=root.dataset.apiBase||"";
    const el=<T extends HTMLElement>(value:string)=>document.getElementById(value) as T;
    const dialog=el<HTMLDialogElement>("case-editor-dialog"),table=el<any>("case-observations-table");
    const esc=(value:any)=>String(value??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;");
    const fields=["complainant_name","complainant_mobile","complainant_cnic","complainant_address","district","tehsil","department","remarks"];
    const labels:any={complainant_name:"Complainant name",complainant_mobile:"Mobile",complainant_cnic:"CNIC",complainant_address:"Address",district:"District",tehsil:"Tehsil",department:"Department",remarks:"Complaint remarks"};
    let data:any,taxonomy:any[]=[];let observationQuery="";

    function stateLabel(value:string){return value.replaceAll("_"," ")}
    function fact(name:string,value:any){return`<div class="crm-case-fact ${value?"":"empty"}"><span>${esc(name)}</span><strong>${esc(value||"Not confirmed")}</strong></div>`}
    function observationValue(value:any){const node=document.createElement("div");node.className="crm-observation-value";node.textContent=String(value??"");node.title=String(value??"");return node}
    function filteredObservations(){const query=observationQuery.trim().toLowerCase();return(data?.field_observations||[]).filter((row:any)=>!query||[row.field_name,row.raw_value,row.normalized_value,row.source_locator,row.decision].some(value=>String(value||"").toLowerCase().includes(query)))}
    async function refreshObservationTable(){await table.setData(filteredObservations())}
    function activeCategories(){return taxonomy.filter((item:any)=>item.active&&!item.merged_into_id)}
    function selectedCategory(){return taxonomy.find((item:any)=>item.id===el<HTMLSelectElement>("case-category-select").value)}
    function renderClassificationGuidance(){const category=selectedCategory(),sub=category?.subcategories?.find((item:any)=>item.id===el<HTMLSelectElement>("case-subcategory-select").value);const blocks=[];if(category?.reply_guidance||category?.policy_notes)blocks.push(`<span><b>${esc(category.name)}:</b> ${esc([category.reply_guidance,category.policy_notes].filter(Boolean).join(" · "))}</span>`);if(sub?.reply_guidance||sub?.policy_notes)blocks.push(`<span><b>${esc(sub.name)}:</b> ${esc([sub.reply_guidance,sub.policy_notes].filter(Boolean).join(" · "))}</span>`);el("classification-guidance").innerHTML=blocks.join("")||`<span>No saved guidance. Add reusable wording and policy notes in Taxonomy.</span>`}
    function renderSubcategoryOptions(selected=""){const category=selectedCategory(),items=(category?.subcategories||[]).filter((item:any)=>item.active&&!item.merged_into_id),select=el<HTMLSelectElement>("case-subcategory-select");select.innerHTML=`<option value="">No subcategory</option>${items.map((item:any)=>`<option value="${item.id}">${esc(item.name)}</option>`).join("")}`;if(items.some((item:any)=>item.id===selected))select.value=selected;renderClassificationGuidance()}

    function render(){
      const approveButton=el<HTMLButtonElement>("approve-fresh"),publishButton=el<HTMLButtonElement>("publish-case");
      approveButton.hidden=!["candidate","review_required"].includes(data.state);publishButton.hidden=data.state!=="fresh";publishButton.disabled=!data.publication_ready;
      const blockers=data.publication_blockers||[];el("publication-readiness").innerHTML=data.publication_ready?`<span class="crm-run-state fresh">Ready for CRM Pending</span>`:blockers.length?`<span class="crm-publication-blocker">Before publishing: ${esc(blockers.join(" · "))}</span>`:"";
      el("case-header").innerHTML=`<div class="inbound-card-heading"><div><p class="eyebrow">Complaint case</p><h2>${esc(data.complaint_number||"Complaint number needs review")}</h2><div class="crm-case-hero-meta"><span>${esc(data.document_count)} evidence document(s)</span><span>•</span><span>${data.paperless_document_id?`Paperless #${esc(data.paperless_document_id)}`:"No Paperless match"}</span></div></div><span class="crm-run-state ${esc(data.state)}">${esc(stateLabel(data.state))}</span></div>`;
      el("case-facts").innerHTML=[fact("Complainant",data.complainant_name),fact("Mobile",data.complainant_mobile),fact("CNIC",data.complainant_cnic),fact("Address",data.complainant_address),fact("District",data.district),fact("Tehsil",data.tehsil),fact("Department",data.department),fact("Category",[data.category,data.sub_category].filter(Boolean).join(" / "))].join("");
      el("case-remarks").innerHTML=`<span>Complaint remarks</span><p>${esc(data.remarks||"No complaint remarks have been confirmed.")}</p>`;
      const categorySelect=el<HTMLSelectElement>("case-category-select");categorySelect.innerHTML=`<option value="">Choose category</option>${activeCategories().map((item:any)=>`<option value="${item.id}">${esc(item.name)}</option>`).join("")}`;categorySelect.value=data.category_id||"";renderSubcategoryOptions(data.sub_category_id||"");const classificationState=String(data.classification_sync_status||"not_synced"),classificationStateNode=el("classification-sync-state");classificationStateNode.textContent=stateLabel(classificationState);classificationStateNode.className=`crm-helpdesk-case-state ${esc(classificationState)}`;
      const helpdeskState=String(data.frappe_sync_status||"not_synced");
      const helpdeskStateNode=el("helpdesk-case-state");
      helpdeskStateNode.textContent=stateLabel(helpdeskState);
      helpdeskStateNode.className=`crm-helpdesk-case-state ${esc(helpdeskState)}`;
      const helpdeskOpen=el<HTMLAnchorElement>("open-helpdesk-ticket");
      helpdeskOpen.hidden=!data.frappe_ticket_url;
      if(data.frappe_ticket_url)helpdeskOpen.href=data.frappe_ticket_url;
      el("helpdesk-case-summary").textContent=data.frappe_ticket_id?`Linked to Helpdesk ticket ${data.frappe_ticket_id}. Last workflow pull ${data.frappe_last_workflow_pull_at?new Date(data.frappe_last_workflow_pull_at).toLocaleString():"not performed"}.`:`Create one Helpdesk ticket after the complaint is published to Paperless.`;
      el("helpdesk-workflow-facts").innerHTML=data.frappe_ticket_id?[
        `Status: ${esc(data.frappe_workflow_status||"Not pulled")}`,
        `Team: ${esc(data.frappe_agent_group||"Unassigned")}`,
        `Officer: ${esc(data.frappe_assigned_officer_name||"Team routing")}`,
        `Reply: ${esc(data.frappe_reply_approval_status||"Not pulled")}`,
      ].map(value=>`<span>${value}</span>`).join(""):"";
      const helpdeskError=el("helpdesk-case-error");
      helpdeskError.hidden=!data.frappe_last_error;
      helpdeskError.textContent=data.frappe_last_error?`Last synchronization error: ${data.frappe_last_error}`:"";
      const helpdeskSync=el<HTMLButtonElement>("sync-helpdesk-case");
      helpdeskSync.textContent=data.frappe_ticket_id?"Refresh Helpdesk ticket":"Sync to Helpdesk";
      helpdeskSync.disabled=helpdeskState==="pending";
      const canonicalDocuments=data.documents.filter((doc:any)=>!doc.duplicate_of_document_id);el("case-document-count").textContent=data.capture_count>data.document_count?`${data.document_count} unique file${data.document_count===1?"":"s"} · ${data.capture_count} captures`:`${data.document_count} file${data.document_count===1?"":"s"}`;
      el("case-documents").innerHTML=canonicalDocuments.map((doc:any)=>{const duplicates=data.documents.filter((candidate:any)=>candidate.duplicate_of_document_id===doc.id),duplicateAudit=duplicates.length?`<details class="crm-duplicate-captures"><summary>Captured ${duplicates.length+1} times — ${duplicates.length} identical capture${duplicates.length===1?"":"s"} retained for audit</summary><div class="crm-duplicate-links">${duplicates.map((duplicate:any,index:number)=>`<a class="btn btn-xs" href="${apiBase}/api/v1/whatsapp/inbound/processing-items/${esc(duplicate.source_processing_item_id)}/content" target="_blank" rel="noreferrer">Duplicate capture ${index+2} ↗</a>`).join("")}</div></details>`:"";return`<article class="crm-evidence-item"><header><div><strong>${esc(doc.original_filename||doc.id)}</strong><small>${esc(doc.mime_type||"Unknown type")} · ${esc(stateLabel(doc.role))}</small></div><span class="crm-run-state ${esc(doc.review_state)}">${esc(doc.review_state)}</span></header><p>${esc(doc.relationship_reason||"Relationship not yet confirmed")}</p>${duplicateAudit}<div class="crm-evidence-actions"><a class="btn btn-xs btn-primary" href="${apiBase}/api/v1/whatsapp/inbound/processing-items/${esc(doc.source_processing_item_id)}/content" target="_blank" rel="noreferrer">Open original ↗</a><button class="btn btn-xs" data-doc="${doc.id}" data-role="main_complaint">Main complaint</button><button class="btn btn-xs" data-doc="${doc.id}" data-role="attachment">Attachment</button><button class="btn btn-xs" data-doc="${doc.id}" data-role="report">Reply/report</button><button class="btn btn-xs" data-doc="${doc.id}" data-reject="1">Reject link</button></div></article>`}).join("")||`<div class="crm-intake-empty"><h3>No evidence linked</h3></div>`;
      el("case-extractions").innerHTML=data.extractions.map((item:any)=>`<details class="crm-extraction-version"><summary><strong>${esc(item.extraction_method)}</strong> · ${Math.round(Number(item.quality_score||0)*100)}% quality${item.text_truncated?" · preview":""}</summary><pre class="crm-extracted-text">${esc(item.text_preview||"No selectable or OCR text was extracted.")}</pre></details>`).join("")||"<p>No extraction record is available.</p>";
      const matches=data.matches.map((item:any)=>`<span class="crm-case-match"><strong>${esc(item.final_decision||item.proposed_decision)}</strong> · ${esc(item.reason)}${item.paperless_document_id?` · Paperless #${esc(item.paperless_document_id)}`:""}</span>`);const publications=(data.paperless_publications||[]).map((item:any)=>`<span class="crm-case-match"><strong>${esc(item.state)}</strong> · ${esc(item.intended_fields_json?.role||"document")}${item.paperless_document_id?` · Paperless #${esc(item.paperless_document_id)}`:""}${item.last_error?` · ${esc(item.last_error)}`:""}</span>`);el("case-matches").innerHTML=[...matches,...publications].join("")||`<span class="crm-case-match">No duplicate decision recorded</span>`;
      document.querySelectorAll<HTMLElement>("[data-doc]").forEach(button=>button.addEventListener("click",async()=>{const role=button.dataset.role||"attachment",accepted=!button.dataset.reject;const result=await actions.crm.reviewComplaintDocument({caseId:id,documentId:button.dataset.doc!,role:accepted?role as any:"attachment",accepted});if(result.error)alert(result.error.message);else await load()}));
      void refreshObservationTable();
    }

    function openEditor(){el("case-form").innerHTML=fields.map(name=>`<label class="${name==="remarks"||name==="complainant_address"?"wide":""}">${labels[name]}${name==="remarks"||name==="complainant_address"?`<textarea class="textarea textarea-bordered" data-field="${name}">${esc(data[name])}</textarea>`:`<input class="input input-bordered" data-field="${name}" value="${esc(data[name])}"/>`}</label>`).join("");dialog.showModal();window.setTimeout(()=>el<HTMLInputElement>("case-form").querySelector<HTMLInputElement>("input")?.focus(),0)}
    async function load(){const [result,taxonomyResponse]=await Promise.all([actions.crm.complaintCase({id}),fetch(`${apiBase}/api/v1/crm/taxonomy?include_inactive=false`).then(async response=>{const body=await response.json().catch(()=>({}));if(!response.ok)throw new Error(body.detail||response.statusText);return body}).catch(()=>({categories:[]}))]);if(result.error){el("case-error").innerHTML=`<p class="alert alert-error">${esc(result.error.message)}</p>`;return}data=result.data;taxonomy=taxonomyResponse.categories||[];render()}

    await table.configure({data:[],columns:[{accessorKey:"field_name",header:"Field",cell:({row}:any)=>stateLabel(row.original.field_name)},{accessorKey:"raw_value",header:"Observed value",cell:({row}:any)=>observationValue(row.original.raw_value)},{accessorKey:"confidence",header:"Confidence",cell:({row}:any)=>`${Math.round(Number(row.original.confidence||0)*100)}%`},{accessorKey:"source_locator",header:"Source"},{accessorKey:"decision",header:"Decision"}]});
    el("observation-search").addEventListener("input",event=>{observationQuery=(event.target as HTMLInputElement).value;void refreshObservationTable()});
    el("open-case-editor").addEventListener("click",openEditor);el("close-case-editor").addEventListener("click",()=>dialog.close());el("cancel-case-editor").addEventListener("click",()=>dialog.close());
    el("save-case").addEventListener("click",async()=>{const values:any={};document.querySelectorAll<HTMLElement>("[data-field]").forEach((node:any)=>values[node.dataset.field]=node.value||null);const accepted=data.documents.filter((item:any)=>item.review_state==="accepted").map((item:any)=>item.id),rejected=data.documents.filter((item:any)=>item.review_state==="rejected").map((item:any)=>item.id);const button=el<HTMLButtonElement>("save-case");button.disabled=true;button.textContent="Saving…";const result=await actions.crm.reviewComplaintCase({id,fields:values,accepted_document_ids:accepted,rejected_document_ids:rejected});button.disabled=false;button.textContent="Save confirmed fields";if(result.error)alert(result.error.message);else{dialog.close();await load()}});
    el("case-category-select").addEventListener("change",()=>renderSubcategoryOptions());el("case-subcategory-select").addEventListener("change",renderClassificationGuidance);el("save-classification").addEventListener("click",async()=>{const categoryId=el<HTMLSelectElement>("case-category-select").value;if(!categoryId){alert("Choose a category first.");return}const button=el<HTMLButtonElement>("save-classification");button.disabled=true;button.textContent="Saving and verifying…";const result=await actions.crm.saveCaseClassification({id,categoryId,subcategoryId:el<HTMLSelectElement>("case-subcategory-select").value,synchronize:true});button.disabled=false;button.textContent="Save and sync";if(result.error)alert(result.error.message);else if((result.data as any).status==="failed")alert((result.data as any).error||"Classification synchronization failed");else alert((result.data as any).synchronized?"Classification saved and verified in Helpdesk.":"Classification saved in PostgreSQL.");await load()});
    el("approve-fresh").addEventListener("click",async()=>{if(!confirm("Confirm that duplicate review is complete and this is a fresh complaint?"))return;const result=await actions.crm.approveFreshComplaint({id});alert(result.error?result.error.message:"Approved as fresh.");await load()});
    el("publish-case").addEventListener("click",async()=>{if(!confirm("Queue this exact approved package for Paperless upload?"))return;const result=await actions.crm.publishComplaint({id});alert(result.error?result.error.message:`Publication queued: ${result.data.task_id}`);await load()});
    el("pull-helpdesk-case").addEventListener("click",async()=>{const button=el<HTMLButtonElement>("pull-helpdesk-case");button.disabled=true;button.textContent="Pulling…";const result=await actions.crm.pullHelpdeskCaseWorkflow({id});button.disabled=false;button.textContent="Pull workflow";alert(result.error?result.error.message:`Workflow pull: ${(result.data as any).status}.`);await load()});
    el("sync-helpdesk-case").addEventListener("click",async()=>{const button=el<HTMLButtonElement>("sync-helpdesk-case");button.disabled=true;button.textContent="Synchronizing…";const result=await actions.crm.syncHelpdeskCase({id,force:false});if(result.error)alert(result.error.message);else if((result.data as any).status==="blocked")alert(`Helpdesk synchronization blocked: ${((result.data as any).blockers||[]).join(" · ")}`);else alert(`Helpdesk synchronization: ${(result.data as any).status}.`);await load()});
    await load();
  </script>
</CrmLayout>
