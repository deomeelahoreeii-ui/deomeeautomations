---
interface Props {
  runId: string;
  active: "overview" | "ready" | "manual" | "existing" | "decisions";
}

const { runId, active } = Astro.props;
const base = `/crm/intake/review/${runId}`;
const links = [
  ["overview", "Overview", "Run status and classifier activity"],
  ["ready", "Ready", "Confident candidates awaiting a decision"],
  ["manual", "Manual review", "Evidence requiring operator verification"],
  ["existing", "Already in Paperless", "Matched records that need no upload"],
  ["decisions", "Decisions", "Approved and rejected candidates"],
] as const;
---

<nav class="crm-workspace-nav" aria-label="Complaint review run views">
  {links.map(([id, label, detail]) => (
    <a href={`${base}/${id}`} class:list={{ active: active === id }} aria-current={active === id ? "page" : undefined}>
      <strong>{label}</strong>
      <small>{detail}</small>
    </a>
  ))}
</nav>

<style>
  .crm-workspace-nav{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));margin:1rem 0;border:1px solid #d8e3ea;border-radius:.8rem;background:#fff;overflow:hidden}.crm-workspace-nav a{display:grid;gap:.15rem;min-width:0;padding:.75rem .9rem;border-right:1px solid #e4ebf0;color:#516176;text-decoration:none}.crm-workspace-nav a:last-child{border-right:0}.crm-workspace-nav a:hover{background:#f5fafb}.crm-workspace-nav a.active{background:#eaf7f8;color:#0d7788;box-shadow:inset 0 -3px #16879a}.crm-workspace-nav strong{font-size:.78rem}.crm-workspace-nav small{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#7b8798;font-size:.64rem}@media(max-width:900px){.crm-workspace-nav{display:flex;overflow-x:auto}.crm-workspace-nav a{min-width:11rem}}
</style>
