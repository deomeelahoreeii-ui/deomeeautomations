---
import CrmCaseNav from "./CrmCaseNav.astro";
interface Props {
  caseId: string;
  active: "overview" | "evidence" | "details" | "publication" | "helpdesk" | "audit";
}
const { caseId, active } = Astro.props;
---
<section class="master-card crm-case-shared-header" id="case-shared-header">
  <div><p class="eyebrow">Complaint case</p><h2 id="case-page-title">Loading complaint…</h2><div class="crm-case-header-meta" id="case-page-meta"><span>Loading case state…</span></div></div>
  <div class="crm-case-header-state"><span class="crm-run-state" id="case-page-state">Loading</span><a class="btn btn-sm btn-primary" id="case-next-action" href={`/crm/cases/${caseId}/overview`}>Open overview</a></div>
</section>
<CrmCaseNav caseId={caseId} active={active} />
<style>.crm-case-shared-header{display:flex;align-items:center;justify-content:space-between;gap:1.5rem;padding:1rem 1.2rem}.crm-case-shared-header h2{margin:.12rem 0;font-size:1.45rem}.crm-case-header-meta{display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;color:#6d7b8e;font-size:.72rem}.crm-case-header-meta span+span:before{content:"•";margin-right:.5rem}.crm-case-header-state{display:flex;align-items:center;justify-content:flex-end;gap:.55rem;flex-wrap:wrap}@media(max-width:700px){.crm-case-shared-header{align-items:flex-start;flex-direction:column}.crm-case-header-state{justify-content:flex-start}}</style>
