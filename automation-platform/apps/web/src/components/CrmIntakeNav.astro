---
interface Props {
  active: "intake" | "runs" | "review" | "spreadsheets" | "packages";
}
const { active } = Astro.props;
const links = [
  ["intake", "Capture", "Find the conversation", "/crm/intake/"],
  ["runs", "Intake runs", "Verify captured evidence", "/crm/intake/batches"],
  ["review", "Review", "Decide complaint candidates", "/crm/intake/review"],
  ["spreadsheets", "Spreadsheets", "Review workbook rows", "/crm/intake/spreadsheets"],
  ["packages", "Packages", "Download approved evidence", "/crm/intake/packages"],
];
---
<nav class="crm-intake-flow" aria-label="CRM complaint intake workflow">
  {links.map(([id, label, detail, href], index) => (
    <a class:list={{ active: active === id }} href={href} aria-current={active === id ? "step" : undefined}>
      <span class="crm-intake-flow-number">{index + 1}</span>
      <span><strong>{label}</strong><small>{detail}</small></span>
    </a>
  ))}
</nav>
