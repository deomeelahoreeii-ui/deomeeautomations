---
interface Props {
  active: "fetch" | "batches" | "processing" | "packages" | "storage";
}
const { active } = Astro.props;
const links = [
  ["fetch", "Fetch files", "/whatsapp/inbound-files"],
  ["batches", "Inbound batches", "/whatsapp/inbound-batches"],
  ["processing", "Processing & review", "/whatsapp/inbound-processing"],
  ["packages", "Download packages", "/whatsapp/inbound-exports"],
  ["storage", "Object storage", "/whatsapp/inbound-storage"],
];
---
<nav class="directory-tabs inbound-subnav" aria-label="WhatsApp inbound file management">
  {links.map(([id, label, href]) => <a class:list={{ active: active === id }} href={href}>{label}</a>)}
</nav>
