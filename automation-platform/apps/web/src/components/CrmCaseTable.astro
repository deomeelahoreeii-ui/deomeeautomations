---
import DataTable from "./DataTable.astro";
interface Props { view?: "registry" | "publication" }
const { view = "registry" } = Astro.props;
---
<section class="master-card crm-case-table-card" data-case-table data-view={view}>
  <div class="inbound-card-heading"><div><p class="eyebrow">{view === "publication" ? "Paperless publication" : "Durable complaint registry"}</p><h2>{view === "publication" ? "Approved cases awaiting publication" : "Complaint cases"}</h2><p>{view === "publication" ? "Select only verified cases. Each package is published once with its accepted evidence roles." : "One row per complaint number, regardless of how many times its evidence was captured."}</p></div>{view === "publication" && <button class="btn btn-sm btn-primary" data-publish-selected type="button" disabled>Publish selected</button>}</div>
  <div class="toolbar crm-case-filter-grid"><input class="input input-bordered input-sm" data-case-search placeholder="Search complaint number, name, mobile or CNIC"/><select class="select select-bordered select-sm" data-case-state aria-label="Case state"><option value="">All case states</option><option value="needs_review">Needs review</option><option value="candidate">Candidate</option><option value="review_required">Review required</option><option value="fresh">Approved — ready for publication</option><option value="existing">Existing in Paperless</option><option value="publishing">Publishing</option><option value="published">Published</option><option value="rejected">Rejected</option></select><select class="select select-bordered select-sm" data-paperless aria-label="Paperless result"><option value="">All Paperless results</option><option value="unmatched">Not linked to Paperless</option><option value="existing">Any existing Paperless record</option><option value="submitted">Existing · Submitted</option><option value="uploaded_pending">Existing · Pending</option><option value="uploaded_not_relevant">Existing · Not Relevant</option></select><select class="select select-bordered select-sm" data-publication aria-label="Publication readiness"><option value="">Any publication readiness</option><option value="ready">Ready to publish</option><option value="blocked">Blocked from publication</option></select><button class="btn btn-sm" data-clear type="button">Clear filters</button><span class="toolbar-status" data-case-count>Loading…</span></div>
  <details class="crm-advanced-filters"><summary>More filters</summary><div><select class="select select-bordered select-sm" data-reply aria-label="Reply lifecycle"><option value="">Any reply status</option><option value="awaiting">Awaiting reply</option><option value="actionable">Reply action required</option><option value="completed">Approved or issued</option><option value="ineligible">Not in reply lifecycle</option></select><select class="select select-bordered select-sm" data-dispatch aria-label="Dispatch lifecycle"><option value="">Any dispatch status</option><option value="upward_sent">Sent upward</option><option value="upward_in_progress">Upward dispatch in progress</option><option value="downward_sent">Sent downward</option><option value="attention">Dispatch needs attention</option><option value="not_started">Dispatch not started</option></select><select class="select select-bordered select-sm" data-helpdesk aria-label="Helpdesk synchronization"><option value="">Any Helpdesk status</option><option value="not_synced">Not synchronized</option><option value="pending">Pending</option><option value="synchronized">Synchronized</option><option value="update_pending">Update pending</option><option value="failed">Failed</option></select><select class="select select-bordered select-sm" data-blocker aria-label="Publication blocker"><option value="">Any blocker</option><option value="complaint number">Complaint number</option><option value="remarks">Complaint remarks</option><option value="main complaint">Main complaint evidence</option><option value="Paperless">Already linked to Paperless</option></select><input class="input input-bordered input-sm" data-category placeholder="Category contains…"/><input class="input input-bordered input-sm" data-district placeholder="District contains…"/><input class="input input-bordered input-sm" data-tehsil placeholder="Tehsil contains…"/><input class="input input-bordered input-sm" data-from type="date" aria-label="Updated from"/><input class="input input-bordered input-sm" data-to type="date" aria-label="Updated through"/></div></details>
  <div class="alert" data-case-message hidden></div>
  <DataTable id={`complaint-cases-${view}`} pageSize={25} pageSizeOptions={[10,25,50,100]} emptyText="No complaint cases match these filters." ariaLabel={view === "publication" ? "Paperless publication queue" : "Complaint case registry"}/>
</section>
<style is:global>.crm-case-table-card{padding:1.05rem 1.15rem}.crm-case-table-card h2{margin:.12rem 0}.crm-case-table-card .inbound-card-heading p:last-child{margin:.25rem 0 0;color:#68778a}.crm-case-filter-grid{display:grid;grid-template-columns:minmax(16rem,1fr) 14rem 14rem 13rem auto auto;gap:.5rem;align-items:center;margin:.9rem 0 .55rem}.crm-case-filter-grid .toolbar-status{justify-self:end;color:#6c7a8d;font-size:.72rem}.crm-advanced-filters{margin-bottom:.8rem;border:1px solid #e1e8ed;border-radius:.65rem;background:#f8fbfc}.crm-advanced-filters summary{cursor:pointer;padding:.55rem .7rem;color:#5f6f82;font-size:.72rem;font-weight:750}.crm-advanced-filters>div{display:grid;grid-template-columns:repeat(5,minmax(8rem,1fr));gap:.5rem;border-top:1px solid #e1e8ed;padding:.65rem}.crm-case-primary{display:block;color:#28374b;font-weight:800}.crm-case-secondary{display:block;margin-top:.15rem;color:#758396;font-size:.68rem}.crm-case-state{display:inline-flex;border-radius:999px;background:#edf3f6;padding:.25rem .5rem;color:#526476;font-size:.67rem;font-weight:800}.crm-case-state.fresh,.crm-case-state.published{background:#e7f8f1;color:#176b57}.crm-case-state.existing{background:#e8f4fa;color:#14677a}.crm-case-state.review_required,.crm-case-state.candidate{background:#fff3dc;color:#895607}.crm-case-state.rejected{background:#fff0f1;color:#9e3038}.crm-case-state.publishing{background:#eaeefe;color:#4054a7}.crm-case-actions{display:flex;justify-content:flex-end;gap:.35rem}.crm-publication-ready{color:#176b57;font-weight:800}.crm-publication-blocked{display:block;max-width:16rem;color:#8a5419;font-size:.68rem}.crm-case-selection{display:grid;place-items:center}.crm-case-selection input{accent-color:#16879a}@media(max-width:1150px){.crm-case-filter-grid{grid-template-columns:1fr 1fr 1fr}.crm-advanced-filters>div{grid-template-columns:repeat(3,1fr)}}@media(max-width:700px){.crm-case-filter-grid,.crm-advanced-filters>div{grid-template-columns:1fr}.crm-case-filter-grid .toolbar-status{justify-self:start}}</style>
<script>
  import { actions } from "astro:actions";
  import { caseStateLabel, paperlessLinkSummary, processingStatusLabel } from "../lib/crm-status";
  await customElements.whenDefined("astro-data-table");
  const root=document.querySelector<HTMLElement>("[data-case-table]")!,view=root.dataset.view!,table=root.querySelector<any>("astro-data-table"),find=<T extends HTMLElement>(selector:string)=>root.querySelector<T>(selector)!;
  const search=find<HTMLInputElement>("[data-case-search]"),state=find<HTMLSelectElement>("[data-case-state]"),paperless=find<HTMLSelectElement>("[data-paperless]"),publication=find<HTMLSelectElement>("[data-publication]"),reply=find<HTMLSelectElement>("[data-reply]"),dispatch=find<HTMLSelectElement>("[data-dispatch]"),helpdesk=find<HTMLSelectElement>("[data-helpdesk]"),blocker=find<HTMLSelectElement>("[data-blocker]"),category=find<HTMLInputElement>("[data-category]"),district=find<HTMLInputElement>("[data-district]"),tehsil=find<HTMLInputElement>("[data-tehsil]"),from=find<HTMLInputElement>("[data-from]"),to=find<HTMLInputElement>("[data-to]"),count=find<HTMLElement>("[data-case-count]"),message=find<HTMLElement>("[data-case-message]"),publishSelected=root.querySelector<HTMLButtonElement>("[data-publish-selected]");
  const selected=new Set<string>();let visibleRows:any[]=[];let searchTimer:number|undefined;const params=new URLSearchParams(location.search);
  const controls:Record<string,HTMLInputElement|HTMLSelectElement>={q:search,state,paperless,publication,reply,dispatch,helpdesk,blocker,category,district,tehsil,from,to};for(const [key,control] of Object.entries(controls))control.value=params.get(key)||"";if(view==="publication"){state.value="fresh";state.hidden=true;publication.value=publication.value||"ready"}
  const initialPage=Math.max(0,Number(params.get("page")||1)-1),initialPageSize=Math.max(1,Number(params.get("page_size")||25)),initialSort=params.get("sort")||"updated_at",initialOrder=params.get("order")==="asc"?"asc":"desc";
  const primary=(value:any,secondary="")=>{const wrap=document.createElement("div"),strong=document.createElement("strong");strong.className="crm-case-primary";strong.textContent=String(value||"—");wrap.append(strong);if(secondary){const small=document.createElement("small");small.className="crm-case-secondary";small.textContent=secondary;wrap.append(small)}return wrap};
  const badge=(value:any)=>{const span=document.createElement("span");span.className=`crm-case-state ${String(value||"")}`;span.textContent=caseStateLabel(value);return span};
  const selection=(row:any)=>{const label=document.createElement("label"),input=document.createElement("input");label.className="crm-case-selection";input.type="checkbox";input.checked=selected.has(row.id);input.setAttribute("aria-label",`Select complaint ${row.complaint_number}`);input.addEventListener("change",()=>{input.checked?selected.add(row.id):selected.delete(row.id);syncSelection()});label.append(input);return label};
  const selectionHeader=()=>{const label=document.createElement("label"),input=document.createElement("input"),ids=visibleRows.filter(row=>row.publication_ready).map(row=>row.id);label.className="crm-case-selection";input.type="checkbox";input.checked=ids.length>0&&ids.every(id=>selected.has(id));input.indeterminate=ids.some(id=>selected.has(id))&&!input.checked;input.setAttribute("aria-label","Select visible publishable cases");input.addEventListener("change",()=>{for(const id of ids)input.checked?selected.add(id):selected.delete(id);syncSelection();void table.refresh(false)});label.append(input);return label};
  function paperlessCell(row:any){const result=row.paperless_result||{},sync=result.status_sync||{},syncNote=sync.state==="failed"?`Dispatch status sync failed: ${sync.last_error||"retry required"}`:sync.state==="pending"||sync.state==="syncing"?`Dispatch status sync ${sync.state}`:result.reason||"";return primary(paperlessLinkSummary(result.document_id||row.paperless_document_id,result.category,result.statuses||[]),syncNote)}
  const lifecycleLabel=(value:any)=>String(value||"not_started").replaceAll("_"," ").replace(/\b\w/g,(letter)=>letter.toUpperCase());
  function replyCell(row:any){const item=row.lifecycle?.reply||{};return primary(item.status||"Not eligible",item.awaiting?"No reply prepared":item.actionable?"Action still required":item.completed?"Reply lifecycle complete":"Outside reply lifecycle")}
  function dispatchCell(row:any){const item=row.lifecycle?.dispatch||{},up=item.upward||{},down=item.downward||{};return primary(`Upward: ${lifecycleLabel(up.status)}`,`Downward: ${lifecycleLabel(down.status)}${item.attention?" · attention required":""}`)}
  function readiness(row:any){const status=row.publication_status||"not_approved";if(["published","publishing","existing"].includes(status))return primary(lifecycleLabel(status),status==="existing"?"Matched an existing Paperless record":"Paperless publication lifecycle");if(row.publication_ready){const span=document.createElement("span");span.className="crm-publication-ready";span.textContent="Ready";return span}const small=document.createElement("small");small.className="crm-publication-blocked";small.textContent=(row.publication_blockers||[])[0]||row.publication_error||(status==="not_approved"?"Awaiting intake approval":"Not ready");return small}
  function action(row:any){const wrap=document.createElement("div");wrap.className="crm-case-actions";const link=document.createElement("a");link.className="btn btn-xs btn-primary";const destination=["candidate","review_required"].includes(row.state)?"evidence":row.state==="fresh"?"publication":row.state==="published"?"helpdesk":"overview";link.href=`/crm/cases/${row.id}/${destination}`;link.textContent=row.state==="fresh"?"Publish →":["candidate","review_required"].includes(row.state)?"Review →":"Open →";wrap.append(link);return wrap}
  function isoDate(value:string,end=false){if(!value)return undefined;const date=new Date(`${value}T00:00:00`);if(end)date.setDate(date.getDate()+1);return date.toISOString()}
  function showMessage(text:string,error=false){message.hidden=!text;message.className=`alert ${error?"alert-error":"alert-success"}`;message.textContent=text}
  function syncSelection(){if(!publishSelected)return;publishSelected.disabled=selected.size===0;publishSelected.textContent=selected.size?`Publish selected (${selected.size})`:"Publish selected"}
  function syncUrl(pagination?:any,sorting?:any[]){const url=new URL(location.href);for(const [key,control] of Object.entries(controls)){if(view==="publication"&&key==="state")continue;control.value?url.searchParams.set(key,control.value):url.searchParams.delete(key)}if(pagination){url.searchParams.set("page",String(pagination.pageIndex+1));url.searchParams.set("page_size",String(pagination.pageSize))}if(sorting){const current=sorting[0];current?url.searchParams.set("sort",current.id):url.searchParams.delete("sort");current?url.searchParams.set("order",current.desc?"desc":"asc"):url.searchParams.delete("order")}history.replaceState({},"",url)}
  const columns:any[]=[];if(view==="publication")columns.push({id:"select",header:selectionHeader,cell:({row}:any)=>row.original.publication_ready?selection(row.original):"",enableSorting:false,meta:{width:"2.8rem"}});columns.push({accessorKey:"complaint_number",header:"Complaint",cell:({row}:any)=>primary(row.original.complaint_number,row.original.complainant_name||"Complainant not confirmed")},{accessorKey:"category",header:"Classification",cell:({row}:any)=>primary(row.original.category||"Not classified",row.original.sub_category||"")},{accessorKey:"district",header:"Location",cell:({row}:any)=>primary(row.original.district||"—",row.original.tehsil||"")},{accessorKey:"document_count",header:"Evidence",cell:({row}:any)=>`${row.original.document_count} file${row.original.document_count===1?"":"s"}`},{accessorKey:"state",header:"Intake / publication",cell:({row}:any)=>badge(row.original.state)},{id:"paperless",header:"Paperless record",cell:({row}:any)=>paperlessCell(row.original),enableSorting:false,meta:{minWidth:"15rem"}},{id:"readiness",header:"Paperless publication",cell:({row}:any)=>readiness(row.original),enableSorting:false},{id:"reply",header:"Reply lifecycle",cell:({row}:any)=>replyCell(row.original),enableSorting:false,meta:{minWidth:"12rem"}},{id:"dispatch",header:"Dispatch lifecycle",cell:({row}:any)=>dispatchCell(row.original),enableSorting:false,meta:{minWidth:"13rem"}},{accessorKey:"frappe_sync_status",header:"Helpdesk sync",cell:({row}:any)=>processingStatusLabel(row.original.frappe_sync_status)},{accessorKey:"updated_at",header:"Updated",cell:({row}:any)=>new Date(row.original.updated_at).toLocaleString()},{id:"actions",header:"",cell:({row}:any)=>action(row.original),enableSorting:false,meta:{align:"right"}});
  await table.configure({manualPagination:true,columns,getRowId:(row:any)=>row.id,initialPageIndex:initialPage,initialPageSize,initialSorting:[{id:initialSort,desc:initialOrder==="desc"}],onPageChange:(paginationState:any)=>syncUrl(paginationState),onSortingChange:(sorting:any[])=>syncUrl(undefined,sorting),loadPage:async(pageIndex:number,pageSize:number,sorting:any[])=>{const current=sorting[0],result=await actions.crm.cases({search:search.value.trim(),state:view==="publication"?"fresh":state.value,publication:publication.value,paperless:paperless.value,reply:reply.value,dispatch:dispatch.value,helpdeskStatus:helpdesk.value,blocker:blocker.value,category:category.value.trim(),district:district.value.trim(),tehsil:tehsil.value.trim(),updatedFrom:isoDate(from.value),updatedTo:isoDate(to.value,true),limit:pageSize,offset:pageIndex*pageSize,sort:current?.id||"updated_at",order:current?.desc===false?"asc":"desc"});if(result.error)throw new Error(result.error.message);const data=result.data as any;visibleRows=data.items||[];count.textContent=`${data.total} case${data.total===1?"":"s"}`;for(const id of selected)if(!visibleRows.some((row:any)=>row.id===id)||!visibleRows.find((row:any)=>row.id===id)?.publication_ready)selected.delete(id);syncSelection();return{rows:visibleRows,total:Number(data.total||0)}}});
  async function refresh(){selected.clear();syncSelection();syncUrl({pageIndex:0,pageSize:table.getPagination().pageSize});await table.refresh(true)}for(const control of [state,paperless,publication,reply,dispatch,helpdesk,blocker,category,district,tehsil,from,to])control.addEventListener("change",()=>void refresh());for(const control of [category,district,tehsil])control.addEventListener("input",()=>{if(searchTimer)clearTimeout(searchTimer);searchTimer=window.setTimeout(()=>void refresh(),300)});search.addEventListener("input",()=>{if(searchTimer)clearTimeout(searchTimer);searchTimer=window.setTimeout(()=>void refresh(),250)});find("[data-clear]").addEventListener("click",()=>{for(const control of Object.values(controls) as HTMLInputElement[])control.value="";if(view==="publication"){state.value="fresh";publication.value="ready"}void refresh()});publishSelected?.addEventListener("click",async()=>{const caseIds=[...selected];if(!caseIds.length||!confirm(`Publish ${caseIds.length} selected complaint case${caseIds.length===1?"":"s"} to Paperless?`))return;publishSelected.disabled=true;const result=await actions.crm.publishComplaintBatch({caseIds});if(result.error){showMessage(result.error.message,true);syncSelection();return}selected.clear();showMessage(`${(result.data as any).queued_count} complaint case(s) queued for Paperless publication.`);await table.refresh(false);syncSelection()});
</script>
