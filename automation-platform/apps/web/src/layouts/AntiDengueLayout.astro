---
import AppLayout from "./AppLayout.astro";

interface Props {
  title: string;
  description: string;
  page: "dashboard" | "routing" | "schedules" | "run-history" | "dispatch-plans" | "manual-reports" | "activity-rules" | "simple-activity-rules" | "messages" | "settings";
}

const { title, description, page } = Astro.props;
const links = [
  ["dashboard", "Dashboard", "/"],
  ["routing", "Routing", "/antidengue/routing"],
  ["schedules", "Schedules", "/antidengue/schedules"],
  ["dispatch-plans", "Runs & Plans", "/antidengue/dispatch-plans"],
  ["manual-reports", "Manual Reports", "/antidengue/manual-reports"],
  ["activity-rules", "Activity Rules", "/antidengue/activity-rules"],
  ["simple-activity-rules", "Timing Rules", "/antidengue/simple-activity-rules"],
  ["messages", "Messages", "/antidengue/messages"],
  ["settings", "Settings", "/antidengue/settings"],
];
---

<AppLayout title={title} eyebrow="Operations / AntiDengue" description={description} active="antidengue">
  <slot name="actions" slot="actions" />
  <nav class="section-tabs" aria-label="AntiDengue pages">
    {links.map(([id, label, href]) => <a class:list={{ active: page === id || (id === "dispatch-plans" && page === "run-history") }} href={href}>{label}</a>)}
  </nav>
  <slot />
  <script>
    import { startAntiDengueNotificationListener } from "../lib/antidengue-notifications";
    startAntiDengueNotificationListener();
  </script>
</AppLayout>
