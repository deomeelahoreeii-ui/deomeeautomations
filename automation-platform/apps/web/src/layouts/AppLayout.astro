---
import "../styles/global.css";
import "../styles/master-data.css";
import "../styles/whatsapp.css";
import "../styles/crm.css";

interface Props {
  title: string;
  eyebrow: string;
  description: string;
  active?: string;
}

const { title, eyebrow, description, active = "master-data" } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="automation">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title} · Automation Platform</title>
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("automation-theme");
        const dark = stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = dark ? "automation-dark" : "automation";
      })();
    </script>
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <a class="brand" href="/">
          <span class="brand-mark">D</span>
          <span><strong>Deomee</strong><small>Automation Platform</small></span>
        </a>
        <nav class="primary-nav" aria-label="Platform modules">
          <p class="nav-label">Operations</p>
          <a class:list={["nav-item", { active: active === "antidengue" }]} href="/">
            <span class="nav-icon">◉</span> AntiDengue
          </a>
          <a class:list={["nav-item", { active: active === "whatsapp" }]} href="/whatsapp/">
            <span class="nav-icon">●</span> WhatsApp
          </a>
          <a class:list={["nav-item", { active: active === "crm" }]} href="/crm/intake/">
            <span class="nav-icon">◆</span> CRM
          </a>
          <span class="nav-item muted"><span class="nav-icon">◇</span> PMDU <small>Later</small></span>
          <p class="nav-label nav-label-spaced">Management</p>
          <a class:list={["nav-item", { active: active === "master-data" }]} href="/master-data/">
            <span class="nav-icon">▦</span> Master Data
          </a>
          <span class="nav-item muted"><span class="nav-icon">≡</span> All jobs</span>
          <span class="nav-item muted"><span class="nav-icon">⌁</span> System health</span>
        </nav>
        <div class="sidebar-status">
          <span class="status-dot"></span>
          <span><strong>API connected</strong><small id="api-status">Platform services available</small></span>
        </div>
      </aside>

      <main class="content master-content">
        <header class="topbar master-topbar">
          <div>
            <p class="eyebrow">{eyebrow}</p>
            <h1>{title}</h1>
            <p>{description}</p>
          </div>
          <div class="topbar-actions">
            <slot name="actions" />
            <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">◐</button>
          </div>
        </header>
        <slot />
      </main>
    </div>
    <script is:inline>
      const button = document.getElementById("theme-toggle");
      const updateLabel = () => {
        const dark = document.documentElement.dataset.theme === "automation-dark";
        if (button) {
          button.textContent = dark ? "☀" : "☾";
          button.setAttribute("aria-label", dark ? "Use light mode" : "Use dark mode");
          button.setAttribute("title", dark ? "Use light mode" : "Use dark mode");
        }
      };
      button?.addEventListener("click", () => {
        const dark = document.documentElement.dataset.theme !== "automation-dark";
        document.documentElement.dataset.theme = dark ? "automation-dark" : "automation";
        localStorage.setItem("automation-theme", dark ? "dark" : "light");
        updateLabel();
      });
      updateLabel();
    </script>
  </body>
</html>
