---
import AppLayout from "./AppLayout.astro";

interface Props {
  title: string;
  description: string;
  page:
    | "intake"
    | "cases"
    | "replies"
    | "taxonomy"
    | "knowledge"
    | "helpdesk"
    | "sheet-filter"
    | "pdf-filter"
    | "sheet-to-pdf";
}

const { title, description, page } = Astro.props;

// Keep the stable tuple contract used by the WhatsApp/CRM ownership tests while
// extending the lifecycle navigation with the Bundle 3.1 workspaces.
const links = [
  ["intake", "Complaint Intake", "/crm/intake/"],
  ["cases", "Complaint Cases", "/crm/cases/"],
  ["replies", "Reply Workspace", "/crm/replies/"],
  ["taxonomy", "Taxonomy", "/crm/taxonomy/"],
  ["knowledge", "AI Reply Archive", "/crm/knowledge/"],
  ["helpdesk", "Helpdesk Sync", "/crm/helpdesk/"],
] as const;

const bulkToolPages = ["sheet-filter", "pdf-filter", "sheet-to-pdf"] as const;
---

<AppLayout title={title} eyebrow="Operations / CRM" description={description} active="crm">
  <slot name="actions" slot="actions" />
  <nav class="section-tabs crm-lifecycle-tabs" aria-label="CRM pages">
    {links.map(([id, label, href]) => (
      <a class:list={{ active: page === id }} href={href}>{label}</a>
    ))}
    <a class:list={{ active: bulkToolPages.includes(page as typeof bulkToolPages[number]) }} href="/crm/">
      Bulk Tools
    </a>
  </nav>
  <slot />
</AppLayout>

<style>
  .crm-lifecycle-tabs{overflow-x:auto;scrollbar-width:thin;white-space:nowrap}
</style>
