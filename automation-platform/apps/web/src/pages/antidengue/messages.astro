---
import DataTable from "../../components/DataTable.astro";
import AntiDengueLayout from "../../layouts/AntiDengueLayout.astro";
---

<AntiDengueLayout
  title="AntiDengue messages"
  description="Manage the message pools used by AntiDengue reporting and review exactly what can be sent."
  page="messages"
>
  <button class="btn btn-sm btn-primary" id="add-variant" slot="actions">＋ Add acknowledgement</button>

  <div class="notice">
    <strong>Saved message configuration</strong><br />
    Changes apply to future Test Runs, Send Now runs and schedules. Already-created previews remain frozen with their original text.
  </div>

  <section style="margin-top:1.25rem">
    <div class="panel-heading">
      <div>
        <p class="eyebrow">Report and profile messages</p>
        <h2>Messages used by each routing profile</h2>
        <p>Profiles sharing one template are shown together. Edit the shared default once, or assign a separate template from Routing when wording must differ.</p>
      </div>
      <span class="badge" id="report-message-count">Loading…</span>
    </div>
    <div id="report-message-groups" style="display:grid;gap:1rem;margin-top:1rem"></div>
  </section>

  <section class="notification-settings-grid" style="margin-top:1.5rem">
    <article class="panel notification-settings-panel">
      <div class="panel-heading">
        <div><p class="eyebrow">Message category</p><h2>Zero dormant schools</h2><p>Positive acknowledgement sent to the configured tehsil group instead of a report attachment.</p></div>
        <span class="badge" id="pool-count">Loading…</span>
      </div>
      <p class="field-help">Available variables: <code>&#123;&#123;tehsil&#125;&#125;</code>, <code>&#123;&#123;wing&#125;&#125;</code>, <code>&#123;&#123;report_date&#125;&#125;</code>, <code>&#123;&#123;checked_at&#125;&#125;</code>, <code>&#123;&#123;group_name&#125;&#125;</code>, and <code>&#123;&#123;submission_deadline&#125;&#125;</code>.</p>
    </article>
    <aside class="panel notification-help-panel">
      <p class="eyebrow">Selection rule</p><h2>Predictable rotation</h2>
      <p>The same Test Run always freezes the exact selected text in its preview. Editing the pool later cannot change an already-created preview.</p>
    </aside>
  </section>

  <article class="master-card" style="margin-top: 1.25rem">
    <DataTable id="acknowledgement-table" pageSize={10} emptyText="No acknowledgement variants are configured. Add and enable at least one variant." />
  </article>

  <dialog class="modal" id="variant-dialog">
    <div class="modal-box master-modal">
      <div class="modal-title"><h2 id="variant-title">Add acknowledgement variant</h2><button type="button" id="close-variant">×</button></div>
      <form class="master-form" id="variant-form">
        <input type="hidden" id="variant-id" />
        <input type="hidden" id="variant-key" />
        <label><span>Variant name *</span><input class="input input-bordered input-sm" id="variant-name" required /></label>
        <label><span>Status</span><select class="select select-bordered select-sm" id="variant-enabled"><option value="true">Enabled in pool</option><option value="false">Disabled</option></select></label>
        <label class="full"><span>Message body *</span><textarea class="textarea textarea-bordered textarea-sm" rows="8" id="variant-body" required></textarea></label>
        <div class="form-actions"><button class="btn btn-sm" type="button" id="cancel-variant">Cancel</button><button class="btn btn-sm btn-primary" type="submit">Save variant</button></div>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <dialog class="modal" id="report-template-dialog">
    <div class="modal-box master-modal" style="max-width:920px">
      <div class="modal-title"><h2 id="report-template-title">Edit report message</h2><button type="button" id="close-report-template">×</button></div>
      <form class="master-form" id="report-template-form">
        <input type="hidden" id="report-template-id" />
        <label><span>Message category</span><input class="input input-bordered input-sm" id="report-template-category" disabled /></label>
        <label><span>Used by profiles</span><input class="input input-bordered input-sm" id="report-template-profiles" disabled /></label>
        <label class="full"><span>Message template *</span><textarea class="textarea textarea-bordered textarea-sm" rows="18" id="report-template-body" required></textarea></label>
        <div class="notice full" id="report-template-help"></div>
        <section class="panel full" style="padding:1rem">
          <p class="eyebrow">Sample preview</p>
          <pre id="report-template-preview" style="white-space:pre-wrap;font:inherit;margin:.5rem 0 0"></pre>
        </section>
        <div class="form-actions full"><button class="btn btn-sm" type="button" id="cancel-report-template">Cancel</button><button class="btn btn-sm btn-primary" type="submit">Save message</button></div>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    import { actions } from "astro:actions";
    import { actionButtons, badge, stack } from "../../scripts/table-cells";
    import { confirmAction, showError, showSuccess } from "../../scripts/alerts";

    await customElements.whenDefined("astro-data-table");
    const table = document.getElementById("acknowledgement-table") as any;
    const dialog = document.getElementById("variant-dialog") as HTMLDialogElement;
    const reportDialog = document.getElementById("report-template-dialog") as HTMLDialogElement;
    const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    let application: any;
    let reportType: any;
    let hotspotReportType: any;
    let simpleActivityReportType: any;
    let tehsilScope: any;
    let variants: any[] = [];
    let allTemplates: any[] = [];
    let profiles: any[] = [];
    let editingReportTemplate: any;
    let editingTemplateProfiles: any[] = [];

    const hotspotDefaultTemplate = `🚨 *Anti-Dengue Activities Requiring Review*
👥 *Group:* {{group_name}}
📌 *Scope:* {{scope_name}}
🕒 *Report window:* {{report_window}}

🏫 *School-wise activity evidence*

{{school_activity_details}}

{{attachment_note}}
{{disclaimer}}`;

    const hotspotSample: Record<string, string> = {
      group_name: "HEADS (M-EE) LAHORE OFFICIAL",
      scope_name: "DEO MEE",
      report_window: "12:00 AM – 04:30 PM (18 Jul 2026)",
      school_activity_details: `🏫 *1. GES EXAMPLE SCHOOL*
🆔 *EMIS:* \`35210001\`
📍 *Tehsil:* CITY  |  *Markaz:* EXAMPLE MARKAZ
🔸 *Activity 1*
📏 *Distance Difference (In meters):* 125.40
🗺️ *Google Maps:* https://www.google.com/maps?q=31.5204000,74.3587000`,
      attachment_note: "📎 The attached Excel file contains every selected activity and its evidence.",
      disclaimer: "⚠️ These are rule-based review candidates, not confirmed fake activities. Please verify each finding.",
    };

    const simpleDefaultTemplate = `⏱️ *Anti-Dengue Activity Timing Review*
👥 *Group:* {{group_name}}
📌 *Scope:* {{scope_name}}
🕒 *Report window:* {{report_window}}

🏫 *School-wise timing evidence*

{{school_activity_details}}

{{attachment_note}}
{{disclaimer}}`;
    const simpleSample: Record<string, string> = {
      ...hotspotSample,
      school_activity_details: `🏫 *1. GES EXAMPLE SCHOOL*
🆔 *EMIS:* \`35210001\`
📍 *Tehsil:* CITY  |  *Markaz:* EXAMPLE MARKAZ
⏱️ *Time Difference:* 245 seconds (4 min 5 sec)`,
      attachment_note: "📎 The attached Excel file contains every selected activity and its timing evidence.",
    };

    async function resolveConfiguration() {
      const result = await actions.whatsapp.configurationOptions();
      if (result.error) throw result.error;
      const options = result.data as any;
      application = options.applications.find((item: any) => item.key === "antidengue");
      reportType = options.report_types.find((item: any) => item.application_key === "antidengue" && item.key === "tehsil_dormant_summary");
      hotspotReportType = options.report_types.find((item: any) => item.application_key === "antidengue" && item.key === "hotspot_distance_activity");
      simpleActivityReportType = options.report_types.find((item: any) => item.application_key === "antidengue" && item.key === "simple_activity_timing");
      tehsilScope = options.recipient_scopes.find((item: any) => item.application_key === "antidengue" && item.channel === "group" && item.key === "tehsil");
      if (!application || !reportType || !hotspotReportType || !simpleActivityReportType || !tehsilScope) throw new Error("AntiDengue message configuration is incomplete.");
    }

    async function loadVariants() {
      variants = allTemplates.filter((item: any) =>
        item.application_id === application.id &&
        item.report_type_id === reportType.id &&
        item.category === "zero_result_acknowledgement" &&
        item.recipient_channel === "group" &&
        (!item.recipient_scope_id || item.recipient_scope_id === tehsilScope.id)
      );
      const active = variants.filter((item) => item.enabled).length;
      el("pool-count").textContent = `${active} enabled · ${variants.length} total`;
      return variants;
    }

    function reportTemplateBody(item: any) {
      if (item.body.trim() !== "{{report_body}}") return item.body;
      if (item.report_type_id === hotspotReportType.id) return hotspotDefaultTemplate;
      if (item.report_type_id === simpleActivityReportType.id) return simpleDefaultTemplate;
      return item.body;
    }

    function renderSample(body: string, activityReview: boolean, assignedProfiles: any[] = editingTemplateProfiles, simple = false) {
      if (!activityReview) return body.replace(/{{\s*report_body\s*}}/g, "[The generated report body appears here]");
      const hasAttachment = assignedProfiles.some((profile) => profile.presentation_policy?.attachment_mode !== "none");
      const source = simple ? simpleSample : hotspotSample;
      const sample = { ...source, attachment_note: hasAttachment ? source.attachment_note : "" };
      return body.replace(/{{\s*([a-zA-Z0-9_]+)\s*}}/g, (_match, key) => sample[key] || (key === "attachment_note" ? "" : `[${key}]`));
    }

    function openReportTemplate(item: any, assignedProfiles: any[]) {
      editingReportTemplate = item;
      editingTemplateProfiles = assignedProfiles;
      const hotspot = item.report_type_id === hotspotReportType.id;
      const simple = item.report_type_id === simpleActivityReportType.id;
      const body = reportTemplateBody(item);
      el("report-template-title").textContent = `Edit · ${item.report_type_name}`;
      el<HTMLInputElement>("report-template-id").value = item.id;
      el<HTMLInputElement>("report-template-category").value = `${item.report_type_name} · ${item.recipient_scope_name}`;
      el<HTMLInputElement>("report-template-profiles").value = assignedProfiles.map((profile) => profile.name).join(", ");
      el<HTMLTextAreaElement>("report-template-body").value = body;
      el("report-template-help").innerHTML = hotspot || simple
        ? `<strong>${simple ? "Simple Activity timing" : "Hotspot"} variables</strong><br><code>{{group_name}}</code>, <code>{{scope_name}}</code>, <code>{{report_window}}</code>, <code>{{school_activity_details}}</code>, <code>{{attachment_note}}</code>, and <code>{{disclaimer}}</code>. The school evidence block is required. <code>{{attachment_note}}</code> is automatically empty for Message only profiles.`
        : "<strong>Native report variable</strong><br>Keep <code>{{report_body}}</code> in this template to include the generated report details.";
      el("report-template-preview").textContent = renderSample(body, hotspot || simple, assignedProfiles, simple);
      reportDialog.showModal();
    }

    async function loadReportMessages() {
      const [templateResult, profileResult] = await Promise.all([
        actions.whatsapp.templates(),
        actions.whatsapp.dispatchProfiles({ applicationId: application.id, search: "", page: 1, pageSize: 100 }),
      ]);
      if (templateResult.error) throw templateResult.error;
      if (profileResult.error) throw profileResult.error;
      allTemplates = templateResult.data as any[];
      profiles = ((profileResult.data as any).items || []).filter((item: any) => item.enabled);
      const reportTemplates = allTemplates.filter((item: any) =>
        item.application_id === application.id && item.category === "report" &&
        profiles.some((profile) => profile.template_id === item.id)
      );
      const container = el("report-message-groups");
      container.replaceChildren();
      for (const item of reportTemplates.sort((a, b) =>
        `${a.report_type_name}:${a.recipient_scope_name}`.localeCompare(`${b.report_type_name}:${b.recipient_scope_name}`)
      )) {
        const assigned = profiles.filter((profile) => profile.template_id === item.id);
        const card = document.createElement("article");
        card.className = "panel";
        card.style.padding = "1.15rem";
        const heading = document.createElement("div");
        heading.className = "panel-heading";
        const copy = document.createElement("div");
        const eyebrow = document.createElement("p");
        eyebrow.className = "eyebrow";
        eyebrow.textContent = item.report_type_name;
        const title = document.createElement("h2");
        title.textContent = item.recipient_scope_name;
        const profileText = document.createElement("p");
        profileText.textContent = `Profiles: ${assigned.map((profile) => profile.name).join(", ")}`;
        copy.append(eyebrow, title, profileText);
        const edit = document.createElement("button");
        edit.className = "btn btn-sm";
        edit.textContent = "Edit message";
        edit.addEventListener("click", () => openReportTemplate(item, assigned));
        heading.append(copy, edit);
        const body = document.createElement("pre");
        body.style.cssText = "white-space:pre-wrap;font:inherit;background:var(--surface-subtle);padding:.85rem;border-radius:.5rem;margin:.85rem 0 0;max-height:12rem;overflow:auto";
        body.textContent = reportTemplateBody(item);
        card.append(heading, body);
        container.append(card);
      }
      if (!reportTemplates.length) container.textContent = "No enabled AntiDengue profile has an assigned report template.";
      el("report-message-count").textContent = `${reportTemplates.length} configured`;
      await loadVariants();
    }

    function openForm(item?: any) {
      el<HTMLFormElement>("variant-form").reset();
      el("variant-title").textContent = item ? "Edit acknowledgement variant" : "Add acknowledgement variant";
      el<HTMLInputElement>("variant-id").value = item?.id || "";
      el<HTMLInputElement>("variant-key").value = item?.key || `antidengue_zero_result_ack_${Date.now()}`;
      el<HTMLInputElement>("variant-name").value = item?.name || "";
      el<HTMLSelectElement>("variant-enabled").value = String(item?.enabled ?? true);
      el<HTMLTextAreaElement>("variant-body").value = item?.body || "";
      dialog.showModal();
    }

    async function save(item: any, enabled = item.enabled) {
      const result = await actions.whatsapp.saveTemplate({
        id: item.id || undefined,
        application_id: application.id,
        report_type_id: reportType.id,
        recipient_scope_id: tehsilScope.id,
        recipient_channel: "group",
        key: item.key,
        name: item.name,
        category: "zero_result_acknowledgement",
        body: item.body,
        enabled,
      });
      if (result.error) throw result.error;
    }

    await resolveConfiguration();
    await loadReportMessages();
    await table.configure({
      data: variants,
      columns: [
        { accessorKey: "name", header: "Variant", cell: ({ row }: any) => stack(row.original.name, row.original.key) },
        { accessorKey: "body", header: "Exact message" },
        { accessorKey: "enabled", header: "Pool status", cell: ({ row }: any) => badge(row.original.enabled ? "Enabled" : "Disabled", row.original.enabled ? "" : "inactive") },
        { id: "actions", header: "", cell: ({ row }: any) => actionButtons([
          { label: "Edit", onClick: () => openForm(row.original) },
          { label: row.original.enabled ? "Disable" : "Enable", onClick: async () => { try { await save(row.original, !row.original.enabled); await loadReportMessages(); await showSuccess("Pool updated", `${row.original.name} is now ${row.original.enabled ? "disabled" : "enabled"}.`); await table.setData(variants); } catch (error) { await showError(error); } } },
          { label: "Delete", tone: "danger", onClick: async () => { if (!await confirmAction("Delete this acknowledgement variant?", "Existing frozen previews will not change.", "Delete variant")) return; const result = await actions.whatsapp.hardDeleteTemplate({ id: row.original.id }); if (result.error) await showError(result.error); else { await loadReportMessages(); await showSuccess("Variant deleted", "The acknowledgement pool has been updated."); await table.setData(variants); } } },
        ]) },
      ],
    });

    el("add-variant").addEventListener("click", () => openForm());
    el("close-variant").addEventListener("click", () => dialog.close());
    el("cancel-variant").addEventListener("click", () => dialog.close());
    el("close-report-template").addEventListener("click", () => reportDialog.close());
    el("cancel-report-template").addEventListener("click", () => reportDialog.close());
    el<HTMLTextAreaElement>("report-template-body").addEventListener("input", () => {
      const hotspot = editingReportTemplate?.report_type_id === hotspotReportType.id;
      const simple = editingReportTemplate?.report_type_id === simpleActivityReportType.id;
      el("report-template-preview").textContent = renderSample(el<HTMLTextAreaElement>("report-template-body").value, hotspot || simple, editingTemplateProfiles, simple);
    });
    el("report-template-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      try {
        const body = el<HTMLTextAreaElement>("report-template-body").value;
        const result = await actions.whatsapp.saveTemplate({
          id: editingReportTemplate.id,
          application_id: editingReportTemplate.application_id,
          report_type_id: editingReportTemplate.report_type_id,
          recipient_scope_id: editingReportTemplate.recipient_scope_id || undefined,
          recipient_channel: editingReportTemplate.recipient_channel,
          key: editingReportTemplate.key,
          name: editingReportTemplate.name,
          category: "report",
          body,
          enabled: true,
        });
        if (result.error) throw result.error;
        reportDialog.close();
        await loadReportMessages();
        await table.setData(variants);
        await showSuccess("Report message saved", `Future runs for ${editingTemplateProfiles.length} profile(s) will use this text.`);
      } catch (error) { await showError(error); }
    });
    el("variant-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      try {
        await save({
          id: el<HTMLInputElement>("variant-id").value || undefined,
          key: el<HTMLInputElement>("variant-key").value,
          name: el<HTMLInputElement>("variant-name").value,
          body: el<HTMLTextAreaElement>("variant-body").value,
          enabled: el<HTMLSelectElement>("variant-enabled").value === "true",
        });
        dialog.close();
        await loadReportMessages();
        await showSuccess("Variant saved", "Future Test Runs can select this message from the enabled pool.");
        await table.setData(variants);
      } catch (error) { await showError(error); }
    });
  </script>
</AntiDengueLayout>
