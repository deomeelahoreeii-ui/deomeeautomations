---
import DataTable from "../../components/DataTable.astro";
import AntiDengueLayout from "../../layouts/AntiDengueLayout.astro";
---

<AntiDengueLayout
  title="Activity classification rules"
  description="Configure evidence-based rules that place portal activities into human review."
  page="activity-rules"
>
  <div class="page-actions" slot="actions">
    <a class="btn btn-sm" href="/antidengue/routing?view=hotspot">Manage routing profiles →</a>
    <button class="btn btn-sm btn-primary" id="add-rule">＋ Add rule</button>
  </div>

  <div class="notice">
    <strong>Automatic matches are not confirmed fake activities.</strong><br />
    Rules create a <em>Review required</em> classification. A human reviewer must later confirm or dismiss each finding.
    Submission times use Asia/Karachi, with an inclusive start and exclusive end.
  </div>

  <section class="notification-settings-grid" style="margin-top:1.25rem">
    <article class="panel notification-settings-panel">
      <div class="panel-heading">
        <div><p class="eyebrow">Rule versions</p><h2>Published classification policy</h2><p>Drafts can be edited and tested. Publishing freezes the version used by future findings.</p></div>
        <span class="badge" id="rule-count">Loading…</span>
      </div>
    </article>
    <aside class="panel notification-help-panel">
      <p class="eyebrow">Boundary contract</p><h2>Exact operators</h2>
      <p><code>&gt; 50</code> excludes exactly 50 metres. <code>≥ 50</code> includes it. Time ranges use <code>[start, end)</code> and can cross midnight.</p>
    </aside>
  </section>

  <article class="master-card" style="margin-top:1.25rem">
    <DataTable id="rules-table" pageSize={10} emptyText="No activity rules are configured. Add a draft and test it against the latest hotspot report." />
  </article>

  <dialog class="modal" id="rule-dialog">
    <div class="modal-box master-modal" style="max-width:900px">
      <div class="modal-title"><h2 id="rule-title">Add activity rule</h2><button type="button" id="close-rule">×</button></div>
      <form class="master-form" id="rule-form">
        <input type="hidden" id="rule-id" />
        <label class="full"><span>Rule name *</span><input class="input input-bordered input-sm" id="rule-name" required maxlength="180" /></label>
        <label><span>Conditions</span><select class="select select-bordered select-sm" id="match-mode"><option value="all">Match all enabled conditions</option><option value="any">Match any enabled condition</option></select></label>
        <label><span>Classification</span><input class="input input-bordered input-sm" value="Review required" disabled /></label>

        <fieldset class="full panel" style="padding:1rem">
          <label style="display:flex;gap:.6rem;align-items:center"><input type="checkbox" class="checkbox checkbox-sm" id="distance-enabled" checked /><strong>Distance condition</strong></label>
          <div class="notification-settings-grid" style="margin-top:.8rem">
            <label><span>Operator</span><select class="select select-bordered select-sm" id="distance-operator"><option value="gte">Equal to or greater than (≥)</option><option value="gt">Greater than (&gt;)</option></select></label>
            <label><span>Distance in metres</span><input type="number" min="0" step="0.01" class="input input-bordered input-sm" id="distance-threshold" value="50" /></label>
          </div>
        </fieldset>

        <fieldset class="full panel" style="padding:1rem">
          <label style="display:flex;gap:.6rem;align-items:center"><input type="checkbox" class="checkbox checkbox-sm" id="time-enabled" /><strong>Submission-time condition</strong></label>
          <div class="notification-settings-grid" style="margin-top:.8rem">
            <label><span>Mode</span><select class="select select-bordered select-sm" id="time-operator"><option value="between">Between these times</option><option value="outside">Outside these times</option></select></label>
            <label><span>Timezone</span><input class="input input-bordered input-sm" value="Asia/Karachi" disabled /></label>
            <label><span>Start — inclusive</span><input type="time" class="input input-bordered input-sm" id="time-start" value="00:00" /></label>
            <label><span>End — exclusive</span><input type="time" class="input input-bordered input-sm" id="time-end" value="07:00" /></label>
          </div>
        </fieldset>

        <div class="form-actions full">
          <button class="btn btn-sm" type="button" id="cancel-rule">Cancel</button>
          <button class="btn btn-sm" type="button" id="preview-rule">Test against latest report</button>
          <button class="btn btn-sm btn-primary" type="submit">Save draft</button>
        </div>
      </form>

      <section id="preview-results" hidden style="margin-top:1rem">
        <div class="notification-settings-grid">
          <article class="panel" style="padding:1rem"><span class="field-help">Matching activities</span><h2 id="preview-matches">—</h2></article>
          <article class="panel" style="padding:1rem"><span class="field-help">Total activities</span><h2 id="preview-total">—</h2></article>
          <article class="panel" style="padding:1rem"><span class="field-help">Unique submitters</span><h2 id="preview-submitters">—</h2></article>
          <article class="panel" style="padding:1rem"><span class="field-help">Unique hotspots</span><h2 id="preview-hotspots">—</h2></article>
        </div>
        <p class="field-help" id="preview-source" style="margin:.8rem 0"></p>
        <DataTable id="preview-table" pageSize={10} emptyText="This rule does not match any activity in the latest report." />
      </section>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    import { actions } from "astro:actions";
    import { actionButtons, badge, stack } from "../../scripts/table-cells";
    import { confirmAction, showError, showSuccess } from "../../scripts/alerts";

    await customElements.whenDefined("astro-data-table");
    const rulesTable = document.getElementById("rules-table") as any;
    const previewTable = document.getElementById("preview-table") as any;
    const dialog = document.getElementById("rule-dialog") as HTMLDialogElement;
    const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    let rules: any[] = [];
    let previewConfigured = false;

    function formPayload() {
      return {
        name: el<HTMLInputElement>("rule-name").value.trim(),
        classification: "review_required" as const,
        match_mode: el<HTMLSelectElement>("match-mode").value as "all" | "any",
        distance_enabled: el<HTMLInputElement>("distance-enabled").checked,
        distance_operator: el<HTMLSelectElement>("distance-operator").value as "gt" | "gte",
        distance_threshold_meters: Number(el<HTMLInputElement>("distance-threshold").value),
        time_enabled: el<HTMLInputElement>("time-enabled").checked,
        time_operator: el<HTMLSelectElement>("time-operator").value as "between" | "outside",
        time_start: el<HTMLInputElement>("time-start").value,
        time_end: el<HTMLInputElement>("time-end").value,
        timezone: "Asia/Karachi" as const,
        created_by: "web-operator",
      };
    }

    function conditionText(item: any) {
      const conditions = [];
      if (item.distance_enabled) conditions.push(`Distance ${item.distance_operator === "gt" ? ">" : "≥"} ${item.distance_threshold_meters} m`);
      if (item.time_enabled) conditions.push(`Time ${item.time_operator} ${item.time_start}–${item.time_end}`);
      return `${conditions.join(item.match_mode === "all" ? " AND " : " OR ")} · Asia/Karachi`;
    }

    async function loadRules() {
      const result = await actions.antidengue.activityRules();
      if (result.error) throw result.error;
      rules = (result.data as any).items || [];
      const enabled = rules.filter((item) => item.status === "published" && item.enabled).length;
      el("rule-count").textContent = `${enabled} active · ${rules.length} versions`;
      return rules;
    }

    function openForm(item?: any) {
      el<HTMLFormElement>("rule-form").reset();
      el("rule-title").textContent = item ? `Edit draft · version ${item.version}` : "Add activity rule";
      el<HTMLInputElement>("rule-id").value = item?.id || "";
      el<HTMLInputElement>("rule-name").value = item?.name || "Distance and submission-time review";
      el<HTMLSelectElement>("match-mode").value = item?.match_mode || "all";
      el<HTMLInputElement>("distance-enabled").checked = item?.distance_enabled ?? true;
      el<HTMLSelectElement>("distance-operator").value = item?.distance_operator || "gte";
      el<HTMLInputElement>("distance-threshold").value = String(item?.distance_threshold_meters ?? 50);
      el<HTMLInputElement>("time-enabled").checked = item?.time_enabled ?? false;
      el<HTMLSelectElement>("time-operator").value = item?.time_operator || "between";
      el<HTMLInputElement>("time-start").value = item?.time_start || "00:00";
      el<HTMLInputElement>("time-end").value = item?.time_end || "07:00";
      el("preview-results").hidden = true;
      dialog.showModal();
    }

    async function configurePreview(rows: any[]) {
      const columns = [
        { accessorKey: "hotspot_name", header: "Hotspot", cell: ({ row }: any) => stack(row.original.hotspot_name, `${row.original.town} · ${row.original.submitted_by}`) },
        { accessorKey: "distance_meters", header: "Distance", cell: ({ row }: any) => `${row.original.distance_meters ?? "—"} m` },
        { accessorKey: "activity_datetime", header: "Submitted" },
        { accessorKey: "explanation", header: "Why it matched" },
      ];
      if (!previewConfigured) { await previewTable.configure({ data: rows, columns }); previewConfigured = true; }
      else await previewTable.setData(rows);
    }

    await rulesTable.configure({
      data: await loadRules(),
      columns: [
        { accessorKey: "name", header: "Rule", cell: ({ row }: any) => stack(row.original.name, `Version ${row.original.version} · ${row.original.classification.replace("_", " ")}`) },
        { id: "conditions", header: "Classification conditions", cell: ({ row }: any) => conditionText(row.original) },
        { accessorKey: "status", header: "Version status", cell: ({ row }: any) => badge(row.original.status, row.original.status === "published" ? "" : "inactive") },
        { accessorKey: "enabled", header: "Evaluation", cell: ({ row }: any) => badge(row.original.enabled ? "Enabled" : "Disabled", row.original.enabled ? "" : "inactive") },
        { id: "actions", header: "", cell: ({ row }: any) => {
          const item = row.original;
          const buttons: any[] = [];
          if (item.status === "draft") buttons.push(
            { label: "Edit", onClick: () => openForm(item) },
            { label: "Publish", onClick: async () => { if (!await confirmAction("Publish this rule version?", "Published versions are immutable and will classify future hotspot reports.", "Publish rule")) return; const result = await actions.antidengue.publishActivityRule({ id:item.id }); if (result.error) await showError(result.error); else { await showSuccess("Rule published", "Future reports will use this exact rule version."); await rulesTable.setData(await loadRules()); } } },
          );
          if (item.status === "published") buttons.push(
            { label: "New version", onClick: async () => { const result = await actions.antidengue.createActivityRuleVersion({ id:item.id }); if (result.error) await showError(result.error); else { await rulesTable.setData(await loadRules()); openForm(result.data); } } },
            { label: item.enabled ? "Disable" : "Enable", onClick: async () => { const result = await actions.antidengue.setActivityRuleEnabled({ id:item.id, enabled:!item.enabled }); if (result.error) await showError(result.error); else { await showSuccess("Rule updated", `Rule is now ${item.enabled ? "disabled" : "enabled"}.`); await rulesTable.setData(await loadRules()); } } },
          );
          buttons.push({ label: "Archive", tone: "danger", onClick: async () => { if (!await confirmAction("Archive this rule version?", "It will no longer classify future reports.", "Archive")) return; const result = await actions.antidengue.archiveActivityRule({ id:item.id }); if (result.error) await showError(result.error); else await rulesTable.setData(await loadRules()); } });
          return actionButtons(buttons);
        } },
      ],
    });

    el("add-rule").addEventListener("click", () => openForm());
    el("close-rule").addEventListener("click", () => dialog.close());
    el("cancel-rule").addEventListener("click", () => dialog.close());
    el("preview-rule").addEventListener("click", async () => {
      try {
        const result = await actions.antidengue.previewActivityRule({ ...formPayload(), sample_size: 20 });
        if (result.error) throw result.error;
        const data = result.data as any;
        el("preview-results").hidden = false;
        el("preview-matches").textContent = String(data.matching_activities);
        el("preview-total").textContent = String(data.total_activities);
        el("preview-submitters").textContent = String(data.unique_submitters);
        el("preview-hotspots").textContent = String(data.unique_hotspots);
        el("preview-source").textContent = `Source: ${data.source.name} · ${data.source.sha256.slice(0, 12)}… · no findings saved`;
        await configurePreview(data.sample || []);
      } catch (error) { await showError(error); }
    });
    el("rule-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      try {
        const id = el<HTMLInputElement>("rule-id").value;
        const result = id
          ? await actions.antidengue.updateActivityRule({ id, ...formPayload() })
          : await actions.antidengue.createActivityRule(formPayload());
        if (result.error) throw result.error;
        dialog.close();
        await showSuccess("Draft saved", "Test the draft, then publish it when the classification is correct.");
        await rulesTable.setData(await loadRules());
      } catch (error) { await showError(error); }
    });
  </script>
</AntiDengueLayout>
