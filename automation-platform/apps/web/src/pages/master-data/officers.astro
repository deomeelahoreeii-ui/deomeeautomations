---
import DataTable from "../../components/DataTable.astro";
import MasterDataLayout from "../../layouts/MasterDataLayout.astro";
---

<MasterDataLayout
  title="Officers"
  description="Manage AEO and DDEO contacts, primary postings and additional-charge jurisdictions."
  page="officers"
>
  <button class="btn btn-sm btn-primary" id="add-officer" slot="actions">＋ Add officer</button>

  <div class="notice">
    Routing uses active jurisdictions, not only the officer's displayed posting. Saving this form synchronizes the primary assignment and every selected additional charge in one transaction.
  </div>

  <div class="toolbar" style="margin-top:12px">
    <div class="join">
      <button class="btn btn-sm join-item btn-primary" data-role="aeo">AEOs</button>
      <button class="btn btn-sm join-item" data-role="ddeo">DDEOs</button>
    </div>
    <input class="input input-bordered input-sm search-input" id="officer-search" placeholder="Search officer or mobile…" />
    <select class="select select-bordered select-sm" id="officer-status"><option value="true">Active</option><option value="false">Archived</option></select>
    <span class="toolbar-status" id="officer-total">Loading…</span>
  </div>

  <article class="master-card">
    <DataTable id="officers-table" pageSize={10} emptyText="No officers match these filters." />
  </article>

  <dialog class="modal" id="officer-dialog">
    <div class="modal-box master-modal officer-assignment-modal">
      <div class="modal-title"><h2 id="officer-dialog-title">Add officer</h2><button type="button" id="close-officer">×</button></div>
      <form class="master-form" id="officer-form">
        <input type="hidden" id="officer-id" />
        <label><span>Role *</span><select class="select select-bordered select-sm" id="officer-role"><option value="aeo">AEO</option><option value="ddeo">DDEO</option></select></label>
        <label><span>Officer name *</span><input required class="input input-bordered input-sm" id="officer-name" /></label>
        <label><span>Mobile *</span><input required class="input input-bordered input-sm" id="officer-mobile" placeholder="03xxxxxxxxx" /></label>
        <label><span>Helpdesk user email</span><input type="email" class="input input-bordered input-sm" id="officer-helpdesk-email" placeholder="officer@example.com" /></label>
        <label class="full"><input class="checkbox checkbox-sm" type="checkbox" id="officer-helpdesk-enabled" /> <span style="display:inline;margin-left:6px">Allow individual Helpdesk assignment</span></label>
        <label><span>District *</span><select required class="select select-bordered select-sm" id="officer-district"></select></label>
        <label><span>Department *</span><select required class="select select-bordered select-sm" id="officer-department"></select></label>
        <label><span>Wing *</span><select required class="select select-bordered select-sm" id="officer-wing"></select></label>
        <label><span id="officer-tehsil-caption">Primary Tehsil *</span><select required class="select select-bordered select-sm" id="officer-tehsil"></select></label>
        <label id="officer-markaz-label"><span>Primary Markaz *</span><select class="select select-bordered select-sm" id="officer-markaz"></select></label>
        <div class="full" id="officer-additional-label">
          <div class="jurisdiction-picker-heading">
            <div>
              <span class="form-field-caption" id="officer-additional-caption">Additional-charge Markazes</span>
              <small id="officer-additional-help">Choose only the extra Markazes held in addition to the primary posting.</small>
            </div>
            <span class="jurisdiction-picker-count" id="officer-additional-count" aria-live="polite">0 selected</span>
          </div>
          <div class="jurisdiction-picker">
            <div class="jurisdiction-picker-toolbar">
              <input class="input input-bordered input-sm" id="officer-additional-search" type="search" placeholder="Search Markaz or Tehsil…" autocomplete="off" />
            </div>
            <div class="jurisdiction-picker-list" id="officer-additional-list" role="group" aria-labelledby="officer-additional-caption"></div>
            <div class="jurisdiction-picker-empty" id="officer-additional-empty" role="status" hidden>No matching jurisdictions are available.</div>
          </div>
        </div>
        <div class="full jurisdiction-transfer-warning" id="officer-transfer-panel" hidden>
          <div class="jurisdiction-transfer-title">
            <input class="checkbox checkbox-sm" type="checkbox" id="officer-replace-conflicts" />
            <label for="officer-replace-conflicts">Transfer occupied jurisdictions from their current officer</label>
          </div>
          <small id="officer-conflict-summary">The previous assignment is archived for audit and WhatsApp routing switches immediately.</small>
        </div>
        <label class="full"><input class="checkbox checkbox-sm" type="checkbox" id="officer-active" checked /> <span style="display:inline;margin-left:6px">Active officer</span></label>
        <div class="form-actions"><span class="form-error" id="officer-form-error"></span><button class="btn btn-sm" type="button" id="cancel-officer">Cancel</button><button class="btn btn-sm btn-primary" type="submit" id="save-officer">Save officer & assignments</button></div>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    import { actions } from "astro:actions";
    import { actionButtons, badge, stack } from "../../scripts/table-cells";
    import { confirmAction, showError, showSuccess } from "../../scripts/alerts";

    await customElements.whenDefined("astro-data-table");
    const table = document.getElementById("officers-table") as any;
    const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const dialog = el<HTMLDialogElement>("officer-dialog");
    let role: "aeo" | "ddeo" = "aeo";
    let officers: any[] = [];
    let options: any = { districts: [], departments: [], wings: [], tehsils: [], markazes: [], jurisdictions: { aeo: [], ddeo: [] } };
    let editingOfficer: any = null;
    let additionalSelection = new Set<string>();
    let additionalRows: any[] = [];
    let searchTimer: number | undefined;
    const escapeHtml = (value: unknown) => String(value ?? "").replace(/[&<>'"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]!));

    function fillSelect(id: string, rows: any[], placeholder = "Select…", label?: (row: any) => string) {
      const select = el<HTMLSelectElement>(id);
      const current = select.value;
      select.innerHTML = `<option value="">${placeholder}</option>` + rows.map((row) => `<option value="${escapeHtml(row.id)}">${escapeHtml(label ? label(row) : row.code || row.name)}</option>`).join("");
      if ([...select.options].some((option) => option.value === current)) select.value = current;
    }

    function currentOwner(scopeRole: "aeo" | "ddeo", scopeRef: string) {
      return (options.jurisdictions?.[scopeRole] || []).find((row: any) => row.scope_ref === scopeRef && row.officer_ref !== editingOfficer?.id);
    }

    function refreshTehsils(selected = "") {
      const district = el<HTMLSelectElement>("officer-district").value;
      const selectedRole = el<HTMLSelectElement>("officer-role").value as "aeo" | "ddeo";
      const rows = options.tehsils.filter((row: any) => !district || row.district_ref === district);
      fillSelect("officer-tehsil", rows, "Select primary Tehsil", (row) => {
        if (selectedRole !== "ddeo") return row.name;
        const owner = currentOwner("ddeo", row.id);
        return owner ? `${row.name} — currently ${owner.officer_name}` : `${row.name} — available`;
      });
      if (selected && rows.some((row: any) => row.id === selected)) el<HTMLSelectElement>("officer-tehsil").value = selected;
      if (!el<HTMLSelectElement>("officer-tehsil").value && rows.length) el<HTMLSelectElement>("officer-tehsil").value = rows[0].id;
    }

    function refreshMarkazes(selected = "") {
      const tehsil = el<HTMLSelectElement>("officer-tehsil").value;
      const wing = el<HTMLSelectElement>("officer-wing").value;
      const rows = options.markazes.filter((row: any) => (!tehsil || row.tehsil_ref === tehsil) && (!wing || row.wing_ref === wing));
      fillSelect("officer-markaz", rows, "Select primary Markaz", (row) => {
        const owner = currentOwner("aeo", row.id);
        return owner ? `${row.name} — currently ${owner.officer_name}` : `${row.name} — available`;
      });
      if (selected && rows.some((row: any) => row.id === selected)) el<HTMLSelectElement>("officer-markaz").value = selected;
      if (!el<HTMLSelectElement>("officer-markaz").value && rows.length) el<HTMLSelectElement>("officer-markaz").value = rows[0].id;
    }

    function additionalRefs() {
      return [...additionalSelection];
    }

    function selectedJurisdictionRefs() {
      const selectedRole = el<HTMLSelectElement>("officer-role").value as "aeo" | "ddeo";
      const primary = selectedRole === "aeo" ? el<HTMLSelectElement>("officer-markaz").value : el<HTMLSelectElement>("officer-tehsil").value;
      return [primary, ...additionalRefs()].filter(Boolean);
    }

    function updateTransferPanel() {
      const selectedRole = el<HTMLSelectElement>("officer-role").value as "aeo" | "ddeo";
      const owners = selectedJurisdictionRefs()
        .map((scopeRef) => currentOwner(selectedRole, scopeRef))
        .filter(Boolean);
      const uniqueOwners = [...new Map(owners.map((owner: any) => [owner.officer_ref, owner])).values()];
      const panel = el<HTMLElement>("officer-transfer-panel");
      const checkbox = el<HTMLInputElement>("officer-replace-conflicts");
      panel.hidden = owners.length === 0;
      if (!owners.length) checkbox.checked = false;
      el("officer-conflict-summary").textContent = owners.length
        ? `${owners.length} selected ${owners.length === 1 ? "jurisdiction is" : "jurisdictions are"} currently assigned to ${uniqueOwners.map((owner: any) => owner.officer_name).join(", ")}. Enable transfer to replace those assignments while retaining their history.`
        : "No occupied jurisdiction is selected.";
    }

    function renderAdditionalPicker() {
      const selectedRole = el<HTMLSelectElement>("officer-role").value as "aeo" | "ddeo";
      const query = el<HTMLInputElement>("officer-additional-search").value.trim().toLowerCase();
      const visibleRows = additionalRows.filter((row: any) => {
        const tehsil = selectedRole === "aeo" ? options.tehsils.find((item: any) => item.id === row.tehsil_ref)?.name || "" : "";
        const owner = currentOwner(selectedRole, row.id)?.officer_name || "";
        return !query || `${row.name} ${tehsil} ${owner}`.toLowerCase().includes(query);
      });
      const list = el<HTMLElement>("officer-additional-list");
      list.innerHTML = visibleRows.map((row: any) => {
        const owner = currentOwner(selectedRole, row.id);
        const tehsil = selectedRole === "aeo" ? options.tehsils.find((item: any) => item.id === row.tehsil_ref)?.name || "Unknown Tehsil" : "";
        const selected = additionalSelection.has(row.id);
        const context = selectedRole === "aeo" ? tehsil : "Tehsil responsibility";
        const ownership = owner ? `Currently assigned to ${owner.officer_name}` : "Available";
        return `<button type="button" class="jurisdiction-option${selected ? " selected" : ""}${owner ? " occupied" : ""}" data-additional-ref="${escapeHtml(row.id)}" aria-pressed="${selected ? "true" : "false"}">
          <span class="jurisdiction-option-check" aria-hidden="true">${selected ? "✓" : "+"}</span>
          <span class="jurisdiction-option-copy"><strong>${escapeHtml(row.name)}</strong><small>${escapeHtml(context)} · ${escapeHtml(ownership)}</small></span>
          <span class="jurisdiction-option-status ${owner ? "occupied" : "available"}">${owner ? "Occupied" : "Available"}</span>
        </button>`;
      }).join("");
      el<HTMLElement>("officer-additional-empty").hidden = visibleRows.length > 0;
      el("officer-additional-count").textContent = `${additionalSelection.size} selected`;
      updateTransferPanel();
    }

    function refreshAdditional(selected?: string[]) {
      const selectedRole = el<HTMLSelectElement>("officer-role").value as "aeo" | "ddeo";
      const wing = el<HTMLSelectElement>("officer-wing").value;
      const district = el<HTMLSelectElement>("officer-district").value;
      const primary = selectedRole === "aeo" ? el<HTMLSelectElement>("officer-markaz").value : el<HTMLSelectElement>("officer-tehsil").value;
      additionalRows = (selectedRole === "aeo"
        ? options.markazes.filter((row: any) => row.wing_ref === wing && row.id !== primary)
        : options.tehsils.filter((row: any) => row.district_ref === district && row.id !== primary)
      ).sort((left: any, right: any) => {
        if (selectedRole === "ddeo") return left.name.localeCompare(right.name);
        const leftTehsil = options.tehsils.find((item: any) => item.id === left.tehsil_ref)?.name || "";
        const rightTehsil = options.tehsils.find((item: any) => item.id === right.tehsil_ref)?.name || "";
        return leftTehsil.localeCompare(rightTehsil) || left.name.localeCompare(right.name);
      });
      if (selected) additionalSelection = new Set(selected);
      const validRefs = new Set(additionalRows.map((row: any) => row.id));
      additionalSelection = new Set([...additionalSelection].filter((scopeRef) => validRefs.has(scopeRef)));
      renderAdditionalPicker();
    }

    function updateRoleFields(preserveSelected = true) {
      const selectedRole = el<HTMLSelectElement>("officer-role").value as "aeo" | "ddeo";
      const isAeo = selectedRole === "aeo";
      el("officer-markaz-label").toggleAttribute("hidden", !isAeo);
      el<HTMLSelectElement>("officer-markaz").required = isAeo;
      el("officer-tehsil-caption").textContent = isAeo ? "Primary Tehsil *" : "Primary Tehsil *";
      el("officer-additional-caption").textContent = isAeo ? "Additional-charge Markazes" : "Additional-charge Tehsils";
      el("officer-additional-help").textContent = isAeo
        ? "Choose only the extra Markazes held in addition to the primary posting. Search by Markaz, Tehsil or current officer."
        : "Choose only the extra Tehsils held in addition to the primary posting. Search by Tehsil or current officer.";
      el<HTMLInputElement>("officer-additional-search").placeholder = isAeo ? "Search Markaz, Tehsil or officer…" : "Search Tehsil or officer…";
      const selected = preserveSelected && editingOfficer
        ? (editingOfficer.additional_jurisdictions || []).map((row: any) => row.scope_ref)
        : [];
      refreshTehsils(editingOfficer?.tehsil_ref || "");
      refreshMarkazes(editingOfficer?.markaz_ref || "");
      refreshAdditional(selected);
    }

    async function loadOptions() {
      const [optionsResult, jurisdictionsResult] = await Promise.all([
        actions.masterData.options(),
        actions.masterData.jurisdictions({ active: true, wingRef: "" }),
      ]);
      if (optionsResult.error) throw optionsResult.error;
      if (jurisdictionsResult.error) throw jurisdictionsResult.error;
      options = { ...(optionsResult.data as any), jurisdictions: jurisdictionsResult.data as any };
      fillSelect("officer-district", options.districts);
      fillSelect("officer-department", options.departments);
      fillSelect("officer-wing", options.wings);
      fillSelect("officer-tehsil", options.tehsils);
      fillSelect("officer-markaz", options.markazes);
    }

    async function loadOfficers() {
      const result = await actions.masterData.officers({
        role,
        search: el<HTMLInputElement>("officer-search").value,
        active: el<HTMLSelectElement>("officer-status").value === "true",
      });
      if (result.error) throw result.error;
      officers = result.data as any[];
      el("officer-total").textContent = `${officers.length} ${role.toUpperCase()}${officers.length === 1 ? '' : 's'}`;
      await table.setData(officers);
    }

    function setValue(id: string, value: unknown) { el<HTMLInputElement | HTMLSelectElement>(id).value = String(value ?? ""); }

    function openForm(officer?: any) {
      editingOfficer = officer || null;
      (el("officer-form") as HTMLFormElement).reset();
      el("officer-form-error").textContent = "";
      el("officer-dialog-title").textContent = officer ? `Edit ${officer.role.toUpperCase()} · ${officer.name}` : "Add officer";
      setValue("officer-id", officer?.id);
      setValue("officer-role", officer?.role || role);
      el<HTMLSelectElement>("officer-role").disabled = Boolean(officer);
      setValue("officer-name", officer?.name);
      setValue("officer-mobile", officer?.mobile);
      setValue("officer-helpdesk-email", officer?.helpdesk_user_email);
      el<HTMLInputElement>("officer-helpdesk-enabled").checked = Boolean(officer?.helpdesk_enabled);
      setValue("officer-district", officer?.district_ref || options.districts[0]?.id);
      setValue("officer-department", officer?.department_ref || options.departments[0]?.id);
      setValue("officer-wing", officer?.wing_ref || options.wings[0]?.id);
      additionalSelection = new Set();
      el<HTMLInputElement>("officer-additional-search").value = "";
      updateRoleFields(true);
      el<HTMLInputElement>("officer-replace-conflicts").checked = false;
      el<HTMLInputElement>("officer-active").checked = officer ? Boolean(officer.active) : true;
      dialog.showModal();
    }

    async function setActive(id: string, active: boolean) {
      const officer = officers.find((row) => row.id === id);
      if (!active && !await confirmAction("Archive this officer?", `${officer?.name || "This officer"} and all active jurisdictions will be paused. Routing history remains available.`, "Archive officer")) return;
      const result = await actions.masterData.setOfficerActive({ id, role, active });
      if (result.error) { await showError(result.error); return; }
      await Promise.all([loadOptions(), loadOfficers()]);
    }

    async function hardDeleteOfficer(officer: any) {
      if (!await confirmAction(
        "Permanently delete this officer?",
        "Jurisdictions, school overrides, WhatsApp contact links, and dependent frozen previews will also be deleted. This cannot be undone.",
        "Delete permanently",
      )) return;
      const result = await actions.masterData.hardDeleteOfficer({ id: officer.id, role: officer.role });
      if (result.error) { await showError(result.error); return; }
      await showSuccess("Officer deleted", `${officer.name} was permanently removed.`);
      await Promise.all([loadOptions(), loadOfficers()]);
    }

    el<HTMLFormElement>("officer-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      const id = el<HTMLInputElement>("officer-id").value;
      const selectedRole = el<HTMLSelectElement>("officer-role").value as "aeo" | "ddeo";
      const primaryRef = selectedRole === "aeo" ? el<HTMLSelectElement>("officer-markaz").value : el<HTMLSelectElement>("officer-tehsil").value;
      const jurisdictionRefs = [primaryRef, ...additionalRefs()].filter(Boolean);
      const payload = {
        id: id || undefined,
        role: selectedRole,
        name: el<HTMLInputElement>("officer-name").value,
        mobile: el<HTMLInputElement>("officer-mobile").value,
        district_ref: el<HTMLSelectElement>("officer-district").value,
        department_ref: el<HTMLSelectElement>("officer-department").value,
        wing_ref: el<HTMLSelectElement>("officer-wing").value,
        tehsil_ref: el<HTMLSelectElement>("officer-tehsil").value,
        markaz_ref: selectedRole === "aeo" ? el<HTMLSelectElement>("officer-markaz").value : "",
        jurisdiction_refs: jurisdictionRefs,
        replace_conflicts: el<HTMLInputElement>("officer-replace-conflicts").checked,
        helpdesk_user_email: el<HTMLInputElement>("officer-helpdesk-email").value.trim(),
        helpdesk_enabled: el<HTMLInputElement>("officer-helpdesk-enabled").checked,
        active: el<HTMLInputElement>("officer-active").checked,
      };
      try {
        el<HTMLButtonElement>("save-officer").disabled = true;
        const result = await actions.masterData.saveOfficer(payload as any);
        if (result.error) throw result.error;
        dialog.close();
        await Promise.all([loadOptions(), loadOfficers()]);
        await showSuccess("Officer assignments saved", "Primary and additional-charge routing was synchronized.");
      } catch (error) {
        el("officer-form-error").textContent = error instanceof Error ? error.message : "Could not save officer";
      } finally {
        el<HTMLButtonElement>("save-officer").disabled = false;
      }
    });

    await table.configure({
      data: [],
      columns: [
        { accessorKey: "name", header: "Officer", cell: ({ row }: any) => stack(row.original.name, row.original.wing_name) },
        { accessorKey: "role", header: "Role", cell: ({ row }: any) => badge(row.original.role.toUpperCase()) },
        { accessorKey: "normalized_mobile", header: "Mobile", cell: ({ row }: any) => stack(row.original.normalized_mobile || row.original.mobile) },
        { id: "area", header: "Current responsibility", cell: ({ row }: any) => stack(row.original.assignment_summary, row.original.additional_charge_count ? `${row.original.additional_charge_count} additional charge${row.original.additional_charge_count === 1 ? "" : "s"}` : row.original.tehsil_name) },
        { id: "helpdesk", header: "Helpdesk", cell: ({ row }: any) => stack(row.original.helpdesk_enabled ? "Individual assignment" : "Team only", row.original.helpdesk_user_email || "No user linked") },
        { accessorKey: "active", header: "Status", cell: ({ row }: any) => badge(row.original.active ? "Active" : "Archived", row.original.active ? "" : "inactive") },
        { id: "actions", header: "", enableSorting: false, cell: ({ row }: any) => actionButtons([
          { label: "Edit assignments", onClick: () => openForm(row.original) },
          { label: row.original.active ? "Archive" : "Restore", tone: row.original.active ? "danger" : "", onClick: () => void setActive(row.original.id, !row.original.active) },
          { label: "Delete permanently", tone: "danger", onClick: () => void hardDeleteOfficer(row.original) },
        ]) },
      ],
    });

    document.querySelectorAll<HTMLButtonElement>("[data-role]").forEach((button) => button.addEventListener("click", () => {
      role = button.dataset.role as "aeo" | "ddeo";
      document.querySelectorAll<HTMLButtonElement>("[data-role]").forEach((candidate) => candidate.classList.toggle("btn-primary", candidate === button));
      void loadOfficers();
    }));
    el("add-officer").addEventListener("click", () => openForm());
    el("close-officer").addEventListener("click", () => dialog.close());
    el("cancel-officer").addEventListener("click", () => dialog.close());
    el("officer-role").addEventListener("change", () => {
      additionalSelection = new Set();
      el<HTMLInputElement>("officer-additional-search").value = "";
      updateRoleFields(false);
    });
    el("officer-additional-search").addEventListener("input", renderAdditionalPicker);
    el("officer-additional-list").addEventListener("click", (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-additional-ref]");
      if (!button) return;
      const scopeRef = button.dataset.additionalRef || "";
      if (!scopeRef) return;
      if (additionalSelection.has(scopeRef)) additionalSelection.delete(scopeRef);
      else additionalSelection.add(scopeRef);
      renderAdditionalPicker();
    });
    el("officer-markaz").addEventListener("change", () => {
      const markaz = options.markazes.find((row: any) => row.id === el<HTMLSelectElement>("officer-markaz").value);
      if (markaz) el<HTMLSelectElement>("officer-tehsil").value = markaz.tehsil_ref;
      refreshAdditional();
    });
    el("officer-tehsil").addEventListener("change", () => { refreshMarkazes(); refreshAdditional(); });
    el("officer-wing").addEventListener("change", () => { refreshMarkazes(); refreshAdditional(); });
    el("officer-district").addEventListener("change", () => { refreshTehsils(); refreshMarkazes(); refreshAdditional(); });
    el("officer-status").addEventListener("change", () => void loadOfficers());
    el("officer-search").addEventListener("input", () => { window.clearTimeout(searchTimer); searchTimer = window.setTimeout(() => void loadOfficers(), 250); });
    await loadOptions();
    await loadOfficers();
  </script>
</MasterDataLayout>
