---
import CrmIntakeNav from "../../../../components/CrmIntakeNav.astro";
import DataTable from "../../../../components/DataTable.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
---
<CrmLayout title="Complaint Intake Runs" description="Search every durable WhatsApp capture and continue it into complaint review." page="intake">
  <button class="btn btn-sm" id="refresh-batches" slot="actions">↻ Refresh</button><a class="btn btn-sm btn-primary" href="/crm/intake/" slot="actions">＋ New intake</a><CrmIntakeNav active="runs" />
  <section class="inbound-summary-grid crm-intake-summary"><article class="master-card"><span>Total intake runs</span><strong id="batch-count-total">—</strong></article><article class="master-card"><span>Active</span><strong id="batch-count-active">—</strong></article><article class="master-card"><span>Completed</span><strong id="batch-count-completed">—</strong></article><article class="master-card"><span>With errors</span><strong id="batch-count-errors">—</strong></article></section>
  <section class="master-card crm-batch-table-page"><div class="inbound-card-heading"><div><p class="eyebrow">Intake history</p><h2>WhatsApp complaint captures</h2><p>Each row is a permanent, received-only capture. Open it to inspect evidence or continue to its processing review.</p></div><span class="badge" id="batch-result-count">Loading…</span></div><div class="toolbar crm-batch-filters"><input class="input input-bordered input-sm" id="batch-search" placeholder="Search complainant, intake code or WhatsApp identity"/><select class="select select-bordered select-sm" id="batch-status"><option value="">All statuses</option><option value="created">Created</option><option value="fetching">Fetching</option><option value="storing">Storing</option><option value="completed">Completed</option><option value="completed_with_errors">Completed with errors</option><option value="failed">Failed</option></select><button class="btn btn-sm" id="clear-batch-filters" type="button">Clear filters</button></div><DataTable id="intake-runs-table" pageSize={25} pageSizeOptions={[10,25,50,100]} emptyText="No intake runs match these filters." ariaLabel="WhatsApp complaint intake runs" /></section>
  <style is:global>.crm-intake-summary{margin:1rem 0}.crm-batch-table-page{padding:1.05rem 1.15rem}.crm-batch-table-page h2{margin:.12rem 0}.crm-batch-table-page p{margin:.25rem 0;color:#68778a}.crm-batch-filters{display:grid;grid-template-columns:minmax(16rem,1fr) 14rem auto;gap:.55rem;margin:.9rem 0}.crm-batch-primary{display:block;color:#29384d;font-weight:800}.crm-batch-secondary{display:block;margin-top:.15rem;color:#758396;font-size:.68rem}.crm-batch-actions{display:flex;justify-content:flex-end;gap:.35rem}@media(max-width:700px){.crm-batch-filters{grid-template-columns:1fr}}</style>
  <script>
    import { actions } from "astro:actions";import { processingStatusLabel } from "../../../../lib/crm-status";await customElements.whenDefined("astro-data-table");
    const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T,table=el<any>("intake-runs-table"),search=el<HTMLInputElement>("batch-search"),status=el<HTMLSelectElement>("batch-status");let timer:number|undefined,searchTimer:number|undefined;const params=new URLSearchParams(location.search);search.value=params.get("q")||"";status.value=params.get("status")||"";const initialPage=Math.max(0,Number(params.get("page")||1)-1),initialPageSize=Math.max(1,Number(params.get("page_size")||25)),initialSort=params.get("sort")||"created_at",initialOrder=params.get("order")==="asc"?"asc":"desc";
    const primary=(value:any,secondary="")=>{const wrap=document.createElement("div"),strong=document.createElement("strong");strong.className="crm-batch-primary";strong.textContent=String(value||"—");wrap.append(strong);if(secondary){const small=document.createElement("small");small.className="crm-batch-secondary";small.textContent=secondary;wrap.append(small)}return wrap};const bytes=(value:any)=>{const size=Number(value||0);if(!size)return"0 B";const units=["B","KB","MB","GB"],index=Math.min(Math.floor(Math.log(size)/Math.log(1024)),3);return`${(size/1024**index).toFixed(index?1:0)} ${units[index]}`};const scope=(row:any)=>row.date_from||row.date_to?`${row.date_from?new Date(row.date_from).toLocaleDateString():"Beginning"} — ${row.date_to?new Date(row.date_to).toLocaleDateString():"Now"}`:row.all_history?"All available history":`Latest ${row.requested_count}`;const action=(row:any)=>{const wrap=document.createElement("div");wrap.className="crm-batch-actions";const intake=document.createElement("a");intake.className="btn btn-xs";intake.href=`/crm/intake/batches/${row.id}`;intake.textContent="Open intake";wrap.append(intake);if(row.processing_run_id){const review=document.createElement("a");review.className="btn btn-xs btn-primary";review.href=`/crm/intake/review/${row.processing_run_id}/overview`;review.textContent="Open review →";wrap.append(review)}return wrap};
    function syncUrl(pagination?:any,sorting?:any[]){const url=new URL(location.href);search.value?url.searchParams.set("q",search.value):url.searchParams.delete("q");status.value?url.searchParams.set("status",status.value):url.searchParams.delete("status");if(pagination){url.searchParams.set("page",String(pagination.pageIndex+1));url.searchParams.set("page_size",String(pagination.pageSize))}if(sorting?.[0]){url.searchParams.set("sort",sorting[0].id);url.searchParams.set("order",sorting[0].desc?"desc":"asc")}history.replaceState({},"",url)}
    await table.configure({manualPagination:true,initialPageIndex:initialPage,initialPageSize,initialSorting:[{id:initialSort,desc:initialOrder==="desc"}],onPageChange:(value:any)=>syncUrl(value),onSortingChange:(value:any[])=>syncUrl(undefined,value),getRowId:(row:any)=>row.id,columns:[{accessorKey:"batch_code",header:"Intake run",cell:({row}:any)=>primary(row.original.batch_code,processingStatusLabel(row.original.status))},{accessorKey:"contact_name",header:"Contact",cell:({row}:any)=>primary(row.original.contact_name,row.original.contact_identity||"")},{id:"scope",header:"Capture scope",cell:({row}:any)=>primary(scope(row.original),"Received only · sent-by-you excluded"),enableSorting:false},{accessorKey:"messages_discovered",header:"Messages",cell:({row}:any)=>row.original.messages_discovered},{accessorKey:"files_discovered",header:"Evidence",cell:({row}:any)=>primary(`${row.original.files_discovered} file${row.original.files_discovered===1?"":"s"}`,bytes(row.original.total_bytes))},{id:"archive",header:"Archive",cell:({row}:any)=>primary(`${row.original.files_stored+row.original.files_reused}/${row.original.files_discovered} durable`,row.original.files_failed?`${row.original.files_failed} failed`:"Ready"),enableSorting:false},{id:"review",header:"Review",cell:({row}:any)=>primary(row.original.processing_run_code||"Not processed",row.original.processing_run_id?row.original.processing_review_items?`${row.original.processing_review_items} need review`:processingStatusLabel(row.original.processing_status):"No classification run"),enableSorting:false},{accessorKey:"created_at",header:"Started",cell:({row}:any)=>new Date(row.original.started_at||row.original.created_at).toLocaleString()},{id:"actions",header:"",cell:({row}:any)=>action(row.original),enableSorting:false,meta:{align:"right",minWidth:"10rem"}}],loadPage:async(pageIndex:number,pageSize:number,sorting:any[])=>{const current=sorting[0],result=await actions.whatsapp.inboundBatches({search:search.value.trim()||undefined,status:status.value||undefined,limit:pageSize,offset:pageIndex*pageSize,sort:current?.id||"created_at",order:current?.desc===false?"asc":"desc"});if(result.error)throw new Error(result.error.message);const data=result.data as any,counts=data.counts||{};el("batch-count-total").textContent=String(counts.total||0);el("batch-count-active").textContent=String(counts.active||0);el("batch-count-completed").textContent=String(counts.completed||0);el("batch-count-errors").textContent=String(counts.with_errors||0);el("batch-result-count").textContent=`${data.total} intake run${data.total===1?"":"s"}`;const active=(data.items||[]).some((row:any)=>["created","fetching","storing"].includes(row.status));if(timer)clearInterval(timer);timer=active?window.setInterval(()=>{if(!document.hidden)void table.refresh(false)},5000):undefined;return{rows:data.items||[],total:Number(data.total||0)}}});async function refresh(){syncUrl({pageIndex:0,pageSize:table.getPagination().pageSize});await table.refresh(true)}search.addEventListener("input",()=>{if(searchTimer)clearTimeout(searchTimer);searchTimer=window.setTimeout(()=>void refresh(),250)});status.addEventListener("change",()=>void refresh());el("clear-batch-filters").addEventListener("click",()=>{search.value="";status.value="";void refresh()});el("refresh-batches").addEventListener("click",()=>void table.refresh(false));window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer)});
  </script>
</CrmLayout>
