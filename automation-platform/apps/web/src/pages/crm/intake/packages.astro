---
import CrmIntakeNav from "../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Complaint Evidence Packages" description="Follow evidence-package jobs, inspect worker logs and download generated CRM intake artifacts." page="intake">
  <button class="btn btn-sm" id="refresh-exports" slot="actions">↻ Refresh</button>
  <CrmIntakeNav active="packages" />
  <section class="crm-package-workspace" data-api-base={apiBase} id="export-page-root">
    <article class="master-card crm-package-list-panel">
      <div class="inbound-card-heading"><div><p class="eyebrow">Evidence history</p><h2>Available packages</h2><p>Select a package to see its downloadable files.</p></div><span class="badge" id="export-list-state">Loading</span></div>
      <div class="crm-package-list" id="export-items"><div class="crm-intake-empty"><span>↓</span><h3>Loading packages…</h3></div></div>
    </article>
    <article class="master-card crm-package-detail-panel">
      <div id="package-empty" class="crm-intake-empty"><span>↙</span><h3>Select an evidence package</h3><p>Its generated ZIP, manifest and supporting artifacts will appear here. Technical worker activity stays collapsed unless you need it.</p></div>
      <div id="package-detail" hidden>
        <div class="inbound-card-heading"><div><p class="eyebrow">Selected package</p><h2>Ready files</h2></div><span class="badge" id="export-job-state">Loading</span></div>
        <div class="inbound-downloads crm-package-downloads" id="export-downloads"><p>Checking generated files…</p></div>
        <details class="crm-package-activity"><summary>Technical package activity</summary><pre class="inbound-log" id="export-job-log">Loading worker activity…</pre></details>
      </div>
    </article>
  </section>
  <script>
    import { actions } from "astro:actions";
    const root=document.getElementById("export-page-root") as HTMLElement,apiBase=root.dataset.apiBase||"";
    const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;
    let jobId="",timer:number|undefined;
    const escapeHtml=(v:unknown)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");
    const formatDate=(v:any)=>{if(!v)return"—";const d=new Date(v);return Number.isNaN(d.getTime())?String(v):d.toLocaleString();};
    const formatBytes=(v:any)=>{const n=Number(v||0);if(!n)return"0 B";const u=["B","KB","MB","GB"];const i=Math.min(Math.floor(Math.log(n)/Math.log(1024)),3);return`${(n/1024**i).toFixed(i?1:0)} ${u[i]}`;};

    function packageCard(x:any){
      const unavailable=x.files_unavailable?" · "+String(x.files_unavailable)+" unavailable":"";
      return `<button class="crm-package-card ${x.job_id===jobId?"selected":""}" data-job="${escapeHtml(x.job_id)}" type="button"><span class="crm-package-icon">ZIP</span><span class="crm-package-main"><strong>${escapeHtml(x.contact_name)}</strong><small>${escapeHtml(formatDate(x.created_at))} · ${escapeHtml((x.media_types||[]).join(", "))}</small><em>${x.files_downloaded+x.files_reused}/${x.files_matched} files ready${unavailable}</em></span><span class="crm-run-state ${escapeHtml(x.status)}">${escapeHtml(x.status)}</span></button>`;
    }

    async function loadList(){
      const r=await actions.whatsapp.inboundExports({page:1,pageSize:50});
      if(r.error){el("export-items").innerHTML=`<div class="crm-intake-empty error"><span>!</span><h3>Could not load packages</h3><p>${escapeHtml(r.error.message)}</p></div>`;return;}
      const items=(r.data as any).items||[];
      el("export-list-state").textContent=`${items.length} package(s)`;
      el("export-items").innerHTML=items.length?items.map(packageCard).join(""):`<div class="crm-intake-empty"><span>↓</span><h3>No evidence packages yet</h3><p>Build one from a captured WhatsApp conversation when an offline evidence bundle is needed.</p><a class="btn btn-sm" href="/crm/intake/">Open complaint intake</a></div>`;
    }

    async function poll(){
      if(!jobId)return;
      const [j,l,a]=await Promise.all([actions.whatsapp.job({id:jobId}),actions.whatsapp.jobLogs({id:jobId}),actions.whatsapp.jobArtifacts({id:jobId})]);
      if(j.data){const s=(j.data as any).status;el("export-job-state").textContent=s;if(["succeeded","failed","cancelled"].includes(s)&&timer){clearInterval(timer);timer=undefined;void loadList();}}
      if(l.data){const rows=l.data as any[];el("export-job-log").textContent=rows.length?rows.map(x=>`[${formatDate(x.created_at)}] ${x.message}`).join("\n"):"Waiting for worker activity…";el<HTMLPreElement>("export-job-log").scrollTop=el<HTMLPreElement>("export-job-log").scrollHeight;}
      if(a.data){const rows=a.data as any[];el("export-downloads").innerHTML=rows.length?rows.map(x=>`<a class="inbound-download-link" href="${apiBase}/api/v1/artifacts/${x.id}/download"><strong>${escapeHtml(x.name)}</strong><small>${escapeHtml(x.kind)} · ${formatBytes(x.size_bytes)}</small></a>`).join(""):'<p>No artifacts are available yet.</p>';}
    }

    function open(id:string){jobId=id;el("package-empty").hidden=true;el("package-detail").hidden=false;document.querySelectorAll(".crm-package-card").forEach(card=>card.classList.toggle("selected",(card as HTMLElement).dataset.job===id));if(timer)clearInterval(timer);void poll();timer=window.setInterval(()=>void poll(),1000);}
    el("export-items").addEventListener("click",e=>{const b=(e.target as HTMLElement).closest<HTMLButtonElement>("button[data-job]");if(b)open(b.dataset.job||"");});el("refresh-exports").addEventListener("click",()=>{void loadList();if(jobId)void poll();});window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer);});void loadList();
  </script>
</CrmLayout>
