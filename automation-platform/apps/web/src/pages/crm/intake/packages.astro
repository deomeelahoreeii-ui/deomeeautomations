---
import CrmIntakeNav from "../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Complaint Evidence Packages" description="Follow evidence-package jobs, inspect worker logs and download generated CRM intake artifacts." page="intake">
  <button class="btn btn-sm" id="refresh-exports" slot="actions">↻ Refresh</button>
  <CrmIntakeNav active="packages" />
  <section class="inbound-detail-grid" data-api-base={apiBase} id="export-page-root">
    <article class="master-card"><div class="inbound-card-heading"><div><p class="eyebrow">Selected package</p><h2>Worker activity</h2></div><span class="badge" id="export-job-state">Select a package</span></div><pre class="inbound-log" id="export-job-log">Open a package from the table below to view its worker log.</pre></article>
    <article class="master-card"><p class="eyebrow">Generated files</p><h2>Downloads</h2><div class="inbound-downloads" id="export-downloads"><p>Artifacts will appear after you open a package.</p></div></article>
  </section>
  <section class="master-card"><div class="inbound-card-heading"><div><p class="eyebrow">Export history</p><h2>Recent packages</h2></div><span class="badge" id="export-list-state">Loading</span></div><div class="table-wrap"><table class="table table-sm inbound-file-table"><thead><tr><th>Created</th><th>Contact</th><th>Filters</th><th>Files</th><th>Status</th><th></th></tr></thead><tbody id="export-items"><tr><td colspan="6" class="empty-cell">Loading packages…</td></tr></tbody></table></div></section>
  <script>
    import { actions } from "astro:actions";
    const root=document.getElementById("export-page-root") as HTMLElement,apiBase=root.dataset.apiBase||"";const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;let jobId="",timer:number|undefined;
    const escapeHtml=(v:unknown)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");const formatDate=(v:any)=>{if(!v)return"—";const d=new Date(v);return Number.isNaN(d.getTime())?String(v):d.toLocaleString();};const formatBytes=(v:any)=>{const n=Number(v||0);if(!n)return"0 B";const u=["B","KB","MB","GB"];const i=Math.min(Math.floor(Math.log(n)/Math.log(1024)),3);return`${(n/1024**i).toFixed(i?1:0)} ${u[i]}`;};
    async function loadList(){const r=await actions.whatsapp.inboundExports({page:1,pageSize:50});if(r.error){el("export-items").innerHTML=`<tr><td colspan="6" class="empty-cell">${escapeHtml(r.error.message)}</td></tr>`;return;}const items=(r.data as any).items||[];el("export-list-state").textContent=`${items.length} package(s)`;el("export-items").innerHTML=items.length?items.map((x:any)=>`<tr><td>${escapeHtml(formatDate(x.created_at))}</td><td><strong>${escapeHtml(x.contact_name)}</strong></td><td>${escapeHtml(x.chat_scope)}<small>${escapeHtml((x.media_types||[]).join(", "))}</small></td><td>${x.files_downloaded+x.files_reused}/${x.files_matched}<small>${x.files_unavailable} unavailable</small></td><td><span class="badge">${escapeHtml(x.status)}</span></td><td><button class="btn btn-xs" data-job="${escapeHtml(x.job_id)}">Open</button></td></tr>`).join(""):'<tr><td colspan="6" class="empty-cell">No packages have been created.</td></tr>';}
    async function poll(){if(!jobId)return;const [j,l,a]=await Promise.all([actions.whatsapp.job({id:jobId}),actions.whatsapp.jobLogs({id:jobId}),actions.whatsapp.jobArtifacts({id:jobId})]);if(j.data){const s=(j.data as any).status;el("export-job-state").textContent=s;if(["succeeded","failed","cancelled"].includes(s)&&timer){clearInterval(timer);timer=undefined;void loadList();}}if(l.data){const rows=l.data as any[];el("export-job-log").textContent=rows.length?rows.map(x=>`[${formatDate(x.created_at)}] ${x.message}`).join("\n"):"Waiting for worker activity…";el<HTMLPreElement>("export-job-log").scrollTop=el<HTMLPreElement>("export-job-log").scrollHeight;}if(a.data){const rows=a.data as any[];el("export-downloads").innerHTML=rows.length?rows.map(x=>`<a class="inbound-download-link" href="${apiBase}/api/v1/artifacts/${x.id}/download"><strong>${escapeHtml(x.name)}</strong><small>${escapeHtml(x.kind)} · ${formatBytes(x.size_bytes)}</small></a>`).join(""):'<p>No artifacts are available yet.</p>';}}
    function open(id:string){jobId=id;if(timer)clearInterval(timer);void poll();timer=window.setInterval(()=>void poll(),1000);}
    el("export-items").addEventListener("click",e=>{const b=(e.target as HTMLElement).closest<HTMLButtonElement>("button[data-job]");if(b)open(b.dataset.job||"");});el("refresh-exports").addEventListener("click",()=>{void loadList();if(jobId)void poll();});window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer);});void loadList();
  </script>
</CrmLayout>
