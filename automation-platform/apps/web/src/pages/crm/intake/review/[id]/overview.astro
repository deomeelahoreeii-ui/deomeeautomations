---
import CrmIntakeNav from "../../../../../components/CrmIntakeNav.astro";
import CrmReviewRunNav from "../../../../../components/CrmReviewRunNav.astro";
import CrmLayout from "../../../../../layouts/CrmLayout.astro";
const runId = Astro.params.id || "";
---
<CrmLayout title="Review Run Overview" description="Monitor classification, inspect its source intake and choose the next review queue." page="intake">
  <a class="btn btn-sm" href="/crm/intake/review" slot="actions">← All processing runs</a>
  <CrmIntakeNav active="review" />
  <CrmReviewRunNav runId={runId} active="overview" />

  <section class="master-card crm-review-overview" id="run-overview" data-run-id={runId}>
    <div class="inbound-card-heading"><div><p class="eyebrow">Complaint review run</p><h2 id="run-code">Loading…</h2><p id="run-contact">—</p><p>Source intake <a id="run-source" href="#">Loading…</a></p></div><span class="crm-run-state" id="run-status">Loading</span></div>
    <div class="inbound-summary-grid crm-run-overview-metrics"><article><span>Complaint groups</span><strong id="run-groups">—</strong></article><article><span>Ready</span><strong id="run-ready">—</strong></article><article><span>Manual review</span><strong id="run-manual">—</strong></article><article><span>Spreadsheet rows</span><strong id="run-sheets">—</strong></article><article><span>Repeated evidence</span><strong id="run-duplicates">—</strong></article><article><span>Existing in Paperless</span><strong id="run-existing">—</strong></article><article><span>Decided</span><strong id="run-decided">—</strong></article></div>
    <div class="crm-next-queues"><a class="btn btn-primary" href={`/crm/intake/review/${runId}/ready`}>Review ready complaints →</a><a class="btn" href={`/crm/intake/review/${runId}/manual`}>Resolve manual evidence</a><a class="btn" href={`/crm/intake/spreadsheets?run_id=${runId}`}>Review spreadsheet rows</a><a class="btn" href={`/crm/intake/review/${runId}/duplicates`}>Inspect repeated evidence</a><a class="btn" href={`/crm/intake/review/${runId}/existing`}>Inspect Paperless matches</a></div>
    <details class="crm-technical-details"><summary>Classifier activity and technical details</summary><div class="inbound-detail-facts"><div><span>Started</span><strong id="run-started">—</strong></div><div><span>Classifier</span><strong id="run-classifier">—</strong></div><div><span>Paperless check</span><strong id="run-paperless">—</strong></div><div><span>Processed files</span><strong id="run-files">—</strong></div></div><pre class="inbound-log" id="run-log">Loading processing activity…</pre></details>
  </section>
  <style>.crm-review-overview{padding:1.1rem 1.25rem}.crm-review-overview h2{margin:.12rem 0}.crm-review-overview p{margin:.25rem 0;color:#68778a}.crm-run-overview-metrics{margin:1rem 0}.crm-run-overview-metrics article{border:1px solid #e0e8ee;border-radius:.65rem;background:#f8fbfc;padding:.75rem}.crm-run-overview-metrics span,.crm-run-overview-metrics strong{display:block}.crm-run-overview-metrics span{color:#738095;font-size:.7rem}.crm-run-overview-metrics strong{margin-top:.2rem;font-size:1.35rem}.crm-next-queues{display:flex;gap:.5rem;flex-wrap:wrap}.crm-technical-details{margin-top:1rem;border-top:1px solid #e2e8f0;padding-top:.8rem}.crm-technical-details summary{cursor:pointer;color:#526276;font-weight:750}.crm-technical-details .inbound-detail-facts{margin:.8rem 0}.crm-technical-details pre{max-height:20rem}</style>
  <script>
    import { actions } from "astro:actions";
    import { processingStatusLabel } from "../../../../../lib/crm-status";
    const root=document.getElementById("run-overview") as HTMLElement,runId=root.dataset.runId!,el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;let after:string|undefined,timer:number|undefined;
    const format=(value:any)=>{if(!value)return"—";const date=new Date(value);return Number.isNaN(date.getTime())?String(value):date.toLocaleString()};
    async function load(){const result=await actions.whatsapp.inboundProcessingRun({id:runId});if(result.error){el("run-log").textContent=result.error.message;return}const data=result.data as any,groups=data.complaint_groups||[],count=(bucket:string)=>groups.filter((group:any)=>group.review_bucket===bucket).length;el("run-code").textContent=data.run_code;el("run-contact").textContent=`${data.contact_name} · ${data.contact_identity||"WhatsApp identity unavailable"}`;const source=el<HTMLAnchorElement>("run-source");source.textContent=data.batch_code;source.href=`/crm/intake/batches/${data.batch_id}`;el("run-status").textContent=processingStatusLabel(data.status);el("run-status").className=`crm-run-state ${data.status}`;el("run-groups").textContent=String(groups.length);el("run-ready").textContent=String(count("ready"));el("run-manual").textContent=String(count("manual_review"));el("run-sheets").textContent=String(data.spreadsheet_candidate_rows||0);el("run-duplicates").textContent=String(data.content_duplicate_items||0);el("run-existing").textContent=String(count("existing"));el("run-decided").textContent=String(count("approved")+count("rejected"));el("run-started").textContent=format(data.started_at||data.created_at);el("run-classifier").textContent=data.classifier_version||"—";el("run-paperless").textContent=processingStatusLabel(data.paperless_check_status);el("run-files").textContent=`${data.processed_items}/${data.total_items}`;if(["completed","completed_with_errors","failed","cancelled"].includes(data.status)&&timer){clearInterval(timer);timer=undefined}}
    async function events(){const result=await actions.whatsapp.inboundProcessingEvents({id:runId,after,limit:500});if(result.error)return;const items=(result.data as any).items||[];if(items.length){const log=el("run-log");if(!after)log.textContent="";log.textContent+=[...items].map((item:any)=>`[${format(item.created_at)}] ${String(item.level||"info").toUpperCase()} ${item.message}`).join("\n")+"\n";log.scrollTop=log.scrollHeight;after=items.at(-1)?.created_at}}
    await Promise.all([load(),events()]);timer=window.setInterval(()=>{if(!document.hidden){void load();void events()}},3000);window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer)});
  </script>
</CrmLayout>
