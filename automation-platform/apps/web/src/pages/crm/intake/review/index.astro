---
import CrmIntakeNav from "../../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
---
<CrmLayout title="Complaint Review Queue" description="Review complaint candidates, supporting evidence and Paperless duplicate checks before creating or linking CRM cases." page="intake">
  <button class="btn btn-sm" id="refresh-processing" slot="actions">↻ Refresh</button>
  <CrmIntakeNav active="review" />

  <section class="wa-health-banner inbound-processing-safety crm-review-safety">
    <span class="status-dot ready"></span>
    <div><strong>Safe review workspace</strong><small>CRM extracts evidence and checks Paperless, but never creates or uploads a Paperless document from this queue.</small></div>
  </section>

  <section class="inbound-summary-grid crm-intake-summary">
    <article class="master-card"><span>Total runs</span><strong id="processing-count-total">—</strong></article>
    <article class="master-card"><span>Active</span><strong id="processing-count-active">—</strong></article>
    <article class="master-card"><span>Completed</span><strong id="processing-count-completed">—</strong></article>
    <article class="master-card"><span>With errors</span><strong id="processing-count-errors">—</strong></article>
  </section>

  <section class="master-card crm-intake-queue-panel">
    <div class="inbound-card-heading"><div><p class="eyebrow">Decision queue</p><h2>Complaint candidates waiting for an operator</h2><p>Open a review to confirm complaint numbers, evidence categories and Paperless duplicate results.</p></div><span class="badge" id="processing-list-state">Loading</span></div>
    <div class="toolbar inbound-processing-toolbar crm-intake-toolbar">
      <input class="input input-bordered input-sm" id="processing-search" placeholder="Search complainant, complaint number or intake code" />
      <select class="select select-bordered select-sm" id="processing-status"><option value="">All run statuses</option><option value="queued">Queued</option><option value="extracting">Extracting</option><option value="checking_paperless">Checking Paperless</option><option value="completed">Completed</option><option value="completed_with_errors">Completed with errors</option><option value="failed">Failed</option></select>
      <select class="select select-bordered select-sm" id="processing-category"><option value="">All results</option><option value="crm_complaint">Confirmed CRM</option><option value="possible_crm_complaint">Possible CRM</option><option value="eligible">Eligible</option><option value="duplicate_in_paperless">Paperless duplicates</option><option value="needs_review">Needs review</option><option value="failed">Failed items</option></select>
      <span class="toolbar-status" id="processing-result-count">Loading…</span>
    </div>
    <div class="crm-review-list" id="processing-list-items"><div class="crm-intake-empty"><span>◇</span><h3>Loading review queue…</h3></div></div>
  </section>

  <style is:global>
    .crm-review-source{display:grid;min-width:0;gap:.18rem}.crm-review-source strong,.crm-review-source small{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.crm-review-source strong{color:#526276;font-size:.72rem}.crm-review-source small{color:#7d8999;font-size:.68rem}.crm-review-links{display:flex;align-items:center;justify-content:flex-end;gap:.45rem;flex-wrap:wrap}@media(max-width:700px){.crm-review-card>footer{align-items:stretch;flex-direction:column}.crm-review-links{justify-content:flex-start}}
  </style>

  <script>
    import { actions } from "astro:actions";
    const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;
    const escapeHtml=(v:unknown)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");
    const formatDate=(v:any)=>{if(!v)return"—";const d=new Date(v);return Number.isNaN(d.getTime())?String(v):d.toLocaleString();};
    let timer:number|undefined,searchTimer:number|undefined;

    function renderReview(x:any){
      const failureLabel=x.failed_items?String(x.failed_items)+" failed":"No failures";
      const actionLabel=x.review_items?"Review decisions":"Open completed review";
      return `<article class="crm-review-card ${x.review_items?"attention":""}"><header><div><span class="crm-run-state ${escapeHtml(x.status)}">${escapeHtml(String(x.status).replaceAll("_"," "))}</span><h3>${escapeHtml(x.contact_name)}</h3><p>Review ${escapeHtml(x.run_code)} · ${escapeHtml(formatDate(x.started_at||x.created_at))}</p></div><div class="crm-review-attention"><strong>${x.review_items}</strong><small>need review</small></div></header><div class="crm-review-breakdown"><div><span>Complaint candidates</span><strong>${x.crm_complaints} confirmed</strong><small>${x.possible_crm} possible · ${x.supporting_documents} supporting</small></div><div><span>Paperless check</span><strong>${x.eligible_items} eligible</strong><small>${x.duplicate_items} duplicate · ${escapeHtml(x.paperless_check_status)}</small></div><div><span>Exceptions</span><strong>${failureLabel}</strong><small>${x.reply_reports} replies or reports</small></div></div><footer><div class="crm-review-source"><strong>Source intake ${escapeHtml(x.batch_code)}</strong><small>${escapeHtml(x.contact_identity||"WhatsApp identity unavailable")}</small></div><div class="crm-review-links"><a class="btn btn-sm" href="/crm/intake/batches/${escapeHtml(x.batch_id)}">Open source intake</a><a class="btn btn-sm btn-primary" href="/crm/intake/review/${escapeHtml(x.id)}">${actionLabel} →</a></div></footer></article>`;
    }

    async function load(){
      const search=el<HTMLInputElement>("processing-search").value.trim(),status=el<HTMLSelectElement>("processing-status").value,category=el<HTMLSelectElement>("processing-category").value;
      el("processing-list-state").textContent="Loading";
      const r=await actions.whatsapp.inboundProcessingRuns({search:search||undefined,status:status||undefined,category:category||undefined,limit:100});
      if(r.error){el("processing-list-items").innerHTML=`<div class="crm-intake-empty error"><span>!</span><h3>Could not load reviews</h3><p>${escapeHtml(r.error.message)}</p></div>`;el("processing-list-state").textContent="Error";return;}
      const d=r.data as any,c=d.counts||{},items=d.items||[];
      el("processing-count-total").textContent=String(c.total||0);el("processing-count-active").textContent=String(c.active||0);el("processing-count-completed").textContent=String(c.completed||0);el("processing-count-errors").textContent=String(c.with_errors||0);
      el("processing-result-count").textContent=`${items.length} review run(s)`;el("processing-list-state").textContent=items.some((x:any)=>["queued","extracting","checking_paperless"].includes(x.status))?"Classifying":"Ready";
      el("processing-list-items").innerHTML=items.length?items.map(renderReview).join(""):`<div class="crm-intake-empty"><span>✓</span><h3>No complaint reviews need attention</h3><p>Completed classifications and new candidates will appear here. Start a new intake to capture another conversation.</p><a class="btn btn-sm" href="/crm/intake/">Start new intake</a></div>`;
    }

    function start(){if(timer)clearInterval(timer);void load();timer=window.setInterval(()=>{if(!document.hidden)void load();},5000);}
    el("refresh-processing").addEventListener("click",()=>void load());el("processing-status").addEventListener("change",()=>void load());el("processing-category").addEventListener("change",()=>void load());el("processing-search").addEventListener("input",()=>{if(searchTimer)clearTimeout(searchTimer);searchTimer=window.setTimeout(()=>void load(),300);});window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer);});start();
  </script>
</CrmLayout>
