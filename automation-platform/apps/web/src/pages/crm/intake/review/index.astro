---
import CrmIntakeNav from "../../../../components/CrmIntakeNav.astro";
import DataTable from "../../../../components/DataTable.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
---
<CrmLayout title="Complaint Review Runs" description="Find a classification run, then open the exact queue that needs your decision." page="intake">
  <button class="btn btn-sm" id="refresh-processing" slot="actions">↻ Refresh</button>
  <a class="btn btn-sm" href="/crm/cases/" slot="actions">Complaint cases →</a>
  <CrmIntakeNav active="review" />

  <section class="wa-health-banner"><span class="status-dot ready"></span><div><strong>Review is safe and reversible</strong><small>Classification and approval do not upload to Paperless. Publication is a separate action in the case workspace.</small></div></section>

  <section class="inbound-summary-grid crm-review-metrics"><article class="master-card"><span>Total runs</span><strong id="processing-count-total">—</strong></article><article class="master-card"><span>Active</span><strong id="processing-count-active">—</strong></article><article class="master-card"><span>Completed</span><strong id="processing-count-completed">—</strong></article><article class="master-card"><span>With errors</span><strong id="processing-count-errors">—</strong></article></section>
  <section class="master-card crm-table-page" id="review-run-table-root">
    <div class="inbound-card-heading"><div><p class="eyebrow">Classification history</p><h2>Processing runs</h2><p>Open a run to review ready candidates, ambiguous evidence, existing Paperless matches, or recorded decisions.</p></div><span class="badge" id="processing-result-count">Loading…</span></div>
    <div class="toolbar crm-run-filters"><input class="input input-bordered input-sm" id="processing-search" placeholder="Search contact, intake code or review code"/><select class="select select-bordered select-sm" id="processing-status"><option value="">All statuses</option><option value="queued">Queued</option><option value="extracting">Extracting</option><option value="checking_paperless">Checking Paperless</option><option value="completed">Completed</option><option value="completed_with_errors">Completed with errors</option><option value="failed">Failed</option></select><select class="select select-bordered select-sm" id="processing-category"><option value="">All results</option><option value="crm_complaint">Confirmed CRM</option><option value="possible_crm_complaint">Possible CRM</option><option value="eligible">Ready candidates</option><option value="duplicate_in_paperless">Existing in Paperless</option><option value="needs_review">Needs review</option><option value="failed">Failed items</option></select><button class="btn btn-sm" id="clear-processing-filters" type="button">Clear filters</button></div>
    <DataTable id="processing-runs-table" pageSize={25} pageSizeOptions={[10,25,50,100]} emptyText="No processing runs match these filters." ariaLabel="Complaint processing runs" />
  </section>
  <style is:global>.crm-review-metrics{margin:1rem 0}.crm-table-page{padding:1.05rem 1.15rem}.crm-table-page h2{margin:.12rem 0}.crm-table-page .inbound-card-heading p:last-child{margin:.25rem 0 0;color:#68778a}.crm-run-filters{display:grid;grid-template-columns:minmax(16rem,1fr) 13rem 14rem auto;gap:.55rem;margin:.9rem 0}.crm-table-primary{display:block;color:#28374b;font-weight:800}.crm-table-secondary{display:block;margin-top:.16rem;color:#758396;font-size:.68rem}.crm-review-attention{display:inline-flex;border-radius:999px;background:#edf3f6;padding:.25rem .5rem;color:#526476;font-size:.68rem;font-weight:800}.crm-review-attention.needs-review{background:#fff3dc;color:#8b5a0a}.crm-review-link{display:flex;justify-content:flex-end;gap:.35rem}@media(max-width:850px){.crm-run-filters{grid-template-columns:1fr 1fr}}@media(max-width:560px){.crm-run-filters{grid-template-columns:1fr}}</style>
  <script>
    import { actions } from "astro:actions";
    import { processingStatusLabel } from "../../../../lib/crm-status";
    await customElements.whenDefined("astro-data-table");
    const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T,table=el<any>("processing-runs-table"),search=el<HTMLInputElement>("processing-search"),status=el<HTMLSelectElement>("processing-status"),category=el<HTMLSelectElement>("processing-category");let timer:number|undefined,searchTimer:number|undefined;
    const params=new URLSearchParams(location.search);search.value=params.get("q")||"";status.value=params.get("status")||"";category.value=params.get("category")||"";const initialPage=Math.max(0,Number(params.get("page")||1)-1),initialPageSize=Math.max(1,Number(params.get("page_size")||25)),initialSort=params.get("sort")||"created_at",initialOrder=params.get("order")==="asc"?"asc":"desc";
    const primary=(value:any,secondary="")=>{const wrap=document.createElement("div"),strong=document.createElement("strong");strong.className="crm-table-primary";strong.textContent=String(value||"—");wrap.append(strong);if(secondary){const small=document.createElement("small");small.className="crm-table-secondary";small.textContent=secondary;wrap.append(small)}return wrap};
    const attention=(value:number)=>{const span=document.createElement("span");span.className=`crm-review-attention ${value?"needs-review":""}`;span.textContent=value?`${value} need review`:"Queue clear";return span};
    const action=(row:any)=>{const wrap=document.createElement("div");wrap.className="crm-review-link";const overview=document.createElement("a");overview.className="btn btn-xs";overview.href=`/crm/intake/review/${row.id}/overview`;overview.textContent="Overview";const next=document.createElement("a");next.className="btn btn-xs btn-primary";next.href=`/crm/intake/review/${row.id}/${row.review_items?"manual":row.eligible_items?"ready":"overview"}`;next.textContent=row.review_items?"Manual review →":row.eligible_items?"Ready queue →":"Open →";wrap.append(overview,next);return wrap};
    function syncUrl(pagination?:any,sorting?:any[]){const url=new URL(location.href);for(const [key,value] of [["q",search.value],["status",status.value],["category",category.value]])value?url.searchParams.set(key,value):url.searchParams.delete(key);if(pagination){url.searchParams.set("page",String(pagination.pageIndex+1));url.searchParams.set("page_size",String(pagination.pageSize))}if(sorting){const current=sorting[0];current?url.searchParams.set("sort",current.id):url.searchParams.delete("sort");current?url.searchParams.set("order",current.desc?"desc":"asc"):url.searchParams.delete("order")}history.replaceState({},"",url)}
    await table.configure({manualPagination:true,initialPageIndex:initialPage,initialPageSize,initialSorting:[{id:initialSort,desc:initialOrder==="desc"}],onPageChange:(value:any)=>syncUrl(value),onSortingChange:(value:any[])=>syncUrl(undefined,value),getRowId:(row:any)=>row.id,columns:[{accessorKey:"run_code",header:"Review run",cell:({row}:any)=>primary(row.original.run_code,`Source ${row.original.batch_code}`)},{accessorKey:"contact_name",header:"Contact",cell:({row}:any)=>primary(row.original.contact_name,row.original.contact_identity||"")},{accessorKey:"status",header:"Status",cell:({row}:any)=>primary(processingStatusLabel(row.original.status),`${row.original.processed_items}/${row.original.total_items} files`)},{accessorKey:"crm_complaints",header:"Candidates",cell:({row}:any)=>primary(row.original.crm_complaints,`${row.original.possible_crm} possible · ${row.original.duplicate_items} existing`)},{accessorKey:"review_items",header:"Attention",cell:({row}:any)=>attention(Number(row.original.review_items||0))},{accessorKey:"paperless_check_status",header:"Paperless check",cell:({row}:any)=>processingStatusLabel(row.original.paperless_check_status)},{accessorKey:"created_at",header:"Started",cell:({row}:any)=>new Date(row.original.started_at||row.original.created_at).toLocaleString()},{id:"actions",header:"",cell:({row}:any)=>action(row.original),enableSorting:false,meta:{align:"right",minWidth:"11rem"}}],loadPage:async(pageIndex:number,pageSize:number,sorting:any[])=>{const current=sorting[0],result=await actions.whatsapp.inboundProcessingRuns({search:search.value.trim()||undefined,status:status.value||undefined,category:category.value||undefined,limit:pageSize,offset:pageIndex*pageSize,sort:current?.id||"created_at",order:current?.desc===false?"asc":"desc"});if(result.error)throw new Error(result.error.message);const data=result.data as any,counts=data.counts||{};el("processing-count-total").textContent=String(counts.total||0);el("processing-count-active").textContent=String(counts.active||0);el("processing-count-completed").textContent=String(counts.completed||0);el("processing-count-errors").textContent=String(counts.with_errors||0);el("processing-result-count").textContent=`${data.total} run${data.total===1?"":"s"}`;const active=(data.items||[]).some((row:any)=>["queued","extracting","checking_paperless"].includes(row.status));if(timer)clearInterval(timer);timer=active?window.setInterval(()=>{if(!document.hidden)void table.refresh(false)},5000):undefined;return{rows:data.items||[],total:Number(data.total||0)}}});
    async function refresh(){syncUrl({pageIndex:0,pageSize:table.getPagination().pageSize});await table.refresh(true)}status.addEventListener("change",()=>void refresh());category.addEventListener("change",()=>void refresh());search.addEventListener("input",()=>{if(searchTimer)clearTimeout(searchTimer);searchTimer=window.setTimeout(()=>void refresh(),250)});el("clear-processing-filters").addEventListener("click",()=>{search.value="";status.value="";category.value="";void refresh()});el("refresh-processing").addEventListener("click",()=>void table.refresh(false));window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer)});
  </script>
</CrmLayout>
