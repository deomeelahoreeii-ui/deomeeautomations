---
import CrmIntakeNav from "../../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const runId = Astro.params.id || "";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Complaint Review" description="Approve confident complaint groups, resolve ambiguous evidence, and keep technical processing details out of the decision path." page="intake">
  <a class="btn btn-sm" href="/crm/intake/review" slot="actions">← All processing runs</a>
  <CrmIntakeNav active="review" />

  <section class="master-card crm-review-result" id="processing-detail-root" data-run-id={runId} data-api-base={apiBase}>
    <div class="inbound-card-heading"><div><p class="eyebrow">Processing result</p><h2 id="processing-run-code">Loading…</h2><p id="processing-run-contact">—</p></div><span class="crm-run-state" id="processing-run-status">Loading</span></div>
    <div class="crm-result-strip"><div><span>Complaint groups</span><strong id="result-groups">—</strong></div><div><span>Ready for decision</span><strong id="result-ready">—</strong></div><div><span>Manual review</span><strong id="result-manual">—</strong></div><div><span>Approved</span><strong id="result-approved">—</strong></div><div><span>Existing</span><strong id="result-existing">—</strong></div></div>
    <details class="crm-technical-details"><summary>Technical processing details</summary><div class="inbound-detail-facts"><div><span>Batch</span><strong id="processing-batch-code">—</strong></div><div><span>Started</span><strong id="processing-started">—</strong></div><div><span>Classifier</span><strong id="processing-classifier">—</strong></div><div><span>Paperless</span><strong id="processing-paperless">—</strong></div></div><pre class="inbound-log" id="processing-log">Loading processing activity…</pre></details>
  </section>

  <nav class="crm-decision-tabs" aria-label="Review queue">
    <button data-tab="ready"><span>Ready</span><b id="tab-ready-count">0</b></button>
    <button data-tab="manual"><span>Manual review</span><b id="tab-manual-count">0</b></button>
    <button data-tab="approved"><span>Approved</span><b id="tab-approved-count">0</b></button>
    <button data-tab="existing"><span>Already exists</span><b id="tab-existing-count">0</b></button>
    <button data-tab="rejected"><span>Rejected</span><b id="tab-rejected-count">0</b></button>
  </nav>

  <section class="master-card crm-decision-panel">
    <div class="inbound-card-heading"><div><p class="eyebrow" id="queue-eyebrow">Decision queue</p><h2 id="queue-title">Ready for approval</h2><p id="queue-description">Confident complaint groups with a fresh Paperless result.</p></div><div class="crm-queue-header-actions"><label class="crm-batch-selector" id="batch-ready-actions"><input type="checkbox" id="select-all-ready"/><span id="selected-ready-count">Select all ready</span></label><button class="btn btn-sm btn-primary" id="approve-selected" type="button" disabled>Approve selected</button><a class="btn btn-sm" id="open-approved-cases" href="/crm/cases/?state=fresh" hidden>Open approved cases →</a></div></div>
    <div id="decision-list" class="crm-decision-list"><div class="crm-intake-empty"><h3>Loading review queue…</h3></div></div>
  </section>

  <style>
    .crm-review-result{margin-top:1rem}.crm-result-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:.7rem;margin-top:1rem}.crm-result-strip div{padding:.8rem;border:1px solid #dbe5ed;border-radius:.7rem;background:#f8fbfc}.crm-result-strip span{display:block;color:#718096;font-size:.75rem}.crm-result-strip strong{display:block;font-size:1.45rem;margin-top:.2rem}.crm-technical-details{margin-top:1rem;border-top:1px solid #e2e8f0;padding-top:.75rem}.crm-technical-details summary{cursor:pointer;font-weight:700;color:#526276}.crm-technical-details .inbound-detail-facts{margin:.8rem 0}.crm-technical-details pre{max-height:18rem}.crm-decision-tabs{display:flex;gap:.45rem;overflow:auto;margin:1rem 0;padding:.3rem;background:#eaf1f5;border-radius:.8rem}.crm-decision-tabs button{display:flex;gap:.5rem;align-items:center;border:0;background:transparent;padding:.7rem 1rem;border-radius:.6rem;white-space:nowrap;font-weight:700;color:#526276}.crm-decision-tabs button.active{background:#fff;color:#0d7788;box-shadow:0 1px 5px #0f172a18}.crm-decision-tabs b{display:grid;place-items:center;min-width:1.5rem;height:1.5rem;padding:0 .35rem;border-radius:1rem;background:#d9e6ec;font-size:.72rem}.crm-decision-tabs button.active b{background:#16879a;color:#fff}.crm-decision-panel{min-height:24rem}.crm-queue-header-actions{display:flex;align-items:center;justify-content:flex-end;gap:.55rem;flex-wrap:wrap}.crm-batch-selector{display:flex;align-items:center;gap:.4rem;border:1px solid #d8e3ea;border-radius:.5rem;background:#f8fbfc;padding:.42rem .6rem;color:#526276;font-size:.72rem;font-weight:700;cursor:pointer}.crm-batch-selector input,.crm-candidate-selector input{accent-color:#16879a}.crm-decision-list{display:grid;gap:.8rem}.crm-candidate{border:1px solid #dbe5ed;border-radius:.8rem;padding:1rem;background:#fff}.crm-candidate.selected{border-color:#69afb9;box-shadow:0 0 0 2px #dff4f6}.crm-candidate>header{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem}.crm-candidate-heading{display:flex;align-items:flex-start;gap:.7rem}.crm-candidate-selector{display:flex;align-items:center;justify-content:center;width:1.8rem;height:1.8rem;flex:0 0 auto;border:1px solid #d8e3ea;border-radius:.45rem;background:#f8fbfc;cursor:pointer}.crm-candidate h3{margin:.2rem 0}.crm-candidate-subtitle{color:#64748b}.crm-candidate-score{text-align:right;color:#0d7788}.crm-candidate-score strong{font-size:1.35rem}.crm-candidate-grid{display:grid;grid-template-columns:1.1fr 1fr 1fr;gap:.7rem;margin:.8rem 0}.crm-candidate-grid>div{padding:.7rem;border:1px solid #e5ebf0;border-radius:.6rem}.crm-candidate-grid span{display:block;color:#718096;font-size:.7rem;text-transform:uppercase;letter-spacing:.04em}.crm-candidate-grid strong{display:block;margin-top:.2rem}.crm-file-chips{display:flex;gap:.35rem;flex-wrap:wrap;margin-top:.45rem}.crm-file-chips a{display:inline-flex;gap:.3rem;align-items:center;padding:.35rem .55rem;background:#edf7f8;border:1px solid #c8e3e7;border-radius:.45rem;color:#0d7788;font-size:.72rem;font-weight:700;text-decoration:none}.crm-file-chips a:hover{background:#dff1f3}.crm-candidate-actions{display:flex;justify-content:flex-end;gap:.5rem;align-items:center;border-top:1px solid #edf1f4;padding-top:.75rem}.crm-candidate-actions .reject{color:#a33;border-color:#e5bcbc}.crm-manual-layout{display:grid;grid-template-columns:minmax(15rem,.8fr) minmax(20rem,1.2fr);gap:1rem}.crm-manual-preview{display:grid;place-items:center;min-height:12rem;border:1px dashed #b9cbd4;border-radius:.7rem;background:#f7fafb}.crm-manual-form{display:grid;gap:.7rem}.crm-manual-form label{display:grid;gap:.25rem;font-weight:700}.crm-manual-actions{display:flex;gap:.5rem}.crm-empty-action{text-align:center;padding:3rem 1rem}.crm-empty-action h3{margin:.4rem 0}.crm-empty-action p{color:#718096}@media(max-width:900px){.crm-result-strip{grid-template-columns:repeat(2,1fr)}.crm-candidate-grid,.crm-manual-layout{grid-template-columns:1fr}.crm-candidate>header{flex-direction:column}.crm-candidate-score{text-align:left}.crm-queue-header-actions{justify-content:flex-start}}
  </style>

  <script>
    import { actions } from "astro:actions";
    const root=document.getElementById("processing-detail-root") as HTMLElement,runId=root.dataset.runId||"",apiBase=root.dataset.apiBase||"";const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;let data:any,timer:number|undefined,activeTab=new URLSearchParams(location.search).get("tab")||"ready";const selectedGroups=new Set<string>();
    const esc=(v:any)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");const formatDate=(v:any)=>{if(!v)return"—";const d=new Date(v);return Number.isNaN(d.getTime())?String(v):d.toLocaleString()};
    const bucketGroups=(bucket:string)=>(data?.complaint_groups||[]).filter((g:any)=>g.review_bucket===bucket);const manualItems=()=>{const groupedManual=new Set(bucketGroups("manual_review").flatMap((g:any)=>g.files.map((f:any)=>f.id)));return(data?.items||[]).filter((x:any)=>["pending","deferred"].includes(x.review_status)).filter((x:any)=>!x.detected_complaint_number||x.status==="needs_review"||x.review_status==="deferred").filter((x:any)=>!groupedManual.has(x.id))};const rejectedLooseItems=()=>(data?.items||[]).filter((x:any)=>x.review_status==="rejected"&&!x.detected_complaint_number);
    function caseLink(g:any){return g.case_id?`<a class="btn btn-sm" href="/crm/cases/${esc(g.case_id)}">Open case</a>`:""}
    function groupCard(g:any){const score=Math.round(Number(g.average_confidence||0)*100),paperless=Object.keys(g.paperless_categories||{}).join(", ").replaceAll("_"," "),selectable=g.review_bucket==="ready",selected=selectedGroups.has(g.complaint_number);return`<article class="crm-candidate ${selected?"selected":""}" data-candidate="${esc(g.complaint_number)}"><header><div class="crm-candidate-heading">${selectable?`<label class="crm-candidate-selector" title="Select complaint ${esc(g.complaint_number)}"><input type="checkbox" data-select-group="${esc(g.complaint_number)}" ${selected?"checked":""}/></label>`:""}<div><p class="eyebrow">${esc(g.review_bucket.replaceAll("_"," "))}</p><h3>Complaint ${esc(g.complaint_number)}</h3><p class="crm-candidate-subtitle">${esc(g.complainant_name||"Complainant name not extracted")}${g.district?` · ${esc(g.district)}`:""}</p></div></div><div class="crm-candidate-score"><strong>${score}%</strong><small>system confidence</small></div></header><div class="crm-candidate-grid"><div><span>Evidence</span><strong>${g.item_count} file(s)</strong><div class="crm-file-chips">${g.files.map((f:any)=>`<a href="${apiBase}/api/v1/whatsapp/inbound/processing-items/${esc(f.id)}/content" target="_blank" rel="noreferrer" title="Open ${esc(f.filename)}">↗ ${esc(f.filename)}</a>`).join("")}</div></div><div><span>Paperless result</span><strong>${esc(paperless||"not checked")}</strong><small>${g.duplicate_items?"Existing record requires linking":"No matching complaint was found"}</small></div><div><span>Human decision</span><strong>${g.approved_items?`${g.approved_items} approved`:g.rejected_items?`${g.rejected_items} rejected`:"Pending"}</strong><small>System confidence never approves automatically</small></div></div><div class="crm-candidate-actions">${caseLink(g)}${["ready","manual_review"].includes(g.review_bucket)?`<button class="btn btn-sm reject" data-group="${esc(g.complaint_number)}" data-decision="rejected">Reject</button><button class="btn btn-sm btn-primary" data-group="${esc(g.complaint_number)}" data-decision="approved">Approve</button>`:""}</div></article>`}
    function manualCard(x:any){const preview=`${apiBase}/api/v1/whatsapp/inbound/processing-items/${x.id}/content`,numbers=x.extracted_metadata?.all_complaint_numbers||[],suggested=x.detected_complaint_number||(numbers.length===1?numbers[0]:"");return`<article class="crm-candidate" data-manual-item="${esc(x.id)}"><header><div><p class="eyebrow">Manual review</p><h3>${esc(x.filename)}</h3><p class="crm-candidate-subtitle">${esc(x.primary_category.replaceAll("_"," "))} · ${Math.round(Number(x.confidence||0)*100)}% system confidence</p></div><a class="btn btn-sm" href="${preview}" target="_blank" rel="noreferrer">Open full preview ↗</a></header><div class="crm-manual-layout"><div class="crm-manual-preview"><div><strong>Document preview</strong><p>Open the original file to verify the complaint number.</p><a class="btn btn-sm" href="${preview}" target="_blank" rel="noreferrer">Preview file</a></div></div><div class="crm-manual-form"><label>Complaint number<input class="input input-bordered manual-number" value="${esc(suggested)}" placeholder="104-6609317"/><small>${suggested&&!x.detected_complaint_number?"Suggested from the filename—verify it against the document.":"Enter the number shown in the document."}</small></label><label>Document type<select class="select select-bordered manual-category"><option value="crm_complaint">Main complaint</option><option value="crm_supporting_document">Complaint attachment</option><option value="crm_reply_or_report">Reply or report</option></select></label><label>Review note<textarea class="textarea textarea-bordered manual-note" placeholder="Optional reason or correction"></textarea></label><div class="crm-manual-actions"><button class="btn reject manual-reject">Reject</button><button class="btn btn-primary manual-approve">Approve and create case</button></div></div></div></article>`}
    function rejectedItemCard(x:any){const preview=`${apiBase}/api/v1/whatsapp/inbound/processing-items/${x.id}/content`;return`<article class="crm-candidate"><header><div><p class="eyebrow">Rejected file</p><h3>${esc(x.filename)}</h3><p class="crm-candidate-subtitle">${esc(x.reviewer_note||"Rejected as unrelated evidence")}</p></div><a class="btn btn-sm" href="${preview}" target="_blank" rel="noreferrer">Preview</a></header></article>`}
    function empty(title:string,text:string,link=""){return`<div class="crm-empty-action"><span>✓</span><h3>${esc(title)}</h3><p>${esc(text)}</p>${link?`<a class="btn btn-sm btn-primary" href="${link}">Open complaint cases →</a>`:""}</div>`}
    function syncBatchControls(){const ready=bucketGroups("ready").map((g:any)=>g.complaint_number),count=selectedGroups.size,visible=activeTab==="ready"&&ready.length>0,selectAll=el<HTMLInputElement>("select-all-ready"),approve=el<HTMLButtonElement>("approve-selected");el("batch-ready-actions").hidden=!visible;approve.hidden=!visible;approve.disabled=count===0;approve.textContent=count?`Approve selected (${count})`:"Approve selected";el("selected-ready-count").textContent=count?`${count} of ${ready.length} selected`:`Select all ${ready.length} ready`;selectAll.checked=ready.length>0&&count===ready.length;selectAll.indeterminate=count>0&&count<ready.length}
    function renderQueue(){document.querySelectorAll<HTMLButtonElement>("[data-tab]").forEach(b=>b.classList.toggle("active",b.dataset.tab===activeTab));const config:any={ready:["Ready for approval","Select the complaints you verified, then approve them together."],manual:["Manual review","Resolve missing numbers, low-confidence OCR and uncertain relationships."],approved:["Approved complaints","Human-approved cases ready for final case review or publication."],existing:["Already in Paperless","Complaints matched to an existing Paperless record."],rejected:["Rejected candidates","Documents explicitly excluded by an operator."]};el("queue-title").textContent=config[activeTab][0];el("queue-description").textContent=config[activeTab][1];el<HTMLAnchorElement>("open-approved-cases").hidden=activeTab!=="approved";let html="";if(activeTab==="manual"){const groups=bucketGroups("manual_review"),items=manualItems();html=[...groups.map(groupCard),...items.map(manualCard)].join("")||empty("Manual queue is clear","No ambiguous evidence remains in this run.")}else{const groups=bucketGroups(activeTab),loose=activeTab==="rejected"?rejectedLooseItems():[];html=[...groups.map(groupCard),...loose.map(rejectedItemCard)].join("")||empty(activeTab==="ready"?"No ready candidates":"Nothing here yet",activeTab==="ready"?"All confident candidates have been decided.":"This queue is currently empty.",activeTab==="approved"?"/crm/cases/?state=fresh":"")}el("decision-list").innerHTML=html;bindActions();syncBatchControls()}
    function render(d:any){data=d;const groups=d.complaint_groups||[],readyNumbers=new Set(bucketGroups("ready").map((g:any)=>g.complaint_number));for(const number of selectedGroups)if(!readyNumbers.has(number))selectedGroups.delete(number);const counts={ready:bucketGroups("ready").length,manual:bucketGroups("manual_review").length+manualItems().length,approved:bucketGroups("approved").length,existing:bucketGroups("existing").length,rejected:bucketGroups("rejected").length+rejectedLooseItems().length};el("processing-run-code").textContent=d.run_code;el("processing-run-contact").textContent=`${d.contact_name} · ${d.contact_identity||""}`;el("processing-run-status").textContent=d.status;el("processing-run-status").className=`crm-run-state ${d.status}`;el("processing-batch-code").textContent=d.batch_code;el("processing-started").textContent=formatDate(d.started_at||d.created_at);el("processing-classifier").textContent=`${d.classifier_version} · ${d.crm_rule_version}`;el("processing-paperless").textContent=d.paperless_check_status;el("result-groups").textContent=String(groups.length);el("result-ready").textContent=String(counts.ready);el("result-manual").textContent=String(counts.manual);el("result-approved").textContent=String(counts.approved);el("result-existing").textContent=String(counts.existing);Object.entries(counts).forEach(([key,value])=>el(`tab-${key}-count`).textContent=String(value));if(!new URLSearchParams(location.search).has("tab")){activeTab=counts.ready?"ready":counts.manual?"manual":counts.approved?"approved":"ready"}renderQueue()}
    function bindActions(){document.querySelectorAll<HTMLInputElement>("[data-select-group]").forEach(input=>input.addEventListener("change",()=>{const number=input.dataset.selectGroup||"";input.checked?selectedGroups.add(number):selectedGroups.delete(number);input.closest(".crm-candidate")?.classList.toggle("selected",input.checked);syncBatchControls()}));document.querySelectorAll<HTMLButtonElement>("[data-group]").forEach(button=>button.addEventListener("click",async()=>{const decision=button.dataset.decision as "approved"|"rejected",number=button.dataset.group||"";if(!confirm(decision==="approved"?`Approve complaint ${number} and its grouped evidence? This does not publish to Paperless.`:`Reject complaint candidate ${number}?`))return;const note=decision==="rejected"?prompt("Optional rejection reason")||null:null;button.disabled=true;button.textContent=decision==="approved"?"Approving…":"Rejecting…";const r=await actions.whatsapp.reviewInboundComplaintGroup({runId,complaintNumber:number,decision,reviewed_by:"web-operator",note});if(r.error)alert(r.error.message);else{selectedGroups.delete(number);activeTab=decision==="approved"?"approved":"rejected";history.replaceState({},"",`?tab=${activeTab}`);await load()}}));document.querySelectorAll<HTMLElement>("[data-manual-item]").forEach(card=>{const id=card.dataset.manualItem!;card.querySelector<HTMLButtonElement>(".manual-approve")?.addEventListener("click",async()=>{const number=card.querySelector<HTMLInputElement>(".manual-number")!.value,category=card.querySelector<HTMLSelectElement>(".manual-category")!.value,note=card.querySelector<HTMLTextAreaElement>(".manual-note")!.value||null;const r=await actions.whatsapp.reviewInboundProcessingItem({id,decision:"approved",reviewed_by:"web-operator",note,category,complaint_number:number});if(r.error)alert(r.error.message);else await load()});card.querySelector<HTMLButtonElement>(".manual-reject")?.addEventListener("click",async()=>{if(!confirm("Reject this file as unrelated evidence?"))return;const note=card.querySelector<HTMLTextAreaElement>(".manual-note")!.value||null,r=await actions.whatsapp.reviewInboundProcessingItem({id,decision:"rejected",reviewed_by:"web-operator",note,category:null,complaint_number:null});if(r.error)alert(r.error.message);else await load()})})}
    async function load(){const [r,e]=await Promise.all([actions.whatsapp.inboundProcessingRun({id:runId}),actions.whatsapp.inboundProcessingEvents({id:runId,limit:1000})]);if(r.error){el("processing-run-code").textContent="Run unavailable";el("decision-list").innerHTML=`<p class="alert alert-error">${esc(r.error.message)}</p>`;return}render(r.data as any);if(e.data){const rows=(e.data as any).items||[];el("processing-log").textContent=rows.length?rows.map((x:any)=>`[${formatDate(x.created_at)}] ${String(x.level).toUpperCase().padEnd(7)} ${x.message}`).join("\n"):"No processing activity recorded."}const status=(r.data as any).status;if(["queued","extracting","checking_paperless"].includes(status)){if(!timer)timer=window.setInterval(()=>{if(!document.hidden)void load()},3000)}else if(timer){clearInterval(timer);timer=undefined}}
    el<HTMLInputElement>("select-all-ready").addEventListener("change",event=>{const checked=(event.target as HTMLInputElement).checked;selectedGroups.clear();if(checked)bucketGroups("ready").forEach((group:any)=>selectedGroups.add(group.complaint_number));renderQueue()});
    el<HTMLButtonElement>("approve-selected").addEventListener("click",async()=>{const numbers=[...selectedGroups];if(!numbers.length)return;if(!confirm(`Approve ${numbers.length} selected complaint${numbers.length===1?"":"s"} and their grouped evidence? This creates native cases but does not publish to Paperless.`))return;const button=el<HTMLButtonElement>("approve-selected");button.disabled=true;button.textContent=`Approving ${numbers.length}…`;const result=await actions.whatsapp.batchApproveInboundComplaintGroups({runId,complaintNumbers:numbers,reviewed_by:"web-operator",note:"Batch-approved from the Ready decision queue."});if(result.error){alert(result.error.message);button.disabled=false;syncBatchControls();return}selectedGroups.clear();activeTab="approved";history.replaceState({},"",`?tab=${activeTab}`);await load()});
    document.querySelectorAll<HTMLButtonElement>("[data-tab]").forEach(button=>button.addEventListener("click",()=>{activeTab=button.dataset.tab||"ready";history.replaceState({},"",`?tab=${activeTab}`);renderQueue()}));void load();window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer)});
  </script>
</CrmLayout>
