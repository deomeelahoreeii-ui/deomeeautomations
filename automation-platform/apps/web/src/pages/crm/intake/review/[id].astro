---
const runId = Astro.params.id || "";
const legacyTab = Astro.url.searchParams.get("tab");
const destination = ({
  ready: "ready",
  manual: "manual",
  existing: "existing",
  approved: "decisions",
  rejected: "decisions",
} as Record<string, string>)[legacyTab || ""] || "overview";
const query = new URLSearchParams(Astro.url.searchParams);
query.delete("tab");
const suffix = query.size ? `?${query}` : "";
return Astro.redirect(`/crm/intake/review/${runId}/${destination}${suffix}`, 302);
---
