---
import CrmIntakeNav from "../../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const runId = Astro.params.id || "";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Complaint Review" description="Approve confident complaint groups, resolve ambiguous evidence, and keep technical processing details out of the decision path." page="intake">
  <a class="btn btn-sm" href="/crm/intake/review" slot="actions">← All processing runs</a>
  <CrmIntakeNav active="review" />

  <section class="master-card crm-review-result" id="processing-detail-root" data-run-id={runId} data-api-base={apiBase}>
    <div class="inbound-card-heading"><div><p class="eyebrow">Complaint review run</p><h2 id="processing-run-code">Loading…</h2><p id="processing-run-contact">—</p><p class="crm-review-lineage">Source intake <a id="processing-source-batch" href="#">Loading…</a></p></div><span class="crm-run-state" id="processing-run-status">Loading</span></div>
    <div class="crm-result-strip"><div><span>Complaint groups</span><strong id="result-groups">—</strong></div><div><span>Ready for decision</span><strong id="result-ready">—</strong></div><div><span>Manual review</span><strong id="result-manual">—</strong></div><div><span>Approved</span><strong id="result-approved">—</strong></div><div><span>Existing</span><strong id="result-existing">—</strong></div></div>
    <details class="crm-technical-details"><summary>Live classifier log and technical details</summary><div class="inbound-detail-facts"><div><span>Batch</span><strong id="processing-batch-code">—</strong></div><div><span>Started</span><strong id="processing-started">—</strong></div><div><span>Classifier</span><strong id="processing-classifier">—</strong></div><div><span>Paperless</span><strong id="processing-paperless">—</strong></div></div><pre class="inbound-log" id="processing-log">Loading processing activity…</pre></details>
  </section>

  <nav class="crm-decision-tabs" aria-label="Review queue">
    <button data-tab="ready"><span>Ready</span><b id="tab-ready-count">0</b></button>
    <button data-tab="manual"><span>Manual review</span><b id="tab-manual-count">0</b></button>
    <button data-tab="approved"><span>Approved</span><b id="tab-approved-count">0</b></button>
    <button data-tab="existing"><span>Already exists</span><b id="tab-existing-count">0</b></button>
    <button data-tab="rejected"><span>Rejected</span><b id="tab-rejected-count">0</b></button>
  </nav>

  <section class="master-card crm-publication-handoff" id="publication-handoff" hidden>
    <div class="crm-publication-handoff-copy"><p class="eyebrow">After approval</p><h2>Paperless publication center</h2><p id="publication-handoff-explanation">Approved complaint groups become unique CRM cases before publication.</p></div>
    <div class="crm-publication-handoff-stats"><div><span>Approved in this run</span><strong id="handoff-run-approved">—</strong></div><div><span>Also approved in another run</span><strong id="handoff-overlap">—</strong></div><div><span>Unique approved cases</span><strong id="handoff-global-approved">—</strong></div><div><span>Ready for Paperless</span><strong id="handoff-ready">—</strong></div></div>
    <a class="btn btn-primary" href="/crm/cases/?state=fresh#complaint-cases">Open Paperless publication center →</a>
  </section>

  <section class="master-card crm-decision-panel">
    <div class="inbound-card-heading"><div><p class="eyebrow" id="queue-eyebrow">Files grouped by CRM complaint number</p><h2 id="queue-title">Ready for approval</h2><p id="queue-description">Confident complaint groups with a fresh Paperless result. No Paperless uploads happen from this queue.</p></div><div class="crm-queue-header-actions"><label class="crm-batch-selector" id="batch-ready-actions"><input type="checkbox" id="select-all-ready"/><span id="selected-ready-count">Select all ready</span></label><button class="btn btn-sm btn-primary" id="approve-selected" type="button" disabled>Approve selected</button></div></div>
    <div id="decision-list" class="crm-decision-list"><div class="crm-intake-empty"><h3>Loading review queue…</h3></div></div>
  </section>

  <!-- Queue cards are rendered with innerHTML, so these styles must be global. -->
  <style is:global>
    .crm-review-result{margin-top:1rem}.crm-review-lineage{margin:.45rem 0 0;color:#718096;font-size:.72rem}.crm-review-lineage a{color:#0d7788;font-weight:750}.crm-result-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:.7rem;margin-top:1rem}.crm-result-strip div{padding:.8rem;border:1px solid #dbe5ed;border-radius:.7rem;background:#f8fbfc}.crm-result-strip span{display:block;color:#718096;font-size:.75rem}.crm-result-strip strong{display:block;font-size:1.45rem;margin-top:.2rem}.crm-technical-details{margin-top:1rem;border-top:1px solid #e2e8f0;padding-top:.75rem}.crm-technical-details summary{cursor:pointer;font-weight:700;color:#526276}.crm-technical-details .inbound-detail-facts{margin:.8rem 0}.crm-technical-details pre{max-height:18rem}.crm-decision-tabs{display:flex;gap:.45rem;overflow:auto;margin:1rem 0;padding:.3rem;background:#eaf1f5;border-radius:.8rem}.crm-decision-tabs button{display:flex;gap:.5rem;align-items:center;border:0;background:transparent;padding:.7rem 1rem;border-radius:.6rem;white-space:nowrap;font-weight:700;color:#526276}.crm-decision-tabs button.active{background:#fff;color:#0d7788;box-shadow:0 1px 5px #0f172a18}.crm-decision-tabs b{display:grid;place-items:center;min-width:1.5rem;height:1.5rem;padding:0 .35rem;border-radius:1rem;background:#d9e6ec;font-size:.72rem}.crm-decision-tabs button.active b{background:#16879a;color:#fff}.crm-decision-panel{min-height:24rem}.crm-queue-header-actions{display:flex;align-items:center;justify-content:flex-end;gap:.55rem;flex-wrap:wrap}.crm-batch-selector{display:flex;align-items:center;gap:.4rem;border:1px solid #d8e3ea;border-radius:.5rem;background:#f8fbfc;padding:.42rem .6rem;color:#526276;font-size:.72rem;font-weight:700;cursor:pointer}.crm-batch-selector input,.crm-candidate-selector input{accent-color:#16879a}.crm-decision-list{display:grid;gap:.8rem}.crm-candidate{overflow:hidden;border:1px solid #dbe5ed;border-radius:.8rem;background:#fff}.crm-candidate.selected{border-color:#69afb9;box-shadow:0 0 0 2px #dff4f6}.crm-candidate>header{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;padding:1rem 1.1rem;border-bottom:1px solid #edf1f4}.crm-candidate-heading{display:flex;align-items:flex-start;gap:.7rem}.crm-candidate-selector{display:flex;align-items:center;justify-content:center;width:1.8rem;height:1.8rem;flex:0 0 auto;border:1px solid #d8e3ea;border-radius:.45rem;background:#f8fbfc;cursor:pointer}.crm-candidate h3{margin:.2rem 0;font-size:1rem;overflow-wrap:anywhere}.crm-candidate-subtitle{margin:0;color:#64748b;font-size:.78rem}.crm-candidate-score{text-align:right;color:#0d7788}.crm-candidate-score strong,.crm-candidate-score small{display:block}.crm-candidate-score strong{font-size:1.35rem}.crm-candidate-grid{display:grid;grid-template-columns:1.1fr 1fr 1fr;gap:.7rem;margin:.9rem 1.1rem}.crm-candidate-grid>div{padding:.7rem;border:1px solid #e5ebf0;border-radius:.6rem}.crm-candidate-grid span{display:block;color:#718096;font-size:.7rem;text-transform:uppercase;letter-spacing:.04em}.crm-candidate-grid strong{display:block;margin-top:.2rem}.crm-file-chips{display:flex;gap:.35rem;flex-wrap:wrap;margin-top:.45rem}.crm-file-chips a{display:inline-flex;gap:.3rem;align-items:center;padding:.35rem .55rem;background:#edf7f8;border:1px solid #c8e3e7;border-radius:.45rem;color:#0d7788;font-size:.72rem;font-weight:700;text-decoration:none}.crm-file-chips a:hover{background:#dff1f3}.crm-candidate-actions{display:flex;justify-content:flex-end;gap:.5rem;align-items:center;border-top:1px solid #edf1f4;padding:.75rem 1.1rem}.crm-candidate-actions .reject,.crm-manual-actions .reject{color:#9f3535;border-color:#e7c3c3}.crm-manual-layout{display:grid;grid-template-columns:minmax(16rem,.72fr) minmax(24rem,1.28fr);gap:0}.crm-manual-preview{display:flex;min-height:21rem;flex-direction:column;justify-content:space-between;border-right:1px solid #e3eaf0;background:linear-gradient(145deg,#f1f7f9,#fbfcfd);padding:1.35rem}.crm-document-icon{display:grid;width:3rem;height:3.4rem;place-items:center;border-radius:.55rem;background:#dceff2;color:#117383;font-size:.72rem;font-weight:850}.crm-manual-preview h4{margin:1rem 0 .35rem;color:#29384d}.crm-manual-preview p{margin:0;color:#718096;font-size:.78rem;line-height:1.55}.crm-manual-preview .btn{align-self:flex-start}.crm-manual-form{display:grid;gap:.85rem;padding:1.25rem 1.35rem}.crm-manual-form label{display:grid;gap:.35rem;color:#425167;font-size:.78rem;font-weight:750}.crm-manual-form label small{color:#7d8999;font-size:.68rem;font-weight:500}.crm-manual-form input,.crm-manual-form select,.crm-manual-form textarea{width:100%}.crm-manual-form textarea{min-height:4.75rem}.crm-target-case{display:flex;align-items:center;justify-content:space-between;gap:1rem;min-height:4.3rem;border:1px solid #d9e5eb;border-radius:.65rem;background:#f8fbfc;padding:.75rem .85rem}.crm-target-case strong,.crm-target-case small{display:block}.crm-target-case strong{color:#334155;font-size:.8rem}.crm-target-case small{margin-top:.18rem;color:#718096;font-size:.69rem}.crm-target-case.matched{border-color:#9acbd1;background:#effafb}.crm-target-case.missing{border-color:#e8c992;background:#fff9ee}.crm-target-case a{flex:0 0 auto;color:#0d7788;font-size:.72rem;font-weight:750}.crm-manual-actions{display:flex;justify-content:space-between;gap:.65rem;border-top:1px solid #e7edf1;padding-top:.9rem}.crm-manual-actions .manual-approve{min-width:13rem}.crm-empty-action{text-align:center;padding:3rem 1rem}.crm-empty-action h3{margin:.4rem 0}.crm-empty-action p{color:#718096}@media(max-width:900px){.crm-result-strip{grid-template-columns:repeat(2,1fr)}.crm-candidate-grid,.crm-manual-layout{grid-template-columns:1fr}.crm-manual-preview{min-height:12rem;border-right:0;border-bottom:1px solid #e3eaf0}.crm-candidate>header{flex-direction:column}.crm-candidate-score{text-align:left}.crm-queue-header-actions{justify-content:flex-start}}@media(max-width:560px){.crm-manual-actions,.crm-target-case{align-items:stretch;flex-direction:column}.crm-manual-actions .btn{width:100%}}
  </style>

  <style>
    .crm-publication-handoff{display:grid;grid-template-columns:minmax(16rem,1.1fr) minmax(28rem,2fr) auto;gap:1rem;align-items:center;margin:0 0 1rem;border-color:#9bcdd4;border-left:5px solid #16879a;background:linear-gradient(120deg,#effafb,#fff)}
    .crm-publication-handoff[hidden]{display:none}
    .crm-publication-handoff h2{margin:.15rem 0 .35rem}
    .crm-publication-handoff p{margin:0;color:#64748b}
    .crm-publication-handoff-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:.55rem}
    .crm-publication-handoff-stats div{padding:.65rem;border:1px solid #d8e7eb;border-radius:.6rem;background:#fff}
    .crm-publication-handoff-stats span{display:block;color:#718096;font-size:.65rem;line-height:1.3}
    .crm-publication-handoff-stats strong{display:block;margin-top:.15rem;font-size:1.25rem}
    @media(max-width:1050px){.crm-publication-handoff{grid-template-columns:1fr}.crm-publication-handoff-stats{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:560px){.crm-publication-handoff-stats{grid-template-columns:1fr}}
  </style>

  <script>
    import { actions } from "astro:actions";
    const root=document.getElementById("processing-detail-root") as HTMLElement,runId=root.dataset.runId||"",apiBase=root.dataset.apiBase||"";const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;let data:any,caseStats:any={},timer:number|undefined,activeTab=new URLSearchParams(location.search).get("tab")||"ready";const selectedGroups=new Set<string>();
    const esc=(v:any)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");const formatDate=(v:any)=>{if(!v)return"—";const d=new Date(v);return Number.isNaN(d.getTime())?String(v):d.toLocaleString()};
    const caseLookup=new Map<string,any|null>();const normalizeNumber=(value:string)=>value.trim().toUpperCase().replace(/[‐‑‒–—−]/g,"-").replace(/\s+/g,"");
    const bucketGroups=(bucket:string)=>(data?.complaint_groups||[]).filter((g:any)=>g.review_bucket===bucket);const manualItems=()=>{const groupedManual=new Set(bucketGroups("manual_review").flatMap((g:any)=>g.files.map((f:any)=>f.id)));return(data?.items||[]).filter((x:any)=>["pending","deferred"].includes(x.review_status)).filter((x:any)=>!x.detected_complaint_number||x.status==="needs_review"||x.review_status==="deferred").filter((x:any)=>!groupedManual.has(x.id))};const rejectedLooseItems=()=>(data?.items||[]).filter((x:any)=>x.review_status==="rejected"&&!x.detected_complaint_number);
    function caseLink(g:any){return g.case_id?`<a class="btn btn-sm" href="/crm/cases/${esc(g.case_id)}">Open case</a>`:""}
    function groupCard(g:any){const score=Math.round(Number(g.average_confidence||0)*100),paperless=Object.keys(g.paperless_categories||{}).join(", ").replaceAll("_"," "),selectable=g.review_bucket==="ready",selected=selectedGroups.has(g.complaint_number);return`<article class="crm-candidate ${selected?"selected":""}" data-candidate="${esc(g.complaint_number)}"><header><div class="crm-candidate-heading">${selectable?`<label class="crm-candidate-selector" title="Select complaint ${esc(g.complaint_number)}"><input type="checkbox" data-select-group="${esc(g.complaint_number)}" ${selected?"checked":""}/></label>`:""}<div><p class="eyebrow">${esc(g.review_bucket.replaceAll("_"," "))}</p><h3>Complaint ${esc(g.complaint_number)}</h3><p class="crm-candidate-subtitle">${esc(g.complainant_name||"Complainant name not extracted")}${g.district?` · ${esc(g.district)}`:""}</p></div></div><div class="crm-candidate-score"><strong>${score}%</strong><small>system confidence</small></div></header><div class="crm-candidate-grid"><div><span>Evidence</span><strong>${g.item_count} file(s)</strong><div class="crm-file-chips">${g.files.map((f:any)=>`<a href="${apiBase}/api/v1/whatsapp/inbound/processing-items/${esc(f.id)}/content" target="_blank" rel="noreferrer" title="Open ${esc(f.filename)}">↗ ${esc(f.filename)}</a>`).join("")}</div></div><div><span>Paperless result</span><strong>${esc(paperless||"not checked")}</strong><small>${g.duplicate_items?"Existing record requires linking":"No matching complaint was found"}</small></div><div><span>Human decision</span><strong>${g.approved_items?`${g.approved_items} approved`:g.rejected_items?`${g.rejected_items} rejected`:"Pending"}</strong><small>System confidence never approves automatically</small></div></div><div class="crm-candidate-actions">${caseLink(g)}${["ready","manual_review"].includes(g.review_bucket)?`<button class="btn btn-sm reject" data-group="${esc(g.complaint_number)}" data-decision="rejected">Reject</button><button class="btn btn-sm btn-primary" data-group="${esc(g.complaint_number)}" data-decision="approved">Approve</button>`:""}</div></article>`}
    function manualCard(x:any){const preview=`${apiBase}/api/v1/whatsapp/inbound/processing-items/${x.id}/content`,numbers=x.extracted_metadata?.all_complaint_numbers||[],suggested=x.detected_complaint_number||(numbers.length===1?numbers[0]:""),suggestedCategory=["crm_complaint","crm_supporting_document","crm_reply_or_report"].includes(x.primary_category)?x.primary_category:"crm_supporting_document";return`<article class="crm-candidate" data-manual-item="${esc(x.id)}"><header><div><p class="eyebrow">Relationship review</p><h3>${esc(x.filename)}</h3><p class="crm-candidate-subtitle">The system found CRM evidence but could not safely attach it to a complaint.</p></div><div class="crm-candidate-score"><strong>${Math.round(Number(x.confidence||0)*100)}%</strong><small>classification confidence</small></div></header><div class="crm-manual-layout"><div class="crm-manual-preview"><div><div class="crm-document-icon">PDF</div><h4>Verify the source document</h4><p>Open the original and confirm both the complaint number and this file’s role. The source file is never changed.</p></div><a class="btn btn-sm" href="${preview}" target="_blank" rel="noreferrer">Open original document ↗</a></div><div class="crm-manual-form"><label>What is this document?<select class="select select-bordered manual-category"><option value="crm_supporting_document" ${suggestedCategory==="crm_supporting_document"?"selected":""}>Attachment / supporting document</option><option value="crm_reply_or_report" ${suggestedCategory==="crm_reply_or_report"?"selected":""}>Reply or report</option><option value="crm_complaint" ${suggestedCategory==="crm_complaint"?"selected":""}>Main complaint document</option></select><small>This controls its role inside the complaint case.</small></label><label>Complaint number<input class="input input-bordered manual-number" value="${esc(suggested)}" placeholder="104-6609317" autocomplete="off"/><small>${suggested&&!x.detected_complaint_number?"Suggested from the filename—verify it against the document.":"Enter the number printed on the document."}</small></label><div class="crm-target-case" aria-live="polite"><div><strong>Checking complaint registry…</strong><small>Looking for the exact complaint number.</small></div></div><label>Review note <span>(optional)</span><textarea class="textarea textarea-bordered manual-note" placeholder="Why this document belongs to the complaint"></textarea></label><div class="crm-manual-actions"><button class="btn reject manual-reject" type="button">Not CRM evidence</button><button class="btn btn-primary manual-approve" type="button" aria-label="Save review and link document" disabled>Check complaint number</button></div></div></div></article>`}
    function rejectedItemCard(x:any){const preview=`${apiBase}/api/v1/whatsapp/inbound/processing-items/${x.id}/content`;return`<article class="crm-candidate"><header><div><p class="eyebrow">Rejected file</p><h3>${esc(x.filename)}</h3><p class="crm-candidate-subtitle">${esc(x.reviewer_note||"Rejected as unrelated evidence")}</p></div><a class="btn btn-sm" href="${preview}" target="_blank" rel="noreferrer">Preview</a></header></article>`}
    function empty(title:string,text:string,link=""){return`<div class="crm-empty-action"><span>✓</span><h3>${esc(title)}</h3><p>${esc(text)}</p>${link?`<a class="btn btn-sm btn-primary" href="${link}">Open complaint cases →</a>`:""}</div>`}
    function syncBatchControls(){const ready=bucketGroups("ready").map((g:any)=>g.complaint_number),count=selectedGroups.size,visible=activeTab==="ready"&&ready.length>0,selectAll=el<HTMLInputElement>("select-all-ready"),approve=el<HTMLButtonElement>("approve-selected");el("batch-ready-actions").hidden=!visible;approve.hidden=!visible;approve.disabled=count===0;approve.textContent=count?`Approve selected (${count})`:"Approve selected";el("selected-ready-count").textContent=count?`${count} of ${ready.length} selected`:`Select all ${ready.length} ready`;selectAll.checked=ready.length>0&&count===ready.length;selectAll.indeterminate=count>0&&count<ready.length}
    function renderQueue(){document.querySelectorAll<HTMLButtonElement>("[data-tab]").forEach(b=>b.classList.toggle("active",b.dataset.tab===activeTab));const config:any={ready:["Ready for approval","Select the complaints you verified, then approve them together."],manual:["Manual review","Resolve missing numbers, low-confidence OCR and uncertain relationships."],approved:["Approved complaints","Human-approved groups from this run. Repeated complaint numbers become one durable CRM case."],existing:["Already in Paperless","Complaints matched to an existing Paperless record."],rejected:["Rejected candidates","Documents explicitly excluded by an operator."]};el("queue-title").textContent=config[activeTab][0];el("queue-description").textContent=config[activeTab][1];const approved=bucketGroups("approved"),overlap=approved.filter((g:any)=>g.approved_in_other_runs).length,handoff=el("publication-handoff");handoff.hidden=activeTab!=="approved";el("handoff-run-approved").textContent=String(approved.length);el("handoff-overlap").textContent=String(overlap);el("handoff-global-approved").textContent=String(caseStats.approved_cases??"—");el("handoff-ready").textContent=String(caseStats.ready_to_publish??"—");el("publication-handoff-explanation").textContent=`This run approved ${approved.length} complaint group${approved.length===1?"":"s"}. ${overlap} ${overlap===1?"is":"are"} also approved in another run, so the CRM registry counts each complaint number once.`;let html="";if(activeTab==="manual"){const groups=bucketGroups("manual_review"),items=manualItems();html=[...groups.map(groupCard),...items.map(manualCard)].join("")||empty("Manual queue is clear","No ambiguous evidence remains in this run.")}else{const groups=bucketGroups(activeTab),loose=activeTab==="rejected"?rejectedLooseItems():[];html=[...groups.map(groupCard),...loose.map(rejectedItemCard)].join("")||empty(activeTab==="ready"?"No ready candidates":"Nothing here yet",activeTab==="ready"?"All confident candidates have been decided.":"This queue is currently empty.",activeTab==="approved"?"/crm/cases/?state=fresh":"")}el("decision-list").innerHTML=html;bindActions();syncBatchControls()}
    function render(d:any){data=d;const groups=d.complaint_groups||[],readyNumbers=new Set(bucketGroups("ready").map((g:any)=>g.complaint_number));for(const number of selectedGroups)if(!readyNumbers.has(number))selectedGroups.delete(number);const counts={ready:bucketGroups("ready").length,manual:bucketGroups("manual_review").length+manualItems().length,approved:bucketGroups("approved").length,existing:bucketGroups("existing").length,rejected:bucketGroups("rejected").length+rejectedLooseItems().length};el("processing-run-code").textContent=`Review ${d.run_code}`;el("processing-run-contact").textContent=`${d.contact_name} · ${d.contact_identity||""}`;const source=el<HTMLAnchorElement>("processing-source-batch");source.textContent=d.batch_code;source.href=`/crm/intake/batches/${d.batch_id}`;el("processing-run-status").textContent=d.status;el("processing-run-status").className=`crm-run-state ${d.status}`;el("processing-batch-code").textContent=d.batch_code;el("processing-started").textContent=formatDate(d.started_at||d.created_at);el("processing-classifier").textContent=`${d.classifier_version} · ${d.crm_rule_version}`;el("processing-paperless").textContent=d.paperless_check_status;el("result-groups").textContent=String(groups.length);el("result-ready").textContent=String(counts.ready);el("result-manual").textContent=String(counts.manual);el("result-approved").textContent=String(counts.approved);el("result-existing").textContent=String(counts.existing);Object.entries(counts).forEach(([key,value])=>el(`tab-${key}-count`).textContent=String(value));if(!new URLSearchParams(location.search).has("tab")){activeTab=counts.ready?"ready":counts.manual?"manual":counts.approved?"approved":"ready"}renderQueue()}
    function roleAction(category:string,matched:boolean){if(category==="crm_complaint")return matched?"Add main complaint to case":"Create complaint case";if(category==="crm_reply_or_report")return matched?"Link report to case":"Create review case & link report";return matched?"Link attachment to case":"Create review case & link attachment"}
    async function resolveTargetCase(card:HTMLElement){
      const input=card.querySelector<HTMLInputElement>(".manual-number")!,target=card.querySelector<HTMLElement>(".crm-target-case")!,button=card.querySelector<HTMLButtonElement>(".manual-approve")!,number=normalizeNumber(input.value),category=card.querySelector<HTMLSelectElement>(".manual-category")!.value;
      delete card.dataset.caseExists;button.disabled=true;target.className="crm-target-case";
      if(!number){target.innerHTML="<div><strong>Complaint number required</strong><small>Enter the number printed on the document to find its case.</small></div>";button.textContent="Check complaint number";return}
      target.innerHTML="<div><strong>Checking complaint registry…</strong><small>Looking for an exact complaint-number match.</small></div>";
      let match=caseLookup.get(number);
      if(!caseLookup.has(number)){const result=await actions.crm.cases({search:number,state:"",limit:20});if(result.error){if(card.isConnected){target.innerHTML=`<div><strong>Could not check cases</strong><small>${esc(result.error.message)}</small></div>`}return}match=((result.data as any).items||[]).find((item:any)=>normalizeNumber(item.complaint_number||"")===number)||null;caseLookup.set(number,match)}
      if(!card.isConnected||normalizeNumber(input.value)!==number)return;
      const currentCategory=card.querySelector<HTMLSelectElement>(".manual-category")!.value;
      if(match){card.dataset.caseExists="true";target.className="crm-target-case matched";target.innerHTML=`<div><strong>Existing complaint ${esc(match.complaint_number)}</strong><small>${esc(match.complainant_name||"Complainant not confirmed")} · ${esc(String(match.state).replaceAll("_"," "))} · ${match.document_count} document(s)</small></div><a href="/crm/cases/${esc(match.id)}" target="_blank">Open case ↗</a>`}
      else{card.dataset.caseExists="false";target.className="crm-target-case missing";target.innerHTML=`<div><strong>No complaint case found for ${esc(number)}</strong><small>This will create a review-required case. Confirm the number before continuing.</small></div>`}
      button.textContent=roleAction(currentCategory,Boolean(match));button.disabled=false
    }
    function bindActions(){
      document.querySelectorAll<HTMLInputElement>("[data-select-group]").forEach(input=>input.addEventListener("change",()=>{const number=input.dataset.selectGroup||"";input.checked?selectedGroups.add(number):selectedGroups.delete(number);input.closest(".crm-candidate")?.classList.toggle("selected",input.checked);syncBatchControls()}));
      document.querySelectorAll<HTMLButtonElement>("[data-group]").forEach(button=>button.addEventListener("click",async()=>{const decision=button.dataset.decision as "approved"|"rejected",number=button.dataset.group||"";if(!confirm(decision==="approved"?`Approve complaint ${number} and its grouped evidence? This does not publish to Paperless.`:`Reject complaint candidate ${number}?`))return;const note=decision==="rejected"?prompt("Optional rejection reason")||null:null;button.disabled=true;button.textContent=decision==="approved"?"Approving…":"Rejecting…";const r=await actions.whatsapp.reviewInboundComplaintGroup({runId,complaintNumber:number,decision,reviewed_by:"web-operator",note});if(r.error)alert(r.error.message);else{selectedGroups.delete(number);activeTab=decision==="approved"?"approved":"rejected";history.replaceState({},"",`?tab=${activeTab}`);await load()}}));
      document.querySelectorAll<HTMLElement>("[data-manual-item]").forEach(card=>{const id=card.dataset.manualItem!,numberInput=card.querySelector<HTMLInputElement>(".manual-number")!,categoryInput=card.querySelector<HTMLSelectElement>(".manual-category")!;let lookupTimer:number|undefined;numberInput.addEventListener("input",()=>{clearTimeout(lookupTimer);lookupTimer=window.setTimeout(()=>void resolveTargetCase(card),300)});categoryInput.addEventListener("change",()=>void resolveTargetCase(card));void resolveTargetCase(card);
        card.querySelector<HTMLButtonElement>(".manual-approve")?.addEventListener("click",async event=>{const button=event.currentTarget as HTMLButtonElement,number=numberInput.value,category=categoryInput.value,note=card.querySelector<HTMLTextAreaElement>(".manual-note")!.value||null,exists=card.dataset.caseExists==="true",description=category==="crm_complaint"?"main complaint":category==="crm_reply_or_report"?"report":"attachment";if(!confirm(exists?`Link this ${description} to complaint ${normalizeNumber(number)}?`:`No existing case was found. Create a review-required case for ${normalizeNumber(number)} and link this ${description}?`))return;button.disabled=true;button.textContent="Saving relationship…";const r=await actions.whatsapp.reviewInboundProcessingItem({id,decision:"approved",reviewed_by:"web-operator",note,category,complaint_number:number});if(r.error){alert(r.error.message);button.disabled=false;void resolveTargetCase(card)}else await load()});
        card.querySelector<HTMLButtonElement>(".manual-reject")?.addEventListener("click",async event=>{if(!confirm("Mark this file as not belonging to a CRM complaint?"))return;const button=event.currentTarget as HTMLButtonElement,note=card.querySelector<HTMLTextAreaElement>(".manual-note")!.value||null;button.disabled=true;button.textContent="Rejecting…";const r=await actions.whatsapp.reviewInboundProcessingItem({id,decision:"rejected",reviewed_by:"web-operator",note,category:null,complaint_number:null});if(r.error){alert(r.error.message);button.disabled=false;button.textContent="Not CRM evidence"}else await load()})
      })
    }
    async function load(){const [r,e,s]=await Promise.all([actions.whatsapp.inboundProcessingRun({id:runId}),actions.whatsapp.inboundProcessingEvents({id:runId,limit:1000}),actions.crm.caseStatistics({})]);if(r.error){el("processing-run-code").textContent="Run unavailable";el("decision-list").innerHTML=`<p class="alert alert-error">${esc(r.error.message)}</p>`;return}caseStats=s.data||{};render(r.data as any);if(e.data){const rows=(e.data as any).items||[];el("processing-log").textContent=rows.length?rows.map((x:any)=>`[${formatDate(x.created_at)}] ${String(x.level).toUpperCase().padEnd(7)} ${x.message}`).join("\n"):"No processing activity recorded."}const status=(r.data as any).status;if(["queued","extracting","checking_paperless"].includes(status)){if(!timer)timer=window.setInterval(()=>{if(!document.hidden)void load()},3000)}else if(timer){clearInterval(timer);timer=undefined}}
    el<HTMLInputElement>("select-all-ready").addEventListener("change",event=>{const checked=(event.target as HTMLInputElement).checked;selectedGroups.clear();if(checked)bucketGroups("ready").forEach((group:any)=>selectedGroups.add(group.complaint_number));renderQueue()});
    el<HTMLButtonElement>("approve-selected").addEventListener("click",async()=>{const numbers=[...selectedGroups];if(!numbers.length)return;if(!confirm(`Approve ${numbers.length} selected complaint${numbers.length===1?"":"s"} and their grouped evidence? This creates native cases but does not publish to Paperless.`))return;const button=el<HTMLButtonElement>("approve-selected");button.disabled=true;button.textContent=`Approving ${numbers.length}…`;const result=await actions.whatsapp.batchApproveInboundComplaintGroups({runId,complaintNumbers:numbers,reviewed_by:"web-operator",note:"Batch-approved from the Ready decision queue."});if(result.error){alert(result.error.message);button.disabled=false;syncBatchControls();return}selectedGroups.clear();activeTab="approved";history.replaceState({},"",`?tab=${activeTab}`);await load()});
    document.querySelectorAll<HTMLButtonElement>("[data-tab]").forEach(button=>button.addEventListener("click",()=>{activeTab=button.dataset.tab||"ready";history.replaceState({},"",`?tab=${activeTab}`);renderQueue()}));void load();window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer)});
  </script>
</CrmLayout>
