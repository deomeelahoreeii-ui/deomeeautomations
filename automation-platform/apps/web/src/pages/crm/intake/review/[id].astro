---
import CrmIntakeNav from "../../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const runId = Astro.params.id || "";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Complaint Evidence Review" description="Review complaint grouping, extracted evidence and Paperless duplicate results before accepting a CRM case candidate." page="intake">
  <a class="btn btn-sm" href="/crm/intake/review" slot="actions">← Review queue</a>
  <CrmIntakeNav active="review" />

  <section class="master-card inbound-processing-header" id="processing-detail-root" data-run-id={runId} data-api-base={apiBase}>
    <div class="inbound-card-heading"><div><p class="eyebrow">Dry-run processing</p><h2 id="processing-run-code">Loading…</h2><p id="processing-run-contact">—</p></div><span class="badge" id="processing-run-status">Loading</span></div>
    <div class="inbound-detail-facts"><div><span>Batch</span><strong id="processing-batch-code">—</strong></div><div><span>Started</span><strong id="processing-started">—</strong></div><div><span>Classifier</span><strong id="processing-classifier">—</strong></div><div><span>Paperless</span><strong id="processing-paperless">—</strong></div></div>
  </section>

  <section class="inbound-summary-grid inbound-processing-summary">
    <article class="master-card"><span>Confirmed CRM</span><strong id="summary-crm">—</strong></article>
    <article class="master-card"><span>Possible / related</span><strong id="summary-possible">—</strong></article>
    <article class="master-card"><span>Eligible / duplicate</span><strong id="summary-paperless">—</strong></article>
    <article class="master-card"><span>Needs review / failed</span><strong id="summary-review">—</strong></article>
  </section>

  <section class="inbound-detail-grid">
    <article class="master-card"><div class="inbound-card-heading"><div><p class="eyebrow">Persisted processing activity</p><h2>Live classifier log</h2></div><span class="badge" id="processing-log-state">Polling</span></div><pre class="inbound-log inbound-processing-log" id="processing-log">Loading processing activity…</pre></article>
    <article class="master-card"><p class="eyebrow">Review filters</p><h2>Focus the queue</h2><div class="inbound-processing-filters"><label><span>Category</span><select class="select select-bordered select-sm" id="item-category"><option value="">All files</option><option value="crm">All CRM-related</option><option value="crm_complaint">Confirmed CRM complaint</option><option value="possible_crm_complaint">Possible CRM complaint</option><option value="crm_supporting_document">Supporting document</option><option value="crm_reply_or_report">Reply or report</option><option value="eligible">Eligible</option><option value="duplicate_in_paperless">Paperless duplicate</option><option value="needs_review">Needs review</option><option value="unknown">Unknown</option></select></label><label><span>Review status</span><select class="select select-bordered select-sm" id="item-review"><option value="">All decisions</option><option value="pending">Pending</option><option value="approved">Approved</option><option value="rejected">Rejected</option><option value="deferred">Deferred</option></select></label><p id="processing-error">No Paperless uploads are performed by this page.</p></div></article>
  </section>

  <section class="master-card"><div class="inbound-card-heading"><div><p class="eyebrow">Canonical complaint grouping</p><h2>Files grouped by CRM complaint number</h2></div><span id="complaint-group-count">0 groups</span></div><div class="inbound-complaint-groups" id="complaint-groups"><p class="empty-cell">Waiting for complaint-number detection…</p></div></section>

  <section class="master-card"><div class="inbound-card-heading"><div><p class="eyebrow">Document review queue</p><h2>Extracted and categorized files</h2></div><span id="processing-item-count">0 files</span></div><div class="inbound-processing-items" id="processing-items"><p class="empty-cell">Loading documents…</p></div></section>

  <script>
    import { actions } from "astro:actions";
    const root=document.getElementById("processing-detail-root") as HTMLElement,runId=root.dataset.runId||"",apiBase=root.dataset.apiBase||"";const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;let timer:number|undefined;
    const escapeHtml=(v:unknown)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");const formatDate=(v:any)=>{if(!v)return"—";const d=new Date(v);return Number.isNaN(d.getTime())?String(v):d.toLocaleString();};const formatBytes=(v:any)=>{const n=Number(v||0);if(!n)return"0 B";const u=["B","KB","MB","GB"];const i=Math.min(Math.floor(Math.log(n)/Math.log(1024)),3);return`${(n/1024**i).toFixed(i?1:0)} ${u[i]}`;};
    const categories=["crm_complaint","possible_crm_complaint","crm_supporting_document","crm_reply_or_report","spreadsheet","general_official_document","image","unknown","unsupported"];
    function itemCard(x:any){const opts=categories.map(c=>`<option value="${c}" ${x.primary_category===c?"selected":""}>${c.replaceAll("_"," ")}</option>`).join("");const preview=`${apiBase}/api/v1/whatsapp/inbound/processing-items/${x.id}/content`;return`<article class="inbound-processing-item" data-item-id="${escapeHtml(x.id)}"><div class="processing-item-main"><div class="processing-item-title"><div><strong>${escapeHtml(x.detected_complaint_number||"No complaint number")}</strong><span class="badge">${escapeHtml(x.primary_category.replaceAll("_"," "))}</span></div><small>${escapeHtml(x.filename)} · ${formatBytes(x.size_bytes)} · ${escapeHtml(formatDate(x.message_timestamp))}</small></div><div class="processing-item-score"><strong>${Math.round(Number(x.confidence||0)*100)}%</strong><small>${escapeHtml(x.status)}</small></div></div><div class="processing-item-grid"><div><span>Evidence</span><ul>${(x.evidence||[]).map((v:string)=>`<li>${escapeHtml(v)}</li>`).join("")||"<li>No CRM evidence</li>"}</ul></div><div><span>Paperless dry-run</span><strong>${escapeHtml(x.paperless_category)}</strong><small>${escapeHtml(x.paperless_reason||"Not checked")}</small>${(x.paperless_document_ids||[]).length?`<small>Document IDs: ${escapeHtml((x.paperless_document_ids||[]).join(", "))}</small>`:""}</div><div><span>Extraction</span><strong>${escapeHtml(x.extraction_method||"Pending")}</strong><small>${escapeHtml(x.error||"")}</small></div></div><details class="processing-text"><summary>Extracted text</summary><pre>${escapeHtml((x.extracted_text||"").slice(0,20000))||"No text extracted."}</pre></details><div class="processing-review-controls"><a class="btn btn-xs" href="${preview}" target="_blank" rel="noreferrer">Preview</a><a class="btn btn-xs" href="${preview}?download=true">Download</a><select class="select select-bordered select-xs review-category">${opts}</select><input class="input input-bordered input-xs review-number" value="${escapeHtml(x.detected_complaint_number||"")}" placeholder="104-6609317"/><select class="select select-bordered select-xs review-decision"><option value="pending" ${x.review_status==="pending"?"selected":""}>Pending</option><option value="approved" ${x.review_status==="approved"?"selected":""}>Approve</option><option value="rejected" ${x.review_status==="rejected"?"selected":""}>Reject</option><option value="deferred" ${x.review_status==="deferred"?"selected":""}>Defer</option></select><input class="input input-bordered input-xs review-note" value="${escapeHtml(x.reviewer_note||"")}" placeholder="Review note"/><button class="btn btn-xs btn-primary save-review">Save review</button></div></article>`;}
    function render(d:any){el("processing-run-code").textContent=d.run_code;el("processing-run-contact").textContent=`${d.contact_name} · ${d.contact_identity||""}`;el("processing-run-status").textContent=d.status;el("processing-batch-code").textContent=d.batch_code;el("processing-started").textContent=formatDate(d.started_at||d.created_at);el("processing-classifier").textContent=`${d.classifier_version} · ${d.crm_rule_version}`;el("processing-paperless").textContent=d.paperless_check_status;el("summary-crm").textContent=String(d.crm_complaints);el("summary-possible").textContent=`${d.possible_crm+d.supporting_documents+d.reply_reports}`;el("summary-paperless").textContent=`${d.eligible_items} / ${d.duplicate_items}`;el("summary-review").textContent=`${d.review_items} / ${d.failed_items}`;el("processing-error").textContent=d.paperless_error||d.error||"No Paperless uploads are performed by this page.";const groups=d.complaint_groups||[];el("complaint-group-count").textContent=`${groups.length} group(s)`;el("complaint-groups").innerHTML=groups.length?groups.map((g:any)=>`<article><strong>${escapeHtml(g.complaint_number)}</strong><span>${g.item_count} file(s)</span><small>${escapeHtml(Object.entries(g.categories||{}).map(([k,v])=>`${String(k).replaceAll("_"," ")}: ${v}`).join(" · "))}</small><small>${g.eligible_items} eligible · ${g.duplicate_items} duplicate · ${g.review_items} review · ${g.approved_items} approved</small></article>`).join(""):'<p class="empty-cell">No canonical CRM complaint number has been detected yet.</p>';const items=d.items||[];el("processing-item-count").textContent=`${items.length} file(s)`;el("processing-items").innerHTML=items.length?items.map(itemCard).join(""):'<p class="empty-cell">No files match these review filters.</p>';bindReviewButtons();}
    function bindReviewButtons(){document.querySelectorAll<HTMLElement>(".inbound-processing-item").forEach(card=>{card.querySelector<HTMLButtonElement>(".save-review")?.addEventListener("click",async()=>{const id=card.dataset.itemId||"",button=card.querySelector<HTMLButtonElement>(".save-review")!;button.disabled=true;button.textContent="Saving…";const result=await actions.whatsapp.reviewInboundProcessingItem({id,decision:(card.querySelector<HTMLSelectElement>(".review-decision")!.value as any),reviewed_by:"web-operator",note:card.querySelector<HTMLInputElement>(".review-note")!.value||null,category:card.querySelector<HTMLSelectElement>(".review-category")!.value||null,complaint_number:card.querySelector<HTMLInputElement>(".review-number")!.value||null});button.disabled=false;button.textContent="Save review";if(result.error)alert(result.error.message);else await load();});});}
    async function load(){const category=el<HTMLSelectElement>("item-category").value,reviewStatus=el<HTMLSelectElement>("item-review").value;const [r,e]=await Promise.all([actions.whatsapp.inboundProcessingRun({id:runId,category:category||undefined,reviewStatus:reviewStatus||undefined}),actions.whatsapp.inboundProcessingEvents({id:runId,limit:1000})]);if(r.error){el("processing-run-code").textContent="Run unavailable";el("processing-log").textContent=r.error.message;return;}render(r.data as any);if(e.data){const rows=(e.data as any).items||[];el("processing-log").textContent=rows.length?rows.map((x:any)=>`[${formatDate(x.created_at)}] ${String(x.level).toUpperCase().padEnd(7)} ${x.message}`).join("\n"):"No processing activity recorded.";el<HTMLPreElement>("processing-log").scrollTop=el<HTMLPreElement>("processing-log").scrollHeight;}const status=(r.data as any).status;el("processing-log-state").textContent=["queued","extracting","checking_paperless"].includes(status)?"Live":"Complete";}
    el("item-category").addEventListener("change",()=>void load());el("item-review").addEventListener("change",()=>void load());void load();timer=window.setInterval(()=>{if(!document.hidden)void load();},3000);window.addEventListener("beforeunload",()=>{if(timer)clearInterval(timer);});
  </script>
</CrmLayout>
