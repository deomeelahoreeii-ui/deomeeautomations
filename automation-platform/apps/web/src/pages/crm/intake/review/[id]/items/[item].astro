---
import CrmIntakeNav from "../../../../../../components/CrmIntakeNav.astro";
import CrmReviewRunNav from "../../../../../../components/CrmReviewRunNav.astro";
import CrmLayout from "../../../../../../layouts/CrmLayout.astro";
const runId = Astro.params.id || "";
const itemId = Astro.params.item || "";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Review Evidence" description="Verify one source document and attach it to the correct complaint case." page="intake">
  <a class="btn btn-sm" href={`/crm/intake/review/${runId}/manual`} slot="actions">← Manual review</a>
  <CrmIntakeNav active="review" /><CrmReviewRunNav runId={runId} active="manual" />
  <section class="wa-health-banner crm-content-match-banner" id="content-match-panel" hidden>
    <span class="status-dot ready"></span><div><strong id="content-match-title">Repeated evidence recognized</strong><small id="content-match-reason"></small><div class="crm-content-match-links"><a id="content-match-canonical" href="#">Open canonical review →</a><a id="content-match-case" href="#" hidden>Open complaint case →</a></div><div id="content-match-relationships"></div></div>
  </section>
  <main class="crm-focused-review" id="manual-item" data-run-id={runId} data-item-id={itemId} data-api-base={apiBase}>
    <section class="master-card crm-focused-source">
      <div><p class="eyebrow">Source evidence</p><h2 id="item-filename">Loading…</h2><p id="item-summary">Reading classification details…</p></div>
      <div class="crm-document-preview"><span>PDF / document</span><p>The source remains immutable. Open it before confirming the relationship.</p><a class="btn btn-primary" id="open-item" href="#" target="_blank" rel="noreferrer">Open original document ↗</a></div>
      <dl class="crm-source-facts"><div><dt>Detected type</dt><dd id="item-detected-type">—</dd></div><div><dt>Confidence</dt><dd id="item-confidence">—</dd></div><div><dt>Paperless</dt><dd id="item-paperless">—</dd></div><div><dt>Processing state</dt><dd id="item-state">—</dd></div></dl>
    </section>
    <section class="master-card crm-focused-form" id="manual-decision-form">
      <div><p class="eyebrow">Operator decision</p><h2>Confirm the complaint relationship</h2><p>Choose the document role and verify the complaint number printed in the original.</p></div>
      <label>Document type<select class="select select-bordered" id="manual-category"><option value="crm_complaint">Main complaint document</option><option value="crm_supporting_document">Attachment / supporting document</option><option value="crm_reply_or_report">Reply or field report</option></select></label>
      <label>Complaint number<input class="input input-bordered" id="manual-number" placeholder="104-6609317" autocomplete="off" /><small>Use the exact number shown in the document.</small></label>
      <div class="crm-case-lookup" id="case-lookup" aria-live="polite"><strong>Enter a complaint number</strong><small>We will check whether its durable CRM case already exists.</small></div>
      <label>Review note <span>(optional)</span><textarea class="textarea textarea-bordered" id="manual-note" placeholder="Why this evidence belongs to the complaint"></textarea></label>
      <div class="alert" id="manual-message" hidden></div>
      <div class="crm-focused-actions"><button class="btn" id="reject-item" type="button">Not CRM evidence</button><button class="btn btn-primary" id="approve-item" type="button">Save and link evidence</button></div>
    </section>
  </main>
  <style>.crm-content-match-banner{margin-bottom:1rem}.crm-content-match-links{display:flex;gap:.8rem;flex-wrap:wrap;margin-top:.35rem}.crm-content-match-links a{font-size:.72rem;font-weight:800}.crm-content-match-relationship{display:inline-flex;margin:.4rem .35rem 0 0;border:1px solid #ecd8a6;border-radius:.45rem;background:#fff9e9;padding:.3rem .45rem;color:#795515;font-size:.68rem}.crm-focused-review{display:grid;grid-template-columns:minmax(18rem,.8fr) minmax(28rem,1.2fr);gap:1rem}.crm-focused-review:has(.crm-focused-form[hidden]){grid-template-columns:minmax(18rem,46rem)}.crm-focused-review>section{padding:1.2rem}.crm-focused-review h2{margin:.12rem 0}.crm-focused-review p{color:#69788b}.crm-focused-source{align-self:start}.crm-document-preview{display:grid;gap:.65rem;place-items:start;min-height:15rem;margin:1rem 0;border:1px dashed #b9d4da;border-radius:.8rem;background:linear-gradient(145deg,#edf7f9,#fbfcfd);padding:1.2rem}.crm-document-preview span{display:grid;place-items:center;width:4rem;height:4.5rem;border-radius:.55rem;background:#d8ecef;color:#117383;font-size:.7rem;font-weight:850}.crm-source-facts{display:grid;grid-template-columns:1fr 1fr;gap:.55rem;margin:0}.crm-source-facts div{border:1px solid #e2e8ee;border-radius:.6rem;padding:.6rem}.crm-source-facts dt{color:#778497;font-size:.65rem;text-transform:uppercase}.crm-source-facts dd{margin:.2rem 0 0;color:#334155;font-size:.78rem;font-weight:750}.crm-focused-form{display:grid;gap:.9rem}.crm-focused-form label{display:grid;gap:.35rem;color:#46556a;font-size:.76rem;font-weight:750}.crm-focused-form label small{color:#7b8797;font-weight:500}.crm-focused-form textarea{min-height:7rem}.crm-case-lookup{display:grid;gap:.2rem;border:1px solid #d9e5eb;border-radius:.65rem;background:#f8fbfc;padding:.75rem}.crm-case-lookup small{color:#758295}.crm-case-lookup.matched{border-color:#8ec6ce;background:#effafb}.crm-focused-actions{display:flex;justify-content:space-between;gap:.6rem;border-top:1px solid #e2e8f0;padding-top:1rem}@media(max-width:900px){.crm-focused-review{grid-template-columns:1fr}}@media(max-width:560px){.crm-source-facts{grid-template-columns:1fr}.crm-focused-actions{align-items:stretch;flex-direction:column}.crm-focused-actions .btn{width:100%}}</style>
  <script>
    import { actions } from "astro:actions";
    import { contentMatchLabel, paperlessLinkSummary, processingStatusLabel } from "../../../../../../lib/crm-status";
    const root=document.getElementById("manual-item") as HTMLElement,runId=root.dataset.runId!,itemId=root.dataset.itemId!,apiBase=root.dataset.apiBase||"",el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;let item:any,lookupTimer:number|undefined;
    function message(text:string,error=false){const target=el("manual-message");target.hidden=!text;target.className=`alert ${error?"alert-error":"alert-success"}`;target.textContent=text}
    function suggestedNumber(value:any){const numbers=value.extracted_metadata?.all_complaint_numbers||[];return value.detected_complaint_number||(numbers.length===1?numbers[0]:"")}
    async function lookup(){const number=el<HTMLInputElement>("manual-number").value.trim(),target=el("case-lookup");if(!number){target.className="crm-case-lookup";target.innerHTML="<strong>Enter a complaint number</strong><small>We will check whether its durable CRM case already exists.</small>";return}target.textContent="Checking complaint registry…";const result=await actions.crm.cases({search:number,state:"",limit:10});if(result.error){target.textContent=result.error.message;return}const match=((result.data as any).items||[]).find((candidate:any)=>candidate.complaint_number===number);target.className=`crm-case-lookup ${match?"matched":""}`;target.replaceChildren();const strong=document.createElement("strong"),small=document.createElement("small");strong.textContent=match?`Existing CRM case ${match.complaint_number}`:"A new CRM case will be created";small.textContent=match?`Current state: ${String(match.state).replaceAll("_"," ")}`:"No exact complaint-number match exists in the durable registry.";target.append(strong,small);if(match){const link=document.createElement("a");link.href=`/crm/cases/${match.id}/overview`;link.textContent="Open existing case →";target.append(link)}}
    async function load(){const result=await actions.whatsapp.inboundProcessingItem({id:itemId});if(result.error){message(result.error.message,true);return}item=result.data as any;el("item-filename").textContent=item.filename;el("item-summary").textContent=item.caption||item.content_match?.reason||item.error||"Verify the original document before saving a decision.";el("item-detected-type").textContent=String(item.primary_category||"unknown").replaceAll("_"," ");el("item-confidence").textContent=`${Math.round(Number(item.confidence||0)*100)}%`;el("item-paperless").textContent=paperlessLinkSummary(item.paperless_document_ids?.[0],item.paperless_category,item.paperless_statuses||[]);el("item-state").textContent=processingStatusLabel(item.status);const open=el<HTMLAnchorElement>("open-item");open.href=`${apiBase}/api/v1/whatsapp/inbound/processing-items/${item.id}/content`;const category=el<HTMLSelectElement>("manual-category");category.value=["crm_complaint","crm_supporting_document","crm_reply_or_report"].includes(item.primary_category)?item.primary_category:"crm_supporting_document";el<HTMLInputElement>("manual-number").value=suggestedNumber(item);const kind=String(item.content_match_kind||"");if(kind){const panel=el("content-match-panel"),canonical=item.content_match?.canonical||(item.content_match?.relationships||[])[0]||{},relationships=item.content_match?.relationships||[];panel.hidden=false;panel.querySelector(".status-dot")?.classList.toggle("ready",kind!=="exact_conflict");el("content-match-title").textContent=contentMatchLabel(kind);el("content-match-reason").textContent=item.content_match?.reason||"This receipt is linked to an earlier content decision.";const canonicalLink=el<HTMLAnchorElement>("content-match-canonical");canonicalLink.hidden=!item.canonical_processing_item_id;canonicalLink.href=`/crm/intake/review/${canonical.run_id||runId}/items/${item.canonical_processing_item_id}`;const caseLink=el<HTMLAnchorElement>("content-match-case");caseLink.hidden=!canonical.case_id;if(canonical.case_id)caseLink.href=`/crm/cases/${canonical.case_id}/evidence`;const relationshipRoot=el("content-match-relationships");relationshipRoot.replaceChildren(...relationships.map((value:any)=>{const span=document.createElement("span");span.className="crm-content-match-relationship";span.textContent=`${value.complaint_number||"Unknown case"} · ${String(value.role||"unknown role").replaceAll("_"," ")}`;return span}));el<HTMLElement>("manual-decision-form").hidden=["exact_reused","exact_pending","normalized_reused"].includes(kind);if(kind==="exact_conflict"){el("manual-decision-form").querySelector("h2")!.textContent="Choose the canonical role once";el("approve-item").textContent="Resolve role conflict"}}if(!el<HTMLElement>("manual-decision-form").hidden)await lookup()}
    el<HTMLInputElement>("manual-number").addEventListener("input",()=>{if(lookupTimer)clearTimeout(lookupTimer);lookupTimer=window.setTimeout(()=>void lookup(),250)});el("approve-item").addEventListener("click",async()=>{const number=el<HTMLInputElement>("manual-number").value.trim();if(!number){message("Enter and verify the complaint number first.",true);return}const button=el<HTMLButtonElement>("approve-item");button.disabled=true;button.textContent="Saving…";const result=await actions.whatsapp.reviewInboundProcessingItem({id:itemId,decision:"approved",reviewed_by:"web-operator",category:el<HTMLSelectElement>("manual-category").value,complaint_number:number,note:el<HTMLTextAreaElement>("manual-note").value||null});if(result.error){button.disabled=false;button.textContent="Save and link evidence";message(result.error.message,true);return}location.href=`/crm/intake/review/${runId}/manual`});el("reject-item").addEventListener("click",async()=>{if(!confirm("Reject this file as unrelated CRM evidence?"))return;const result=await actions.whatsapp.reviewInboundProcessingItem({id:itemId,decision:"rejected",reviewed_by:"web-operator",note:el<HTMLTextAreaElement>("manual-note").value||null});if(result.error){message(result.error.message,true);return}location.href=`/crm/intake/review/${runId}/manual`});await load();
  </script>
</CrmLayout>
