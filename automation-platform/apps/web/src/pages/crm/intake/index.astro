---
import CrmIntakeNav from "../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";
---

<CrmLayout
  title="WhatsApp Complaint Intake"
  description="Start a durable complaint intake run for one WhatsApp contact."
  page="intake"
>
  <a class="btn btn-sm" href="/crm/intake/" slot="actions">Reset intake</a>
  <CrmIntakeNav active="intake" />

  <section class="crm-intake-brief">
    <div>
      <p class="eyebrow">New intake</p>
      <h2>Turn a WhatsApp conversation into reviewable complaint evidence</h2>
      <p>Your draft selection is stored in this page URL. CRM will preserve the source history in an immutable run, then open its permanent detail page.</p>
    </div>
    <div class="crm-intake-boundary"><span>Draft URL</span><i>keeps setup on refresh</i><b>→</b><span>Run URL</span><i>keeps results permanently</i></div>
  </section>

  <section class="inbound-workspace-grid">
    <article class="master-card inbound-fetch-card crm-intake-builder">
      <div class="inbound-card-heading">
        <div><p class="eyebrow">Capture setup</p><h2>Choose the complainant</h2><p>Select a contact and define this run. These choices remain after refresh until you reset the intake.</p></div>
        <span class="badge" id="inbound-bridge-state">Bridge not checked</span>
      </div>

      <div class="inbound-contact-picker">
        <label><span>WhatsApp contact</span><input class="input input-bordered" id="inbound-contact-search" autocomplete="off" placeholder="Search name, phone JID or LID…" /></label>
        <input type="hidden" id="inbound-contact-id" />
        <div class="inbound-contact-results" id="inbound-contact-results" hidden></div>
        <div class="inbound-selected-contact" id="inbound-selected-contact" hidden>
          <div><strong id="inbound-selected-name"></strong><small id="inbound-selected-identity"></small></div>
          <button class="btn btn-xs" type="button" id="clear-inbound-contact">Change</button>
        </div>
      </div>

      <div class="inbound-history-request">
        <div class="inbound-history-scope">
          <label><span>Messages to capture</span><input class="input input-bordered" id="inbound-history-count" type="number" inputmode="numeric" min="1" max="5000" step="1" value="50" list="inbound-history-suggestions" aria-describedby="inbound-history-scope-help" /></label>
          <datalist id="inbound-history-suggestions"><option value="50"></option><option value="200"></option><option value="500"></option><option value="1000"></option><option value="5000"></option></datalist>
          <label class="inbound-all-history"><input id="inbound-all-history" type="checkbox" /><span><strong>All available history</strong><small>Capture everything WhatsApp makes available, up to the 5,000-message safety limit.</small></span></label>
          <small id="inbound-history-scope-help">Enter any whole number from 1 to 5,000.</small>
        </div>
        <button class="btn btn-primary" id="request-inbound-history" type="button" disabled>Start complaint intake</button>
      </div>
      <p class="inbound-history-help" id="inbound-bridge-detail">Select a contact to check the managed browser.</p>
      <p class="inbound-form-status" id="inbound-form-status"></p>
    </article>

    <article class="master-card crm-contact-glance">
      <div class="inbound-card-heading">
        <div><p class="eyebrow">Intake readiness</p><h2 id="contact-glance-title">Choose a contact</h2><p id="contact-glance-description">The contact's accumulated evidence and earlier intake runs live in a separate workspace.</p></div>
        <span class="badge" id="contact-glance-state">No contact</span>
      </div>
      <div class="crm-intake-live-empty" id="contact-glance-empty"><span>↙</span><h3>Select a complainant</h3><p>We will show a summary here. The full history page separates evidence accumulated across runs from files captured by any single run.</p></div>
      <div id="contact-glance-content" hidden>
        <div class="inbound-metrics crm-contact-glance-metrics">
          <article><span>Intake runs</span><strong id="contact-run-count">0</strong></article>
          <article><span>All evidence</span><strong id="contact-evidence-count">0</strong></article>
          <article><span>PDFs</span><strong id="contact-pdf-count">0</strong></article>
          <article><span>Images</span><strong id="contact-image-count">0</strong></article>
        </div>
        <div class="crm-contact-recent-runs"><h3>Recent intake runs</h3><div id="contact-recent-runs"></div></div>
        <a class="btn btn-primary crm-contact-workspace-link" id="open-contact-workspace" href="#">Open contact intake history →</a>
      </div>
    </article>
  </section>

  <section class="master-card crm-intake-separation-note">
    <div><p class="eyebrow">Clear ownership</p><h2>Run evidence and contact evidence are now separate</h2></div>
    <p><strong>Each run page</strong> shows only files captured by that run. <strong>Contact intake history</strong> shows the combined evidence library and all runs for that person.</p>
  </section>

  <script>
    import { actions } from "astro:actions";
    const el = <T extends HTMLElement>(id:string) => document.getElementById(id) as T;
    const contactSearch=el<HTMLInputElement>("inbound-contact-search"),contactId=el<HTMLInputElement>("inbound-contact-id"),contactResults=el<HTMLDivElement>("inbound-contact-results"),selectedContact=el<HTMLDivElement>("inbound-selected-contact"),historyButton=el<HTMLButtonElement>("request-inbound-history"),historyCount=el<HTMLInputElement>("inbound-history-count"),allHistory=el<HTMLInputElement>("inbound-all-history");
    let selected:any=null,bridgeReady=false,searchTimer:number|undefined;
    const escapeHtml=(v:unknown)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");
    const formatDate=(v:any)=>{if(!v)return"—";const d=new Date(v);return Number.isNaN(d.getTime())?String(v):d.toLocaleString();};
    function status(message:string,kind=""){const node=el("inbound-form-status");node.textContent=message;node.className=`inbound-form-status ${kind}`;}
    function syncDraftUrl(){const url=new URL(window.location.href),params=url.searchParams;if(contactId.value)params.set("contact",contactId.value);else params.delete("contact");params.set("count",historyCount.value||"50");params.set("all",allHistory.checked?"1":"0");history.replaceState({},"",url);}
    function updateHistoryScope({persist=true}={}){historyCount.disabled=allHistory.checked;el("inbound-history-scope-help").textContent=allHistory.checked?"All available history will be requested, with a 5,000-message safety limit.":"Enter any whole number from 1 to 5,000.";if(persist)syncDraftUrl();}
    async function searchContacts(){const q=contactSearch.value.trim();if(q.length<2){contactResults.hidden=true;return;}const r=await actions.whatsapp.directoryContacts({search:q,tokenStatus:"",page:1,pageSize:20});if(r.error){status(r.error.message,"error");return;}const items=(r.data as any).items||[];contactResults.innerHTML=items.length?items.map((x:any)=>`<button type="button" data-contact='${escapeHtml(JSON.stringify(x))}'><strong>${escapeHtml(x.display_name||"Unnamed contact")}</strong><small>${escapeHtml(x.phone_jid||x.primary_lid_jid||x.canonical_key||"")}</small></button>`).join(""):'<p class="empty-cell">No contacts matched.</p>';contactResults.hidden=false;}
    async function loadBridge(){const r=await actions.whatsapp.inboundHistoryBridgeStatus({contactId:contactId.value});const state=el("inbound-bridge-state"),detail=el("inbound-bridge-detail");if(r.error){bridgeReady=false;state.textContent="Browser unavailable";detail.textContent="Could not check managed WhatsApp Web. Retry shortly.";historyButton.disabled=true;return;}const d=r.data as any;bridgeReady=Boolean(d.historyReady??d.ready);state.textContent=bridgeReady?"Managed browser ready":String(d.status||"Unavailable");detail.textContent=bridgeReady?`Managed Brave page ready${d.webVersion?` · Web ${d.webVersion}`:""}. Starting intake will open a permanent run URL.`:String(d.message||"Managed WhatsApp Web is unavailable.").slice(0,240);historyButton.disabled=!bridgeReady;}
    async function loadContactGlance(){const id=contactId.value;if(!id)return;el("contact-glance-state").textContent="Loading";const [workspace,runs]=await Promise.all([actions.whatsapp.inboundContactWorkspace({contactId:id,page:1,pageSize:1}),actions.whatsapp.inboundBatches({contactId:id,limit:5})]);if(workspace.error){el("contact-glance-state").textContent="Unavailable";return;}const d=workspace.data as any,m=d.metrics||{},categories=m.category_counts||{},runItems=(runs.data as any)?.items||[];el("contact-glance-title").textContent=d.contact.display_name;el("contact-glance-description").textContent=d.contact.identity||"WhatsApp contact";el("contact-run-count").textContent=String(m.run_count||0);el("contact-evidence-count").textContent=String(m.evidence_total||0);el("contact-pdf-count").textContent=String(categories.pdf||0);el("contact-image-count").textContent=String(categories.image||0);el("contact-recent-runs").innerHTML=runItems.length?runItems.map((x:any)=>`<a href="/crm/intake/batches/${escapeHtml(x.id)}"><span><strong>${escapeHtml(x.batch_code)}</strong><small>${escapeHtml(formatDate(x.created_at))}</small></span><b>${escapeHtml(String(x.status).replaceAll("_"," "))}</b></a>`).join(""):'<p class="empty-cell">No earlier intake runs for this contact.</p>';el<HTMLAnchorElement>("open-contact-workspace").href=`/crm/intake/contacts/${id}`;el("contact-glance-empty").hidden=true;el("contact-glance-content").hidden=false;el("contact-glance-state").textContent="Ready";}
    function chooseContact(x:any,{persist=true}={}){selected=x;contactId.value=x.id;el("inbound-selected-name").textContent=x.display_name||"Unnamed contact";el("inbound-selected-identity").textContent=x.phone_jid||x.primary_lid_jid||x.identity||x.canonical_key||"";selectedContact.hidden=false;contactSearch.hidden=true;contactResults.hidden=true;if(persist)syncDraftUrl();void Promise.all([loadBridge(),loadContactGlance()]);}
    function clearContact(){selected=null;contactId.value="";contactSearch.value="";contactSearch.hidden=false;selectedContact.hidden=true;historyButton.disabled=true;bridgeReady=false;el("contact-glance-empty").hidden=false;el("contact-glance-content").hidden=true;el("contact-glance-state").textContent="No contact";syncDraftUrl();}
    async function hydrateDraft(){const p=new URLSearchParams(window.location.search),count=Number(p.get("count"));if(Number.isInteger(count)&&count>=1&&count<=5000)historyCount.value=String(count);allHistory.checked=p.get("all")==="1";updateHistoryScope({persist:false});const id=p.get("contact");if(!id){syncDraftUrl();return;}const r=await actions.whatsapp.inboundContactWorkspace({contactId:id,page:1,pageSize:1});if(r.data)chooseContact((r.data as any).contact);else status("The contact saved in this draft is no longer available.","error");}
    async function requestHistory(){try{historyButton.disabled=true;const count=historyCount.valueAsNumber;if(!allHistory.checked&&(!Number.isInteger(count)||count<1||count>5000))throw new Error("Enter a whole number from 1 to 5,000, or choose All available history.");const requestedCount=allHistory.checked?5000:count;status(allHistory.checked?"Creating a durable run for all available history…":`Creating a durable run for up to ${requestedCount} messages…`);const r=await actions.whatsapp.requestInboundHistory({contact_id:contactId.value,count:requestedCount,all_history:allHistory.checked});if(r.error)throw new Error(r.error.message);const d=r.data as any;if(!d.batch_id)throw new Error("The server created the intake without a run identifier.");window.location.assign(`/crm/intake/batches/${d.batch_id}`);}catch(e:any){status(e.message||String(e),"error");historyButton.disabled=!bridgeReady;}}
    contactSearch.addEventListener("input",()=>{if(searchTimer)clearTimeout(searchTimer);searchTimer=window.setTimeout(()=>void searchContacts(),250);});contactResults.addEventListener("click",e=>{const b=(e.target as HTMLElement).closest<HTMLButtonElement>("button[data-contact]");if(b)chooseContact(JSON.parse(b.dataset.contact||"{}"));});el("clear-inbound-contact").addEventListener("click",clearContact);historyCount.addEventListener("change",syncDraftUrl);allHistory.addEventListener("change",updateHistoryScope);historyButton.addEventListener("click",()=>void requestHistory());document.addEventListener("click",e=>{if(!(e.target as HTMLElement).closest(".inbound-contact-picker"))contactResults.hidden=true;});void hydrateDraft();
  </script>
</CrmLayout>
