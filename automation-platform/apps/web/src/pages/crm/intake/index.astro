---
import CrmIntakeNav from "../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";
---

<CrmLayout
  title="WhatsApp Complaint Intake"
  description="Capture received complaint evidence from one WhatsApp contact and continue it into review."
  page="intake"
>
  <a class="btn btn-sm" href="/crm/intake/" slot="actions">Reset intake</a>
  <CrmIntakeNav active="intake" />

  <section class="crm-intake-brief crm-intake-brief-simple">
    <div>
      <p class="eyebrow">New complaint intake</p>
      <h2>Choose a complainant and the part of their conversation to capture</h2>
      <p>Only messages and supported files received from the selected contact are considered. Messages sent by you are always excluded.</p>
    </div>
    <span class="crm-received-only-badge">↓ Received only</span>
  </section>

  <section class="inbound-workspace-grid crm-intake-start-grid">
    <article class="master-card crm-intake-builder">
      <div class="inbound-card-heading">
        <div>
          <p class="eyebrow">1 · Complainant</p>
          <h2>Find the WhatsApp contact</h2>
          <p>Search by the saved name or phone number.</p>
        </div>
        <span class="badge" id="inbound-bridge-state">Waiting for contact</span>
      </div>

      <div class="inbound-contact-picker">
        <label for="inbound-contact-search"><span>WhatsApp contact</span></label>
        <input
          class="input input-bordered"
          id="inbound-contact-search"
          autocomplete="off"
          placeholder="Search name or phone number…"
          role="combobox"
          aria-autocomplete="list"
          aria-controls="inbound-contact-results"
          aria-expanded="false"
        />
        <input type="hidden" id="inbound-contact-id" />
        <div class="inbound-contact-results" id="inbound-contact-results" role="listbox" hidden></div>
        <div class="inbound-selected-contact" id="inbound-selected-contact" hidden>
          <div><strong id="inbound-selected-name"></strong><small id="inbound-selected-identity"></small></div>
          <button class="btn btn-xs" type="button" id="clear-inbound-contact">Change</button>
        </div>
      </div>

      <fieldset class="crm-capture-scope" id="capture-scope-fieldset">
        <legend><span class="eyebrow">2 · Capture scope</span><strong>Which received messages should be checked?</strong></legend>
        <div class="crm-scope-options">
          <label><input type="radio" name="inbound-scope" value="50" checked /><span><strong id="scope-50-title">Latest 50 messages</strong><small id="scope-50-detail">Best for a first intake.</small></span></label>
          <label><input type="radio" name="inbound-scope" value="200" /><span><strong id="scope-200-title">Latest 200 messages</strong><small>Use when the complaint has a longer conversation.</small></span></label>
          <label><input type="radio" name="inbound-scope" value="range" /><span><strong>Date range</strong><small>Include received messages from selected calendar dates.</small></span></label>
          <label><input type="radio" name="inbound-scope" value="all" /><span><strong>Backfill available history</strong><small>Up to the 5,000-message safety limit.</small></span></label>
          <label><input type="radio" name="inbound-scope" value="custom" /><span><strong>Custom amount</strong><small>Choose between 1 and 5,000 messages.</small></span></label>
        </div>

        <div class="crm-scope-custom" id="custom-scope-fields" hidden>
          <label for="inbound-history-count"><span>Maximum messages</span></label>
          <input class="input input-bordered" id="inbound-history-count" type="number" inputmode="numeric" min="1" max="5000" step="1" value="500" />
        </div>

        <div class="crm-date-range-fields" id="date-range-fields" hidden>
          <label for="inbound-date-from"><span>From date</span><input class="input input-bordered" id="inbound-date-from" type="date" /></label>
          <label for="inbound-date-to"><span>Through date</span><input class="input input-bordered" id="inbound-date-to" type="date" /></label>
          <small>Both dates are inclusive in your local timezone. Up to 5,000 matching received messages will be checked.</small>
        </div>
      </fieldset>

      <fieldset class="crm-capture-scope" id="capture-file-types">
        <legend><span class="eyebrow">3 · Evidence types</span><strong>Which received files should be included?</strong></legend>
        <div class="crm-scope-options">
          <label><input id="inbound-media-pdf" type="checkbox" name="inbound-media" value="pdf" checked /><span><strong>PDF documents</strong><small>Complaint forms, letters and supporting documents.</small></span></label>
          <label><input id="inbound-media-image" type="checkbox" name="inbound-media" value="image" checked /><span><strong>Images</strong><small>Scans and photographed complaint evidence.</small></span></label>
          <label><input id="inbound-media-spreadsheet" type="checkbox" name="inbound-media" value="spreadsheet" /><span><strong>Spreadsheets and CSV</strong><small>Routed to a separate row-review workspace; rows never create cases automatically.</small></span></label>
        </div>
      </fieldset>

      <div class="crm-intake-submit-block">
        <label class="crm-auto-review-option"><input id="auto-classify" type="checkbox" checked /><span><strong>Continue to classification automatically</strong><small>When capture completes, open the complaint review workspace. No Paperless publication happens automatically.</small></span></label>
        <div class="crm-intake-submit-row">
          <div><strong id="scope-summary">Latest 50 received messages</strong><small id="inbound-bridge-detail">Select a contact to check WhatsApp readiness.</small></div>
          <button class="btn btn-primary" id="request-inbound-history" type="button" disabled>Capture and classify</button>
        </div>
        <p class="inbound-form-status" id="inbound-form-status" role="status" aria-live="polite"></p>
      </div>
    </article>

    <article class="master-card crm-contact-glance">
      <div class="inbound-card-heading">
        <div><p class="eyebrow">Contact history</p><h2 id="contact-glance-title">No contact selected</h2><p id="contact-glance-description">Choose a complainant to preview existing coverage and earlier intake runs.</p></div>
        <span class="badge" id="contact-glance-state">Waiting</span>
      </div>
      <div class="crm-intake-live-empty crm-contact-empty" id="contact-glance-empty"><span>↙</span><h3>Select a complainant</h3><p>Their existing evidence coverage will help you choose the right capture scope.</p></div>
      <div id="contact-glance-content" hidden>
        <div class="crm-contact-coverage">
          <span>Existing message coverage</span>
          <strong id="contact-coverage">No messages captured yet</strong>
          <small id="contact-coverage-note">The first intake starts with the latest available messages.</small>
        </div>
        <div class="inbound-metrics crm-contact-glance-metrics">
          <article><span>Intake runs</span><strong id="contact-run-count">0</strong></article>
          <article><span>All evidence</span><strong id="contact-evidence-count">0</strong></article>
          <article><span>PDFs</span><strong id="contact-pdf-count">0</strong></article>
          <article><span>Images</span><strong id="contact-image-count">0</strong></article>
        </div>
        <div class="crm-contact-recent-runs"><h3>Recent intake runs</h3><div id="contact-recent-runs"></div></div>
        <a class="btn crm-contact-workspace-link" id="open-contact-workspace" href="#">Open full contact history →</a>
      </div>
    </article>
  </section>

  <section class="master-card crm-live-intake" id="inbound-live-run" hidden>
    <div class="inbound-card-heading">
      <div><p class="eyebrow">Live intake</p><h2 id="inbound-live-title">Preparing intake…</h2><p id="inbound-live-summary">Server progress will appear here.</p></div>
      <div class="crm-live-intake-actions">
        <a class="btn btn-sm" id="inbound-live-link" href="#">Open permanent run</a>
        <button class="btn btn-sm btn-primary" id="inbound-review-link" type="button" hidden>Classify and review →</button>
      </div>
    </div>
    <div class="crm-live-progress-grid">
      <div><span>Messages received</span><strong id="live-message-count">0</strong></div>
      <div><span>Files discovered</span><strong id="live-file-count">0</strong></div>
      <div><span>Archived / reused</span><strong id="live-stored-count">0</strong></div>
      <div><span>Failed</span><strong id="live-failed-count">0</strong></div>
    </div>
    <details class="crm-intake-activity"><summary>Technical activity</summary><pre class="log-console" id="inbound-live-log">Activity from the server will appear here.</pre></details>
  </section>

  <script>
    import { actions } from "astro:actions";

    const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const contactSearch = el<HTMLInputElement>("inbound-contact-search");
    const contactId = el<HTMLInputElement>("inbound-contact-id");
    const contactResults = el<HTMLDivElement>("inbound-contact-results");
    const selectedContact = el<HTMLDivElement>("inbound-selected-contact");
    const historyButton = el<HTMLButtonElement>("request-inbound-history");
    const historyCount = el<HTMLInputElement>("inbound-history-count");
    const dateFrom = el<HTMLInputElement>("inbound-date-from");
    const dateTo = el<HTMLInputElement>("inbound-date-to");
    const autoClassify = el<HTMLInputElement>("auto-classify");
    const terminalStatuses = new Set(["completed", "completed_with_errors", "failed", "cancelled"]);

    let selected: any = null;
    let bridgeReady = false;
    let bridgeSupportsDateRange = false;
    let requestBusy = false;
    let searchTimer: number | undefined;
    let searchSequence = 0;
    let currentBatchId = "";
    let batchPoll: number | undefined;
    let lastEventAt = "";
    let logLines: string[] = [];
    let reviewStarting = false;
    const contactsById = new Map<string, any>();

    const escapeHtml = (value: unknown) => String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
    const formatDate = (value: any) => {
      if (!value) return "—";
      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? String(value) : date.toLocaleString();
    };
    const localDateValue = (date: Date) => {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    };
    const dateBoundary = (value: string, addDay = false) => {
      const [year, month, day] = value.split("-").map(Number);
      return new Date(year, month - 1, day + (addDay ? 1 : 0)).toISOString();
    };
    const selectedScope = () => document.querySelector<HTMLInputElement>('input[name="inbound-scope"]:checked')?.value || "50";
    const selectedMediaTypes = () => [...document.querySelectorAll<HTMLInputElement>('input[name="inbound-media"]:checked')].map((input) => input.value);

    function status(message: string, kind = "") {
      const node = el("inbound-form-status");
      node.textContent = message;
      node.className = `inbound-form-status ${kind}`;
    }

    function syncButtonState() {
      const rangeUnavailable = selectedScope() === "range" && !bridgeSupportsDateRange;
      historyButton.disabled = requestBusy || !selected || !bridgeReady || rangeUnavailable || selectedMediaTypes().length === 0;
      historyButton.textContent = autoClassify.checked ? "Capture and classify" : "Start capture";
    }

    function syncDraftUrl() {
      const url = new URL(window.location.href);
      const params = url.searchParams;
      contactId.value ? params.set("contact", contactId.value) : params.delete("contact");
      params.set("scope", selectedScope());
      params.set("count", historyCount.value || "500");
      params.set("auto", autoClassify.checked ? "1" : "0");
      dateFrom.value ? params.set("from", dateFrom.value) : params.delete("from");
      dateTo.value ? params.set("to", dateTo.value) : params.delete("to");
      params.set("types", selectedMediaTypes().join(","));
      history.replaceState({}, "", url);
    }

    function updateScope({ persist = true } = {}) {
      const scope = selectedScope();
      el("custom-scope-fields").hidden = scope !== "custom";
      el("date-range-fields").hidden = scope !== "range";
      const summaries: Record<string, string> = {
        "50": selected ? (Number(el("contact-run-count").textContent || 0) ? "Next 50 older received messages" : "Latest 50 received messages") : "Latest 50 received messages",
        "200": selected ? (Number(el("contact-run-count").textContent || 0) ? "Next 200 older received messages" : "Latest 200 received messages") : "Latest 200 received messages",
        all: "Available received history · maximum 5,000 messages",
        custom: `Up to ${historyCount.value || "500"} received messages`,
        range: dateFrom.value && dateTo.value ? `Received messages from ${dateFrom.value} through ${dateTo.value}` : "Received messages in a date range",
      };
      el("scope-summary").textContent = summaries[scope];
      if (scope === "range" && selected && bridgeReady && !bridgeSupportsDateRange) {
        el("inbound-bridge-detail").textContent = "Restart the managed WhatsApp bridge to enable date-range intake.";
      }
      if (persist) syncDraftUrl();
      syncButtonState();
    }

    async function searchContacts() {
      const query = contactSearch.value.trim();
      const sequence = ++searchSequence;
      contactSearch.setAttribute("aria-expanded", query.length >= 2 ? "true" : "false");
      if (query.length < 2) {
        contactResults.hidden = true;
        return;
      }
      contactResults.innerHTML = '<p class="empty-cell">Searching contacts…</p>';
      contactResults.hidden = false;
      const result = await actions.whatsapp.directoryContacts({ search: query, tokenStatus: "", page: 1, pageSize: 20 });
      if (sequence !== searchSequence || query !== contactSearch.value.trim()) return;
      if (result.error) {
        status(result.error.message, "error");
        contactResults.hidden = true;
        contactSearch.setAttribute("aria-expanded", "false");
        return;
      }
      const items = (result.data as any).items || [];
      contactsById.clear();
      items.forEach((item: any) => contactsById.set(item.id, item));
      contactResults.innerHTML = items.length
        ? items.map((item: any) => `<button type="button" role="option" data-contact-id="${escapeHtml(item.id)}"><strong>${escapeHtml(item.display_name || "Unnamed contact")}</strong><small>${escapeHtml(item.phone_jid || item.primary_lid_jid || item.canonical_key || "No phone identity")}</small></button>`).join("")
        : '<p class="empty-cell">No contacts matched.</p>';
    }

    async function loadBridge() {
      const state = el("inbound-bridge-state");
      const detail = el("inbound-bridge-detail");
      state.textContent = "Checking WhatsApp";
      const result = await actions.whatsapp.inboundHistoryBridgeStatus({ contactId: contactId.value });
      if (result.error) {
        bridgeReady = false;
        bridgeSupportsDateRange = false;
        state.textContent = "WhatsApp unavailable";
        detail.textContent = "Could not check WhatsApp readiness. Try again shortly.";
        syncButtonState();
        return;
      }
      const data = result.data as any;
      bridgeReady = Boolean(data.historyReady ?? data.ready);
      bridgeSupportsDateRange = Number(data.protocolVersion || 0) >= 4 && Boolean(data.capabilities?.dateRange);
      state.textContent = bridgeReady ? "WhatsApp ready" : String(data.status || "Unavailable").replaceAll("_", " ");
      detail.textContent = bridgeReady
        ? "Ready to capture received messages. Sent-by-you messages will be excluded."
        : String(data.message || "Managed WhatsApp is unavailable.").slice(0, 240);
      updateScope({ persist: false });
    }

    async function loadContactGlance() {
      const id = contactId.value;
      if (!id) return;
      el("contact-glance-state").textContent = "Loading";
      const [workspace, runs] = await Promise.all([
        actions.whatsapp.inboundContactWorkspace({ contactId: id, page: 1, pageSize: 1 }),
        actions.whatsapp.inboundBatches({ contactId: id, limit: 5 }),
      ]);
      if (workspace.error) {
        el("contact-glance-state").textContent = "Unavailable";
        return;
      }
      const data = workspace.data as any;
      const metrics = data.metrics || {};
      const categories = metrics.category_counts || {};
      const coverage = data.coverage || {};
      const runItems = (runs.data as any)?.items || [];
      el("contact-glance-title").textContent = data.contact.display_name;
      el("contact-glance-description").textContent = data.contact.identity || "WhatsApp contact";
      el("contact-run-count").textContent = String(metrics.run_count || 0);
      el("contact-evidence-count").textContent = String(metrics.evidence_total || 0);
      el("contact-pdf-count").textContent = String(categories.pdf || 0);
      el("contact-image-count").textContent = String(categories.image || 0);
      const hasCoverage = Boolean(coverage.earliest_message_at || coverage.latest_message_at);
      el("contact-coverage").textContent = hasCoverage
        ? `${formatDate(coverage.earliest_message_at)} — ${formatDate(coverage.latest_message_at)}`
        : "No messages captured yet";
      el("contact-coverage-note").textContent = hasCoverage
        ? "Count-based capture continues backward from the earliest captured message."
        : "The first count-based intake starts with the latest available messages.";
      el("scope-50-title").textContent = metrics.run_count ? "Next 50 older messages" : "Latest 50 messages";
      el("scope-50-detail").textContent = metrics.run_count ? "Continue backward from existing coverage." : "Best for a first intake.";
      el("scope-200-title").textContent = metrics.run_count ? "Next 200 older messages" : "Latest 200 messages";
      el("contact-recent-runs").innerHTML = runItems.length
        ? runItems.map((item: any) => `<a href="/crm/intake/batches/${escapeHtml(item.id)}"><span><strong>${escapeHtml(item.batch_code)}</strong><small>${escapeHtml(formatDate(item.created_at))}</small></span><b>${escapeHtml(String(item.status).replaceAll("_", " "))}</b></a>`).join("")
        : '<p class="empty-cell">No earlier intake runs for this contact.</p>';
      el<HTMLAnchorElement>("open-contact-workspace").href = `/crm/intake/contacts/${id}`;
      el("contact-glance-empty").hidden = true;
      el("contact-glance-content").hidden = false;
      el("contact-glance-state").textContent = "Ready";
      updateScope({ persist: false });
    }

    function chooseContact(contact: any, { persist = true } = {}) {
      selected = contact;
      contactId.value = contact.id;
      el("inbound-selected-name").textContent = contact.display_name || "Unnamed contact";
      el("inbound-selected-identity").textContent = contact.phone_jid || contact.primary_lid_jid || contact.identity || contact.canonical_key || "";
      selectedContact.hidden = false;
      contactSearch.hidden = true;
      contactResults.hidden = true;
      contactSearch.setAttribute("aria-expanded", "false");
      if (persist) syncDraftUrl();
      void Promise.all([loadBridge(), loadContactGlance()]);
    }

    function clearContact() {
      selected = null;
      contactId.value = "";
      contactSearch.value = "";
      contactSearch.hidden = false;
      selectedContact.hidden = true;
      bridgeReady = false;
      bridgeSupportsDateRange = false;
      el("inbound-bridge-state").textContent = "Waiting for contact";
      el("inbound-bridge-detail").textContent = "Select a contact to check WhatsApp readiness.";
      el("contact-glance-title").textContent = "No contact selected";
      el("contact-glance-description").textContent = "Choose a complainant to preview existing coverage and earlier intake runs.";
      el("contact-glance-empty").hidden = false;
      el("contact-glance-content").hidden = true;
      el("contact-glance-state").textContent = "Waiting";
      syncDraftUrl();
      syncButtonState();
      contactSearch.focus();
    }

    async function startReview() {
      if (!currentBatchId || reviewStarting) return;
      reviewStarting = true;
      const button = el<HTMLButtonElement>("inbound-review-link");
      button.disabled = true;
      button.textContent = "Opening review…";
      const result = await actions.whatsapp.createInboundProcessingRun({ batch_id: currentBatchId, paperless_check: true });
      if (result.error) {
        reviewStarting = false;
        button.disabled = false;
        button.textContent = "Classify and review →";
        status(result.error.message, "error");
        return;
      }
      const run = (result.data as any)?.processing_run;
      if (run?.id) window.location.href = `/crm/intake/review/${run.id}`;
    }

    async function loadBatch() {
      if (!currentBatchId) return;
      const [batchResult, eventResult] = await Promise.all([
        actions.whatsapp.inboundBatch({ id: currentBatchId }),
        actions.whatsapp.inboundBatchEvents({ id: currentBatchId, after: lastEventAt || undefined, limit: 250 }),
      ]);
      if (eventResult.data) {
        const rows = (eventResult.data as any).items || [];
        if (rows.length) {
          logLines.push(...rows.map((item: any) => `[${formatDate(item.created_at)}] ${String(item.level).toUpperCase().padEnd(7)} ${item.message}`));
          logLines = logLines.slice(-500);
          lastEventAt = rows[rows.length - 1].created_at;
          el("inbound-live-log").textContent = logLines.join("\n");
        }
      }
      if (!batchResult.data) return;
      const batch = batchResult.data as any;
      const archived = Number(batch.files_stored || 0) + Number(batch.files_reused || 0);
      el("inbound-live-title").textContent = `${batch.batch_code} · ${String(batch.status).replaceAll("_", " ")}`;
      el("inbound-live-summary").textContent = `${batch.messages_discovered || 0} received messages checked · ${batch.files_discovered || 0} supported files found`;
      el("live-message-count").textContent = String(batch.messages_discovered || 0);
      el("live-file-count").textContent = String(batch.files_discovered || 0);
      el("live-stored-count").textContent = String(archived);
      el("live-failed-count").textContent = String(batch.files_failed || 0);
      if (!terminalStatuses.has(batch.status)) return;

      if (batchPoll) window.clearInterval(batchPoll);
      batchPoll = undefined;
      requestBusy = false;
      syncButtonState();
      const reviewButton = el<HTMLButtonElement>("inbound-review-link");
      if (["completed", "completed_with_errors"].includes(batch.status) && Number(batch.files_discovered || 0) > 0) {
        reviewButton.hidden = false;
        status("Capture complete. The evidence is ready for classification.", "success");
        if (autoClassify.checked) await startReview();
      } else if (["completed", "completed_with_errors"].includes(batch.status)) {
        status("Capture completed, but no supported received files were found in this scope.", "success");
      } else {
        status(batch.error || "The intake did not complete. Open the permanent run for details.", "error");
      }
    }

    function beginBatch(batchId: string, message: string) {
      currentBatchId = batchId;
      lastEventAt = "";
      logLines = [];
      el("inbound-live-run").hidden = false;
      el<HTMLAnchorElement>("inbound-live-link").href = `/crm/intake/batches/${currentBatchId}`;
      el<HTMLButtonElement>("inbound-review-link").hidden = true;
      status(message, "success");
      void loadBatch();
      if (batchPoll) window.clearInterval(batchPoll);
      batchPoll = window.setInterval(() => void loadBatch(), 2000);
      el("inbound-live-run").scrollIntoView({ behavior: "smooth", block: "start" });
    }

    async function recoverActiveRun() {
      const result = await actions.whatsapp.inboundHistoryRequests({ contactId: contactId.value, limit: 5 });
      const active = ((result.data as any)?.items || []).find((item: any) => item.active && item.batch_id);
      if (!active) return false;
      beginBatch(active.batch_id, "An intake was already running for this contact. Its live progress is shown below.");
      return true;
    }

    async function hydrateDraft() {
      const params = new URLSearchParams(window.location.search);
      const scope = params.get("scope") || (params.get("all") === "1" ? "all" : "50");
      const scopeInput = document.querySelector<HTMLInputElement>(`input[name="inbound-scope"][value="${CSS.escape(scope)}"]`);
      if (scopeInput) scopeInput.checked = true;
      const count = Number(params.get("count"));
      if (Number.isInteger(count) && count >= 1 && count <= 5000) historyCount.value = String(count);
      autoClassify.checked = params.get("auto") !== "0";
      const savedFrom = params.get("from");
      const savedTo = params.get("to");
      if (savedFrom) dateFrom.value = savedFrom;
      if (savedTo) dateTo.value = savedTo;
      const savedTypes = (params.get("types") || "pdf,image").split(",").filter((value) => ["pdf", "image", "spreadsheet"].includes(value));
      document.querySelectorAll<HTMLInputElement>('input[name="inbound-media"]').forEach((input) => { input.checked = savedTypes.includes(input.value); });
      updateScope({ persist: false });
      const id = params.get("contact");
      if (!id) {
        syncDraftUrl();
        return;
      }
      const result = await actions.whatsapp.inboundContactWorkspace({ contactId: id, page: 1, pageSize: 1 });
      if (result.data) chooseContact((result.data as any).contact, { persist: false });
      else status("The contact saved in this draft is no longer available.", "error");
    }

    async function requestHistory() {
      try {
        requestBusy = true;
        syncButtonState();
        const scope = selectedScope();
        let count = scope === "50" ? 50 : scope === "200" ? 200 : scope === "custom" ? historyCount.valueAsNumber : 5000;
        if (!Number.isInteger(count) || count < 1 || count > 5000) throw new Error("Enter a whole number from 1 to 5,000.");
        const mediaTypes = selectedMediaTypes();
        if (!mediaTypes.length) throw new Error("Select at least one evidence type.");
        let rangeFrom: string | null = null;
        let rangeTo: string | null = null;
        if (scope === "range") {
          if (!dateFrom.value || !dateTo.value) throw new Error("Choose both a From date and a Through date.");
          if (dateFrom.value > dateTo.value) throw new Error("The From date must not be later than the Through date.");
          rangeFrom = dateBoundary(dateFrom.value);
          rangeTo = dateBoundary(dateTo.value, true);
          count = 5000;
        }
        status(scope === "range" ? "Creating an intake for the selected received-message date range…" : `Creating an intake for up to ${count} received messages…`);
        const result = await actions.whatsapp.requestInboundHistory({
          contact_id: contactId.value,
          count,
          all_history: scope === "all",
          date_from: rangeFrom,
          date_to: rangeTo,
          media_types: mediaTypes as ("image" | "pdf" | "spreadsheet")[],
        });
        if (result.error) {
          if (result.error.code === "CONFLICT" && await recoverActiveRun()) return;
          throw new Error(result.error.message);
        }
        const data = result.data as any;
        if (!data.batch_id) throw new Error("The server created the intake without a run identifier.");
        currentBatchId = data.batch_id;
        beginBatch(currentBatchId, "Intake started. Live progress is shown below.");
      } catch (error: any) {
        requestBusy = false;
        status(error.message || String(error), "error");
        syncButtonState();
      }
    }

    const today = new Date();
    const thirtyDaysAgo = new Date(today);
    thirtyDaysAgo.setDate(today.getDate() - 30);
    dateFrom.value = localDateValue(thirtyDaysAgo);
    dateTo.value = localDateValue(today);
    dateFrom.max = localDateValue(today);
    dateTo.max = localDateValue(today);

    contactSearch.addEventListener("input", () => {
      if (searchTimer) clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => void searchContacts(), 250);
    });
    contactSearch.addEventListener("keydown", (event) => {
      const options = [...contactResults.querySelectorAll<HTMLButtonElement>("button[data-contact-id]")];
      const focused = document.activeElement as HTMLButtonElement;
      if (event.key === "ArrowDown" && options.length) {
        event.preventDefault();
        options[0].focus();
      } else if (event.key === "Escape") {
        contactResults.hidden = true;
        contactSearch.setAttribute("aria-expanded", "false");
      } else if (event.key === "Enter" && options.length && focused === contactSearch) {
        event.preventDefault();
        options[0].click();
      }
    });
    contactResults.addEventListener("keydown", (event) => {
      const options = [...contactResults.querySelectorAll<HTMLButtonElement>("button[data-contact-id]")];
      const index = options.indexOf(document.activeElement as HTMLButtonElement);
      if (event.key === "ArrowDown" && index >= 0) {
        event.preventDefault();
        options[(index + 1) % options.length]?.focus();
      } else if (event.key === "ArrowUp" && index >= 0) {
        event.preventDefault();
        if (index === 0) contactSearch.focus();
        else options[index - 1]?.focus();
      } else if (event.key === "Escape") {
        contactResults.hidden = true;
        contactSearch.focus();
      }
    });
    contactResults.addEventListener("click", (event) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>("button[data-contact-id]");
      const contact = button ? contactsById.get(button.dataset.contactId || "") : null;
      if (contact) chooseContact(contact);
    });
    el("clear-inbound-contact").addEventListener("click", clearContact);
    document.querySelectorAll<HTMLInputElement>('input[name="inbound-scope"]').forEach((input) => input.addEventListener("change", () => updateScope()));
    historyCount.addEventListener("input", () => updateScope());
    dateFrom.addEventListener("change", () => updateScope());
    dateTo.addEventListener("change", () => updateScope());
    autoClassify.addEventListener("change", () => { syncDraftUrl(); syncButtonState(); });
    document.querySelectorAll<HTMLInputElement>('input[name="inbound-media"]').forEach((input) => input.addEventListener("change", () => { syncDraftUrl(); syncButtonState(); }));
    historyButton.addEventListener("click", () => void requestHistory());
    el("inbound-review-link").addEventListener("click", () => void startReview());
    document.addEventListener("click", (event) => {
      if (!(event.target as HTMLElement).closest(".inbound-contact-picker")) {
        contactResults.hidden = true;
        contactSearch.setAttribute("aria-expanded", "false");
      }
    });
    window.addEventListener("beforeunload", () => { if (batchPoll) window.clearInterval(batchPoll); });
    void hydrateDraft();
  </script>
</CrmLayout>
