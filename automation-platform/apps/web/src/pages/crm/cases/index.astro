---
import CrmCaseTable from "../../../components/CrmCaseTable.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";
---
<CrmLayout title="Complaint Cases" description="Search the durable complaint registry and open the exact case step that needs attention." page="cases">
  <a class="btn btn-sm btn-primary" href="/crm/cases/publication/" slot="actions">Paperless publication →</a><a class="btn btn-sm" href="/crm/helpdesk/" slot="actions">Helpdesk workspace</a>
  <section class="inbound-summary-grid crm-case-index-metrics" aria-label="Complaint lifecycle statistics"><article class="master-card"><span>Unique cases</span><strong id="case-total">—</strong><small>Active registry records</small></article><article class="master-card"><span>Intake review</span><strong id="case-review">—</strong><small>Evidence decision required</small></article><article class="master-card"><span>Ready for Paperless</span><strong id="case-ready">—</strong><small>Approved and publication-ready</small></article><article class="master-card"><span>Published to Paperless</span><strong id="case-published">—</strong><small>Publication lifecycle completed</small></article><article class="master-card"><span>Awaiting reply</span><strong id="case-awaiting-reply">—</strong><small>No reply has been prepared</small></article><article class="master-card"><span>Reply action required</span><strong id="case-actionable-reply">—</strong><small>Draft, review or sync remains</small></article><article class="master-card"><span>Reply completed</span><strong id="case-completed-reply">—</strong><small>Approved or issued</small></article><article class="master-card"><span>Sent upward</span><strong id="case-upward-sent">—</strong><small>Delivered or awaiting confirmation</small></article><article class="master-card"><span>Dispatch attention</span><strong id="case-dispatch-attention">—</strong><small>Blocked or failed route</small></article></section>
  <CrmCaseTable view="registry" />
  <style>.crm-case-index-metrics{margin:1rem 0}</style>
  <script>
    import { actions } from "astro:actions";
    const result=await actions.crm.caseStatistics({});if(result.data){const data=result.data as any;document.getElementById("case-total")!.textContent=String(data.unique_cases||0);document.getElementById("case-review")!.textContent=String(data.needs_review||0);document.getElementById("case-ready")!.textContent=String(data.ready_to_publish||0);document.getElementById("case-published")!.textContent=String(data.published||0);document.getElementById("case-awaiting-reply")!.textContent=String(data.awaiting_reply||0);document.getElementById("case-actionable-reply")!.textContent=String(data.actionable_replies||0);document.getElementById("case-completed-reply")!.textContent=String(data.completed_replies||0);document.getElementById("case-upward-sent")!.textContent=String(data.upward_sent||0);document.getElementById("case-dispatch-attention")!.textContent=String(data.dispatch_attention||0)}
  </script>
</CrmLayout>
