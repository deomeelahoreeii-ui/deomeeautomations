---
import CrmCaseTable from "../../../components/CrmCaseTable.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";
---
<CrmLayout title="Complaint Cases" description="Search the durable complaint registry and open the exact case step that needs attention." page="cases">
  <a class="btn btn-sm btn-primary" href="/crm/cases/publication/" slot="actions">Paperless publication →</a><a class="btn btn-sm" href="/crm/helpdesk/" slot="actions">Helpdesk workspace</a>
  <section class="inbound-summary-grid crm-case-index-metrics"><article class="master-card"><span>Unique cases</span><strong id="case-total">—</strong></article><article class="master-card"><span>Need review</span><strong id="case-review">—</strong></article><article class="master-card"><span>Ready to publish</span><strong id="case-ready">—</strong></article><article class="master-card"><span>Existing in Paperless</span><strong id="case-existing">—</strong></article><article class="master-card"><span>Published</span><strong id="case-published">—</strong></article></section>
  <CrmCaseTable view="registry" />
  <style>.crm-case-index-metrics{margin:1rem 0}</style>
  <script>
    import { actions } from "astro:actions";
    const result=await actions.crm.caseStatistics({});if(result.data){const data=result.data as any;document.getElementById("case-total")!.textContent=String(data.unique_cases||0);document.getElementById("case-review")!.textContent=String(data.needs_review||0);document.getElementById("case-ready")!.textContent=String(data.ready_to_publish||0);document.getElementById("case-existing")!.textContent=String(data.existing||0);document.getElementById("case-published")!.textContent=String(data.published||0)}
  </script>
</CrmLayout>
