---
import CrmCaseHeader from "../../../../components/CrmCaseHeader.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const caseId = Astro.params.id || "";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Complaint Details" description="Confirm canonical complaint fields and assign the authoritative category." page="cases">
  <a class="btn btn-sm" href="/crm/cases/" slot="actions">← All cases</a><a class="btn btn-sm btn-primary" href={`/crm/cases/${caseId}/publication`} slot="actions">Continue to Paperless →</a>
  <main id="case-details" data-case-id={caseId} data-api-base={apiBase}><div id="case-error"></div><CrmCaseHeader caseId={caseId} active="details" />
    <div class="crm-details-grid">
      <section class="master-card crm-case-form-card"><div><p class="eyebrow">Canonical record</p><h2>Confirmed complaint fields</h2><p>These values drive Paperless metadata and Helpdesk. Extracted observations remain unchanged in the audit.</p></div><form id="case-details-form"><label>Complainant name<input class="input input-bordered" data-field="complainant_name"/></label><label>Mobile<input class="input input-bordered" data-field="complainant_mobile"/></label><label>CNIC<input class="input input-bordered" data-field="complainant_cnic"/></label><label>District<input class="input input-bordered" data-field="district"/></label><label>Tehsil<input class="input input-bordered" data-field="tehsil"/></label><label>Department<input class="input input-bordered" data-field="department"/></label><label class="wide">Address<textarea class="textarea textarea-bordered" data-field="complainant_address"></textarea></label><label class="wide">Complete complaint remarks<textarea class="textarea textarea-bordered crm-remarks-editor" data-field="remarks"></textarea></label></form><div class="alert" id="details-message" hidden></div><div class="crm-form-actions"><a class="btn" href={`/crm/cases/${caseId}/audit`}>Compare extraction audit</a><button class="btn btn-primary" id="save-details" type="button">Save confirmed fields</button></div></section>
      <section class="master-card crm-taxonomy-form"><div><p class="eyebrow">Authoritative classification</p><h2>Category and subcategory</h2><p>Use controlled taxonomy values instead of free text.</p></div><label>Category<select class="select select-bordered" id="category-select"><option value="">Choose category</option></select></label><label>Subcategory<select class="select select-bordered" id="subcategory-select"><option value="">No subcategory</option></select></label><div class="crm-classification-guidance" id="classification-guidance"></div><div class="crm-sync-status"><span>Helpdesk taxonomy sync</span><strong id="classification-sync-state">Not synchronized</strong></div><div class="crm-form-actions"><a class="btn" href="/crm/taxonomy/">Manage taxonomy</a><button class="btn btn-primary" id="save-classification" type="button">Save classification</button></div></section>
    </div>
  </main>
  <style>.crm-details-grid{display:grid;grid-template-columns:minmax(0,1.3fr) minmax(19rem,.7fr);gap:1rem}.crm-details-grid>section{align-self:start;padding:1.15rem 1.2rem}.crm-details-grid h2{margin:.12rem 0}.crm-details-grid p{color:#68778a}.crm-case-form-card form{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:1rem}.crm-case-form-card label,.crm-taxonomy-form label{display:grid;gap:.32rem;color:#46556a;font-size:.75rem;font-weight:750}.crm-case-form-card label.wide{grid-column:1/-1}.crm-case-form-card textarea{min-height:5rem}.crm-case-form-card .crm-remarks-editor{min-height:12rem}.crm-taxonomy-form{display:grid;gap:.85rem;border-left:5px solid #16879a}.crm-classification-guidance{display:grid;gap:.4rem}.crm-classification-guidance span{border-radius:.5rem;background:#effafb;padding:.55rem;color:#536274;font-size:.7rem}.crm-sync-status{border:1px solid #e2e8ee;border-radius:.6rem;background:#f8fbfc;padding:.65rem}.crm-sync-status span,.crm-sync-status strong{display:block}.crm-sync-status span{color:#758396;font-size:.67rem}.crm-sync-status strong{margin-top:.18rem}.crm-form-actions{display:flex;justify-content:flex-end;gap:.5rem;border-top:1px solid #e2e8f0;margin-top:1rem;padding-top:1rem}@media(max-width:950px){.crm-details-grid{grid-template-columns:1fr}}@media(max-width:600px){.crm-case-form-card form{grid-template-columns:1fr}.crm-case-form-card label.wide{grid-column:auto}.crm-form-actions{align-items:stretch;flex-direction:column}}</style>
  <script>
    import { actions } from "astro:actions";import { hydrateCaseHeader } from "../../../../lib/crm-case-ui";import { processingStatusLabel } from "../../../../lib/crm-status";
    const root=document.getElementById("case-details") as HTMLElement,id=root.dataset.caseId!,apiBase=root.dataset.apiBase||"",el=<T extends HTMLElement>(value:string)=>document.getElementById(value) as T;let data:any,taxonomy:any[]=[];
    function show(text:string,error=false){const target=el("details-message");target.hidden=!text;target.className=`alert ${error?"alert-error":"alert-success"}`;target.textContent=text}function selectedCategory(){return taxonomy.find(item=>item.id===el<HTMLSelectElement>("category-select").value)}function guidance(){const category=selectedCategory(),sub=category?.subcategories?.find((item:any)=>item.id===el<HTMLSelectElement>("subcategory-select").value),values=[];if(category?.reply_guidance||category?.policy_notes)values.push(`${category.name}: ${[category.reply_guidance,category.policy_notes].filter(Boolean).join(" · ")}`);if(sub?.reply_guidance||sub?.policy_notes)values.push(`${sub.name}: ${[sub.reply_guidance,sub.policy_notes].filter(Boolean).join(" · ")}`);const target=el("classification-guidance");target.replaceChildren(...(values.length?values:["No saved guidance for this classification."]).map(value=>{const span=document.createElement("span");span.textContent=value;return span}))}function subcategories(selected=""){const category=selectedCategory(),select=el<HTMLSelectElement>("subcategory-select"),items=(category?.subcategories||[]).filter((item:any)=>item.active&&!item.merged_into_id);select.replaceChildren(new Option("No subcategory",""),...items.map((item:any)=>new Option(item.name,item.id)));if(items.some((item:any)=>item.id===selected))select.value=selected;guidance()}
    async function load(){const [caseResult,taxonomyResult]=await Promise.all([actions.crm.complaintCase({id}),fetch(`${apiBase}/api/v1/crm/taxonomy?include_inactive=false`).then(response=>response.ok?response.json():{categories:[]}).catch(()=>({categories:[]}))]);if(caseResult.error){el("case-error").className="alert alert-error";el("case-error").textContent=caseResult.error.message;return}data=caseResult.data as any;taxonomy=taxonomyResult.categories||[];hydrateCaseHeader(data);document.querySelectorAll<HTMLInputElement|HTMLTextAreaElement>("[data-field]").forEach(control=>control.value=data[control.dataset.field!]||"");const category=el<HTMLSelectElement>("category-select");category.replaceChildren(new Option("Choose category",""),...taxonomy.filter(item=>item.active&&!item.merged_into_id).map(item=>new Option(item.name,item.id)));category.value=data.category_id||"";subcategories(data.sub_category_id||"");el("classification-sync-state").textContent=processingStatusLabel(data.classification_sync_status)}
    el("category-select").addEventListener("change",()=>subcategories());el("subcategory-select").addEventListener("change",guidance);el("save-details").addEventListener("click",async()=>{const fields:Record<string,string|null>={};document.querySelectorAll<HTMLInputElement|HTMLTextAreaElement>("[data-field]").forEach(control=>fields[control.dataset.field!]=control.value.trim()||null);const button=el<HTMLButtonElement>("save-details");button.disabled=true;button.textContent="Saving…";const accepted=data.documents.filter((item:any)=>item.review_state==="accepted").map((item:any)=>item.id),rejected=data.documents.filter((item:any)=>item.review_state==="rejected").map((item:any)=>item.id),result=await actions.crm.reviewComplaintCase({id,fields,accepted_document_ids:accepted,rejected_document_ids:rejected});button.disabled=false;button.textContent="Save confirmed fields";if(result.error){show(result.error.message,true);return}show("Confirmed complaint fields saved.");await load()});el("save-classification").addEventListener("click",async()=>{const categoryId=el<HTMLSelectElement>("category-select").value;if(!categoryId){show("Choose a category first.",true);return}const button=el<HTMLButtonElement>("save-classification");button.disabled=true;button.textContent="Saving…";const result=await actions.crm.saveCaseClassification({id,categoryId,subcategoryId:el<HTMLSelectElement>("subcategory-select").value,synchronize:true});button.disabled=false;button.textContent="Save classification";if(result.error){show(result.error.message,true);return}const response=result.data as any;show(response.status==="failed"?(response.error||"Classification synchronization failed."):response.synchronized?"Classification saved and synchronized with Helpdesk.":"Classification saved.",response.status==="failed");await load()});await load();
  </script>
</CrmLayout>
