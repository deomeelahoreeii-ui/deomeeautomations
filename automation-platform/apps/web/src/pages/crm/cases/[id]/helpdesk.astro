---
import CrmCaseHeader from "../../../../components/CrmCaseHeader.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const caseId = Astro.params.id || "";
---
<CrmLayout title="Case Helpdesk Workflow" description="Create or refresh the linked Helpdesk ticket and inspect its operational workflow." page="cases">
  <a class="btn btn-sm" href="/crm/cases/" slot="actions">← All cases</a><a class="btn btn-sm" href="/crm/helpdesk/" slot="actions">Global Helpdesk workspace</a><a class="btn btn-sm btn-primary" href={`/crm/replies/${caseId}/`} slot="actions">Write reply →</a>
  <main id="case-helpdesk" data-case-id={caseId}><div id="case-error"></div><CrmCaseHeader caseId={caseId} active="helpdesk" />
    <section class="crm-helpdesk-layout"><article class="master-card crm-helpdesk-status-card"><p class="eyebrow">Linked operational record</p><h2 id="helpdesk-title">Loading…</h2><p id="helpdesk-summary">Checking the Helpdesk relationship.</p><div class="crm-helpdesk-facts" id="helpdesk-facts"></div><p class="crm-helpdesk-error" id="helpdesk-error" hidden></p><div class="alert" id="helpdesk-message" hidden></div><div class="crm-helpdesk-buttons"><a class="btn" id="open-helpdesk-ticket" href="#" target="_blank" rel="noreferrer" hidden>Open Helpdesk ticket ↗</a><button class="btn" id="pull-helpdesk" type="button">Pull latest workflow</button><button class="btn btn-primary" id="sync-helpdesk" type="button">Sync to Helpdesk</button></div></article><aside class="master-card crm-helpdesk-requirements"><p class="eyebrow">Before synchronization</p><h2>Eligibility</h2><ul id="helpdesk-requirements"></ul><a class="btn" href={`/crm/cases/${caseId}/details`}>Review case details</a></aside></section>
  </main>
  <style>.crm-helpdesk-layout{display:grid;grid-template-columns:minmax(0,1.35fr) minmax(18rem,.65fr);gap:1rem}.crm-helpdesk-layout>article,.crm-helpdesk-layout>aside{padding:1.15rem 1.2rem}.crm-helpdesk-layout h2{margin:.12rem 0}.crm-helpdesk-layout p{color:#68778a}.crm-helpdesk-status-card{border-left:5px solid #16879a}.crm-helpdesk-facts{display:grid;grid-template-columns:repeat(3,1fr);gap:.55rem;margin:1rem 0}.crm-helpdesk-facts div{border:1px solid #e1e8ee;border-radius:.6rem;background:#f8fbfc;padding:.65rem}.crm-helpdesk-facts span,.crm-helpdesk-facts strong{display:block}.crm-helpdesk-facts span{color:#758396;font-size:.66rem}.crm-helpdesk-facts strong{margin-top:.2rem}.crm-helpdesk-buttons{display:flex;justify-content:flex-end;gap:.5rem;flex-wrap:wrap;border-top:1px solid #e2e8f0;margin-top:1rem;padding-top:1rem}.crm-helpdesk-error{border-radius:.45rem;background:#fff0f1;padding:.5rem!important;color:#a52630!important;font-weight:750}.crm-helpdesk-requirements{align-self:start}.crm-helpdesk-requirements ul{display:grid;gap:.5rem;padding-left:1.2rem;color:#526276;font-size:.75rem}@media(max-width:850px){.crm-helpdesk-layout{grid-template-columns:1fr}}@media(max-width:600px){.crm-helpdesk-facts{grid-template-columns:1fr}.crm-helpdesk-buttons{align-items:stretch;flex-direction:column}}</style>
  <script>
    import { actions } from "astro:actions";import { hydrateCaseHeader } from "../../../../lib/crm-case-ui";import { processingStatusLabel } from "../../../../lib/crm-status";
    const root=document.getElementById("case-helpdesk") as HTMLElement,id=root.dataset.caseId!,el=<T extends HTMLElement>(value:string)=>document.getElementById(value) as T;let data:any;const fact=(label:string,value:any)=>{const wrap=document.createElement("div"),span=document.createElement("span"),strong=document.createElement("strong");span.textContent=label;strong.textContent=String(value||"—");wrap.append(span,strong);return wrap};function message(text:string,error=false){const target=el("helpdesk-message");target.hidden=!text;target.className=`alert ${error?"alert-error":"alert-success"}`;target.textContent=text}
    async function load(){const result=await actions.crm.complaintCase({id});if(result.error){el("case-error").className="alert alert-error";el("case-error").textContent=result.error.message;return}data=result.data as any;hydrateCaseHeader(data);el("helpdesk-title").textContent=data.frappe_ticket_id?`Helpdesk ticket ${data.frappe_ticket_id}`:"No Helpdesk ticket linked";el("helpdesk-summary").textContent=data.frappe_ticket_id?`Last synchronized ${data.frappe_last_synced_at?new Date(data.frappe_last_synced_at).toLocaleString():"not yet"}. Last workflow pull ${data.frappe_last_workflow_pull_at?new Date(data.frappe_last_workflow_pull_at).toLocaleString():"not performed"}.`:"Create a Helpdesk ticket after the complaint is published to Paperless.";el("helpdesk-facts").replaceChildren(fact("Synchronization",processingStatusLabel(data.frappe_sync_status)),fact("Workflow",processingStatusLabel(data.frappe_workflow_status||"not pulled")),fact("Assignment",data.frappe_agent_group||data.frappe_assigned_officer_name||"Unassigned"));const error=el("helpdesk-error");error.hidden=!data.frappe_last_error;error.textContent=data.frappe_last_error||"";const open=el<HTMLAnchorElement>("open-helpdesk-ticket");open.hidden=!data.frappe_ticket_url;if(data.frappe_ticket_url)open.href=data.frappe_ticket_url;el<HTMLButtonElement>("pull-helpdesk").hidden=!data.frappe_ticket_id;el<HTMLButtonElement>("sync-helpdesk").textContent=data.frappe_ticket_id?"Refresh Helpdesk ticket":"Sync to Helpdesk";const requirements=[data.paperless_document_id?"Published or linked Paperless document available":"Publish the complaint to Paperless first",data.complaint_number?"Complaint number confirmed":"Confirm the complaint number",data.category?"Authoritative category selected":"Select a category",data.remarks?"Complaint remarks confirmed":"Confirm complaint remarks"];el("helpdesk-requirements").replaceChildren(...requirements.map(value=>{const item=document.createElement("li");item.textContent=value;return item}))}
    el("pull-helpdesk").addEventListener("click",async()=>{const button=el<HTMLButtonElement>("pull-helpdesk");button.disabled=true;button.textContent="Pulling…";const result=await actions.crm.pullHelpdeskCaseWorkflow({id});button.disabled=false;button.textContent="Pull latest workflow";if(result.error){message(result.error.message,true);return}message(`Workflow pull: ${(result.data as any).status}.`);await load()});el("sync-helpdesk").addEventListener("click",async()=>{const button=el<HTMLButtonElement>("sync-helpdesk");button.disabled=true;button.textContent="Synchronizing…";const result=await actions.crm.syncHelpdeskCase({id,force:false});button.disabled=false;if(result.error){message(result.error.message,true);await load();return}const response=result.data as any;if(response.status==="blocked")message(`Helpdesk synchronization blocked: ${(response.blockers||[]).join(" · ")}`,true);else message(`Helpdesk synchronization: ${response.status}.`);await load()});await load();
  </script>
</CrmLayout>
