---
import CrmCaseHeader from "../../../../components/CrmCaseHeader.astro";
import DataTable from "../../../../components/DataTable.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const caseId = Astro.params.id || "";
---
<CrmLayout title="Complaint Extraction Audit" description="Trace canonical values back to OCR, selectable text and structured source observations." page="cases">
  <a class="btn btn-sm" href="/crm/cases/" slot="actions">← All cases</a><a class="btn btn-sm" href={`/crm/cases/${caseId}/details`} slot="actions">Edit confirmed details</a>
  <main id="case-audit" data-case-id={caseId}><div id="case-error"></div><CrmCaseHeader caseId={caseId} active="audit" />
    <section class="master-card crm-audit-page"><div class="inbound-card-heading"><div><p class="eyebrow">Extraction observations</p><h2>Observed fields</h2><p>Sortable observations from source documents. These records remain unchanged when canonical case fields are edited.</p></div><input class="input input-bordered input-sm" id="audit-search" placeholder="Search field, value or source"/></div><DataTable id="case-observations-table" pageSize={20} pageSizeOptions={[10,20,50,100]} emptyText="No structured observations were extracted." ariaLabel="Complaint field observations" /></section>
    <section class="master-card crm-extraction-page"><div><p class="eyebrow">Source text</p><h2>Extraction versions</h2><p>Open only when you need to audit how a value was obtained.</p></div><div id="case-extractions"></div></section>
  </main>
  <style is:global>.crm-audit-page,.crm-extraction-page{padding:1.1rem 1.2rem}.crm-audit-page h2,.crm-extraction-page h2{margin:.12rem 0}.crm-audit-page p,.crm-extraction-page p{color:#68778a}.crm-audit-page .inbound-card-heading input{width:min(26rem,100%)}.crm-extraction-page{margin-top:1rem}.crm-extraction-list{display:grid;gap:.65rem;margin-top:1rem}.crm-extraction-item{border:1px solid #e1e8ee;border-radius:.65rem;padding:.7rem}.crm-extraction-item summary{cursor:pointer;color:#405066;font-size:.75rem;font-weight:750}.crm-extraction-text{max-height:28rem;overflow:auto;white-space:pre-wrap;overflow-wrap:anywhere;border-radius:.55rem;background:#17212b;color:#d9e4ee;padding:1rem;font-size:.72rem;line-height:1.5}.crm-observation-value{display:block;max-width:38rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}</style>
  <script>
    import { actions } from "astro:actions";import { hydrateCaseHeader } from "../../../../lib/crm-case-ui";import { processingStatusLabel } from "../../../../lib/crm-status";await customElements.whenDefined("astro-data-table");
    const root=document.getElementById("case-audit") as HTMLElement,id=root.dataset.caseId!,table=document.getElementById("case-observations-table") as any,search=document.getElementById("audit-search") as HTMLInputElement;let data:any;const valueCell=(value:any)=>{const span=document.createElement("span");span.className="crm-observation-value";span.textContent=String(value??"");span.title=String(value??"");return span};function filtered(){const term=search.value.trim().toLowerCase();return(data?.field_observations||[]).filter((row:any)=>!term||[row.field_name,row.raw_value,row.normalized_value,row.source_locator,row.decision].some(value=>String(value||"").toLowerCase().includes(term)))}async function render(){await table.setData(filtered())}await table.configure({data:[],columns:[{accessorKey:"field_name",header:"Field",cell:({row}:any)=>processingStatusLabel(row.original.field_name)},{accessorKey:"raw_value",header:"Observed value",cell:({row}:any)=>valueCell(row.original.raw_value)},{accessorKey:"normalized_value",header:"Normalized value",cell:({row}:any)=>valueCell(row.original.normalized_value)},{accessorKey:"confidence",header:"Confidence",cell:({row}:any)=>`${Math.round(Number(row.original.confidence||0)*100)}%`},{accessorKey:"source_locator",header:"Source"},{accessorKey:"decision",header:"Decision",cell:({row}:any)=>processingStatusLabel(row.original.decision)}]});const result=await actions.crm.complaintCase({id});if(result.error){table.showError(result.error.message)}else{data=result.data as any;hydrateCaseHeader(data);const list=document.createElement("div");list.className="crm-extraction-list";for(const extraction of data.extractions||[]){const details=document.createElement("details"),summary=document.createElement("summary"),pre=document.createElement("pre");details.className="crm-extraction-item";summary.textContent=`${processingStatusLabel(extraction.method||"unknown")} · ${new Date(extraction.created_at).toLocaleString()}${extraction.text_truncated?" · preview truncated":""}`;pre.className="crm-extraction-text";pre.textContent=extraction.text_preview||"No source text retained.";details.append(summary,pre);list.append(details)}document.getElementById("case-extractions")!.replaceChildren(list);await render()}search.addEventListener("input",()=>void render());
  </script>
</CrmLayout>
