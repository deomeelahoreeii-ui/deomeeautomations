---
import CrmCaseHeader from "../../../../components/CrmCaseHeader.astro";
import DataTable from "../../../../components/DataTable.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const caseId = Astro.params.id || "";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Complaint Evidence" description="Inspect source documents, remove duplicate captures and confirm each document role." page="cases">
  <a class="btn btn-sm" href="/crm/cases/" slot="actions">← All cases</a><a class="btn btn-sm btn-primary" href={`/crm/cases/${caseId}/details`} slot="actions">Continue to details →</a>
  <main id="case-evidence" data-case-id={caseId} data-api-base={apiBase}><div id="case-error"></div><CrmCaseHeader caseId={caseId} active="evidence" />
    <section class="master-card crm-evidence-page"><div class="inbound-card-heading"><div><p class="eyebrow">Evidence review</p><h2>Documents and attachments</h2><p>Open each source and confirm its role. Exactly one accepted main complaint is required for publication.</p></div><span class="badge" id="evidence-count">Loading…</span></div><div class="toolbar crm-evidence-filters"><input class="input input-bordered input-sm" id="evidence-search" placeholder="Search filename, role or relationship"/><select class="select select-bordered select-sm" id="evidence-state"><option value="">All review states</option><option value="accepted">Accepted</option><option value="proposed">Proposed</option><option value="duplicate">Duplicate capture</option><option value="rejected">Rejected</option></select></div><div class="alert" id="evidence-message" hidden></div><DataTable id="case-evidence-table" pageSize={15} pageSizeOptions={[10,15,25,50]} emptyText="No evidence documents match these filters." ariaLabel="Complaint evidence documents" /></section>
  </main>
  <style is:global>.crm-evidence-page{padding:1.05rem 1.15rem}.crm-evidence-page h2{margin:.12rem 0}.crm-evidence-page p{margin:.25rem 0;color:#68778a}.crm-evidence-filters{display:grid;grid-template-columns:minmax(16rem,1fr) 13rem;gap:.55rem;margin:.9rem 0}.crm-evidence-file{display:block;color:#29384d;font-weight:800;overflow-wrap:anywhere}.crm-evidence-secondary{display:block;margin-top:.15rem;color:#758396;font-size:.68rem}.crm-evidence-actions{display:flex;justify-content:flex-end;gap:.3rem;flex-wrap:wrap}.crm-evidence-state{display:inline-flex;border-radius:999px;background:#edf3f6;padding:.25rem .5rem;font-size:.68rem;font-weight:800}.crm-evidence-state.accepted{background:#e7f8f1;color:#176b57}.crm-evidence-state.duplicate{background:#e8f4fa;color:#14677a}.crm-evidence-state.rejected{background:#fff0f1;color:#9e3038}@media(max-width:650px){.crm-evidence-filters{grid-template-columns:1fr}}</style>
  <script>
    import { actions } from "astro:actions";import { hydrateCaseHeader } from "../../../../lib/crm-case-ui";import { processingStatusLabel } from "../../../../lib/crm-status";await customElements.whenDefined("astro-data-table");
    const root=document.getElementById("case-evidence") as HTMLElement,id=root.dataset.caseId!,apiBase=root.dataset.apiBase||"",table=document.getElementById("case-evidence-table") as any,search=document.getElementById("evidence-search") as HTMLInputElement,state=document.getElementById("evidence-state") as HTMLSelectElement,message=document.getElementById("evidence-message")!;let data:any;
    const primary=(value:any,secondary="")=>{const wrap=document.createElement("div"),strong=document.createElement("strong");strong.className="crm-evidence-file";strong.textContent=String(value||"—");wrap.append(strong);if(secondary){const small=document.createElement("small");small.className="crm-evidence-secondary";small.textContent=secondary;wrap.append(small)}return wrap};const status=(value:any)=>{const span=document.createElement("span");span.className=`crm-evidence-state ${String(value||"")}`;span.textContent=processingStatusLabel(value);return span};function show(text:string,error=false){message.hidden=!text;message.className=`alert ${error?"alert-error":"alert-success"}`;message.textContent=text}
    function actionsCell(documentRow:any){const wrap=document.createElement("div");wrap.className="crm-evidence-actions";const sourceUrl=documentRow.source_processing_item_id?`${apiBase}/api/v1/whatsapp/inbound/processing-items/${documentRow.source_processing_item_id}/content`:documentRow.source_kind==="manual_upload"?`${apiBase}/api/v1/crm/reply-workspace/documents/${documentRow.id}/download`:"";if(sourceUrl){const open=document.createElement("a");open.className="btn btn-xs btn-primary";open.href=sourceUrl;open.target="_blank";open.rel="noreferrer";open.textContent="Open ↗";wrap.append(open)}for(const [role,label] of [["main_complaint","Main complaint"],["attachment","Attachment"],["report","Reply/report"]]){const button=document.createElement("button");button.className="btn btn-xs";button.type="button";button.textContent=label;button.addEventListener("click",()=>void update(documentRow,role,true));wrap.append(button)}const reject=document.createElement("button");reject.className="btn btn-xs";reject.type="button";reject.textContent="Reject link";reject.addEventListener("click",()=>void update(documentRow,documentRow.role,false));wrap.append(reject);return wrap}
    async function update(documentRow:any,role:string,accepted:boolean){if(!accepted&&!confirm(`Reject the link for ${documentRow.original_filename||"this document"}?`))return;const result=await actions.crm.reviewComplaintDocument({caseId:id,documentId:documentRow.id,role:role as any,accepted});if(result.error){show(result.error.message,true);return}show(accepted?`Document linked as ${role.replaceAll("_"," ")}.`:"Document relationship rejected.");await load()}
    function filtered(){const term=search.value.trim().toLowerCase();return(data?.documents||[]).filter((row:any)=>!row.duplicate_of_document_id).filter((row:any)=>state.value==="duplicate"?row.duplicate_capture_count>1:!state.value||row.review_state===state.value).filter((row:any)=>!term||[row.original_filename,row.role,row.review_state,row.relationship_reason].some(value=>String(value||"").toLowerCase().includes(term)))}async function render(){const rows=filtered();document.getElementById("evidence-count")!.textContent=`${rows.length} of ${data.document_count} unique`;await table.setData(rows)}async function load(){const result=await actions.crm.complaintCase({id});if(result.error){table.showError(result.error.message);return}data=result.data as any;hydrateCaseHeader(data);await render()}await table.configure({data:[],getRowId:(row:any)=>row.id,columns:[{accessorKey:"original_filename",header:"Document",cell:({row}:any)=>primary(row.original.original_filename,row.original.mime_type||"")},{accessorKey:"role",header:"Role",cell:({row}:any)=>processingStatusLabel(row.original.role)},{accessorKey:"review_state",header:"Review state",cell:({row}:any)=>status(row.original.review_state)},{accessorKey:"relationship_confidence",header:"Confidence",cell:({row}:any)=>`${Math.round(Number(row.original.relationship_confidence||0)*100)}%`},{accessorKey:"relationship_reason",header:"Relationship",cell:({row}:any)=>primary(row.original.relationship_reason||"Not confirmed",row.original.duplicate_capture_count>1?`${row.original.duplicate_capture_count} identical captures`:"")},{id:"actions",header:"",cell:({row}:any)=>actionsCell(row.original),enableSorting:false,meta:{align:"right",minWidth:"20rem"}}]});search.addEventListener("input",()=>void render());state.addEventListener("change",()=>void render());await load();
  </script>
</CrmLayout>
