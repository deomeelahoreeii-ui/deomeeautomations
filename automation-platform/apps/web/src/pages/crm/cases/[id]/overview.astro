---
import CrmCaseHeader from "../../../../components/CrmCaseHeader.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const caseId = Astro.params.id || "";
---
<CrmLayout title="Complaint Overview" description="Understand the complaint record, its readiness and the next required operator action." page="cases">
  <a class="btn btn-sm" href="/crm/cases/" slot="actions">← All cases</a><a class="btn btn-sm" href={`/crm/replies/${caseId}/`} slot="actions">Write reply</a>
  <main id="case-overview" data-case-id={caseId}><div id="case-error"></div><CrmCaseHeader caseId={caseId} active="overview" />
    <section class="crm-overview-grid">
      <article class="master-card crm-overview-summary"><div class="inbound-card-heading"><div><p class="eyebrow">Canonical record</p><h2>Confirmed complaint snapshot</h2><p>Working values used by publication and Helpdesk.</p></div><a class="btn btn-sm btn-primary" href={`/crm/cases/${caseId}/details`}>Edit details →</a></div><div class="crm-overview-facts" id="overview-facts"></div><div class="crm-overview-remarks"><span>Complaint remarks</span><p id="overview-remarks">—</p></div></article>
      <aside class="master-card crm-next-step"><p class="eyebrow">Next required action</p><h2 id="next-step-title">Loading…</h2><p id="next-step-description">Checking evidence and publication readiness.</p><div id="overview-blockers"></div><a class="btn btn-primary" id="overview-next-link" href="#">Continue →</a></aside>
    </section>
    <section class="crm-lifecycle-grid"><article class="master-card"><span>Evidence</span><strong id="lifecycle-evidence">—</strong><small id="lifecycle-evidence-detail">—</small><a href={`/crm/cases/${caseId}/evidence`}>Open evidence →</a></article><article class="master-card"><span>Classification</span><strong id="lifecycle-classification">—</strong><small id="lifecycle-classification-detail">—</small><a href={`/crm/cases/${caseId}/details`}>Review details →</a></article><article class="master-card"><span>Paperless</span><strong id="lifecycle-paperless">—</strong><small id="lifecycle-paperless-detail">—</small><a href={`/crm/cases/${caseId}/publication`}>Open publication →</a></article><article class="master-card"><span>Helpdesk</span><strong id="lifecycle-helpdesk">—</strong><small id="lifecycle-helpdesk-detail">—</small><a href={`/crm/cases/${caseId}/helpdesk`}>Open workflow →</a></article></section>
  </main>
  <style>.crm-overview-grid{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(18rem,.7fr);gap:1rem}.crm-overview-grid>article,.crm-overview-grid>aside{padding:1.1rem 1.2rem}.crm-overview-grid h2{margin:.12rem 0}.crm-overview-grid p{color:#68778a}.crm-overview-facts{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.55rem;margin-top:1rem}.crm-overview-fact{border:1px solid #e1e8ee;border-radius:.6rem;background:#f9fbfc;padding:.65rem}.crm-overview-fact span,.crm-overview-fact strong{display:block}.crm-overview-fact span,.crm-overview-remarks span{color:#778497;font-size:.65rem;text-transform:uppercase}.crm-overview-fact strong{margin-top:.18rem;color:#334155;font-size:.8rem;overflow-wrap:anywhere}.crm-overview-remarks{margin-top:.7rem;border-left:3px solid #77b8c1;background:#f4fafb;padding:.7rem .8rem}.crm-overview-remarks p{margin:.25rem 0 0;white-space:pre-wrap}.crm-next-step{align-self:start;border-left:5px solid #16879a}.crm-next-step>div{display:grid;gap:.4rem;margin:.8rem 0}.crm-next-step .crm-blocker{border-radius:.45rem;background:#fff4df;padding:.45rem .55rem;color:#87540b;font-size:.7rem}.crm-lifecycle-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.8rem;margin-top:1rem}.crm-lifecycle-grid article{display:grid;gap:.22rem;padding:.9rem}.crm-lifecycle-grid span,.crm-lifecycle-grid small{color:#718096}.crm-lifecycle-grid strong{font-size:1rem}.crm-lifecycle-grid a{margin-top:.35rem;color:#0d7788;font-size:.72rem;font-weight:750}@media(max-width:1000px){.crm-overview-grid{grid-template-columns:1fr}.crm-lifecycle-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:650px){.crm-overview-facts,.crm-lifecycle-grid{grid-template-columns:1fr}}</style>
  <script>
    import { actions } from "astro:actions";import { hydrateCaseHeader } from "../../../../lib/crm-case-ui";import { paperlessLinkSummary, processingStatusLabel } from "../../../../lib/crm-status";
    const root=document.getElementById("case-overview") as HTMLElement,id=root.dataset.caseId!,el=<T extends HTMLElement>(value:string)=>document.getElementById(value) as T;
    const fact=(name:string,value:any)=>{const wrap=document.createElement("div"),label=document.createElement("span"),strong=document.createElement("strong");wrap.className="crm-overview-fact";label.textContent=name;strong.textContent=String(value||"Not confirmed");wrap.append(label,strong);return wrap};
    const result=await actions.crm.complaintCase({id});if(result.error){el("case-error").className="alert alert-error";el("case-error").textContent=result.error.message}else{const data=result.data as any;hydrateCaseHeader(data);el("overview-facts").replaceChildren(...[["Complainant",data.complainant_name],["Mobile",data.complainant_mobile],["CNIC",data.complainant_cnic],["District",data.district],["Tehsil",data.tehsil],["Category",[data.category,data.sub_category].filter(Boolean).join(" / ")]].map(([name,value])=>fact(String(name),value)));el("overview-remarks").textContent=data.remarks||"Not confirmed";const blockers=data.publication_blockers||[],nextTitle=blockers.length?"Complete case verification":data.state==="fresh"?"Publish the approved package":data.state==="existing"?"Review newly captured evidence":data.state==="published"?"Continue operational workflow":"Review case evidence",destination=blockers.some((value:string)=>value.toLowerCase().includes("document"))?"evidence":blockers.length?"details":data.state==="fresh"?"publication":data.state==="published"?"helpdesk":"evidence";el("next-step-title").textContent=nextTitle;el("next-step-description").textContent=blockers.length?"Resolve the blockers below before Paperless publication.":"The case is ready for its next workflow step.";el("overview-blockers").replaceChildren(...blockers.map((value:string)=>{const node=document.createElement("span");node.className="crm-blocker";node.textContent=value;return node}));const next=el<HTMLAnchorElement>("overview-next-link");next.href=`/crm/cases/${id}/${destination}`;next.textContent=`${nextTitle} →`;el("lifecycle-evidence").textContent=`${data.document_count} unique file${data.document_count===1?"":"s"}`;el("lifecycle-evidence-detail").textContent=data.capture_count>data.document_count?`${data.capture_count} total captures including duplicates`:"No duplicate captures";el("lifecycle-classification").textContent=[data.category,data.sub_category].filter(Boolean).join(" / ")||"Not classified";el("lifecycle-classification-detail").textContent=processingStatusLabel(data.classification_sync_status);const paperless=data.paperless_result||{};el("lifecycle-paperless").textContent=paperlessLinkSummary(paperless.document_id||data.paperless_document_id,paperless.category,paperless.statuses||[]);el("lifecycle-paperless-detail").textContent=paperless.reason||`${blockers.length} publication blocker(s)`;el("lifecycle-helpdesk").textContent=data.frappe_ticket_id?`Ticket ${data.frappe_ticket_id}`:"Not linked";el("lifecycle-helpdesk-detail").textContent=processingStatusLabel(data.frappe_sync_status)}
  </script>
</CrmLayout>
