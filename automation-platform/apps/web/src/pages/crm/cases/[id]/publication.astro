---
import CrmCaseHeader from "../../../../components/CrmCaseHeader.astro";
import DataTable from "../../../../components/DataTable.astro";
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const caseId = Astro.params.id || "";
---
<CrmLayout title="Case Paperless Publication" description="Understand the duplicate result, resolve publication blockers and publish the verified package." page="cases">
  <a class="btn btn-sm" href="/crm/cases/publication/" slot="actions">← Publication queue</a><a class="btn btn-sm" href={`/crm/cases/${caseId}/evidence`} slot="actions">Review evidence</a>
  <main id="case-publication" data-case-id={caseId}><div id="case-error"></div><CrmCaseHeader caseId={caseId} active="publication" />
    <section class="crm-publication-layout"><article class="master-card crm-publication-decision"><p class="eyebrow">Current Paperless result</p><h2 id="paperless-result-title">Loading…</h2><p id="paperless-result-reason">Checking the recorded match.</p><div class="crm-paperless-facts"><div><span>Paperless document</span><strong id="paperless-document">—</strong></div><div><span>Paperless status</span><strong id="paperless-status">—</strong></div><div><span>Case publication state</span><strong id="publication-state">—</strong></div></div><div class="crm-publication-blockers" id="publication-blockers"></div><div class="alert" id="publication-message" hidden></div><div class="crm-publication-actions"><button class="btn" id="approve-fresh" type="button">Approve as fresh complaint</button><button class="btn btn-primary" id="publish-case" type="button">Publish approved package</button></div></article><aside class="master-card crm-publication-help"><p class="eyebrow">Meaning of the result</p><h2>Paperless checks do not upload</h2><p><b>Existing · Submitted</b> means an earlier Paperless document with the same complaint number already has status Submitted. It does not mean this intake submitted anything.</p><p>When an exact match exists, the CRM case is already linked to its Paperless document and no new upload is required.</p></aside></section>
    <section class="master-card crm-publication-table"><div class="inbound-card-heading"><div><p class="eyebrow">Duplicate reconciliation</p><h2>Paperless match history</h2></div></div><DataTable id="case-match-table" pageSize={10} emptyText="No Paperless duplicate decision has been recorded." ariaLabel="Paperless match history" /></section>
    <section class="master-card crm-publication-table"><div class="inbound-card-heading"><div><p class="eyebrow">Publication audit</p><h2>Queued and completed uploads</h2></div></div><DataTable id="case-publication-table" pageSize={10} emptyText="This case has not queued a Paperless publication." ariaLabel="Paperless publication history" /></section>
  </main>
  <style is:global>.crm-publication-layout{display:grid;grid-template-columns:minmax(0,1.4fr) minmax(18rem,.6fr);gap:1rem}.crm-publication-layout>article,.crm-publication-layout>aside,.crm-publication-table{padding:1.1rem 1.2rem}.crm-publication-layout h2,.crm-publication-table h2{margin:.12rem 0}.crm-publication-layout p{color:#68778a}.crm-publication-decision{border-left:5px solid #16879a}.crm-paperless-facts{display:grid;grid-template-columns:repeat(3,1fr);gap:.55rem;margin:1rem 0}.crm-paperless-facts div{border:1px solid #e1e8ee;border-radius:.6rem;background:#f8fbfc;padding:.65rem}.crm-paperless-facts span,.crm-paperless-facts strong{display:block}.crm-paperless-facts span{color:#758396;font-size:.66rem}.crm-paperless-facts strong{margin-top:.2rem}.crm-publication-blockers{display:grid;gap:.4rem}.crm-publication-blockers span{border-radius:.45rem;background:#fff4df;padding:.5rem .6rem;color:#87540b;font-size:.7rem}.crm-publication-actions{display:flex;justify-content:flex-end;gap:.5rem;border-top:1px solid #e2e8f0;margin-top:1rem;padding-top:1rem}.crm-publication-help{align-self:start;background:#f8fbfc}.crm-publication-help b{color:#334155}.crm-publication-table{margin-top:1rem}.crm-audit-primary{display:block;font-weight:800}.crm-audit-secondary{display:block;margin-top:.15rem;color:#758396;font-size:.68rem}@media(max-width:900px){.crm-publication-layout{grid-template-columns:1fr}}@media(max-width:600px){.crm-paperless-facts{grid-template-columns:1fr}.crm-publication-actions{align-items:stretch;flex-direction:column}}</style>
  <script>
    import { actions } from "astro:actions";import { hydrateCaseHeader } from "../../../../lib/crm-case-ui";import { caseStateLabel, paperlessResultLabel, processingStatusLabel } from "../../../../lib/crm-status";await customElements.whenDefined("astro-data-table");
    const root=document.getElementById("case-publication") as HTMLElement,id=root.dataset.caseId!,el=<T extends HTMLElement>(value:string)=>document.getElementById(value) as T,matchTable=el<any>("case-match-table"),publicationTable=el<any>("case-publication-table");let data:any;
    const primary=(value:any,secondary="")=>{const wrap=document.createElement("div"),strong=document.createElement("strong");strong.className="crm-audit-primary";strong.textContent=String(value||"—");wrap.append(strong);if(secondary){const small=document.createElement("small");small.className="crm-audit-secondary";small.textContent=secondary;wrap.append(small)}return wrap};function show(text:string,error=false){const target=el("publication-message");target.hidden=!text;target.className=`alert ${error?"alert-error":"alert-success"}`;target.textContent=text}
    await matchTable.configure({data:[],columns:[{accessorKey:"created_at",header:"Checked",cell:({row}:any)=>new Date(row.original.created_at).toLocaleString()},{accessorKey:"proposed_decision",header:"Result",cell:({row}:any)=>processingStatusLabel(row.original.final_decision||row.original.proposed_decision)},{accessorKey:"paperless_document_id",header:"Paperless document",cell:({row}:any)=>row.original.paperless_document_id?`#${row.original.paperless_document_id}`:"No match"},{accessorKey:"reason",header:"Reason"}]});await publicationTable.configure({data:[],columns:[{accessorKey:"created_at",header:"Queued",cell:({row}:any)=>new Date(row.original.created_at).toLocaleString()},{accessorKey:"state",header:"State",cell:({row}:any)=>processingStatusLabel(row.original.state)},{accessorKey:"intended_fields_json",header:"Document role",cell:({row}:any)=>processingStatusLabel(row.original.intended_fields_json?.role||"document")},{accessorKey:"paperless_document_id",header:"Paperless document",cell:({row}:any)=>row.original.paperless_document_id?`#${row.original.paperless_document_id}`:"—"},{accessorKey:"last_error",header:"Result",cell:({row}:any)=>primary(row.original.last_error?"Failed":"No error",row.original.last_error||"")}]});
    async function load(){const result=await actions.crm.complaintCase({id});if(result.error){el("case-error").className="alert alert-error";el("case-error").textContent=result.error.message;return}data=result.data as any;hydrateCaseHeader(data);const paperless=data.paperless_result||{},statuses=paperless.statuses||[];el("paperless-result-title").textContent=paperlessResultLabel(paperless.category,statuses);el("paperless-result-reason").textContent=paperless.reason||"No duplicate-check explanation was recorded.";el("paperless-document").textContent=paperless.document_id?`#${paperless.document_id}`:"No linked document";el("paperless-status").textContent=statuses.join(", ")||"No matching status";el("publication-state").textContent=caseStateLabel(data.state);const blockers=data.publication_blockers||[];el("publication-blockers").replaceChildren(...blockers.map((value:string)=>{const span=document.createElement("span");span.textContent=value;return span}));const approve=el<HTMLButtonElement>("approve-fresh"),publish=el<HTMLButtonElement>("publish-case");approve.hidden=!["candidate","review_required"].includes(data.state)||Boolean(data.paperless_document_id);publish.hidden=data.state!=="fresh";publish.disabled=!data.publication_ready;await Promise.all([matchTable.setData(data.matches||[]),publicationTable.setData(data.paperless_publications||[])])}
    el("approve-fresh").addEventListener("click",async()=>{if(!confirm("Confirm that duplicate review is complete and approve this as a fresh complaint?"))return;const result=await actions.crm.approveFreshComplaint({id});if(result.error){show(result.error.message,true);return}show("Complaint approved as fresh and ready for publication.");await load()});el("publish-case").addEventListener("click",async()=>{if(!confirm("Queue this exact approved evidence package for Paperless publication?"))return;const result=await actions.crm.publishComplaint({id});if(result.error){show(result.error.message,true);return}show(`Publication queued: ${(result.data as any).task_id}`);await load()});await load();
  </script>
</CrmLayout>
