---
import CrmLayout from "../../../layouts/CrmLayout.astro";
import DataTable from "../../../components/DataTable.astro";
import CheckboxField from "../../../components/ui/CheckboxField.astro";
import ModalDialog from "../../../components/ui/ModalDialog.astro";
import StatusBadge from "../../../components/ui/StatusBadge.astro";

const { id } = Astro.params;
if (!id) return Astro.redirect("/crm/replies/");
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
const requestedReturn = Astro.url.searchParams.get("return") || "";
const returnTo = requestedReturn.startsWith("/crm/replies") ? requestedReturn : "/crm/replies/";
---

<CrmLayout
  title="Reply Editor"
  description="Investigate, draft, verify and approve one complaint reply while preserving Helpdesk workflow and PostgreSQL revision history."
  page="replies"
>
  <a class="btn btn-sm" href={returnTo} slot="actions">← Reply Queue</a>
  <a class="btn btn-sm" href="/crm/knowledge/" slot="actions">AI Reply Archive</a>

  <main id="reply-editor" data-api-base={apiBase} data-case-id={id} class="crm32-page reply-editor-page">
    <section class="master-card editor-hero">
      <div class="editor-hero-copy">
        <p class="eyebrow">Complaint reply workspace</p>
        <div class="editor-title-line">
          <h2 id="editor-title">Loading complaint…</h2>
          <StatusBadge id="editor-reply-status" label="Loading" />
          <StatusBadge id="classification-state" label="Classification" />
        </div>
        <p id="editor-subtitle">Reading complaint and current Helpdesk fields.</p>
      </div>
      <div id="editor-links" class="editor-links"></div>
    </section>

    <section id="editor-warning" class="crm-warning-box" hidden></section>

    <section class="editor-workspace">
      <aside class="master-card editor-context-card">
        <header class="crm-card-heading editor-context-heading">
          <div>
            <p class="eyebrow">Original context</p>
            <h2>Complaint record</h2>
            <p id="complaint-context-caption">Source, evidence, approved revisions and workflow history.</p>
          </div>
          <button id="read-full-complaint" class="btn btn-sm" type="button">Read full complaint</button>
        </header>

        <nav class="editor-context-tabs" aria-label="Complaint context">
          <button class="active" type="button" data-context-tab="complaint" aria-selected="true">Complaint</button>
          <button type="button" data-context-tab="evidence" aria-selected="false">Evidence <span id="document-count">0</span></button>
          <button type="button" data-context-tab="revisions" aria-selected="false">Revisions <span id="revision-count">0</span></button>
          <button type="button" data-context-tab="activity" aria-selected="false">Activity</button>
        </nav>

        <div class="editor-context-body">
          <section id="context-complaint" class="editor-context-panel active" data-context-panel="complaint">
            <div id="complaint-meta" class="crm-chip-row"></div>
            <article id="complaint-excerpt" class="complaint-excerpt">Loading complaint text…</article>

            <section class="editor-classification-section">
              <header class="editor-section-heading">
                <div>
                  <p class="eyebrow">Controlled classification</p>
                  <h3>Category and subcategory</h3>
                </div>
                <a class="table-inline-link" href="/crm/taxonomy/">Manage taxonomy</a>
              </header>
              <div class="editor-classification-grid">
                <label class="crm-field" for="editor-category">
                  <span>Category</span>
                  <select id="editor-category" class="select select-bordered"></select>
                </label>
                <label class="crm-field" for="editor-subcategory">
                  <span>Subcategory</span>
                  <select id="editor-subcategory" class="select select-bordered"><option value="">No subcategory</option></select>
                </label>
              </div>
              <button id="save-classification" class="btn btn-primary editor-classification-save" type="button">Save and sync classification</button>
              <div id="classification-guidance" class="editor-guidance-grid"></div>
            </section>
          </section>

          <section id="context-evidence" class="editor-context-panel" data-context-panel="evidence" hidden>
            <DataTable id="editor-evidence-table" pageSize={8} emptyText="No evidence documents are linked to this complaint." ariaLabel="Complaint evidence documents" class="editor-context-table" />
          </section>

          <section id="context-revisions" class="editor-context-panel" data-context-panel="revisions" hidden>
            <div class="editor-context-note">Only approved or issued replies enter the immutable archive. Drafts and pending replies are intentionally excluded.</div>
            <DataTable id="editor-revisions-table" pageSize={8} emptyText="No approved revisions exist yet." ariaLabel="Approved reply revisions" class="editor-context-table" />
          </section>

          <section id="context-activity" class="editor-context-panel" data-context-panel="activity" hidden>
            <DataTable id="editor-activity-table" pageSize={12} emptyText="No complaint workflow activity has been recorded." ariaLabel="Complaint workflow activity" class="editor-context-table" />
          </section>
        </div>
      </aside>

      <section class="master-card reply-composer-card">
        <header class="crm-card-heading reply-composer-heading">
          <div>
            <p class="eyebrow">Operational reply</p>
            <h2>Findings and final response</h2>
            <p>Writes are saved to Frappe Helpdesk, read back for verification, and then reflected in PostgreSQL.</p>
          </div>
          <StatusBadge id="live-source" label="Loading" />
        </header>

        <section id="reply-source-panel" class="reply-source-panel" hidden>
          <div class="reply-source-copy">
            <p class="eyebrow">Reply source</p>
            <strong id="reply-source-title">Local workspace</strong>
            <small id="reply-source-detail">Loading reply provenance…</small>
          </div>
          <div class="reply-source-actions">
            <a id="reply-source-batch" class="btn btn-sm" href="#" hidden>Open import batch</a>
            <button id="compare-replies" class="btn btn-sm" type="button" hidden>Compare versions</button>
          </div>
        </section>

        <form id="reply-form" class="reply-composer-form" autocomplete="off">
          <section class="reply-form-section">
            <header class="editor-section-heading">
              <div>
                <span class="editor-step-number">1</span>
                <h3>Investigation record</h3>
                <p>Keep internal findings factual and distinct from the citizen-facing response.</p>
              </div>
            </header>
            <div class="investigation-grid">
              <label class="crm-field" for="inquiry-findings">
                <span>Inquiry findings</span>
                <textarea id="inquiry-findings" class="textarea textarea-bordered" rows="7" placeholder="Record verified field inquiry or administrative findings."></textarea>
              </label>
              <label class="crm-field" for="school-version">
                <span>School / institution version</span>
                <textarea id="school-version" class="textarea textarea-bordered" rows="7" placeholder="Record the institution's response, denial, admission or supporting position."></textarea>
              </label>
              <label class="crm-field" for="applicable-policy">
                <span>Applicable policy / rule</span>
                <textarea id="applicable-policy" class="textarea textarea-bordered" rows="7" placeholder="Record the relevant policy, circular, rule or safe administrative basis."></textarea>
              </label>
            </div>
          </section>

          <section class="reply-form-section">
            <header class="editor-section-heading reply-section-heading-row">
              <div>
                <span class="editor-step-number">2</span>
                <h3>Citizen-facing final reply</h3>
                <p>Write the response that will be saved and verified in Helpdesk.</p>
              </div>
              <button id="copy-reply" class="btn btn-sm" type="button">Copy Reply</button>
            </header>
            <label class="crm-field final-reply-field" for="final-reply">
              <span class="sr-only">Final reply</span>
              <textarea id="final-reply" class="textarea textarea-bordered" rows="15" placeholder="Draft the citizen-facing final response here."></textarea>
              <small><span id="reply-character-count">0</span> characters</small>
            </label>
          </section>

          <section class="reply-form-section">
            <header class="editor-section-heading">
              <div>
                <span class="editor-step-number">3</span>
                <h3>Disposal and workflow</h3>
                <p>Choose the operational state. Only approved or issued text may be included in the AI archive.</p>
              </div>
            </header>
            <div class="reply-workflow-grid">
              <label class="crm-field" for="disposal-outcome">
                <span>Disposal outcome</span>
                <input id="disposal-outcome" class="input input-bordered" maxlength="10000" placeholder="Addressed, disposed, action initiated, clarification provided…" />
              </label>
              <label class="crm-field" for="reply-status">
                <span>Reply status</span>
                <select id="reply-status" class="select select-bordered">
                  <option>Not Prepared</option>
                  <option>Draft</option>
                  <option>Pending Approval</option>
                  <option>Approved</option>
                  <option>Issued</option>
                  <option>Rejected</option>
                </select>
              </label>
              <CheckboxField
                id="ai-eligible"
                label="Include latest approved version in AI archive"
                description="Draft, pending and rejected replies never enter the archive."
                class="editor-ai-setting"
                wide
              />
            </div>
            <div id="reply-rule-note" class="editor-rule-note">Draft and pending replies never enter the AI archive.</div>
          </section>
        </form>

        <footer class="editor-action-bar">
          <div class="editor-save-state">
            <strong id="save-indicator">No unsaved changes</strong>
            <small id="last-pull">Last verified pull: —</small>
          </div>
          <div class="editor-actions">
            <details class="crm-action-menu editor-more-actions">
              <summary class="btn" aria-label="More reply actions">More actions ▾</summary>
              <div class="crm-action-popover">
                <button id="save-current" type="button">Save Selected Status</button>
                <button id="create-revision" type="button">Create revised draft</button>
              </div>
            </details>
            <button id="save-draft" class="btn" type="button">Save Draft</button>
            <button id="submit-approval" class="btn btn-primary" type="button">Submit for Approval</button>
            <button id="reject-reply" class="btn" type="button">Reject Reply</button>
            <button id="approve-reply" class="btn btn-primary" type="button">Approve Reply</button>
            <button id="issue-reply" class="btn btn-primary" type="button">Mark as Issued</button>
          </div>
        </footer>
      </section>
    </section>

    <div id="editor-toast" class="crm-toast" role="status" aria-live="polite" hidden></div>
  </main>

  <ModalDialog
    id="full-complaint-dialog"
    formId="full-complaint-form"
    title="Complete complaint"
    eyebrow="Original context"
    description="Read the complete complaint while keeping your reply draft open behind this dialog."
    size="xl"
  >
    <div id="full-complaint-meta" class="crm-chip-row"></div>
    <article id="full-complaint-text" class="editor-reading-surface">Loading complaint…</article>
    <Fragment slot="footer">
      <button class="btn" type="button" data-dialog-close>Close</button>
      <a id="full-complaint-case-link" class="btn btn-primary" href="#">Open complete case</a>
    </Fragment>
  </ModalDialog>

  <ModalDialog
    id="revision-dialog"
    formId="revision-dialog-form"
    title="Archived approved reply"
    eyebrow="Immutable revision"
    description="This version is a preserved PostgreSQL snapshot of verified approved or issued text."
    size="lg"
  >
    <div id="revision-dialog-meta" class="crm-chip-row"></div>
    <article id="revision-dialog-text" class="editor-reading-surface">Choose a revision to read.</article>
    <Fragment slot="footer">
      <button class="btn" type="button" data-dialog-close>Close</button>
      <button id="copy-revision" class="btn btn-primary" type="button">Copy archived reply</button>
    </Fragment>
  </ModalDialog>

  <ModalDialog
    id="reply-conflict-dialog"
    formId="reply-conflict-form"
    title="Reply version comparison"
    eyebrow="Synchronization conflict"
    description="The local imported draft and the current Helpdesk reply differ. Nothing is replaced until you choose and save a version."
    size="xl"
  >
    <div class="reply-comparison-grid">
      <article><span>Local workspace draft</span><pre id="local-conflict-reply" class="editor-reading-surface"></pre></article>
      <article><span>Current Helpdesk reply</span><pre id="remote-conflict-reply" class="editor-reading-surface"></pre></article>
    </div>
    <Fragment slot="footer">
      <button class="btn" type="button" data-dialog-close>Keep local draft</button>
      <button id="use-helpdesk-reply" class="btn btn-primary" type="button">Use Helpdesk text in editor</button>
    </Fragment>
  </ModalDialog>

  <script>
    import { confirmAction } from "../../../scripts/alerts";
    import { closeDialog, openDialog, wireDialogs } from "../../../scripts/dialogs";
    import { badge, stack } from "../../../scripts/table-cells";

    type Category = {
      id: string;
      name: string;
      active: boolean;
      default_ai_eligible?: boolean;
      reply_guidance?: string;
      policy_notes?: string;
      merged_into_id?: string | null;
      subcategories: Array<{
        id: string;
        name: string;
        active: boolean;
        reply_guidance?: string;
        policy_notes?: string;
        merged_into_id?: string | null;
      }>;
    };
    type EditorPayload = {
      case: Record<string, any>;
      reply: Record<string, any>;
      approved_archive?: Record<string, any>;
      revisions: Array<Record<string, any>>;
      documents: Array<Record<string, any>>;
      reply_statuses?: string[];
      live_helpdesk: boolean;
      live_helpdesk_error?: string;
    };

    const root = document.getElementById("reply-editor") as HTMLElement;
    const API = root.dataset.apiBase || "";
    const caseId = root.dataset.caseId || "";
    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
    const evidenceTable = $("editor-evidence-table") as any;
    const revisionsTable = $("editor-revisions-table") as any;
    const activityTable = $("editor-activity-table") as any;
    const formIds = ["inquiry-findings", "school-version", "applicable-policy", "final-reply", "disposal-outcome", "reply-status", "ai-eligible"];
    let categories: Category[] = [];
    let data: EditorPayload | null = null;
    let dirty = false;
    let saving = false;
    let auditLoaded = false;
    let selectedRevisionText = "";

    const statusTone = (value: unknown) => {
      const normalized = String(value || "").toLowerCase().replaceAll("_", " ");
      if (["approved", "issued", "synchronized", "live helpdesk", "succeeded"].includes(normalized)) return "success";
      if (["imported draft", "draft", "pending approval", "pending", "not synced", "not prepared", "created", "local workspace draft"].includes(normalized)) return "warning";
      if (["rejected", "failed", "offline", "error", "conflict"].includes(normalized)) return "danger";
      return "neutral";
    };

    function setStatus(id: string, label: unknown, tone = statusTone(label)) {
      const node = $(id);
      node.textContent = String(label || "—");
      node.className = `crm-status-badge ${tone}`;
    }

    function formatDate(value: unknown) {
      if (!value) return "—";
      const date = new Date(String(value));
      return Number.isNaN(date.getTime()) ? String(value) : date.toLocaleString();
    }

    function textNode(value: unknown, className = "") {
      const node = document.createElement("span");
      if (className) node.className = className;
      node.textContent = String(value ?? "");
      return node;
    }

    function button(label: string, onClick: () => void, className = "table-inline-link") {
      const node = document.createElement("button");
      node.type = "button";
      node.className = className;
      node.textContent = label;
      node.addEventListener("click", onClick);
      return node;
    }

    function externalLink(label: string, href: string) {
      const node = document.createElement("a");
      node.className = "btn btn-sm";
      node.href = href;
      node.target = "_blank";
      node.rel = "noreferrer";
      node.textContent = `${label} ↗`;
      return node;
    }

    async function api(path: string, init?: RequestInit) {
      const headers = new Headers(init?.headers || {});
      if (init?.body && !(init.body instanceof FormData)) headers.set("Content-Type", "application/json");
      const response = await fetch(`${API}${path}`, { ...init, headers });
      const body = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(typeof body.detail === "string" ? body.detail : body.detail?.message || response.statusText);
      return body;
    }

    function toast(message: string, error = false) {
      const node = $("editor-toast");
      node.textContent = message;
      node.className = `crm-toast${error ? " error" : ""}`;
      node.hidden = false;
      window.setTimeout(() => node.hidden = true, 4600);
    }

    function chip(label: unknown) {
      const node = document.createElement("span");
      node.textContent = String(label || "—");
      return node;
    }

    function setChips(target: HTMLElement, labels: unknown[]) {
      target.replaceChildren(...labels.filter((value) => value !== null && value !== undefined && value !== "").map(chip));
    }

    function activeCategories() {
      return categories.filter((item) => item.active && !item.merged_into_id);
    }

    function selectedCategory() {
      const id = ($("editor-category") as HTMLSelectElement).value;
      return categories.find((item) => item.id === id);
    }

    function selectedSubcategory() {
      const category = selectedCategory();
      const id = ($("editor-subcategory") as HTMLSelectElement).value;
      return category?.subcategories.find((item) => item.id === id);
    }

    function updateSubcategories(preferred = "") {
      const select = $("editor-subcategory") as HTMLSelectElement;
      const items = (selectedCategory()?.subcategories || []).filter((item) => item.active && !item.merged_into_id);
      select.replaceChildren(new Option("No subcategory", ""), ...items.map((item) => new Option(item.name, item.id)));
      if (preferred && items.some((item) => item.id === preferred)) select.value = preferred;
      renderGuidance();
    }

    function guidanceCard(label: string, value: unknown) {
      const article = document.createElement("article");
      const title = document.createElement("strong");
      const copy = document.createElement("span");
      title.textContent = label;
      copy.textContent = String(value || `No ${label.toLowerCase()} saved.`);
      article.append(title, copy);
      return article;
    }

    function renderGuidance() {
      const category = selectedCategory();
      const subcategory = selectedSubcategory();
      $("classification-guidance").replaceChildren(
        guidanceCard("Reply guidance", subcategory?.reply_guidance || category?.reply_guidance),
        guidanceCard("Policy notes", subcategory?.policy_notes || category?.policy_notes),
      );
    }

    function setField(id: string, value: unknown) {
      const node = $(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;
      if (node instanceof HTMLInputElement && node.type === "checkbox") node.checked = Boolean(value);
      else node.value = String(value ?? "");
    }

    function markDirty() {
      dirty = true;
      $("save-indicator").textContent = "Unsaved changes";
    }

    function enforceRules() {
      const status = ($("reply-status") as HTMLSelectElement).value;
      const approved = ["Approved", "Issued"].includes(status);
      const ai = $("ai-eligible") as HTMLInputElement;
      ai.disabled=!approved;if(!approved)ai.checked=false;
      $("reply-rule-note").textContent = approved
        ? "This verified reply can be included in the AI archive."
        : "Draft, pending and rejected replies never enter the AI archive.";
      renderWorkflowActions(status);
    }

    function renderWorkflowActions(status: string) {
      const visible: Record<string, boolean> = {
        "save-draft": ["Not Prepared", "Draft", "Rejected"].includes(status),
        "submit-approval": ["Not Prepared", "Draft", "Rejected"].includes(status),
        "reject-reply": status === "Pending Approval",
        "approve-reply": status === "Pending Approval",
        "issue-reply": status === "Approved",
        "create-revision": ["Approved", "Issued"].includes(status),
      };
      for (const [id, show] of Object.entries(visible)) $(id).hidden = !show;
      $("save-current").hidden = false;
    }

    function replyPayload(statusOverride?: string) {
      const status = statusOverride || ($("reply-status") as HTMLSelectElement).value;
      return {
        inquiry_findings: ($("inquiry-findings") as HTMLTextAreaElement).value,
        school_version: ($("school-version") as HTMLTextAreaElement).value,
        applicable_policy: ($("applicable-policy") as HTMLTextAreaElement).value,
        final_reply: ($("final-reply") as HTMLTextAreaElement).value,
        reply_status: status,
        disposal_outcome: ($("disposal-outcome") as HTMLInputElement).value,
        ai_eligible: ["Approved", "Issued"].includes(status) && ($("ai-eligible") as HTMLInputElement).checked,
      };
    }

    function renderHero() {
      if (!data) return;
      const complaint = data.case;
      const reply = data.reply;
      $("editor-title").textContent = `Complaint ${complaint.complaint_number || complaint.id}`;
      $("editor-subtitle").textContent = `${complaint.category || "Unclassified"}${complaint.subcategory ? ` · ${complaint.subcategory}` : ""} · ${complaint.source_system || "Unknown source"}`;
      setStatus("editor-reply-status", reply.display_status || reply.reply_status || "Not Prepared");
      setStatus("classification-state", complaint.classification_sync_status || "Not synced");
      setStatus("live-source", reply.source_label || (data.live_helpdesk ? "Live Helpdesk" : "CRM snapshot"), statusTone(reply.sync_status || reply.source_label));

      const links = $("editor-links");
      links.replaceChildren();
      if (complaint.helpdesk_ticket_url) links.append(externalLink(`Helpdesk #${complaint.helpdesk_ticket_id || "ticket"}`, complaint.helpdesk_ticket_url));
      if (complaint.paperless_url) links.append(externalLink("Paperless", complaint.paperless_url));
      const archive = document.createElement("a");
      archive.className = "btn btn-sm";
      archive.href = `/crm/knowledge/?search=${encodeURIComponent(complaint.complaint_number || "")}`;
      archive.textContent = "Archive record";
      links.append(archive);
      if ((data.revisions || []).length) {
        const letter = document.createElement("a");
        letter.className = "btn btn-primary btn-sm";
        letter.href = `/crm/replies/${complaint.id}/official-letter/`;
        letter.textContent = "Create Official Letter";
        links.append(letter);
      }

      const warning = $("editor-warning");
      const warnings: string[] = [];
      if (reply.conflict) warnings.push("The imported/local draft differs from the current Helpdesk reply. The local draft is shown; compare both versions before saving.");
      if (reply.sync_status === "failed") warnings.push(`The local draft is safe, but Helpdesk synchronization failed${reply.sync_error ? `: ${reply.sync_error}` : "."}`);
      if (data.live_helpdesk_error) warnings.push(`Helpdesk could not be read: ${data.live_helpdesk_error}. The local workspace or last PostgreSQL snapshot is shown.`);
      warning.hidden = warnings.length === 0;
      warning.textContent = warnings.join(" ");
    }

    function renderComplaint() {
      if (!data) return;
      const complaint = data.case;
      setChips($("complaint-meta"), [
        complaint.state,
        complaint.source_system,
        `Created ${formatDate(complaint.created_at)}`,
        `Updated ${formatDate(complaint.updated_at)}`,
        complaint.paperless_document_id ? `Paperless #${complaint.paperless_document_id}` : null,
      ]);
      setChips($("full-complaint-meta"), [
        complaint.complaint_number,
        complaint.state,
        complaint.source_system,
        complaint.category || "Unclassified",
        complaint.subcategory || null,
      ]);
      const complaintText = String(complaint.complaint_text || "No complaint text is stored.");
      $("complaint-excerpt").textContent = complaintText;
      $("full-complaint-text").textContent = complaintText;
      const caseUrl = `/crm/cases/${complaint.id}/`;
      $("full-complaint-case-link").setAttribute("href", caseUrl);
    }

    function renderClassification() {
      if (!data) return;
      const complaint = data.case;
      const select = $("editor-category") as HTMLSelectElement;
      select.replaceChildren(new Option("Choose category", ""), ...activeCategories().map((item) => new Option(item.name, item.id)));
      select.value = complaint.category_id || "";
      updateSubcategories(complaint.subcategory_id || "");
    }

    function configureTables() {
      void evidenceTable.configure({
        columns: [
          { header: "Document", accessorKey: "filename", cell: (context: any) => stack(context.row.original.filename || context.row.original.id, context.row.original.role || "Evidence") },
          { header: "Review", accessorKey: "review_state", cell: (context: any) => badge(context.getValue() || "Unreviewed", statusTone(context.getValue()) === "success" ? "" : "inactive"), meta: { width: "110px" } },
          { header: "Paperless", accessorKey: "paperless_document_id", cell: (context: any) => textNode(context.getValue() ? `#${context.getValue()}` : "—"), meta: { width: "100px" } },
        ],
        data: [],
      });

      void revisionsTable.configure({
        columns: [
          { header: "Version", accessorKey: "version", cell: (context: any) => stack(`Version ${context.getValue() || "—"}`, formatDate(context.row.original.captured_at)), meta: { minWidth: "150px" } },
          { header: "Status", accessorKey: "approval_status", cell: (context: any) => badge(context.getValue() || "Approved", statusTone(context.getValue()) === "success" ? "" : "warning"), meta: { width: "110px" } },
          { header: "Reply", id: "read", cell: (context: any) => button("Read", () => openRevision(context.row.original)), meta: { width: "70px", align: "right" } },
        ],
        data: [],
      });

      void activityTable.configure({
        columns: [
          { header: "Event", accessorKey: "event_type", cell: (context: any) => stack(String(context.getValue() || "Activity").replaceAll("_", " "), context.row.original.actor || "System"), meta: { minWidth: "160px" } },
          { header: "State", accessorKey: "state", cell: (context: any) => badge(context.getValue() || "—", statusTone(context.getValue()) === "success" ? "" : statusTone(context.getValue()) === "danger" ? "error" : "inactive"), meta: { width: "95px" } },
          { header: "When", accessorKey: "created_at", cell: (context: any) => textNode(formatDate(context.getValue())), meta: { minWidth: "145px" } },
          { header: "Error", accessorKey: "error", cell: (context: any) => textNode(context.getValue() || "—", context.getValue() ? "table-error-copy" : ""), meta: { minWidth: "150px" } },
        ],
        data: [],
      });
    }

    function openRevision(revision: Record<string, any>) {
      selectedRevisionText = String(revision.reply_text || "");
      setChips($("revision-dialog-meta"), [
        `Version ${revision.version || "—"}`,
        revision.approval_status || "Approved",
        formatDate(revision.captured_at),
      ]);
      $("revision-dialog-text").textContent = selectedRevisionText || "This revision contains no text.";
      openDialog("revision-dialog");
    }

    async function renderTables() {
      if (!data) return;
      $("document-count").textContent = String(data.documents?.length || 0);
      $("revision-count").textContent = String(data.revisions?.length || 0);
      await evidenceTable.setData(data.documents || []);
      await revisionsTable.setData(data.revisions || []);
    }

    function renderReply() {
      if (!data) return;
      const reply = data.reply;
      setField("inquiry-findings", reply.inquiry_findings);
      setField("school-version", reply.school_version);
      setField("applicable-policy", reply.applicable_policy);
      setField("final-reply", reply.final_reply);
      setField("disposal-outcome", reply.disposal_outcome);
      setField("reply-status", reply.reply_status || "Not Prepared");
      setField("ai-eligible", reply.ai_eligible);
      $("reply-character-count").textContent = String(String(reply.final_reply || "").length);
      $("last-pull").textContent = reply.last_synced_at
        ? `Last Helpdesk sync: ${formatDate(reply.last_synced_at)}`
        : `Last verified pull: ${formatDate(reply.last_pulled_at || data.case.updated_at)}`;
      const sourcePanel = $("reply-source-panel");
      sourcePanel.hidden = !reply.final_reply && !reply.source_filename && !reply.source_batch;
      $("reply-source-title").textContent = reply.source_label || "Reply workspace";
      const details = [
        reply.source_filename ? `File: ${reply.source_filename}` : null,
        reply.source_row ? `row ${reply.source_row}` : null,
        reply.workspace_version ? `version ${reply.workspace_version}` : null,
        reply.sync_status ? `sync: ${String(reply.sync_status).replaceAll("_", " ")}` : null,
      ].filter(Boolean);
      $("reply-source-detail").textContent = details.join(" · ") || "Current operational reply";
      const batchLink = $("reply-source-batch") as HTMLAnchorElement;
      batchLink.hidden = !reply.source_batch?.url;
      if (reply.source_batch?.url) {
        batchLink.href = reply.source_batch.url;
        batchLink.textContent = `Open ${reply.source_batch.batch_number}`;
      }
      $("compare-replies").hidden = !reply.conflict;
      $("local-conflict-reply").textContent = reply.local_final_reply || "No local draft text.";
      $("remote-conflict-reply").textContent = reply.remote_final_reply || "No Helpdesk reply text.";
      enforceRules();
      dirty = false;
      $("save-indicator").textContent = reply.sync_status === "failed" ? "Local draft saved — Helpdesk sync failed" : "No unsaved changes";
      setSaveDisabled(false);
    }

    function setSaveDisabled(disabled: boolean) {
      const remoteRequired = ["submit-approval", "reject-reply", "approve-reply", "issue-reply"];
      document.querySelectorAll<HTMLButtonElement>("#save-current,#save-draft,#submit-approval,#reject-reply,#approve-reply,#issue-reply,#create-revision").forEach((node) => {
        if (disabled) node.disabled = true;
        else if (remoteRequired.includes(node.id)) node.disabled = !Boolean(data?.live_helpdesk);
        else node.disabled = false;
      });
    }

    async function load() {
      try {
        const [taxonomy, editor] = await Promise.all([
          api("/api/v1/crm/taxonomy?include_inactive=false"),
          api(`/api/v1/crm/reply-workspace/cases/${caseId}`),
        ]);
        categories = taxonomy.categories || [];
        data = editor;
        renderHero();
        renderComplaint();
        renderClassification();
        renderReply();
        await renderTables();
      } catch (error) {
        const message = error instanceof Error ? error.message : String(error);
        $("editor-warning").hidden = false;
        $("editor-warning").textContent = message;
        toast(message || "Unable to load reply editor", true);
      }
    }

    async function loadAudit() {
      if (auditLoaded) return;
      auditLoaded = true;
      try {
        const result = await api(`/api/v1/crm/reply-workspace/audit?case_id=${caseId}&limit=100`);
        await activityTable.setData(result.items || []);
      } catch (error) {
        activityTable.showError(error instanceof Error ? error.message : String(error));
      }
    }

    async function saveClassification() {
      const categoryId = ($("editor-category") as HTMLSelectElement).value;
      if (!categoryId) {
        toast("Choose a category before saving classification.", true);
        ($("editor-category") as HTMLSelectElement).focus();
        return;
      }
      const node = $("save-classification") as HTMLButtonElement;
      node.disabled = true;
      node.textContent = "Saving and verifying…";
      try {
        const result = await api(`/api/v1/crm/reply-workspace/cases/${caseId}/classification`, {
          method: "PUT",
          body: JSON.stringify({
            category_id: categoryId,
            subcategory_id: ($("editor-subcategory") as HTMLSelectElement).value || null,
            synchronize: true,
          }),
        });
        if (result.status === "failed") throw new Error(result.error || "Classification synchronization failed");
        toast(result.synchronized ? "Classification saved and verified in Helpdesk." : "Classification saved in PostgreSQL; this complaint has no linked Helpdesk ticket.");
        await load();
      } catch (error) {
        toast(error instanceof Error ? error.message : String(error), true);
      } finally {
        node.disabled = false;
        node.textContent = "Save and sync classification";
      }
    }

    async function saveReply(status: string) {
      if (saving) return;
      const payload = replyPayload(status);
      if (["Pending Approval", "Approved", "Issued"].includes(status) && !payload.final_reply.trim()) {
        toast("Enter the final reply before using this status.", true);
        ($("final-reply") as HTMLTextAreaElement).focus();
        return;
      }
      if (["Approved", "Issued"].includes(status)) {
        const confirmed = await confirmAction(
          `${status} this reply?`,
          `The verified text will create an immutable approved revision in PostgreSQL.`,
          status === "Issued" ? "Mark as Issued" : "Approve Reply",
        );
        if (!confirmed) return;
      }
      saving = true;
      setSaveDisabled(true);
      $("save-indicator").textContent = "Writing to Helpdesk and verifying read-back…";
      try {
        const result = await api(`/api/v1/crm/reply-workspace/cases/${caseId}/reply`, {
          method: "PUT",
          body: JSON.stringify(payload),
        });
        toast(result.write_verified
          ? `${status} reply saved and verified.${result.archive?.imported ? " Approved revision archived." : ""}`
          : `${status} saved locally. Helpdesk synchronization is not available for this complaint.`);
        await load();
      } catch (error) {
        dirty = false;
        $("save-indicator").textContent = "Local draft preserved — Helpdesk sync failed";
        toast(`${error instanceof Error ? error.message : String(error)} The local draft was preserved.`, true);
        await load();
      } finally {
        saving = false;
        setSaveDisabled(false);
      }
    }

    function switchContext(name: string) {
      document.querySelectorAll<HTMLButtonElement>("[data-context-tab]").forEach((node) => {
        const active = node.dataset.contextTab === name;
        node.classList.toggle("active", active);
        node.setAttribute("aria-selected", String(active));
      });
      document.querySelectorAll<HTMLElement>("[data-context-panel]").forEach((node) => {
        const active = node.dataset.contextPanel === name;
        node.hidden = !active;
        node.classList.toggle("active", active);
      });
      if (name === "activity") void loadAudit();
    }

    configureTables();
    wireDialogs();

    formIds.forEach((id) => $(id).addEventListener("input", () => {
      markDirty();
      if (id === "final-reply") $("reply-character-count").textContent = String(($("final-reply") as HTMLTextAreaElement).value.length);
      if (id === "reply-status") enforceRules();
    }));
    $("editor-category").addEventListener("change", () => {
      updateSubcategories();
      const category = selectedCategory();
      const status = ($("reply-status") as HTMLSelectElement).value;
      if (category && ["Approved", "Issued"].includes(status)) ($("ai-eligible") as HTMLInputElement).checked = Boolean(category.default_ai_eligible);
      markDirty();
    });
    $("editor-subcategory").addEventListener("change", () => { renderGuidance(); markDirty(); });
    $("save-classification").addEventListener("click", () => void saveClassification());
    $("save-current").addEventListener("click", () => void saveReply(($("reply-status") as HTMLSelectElement).value));
    $("save-draft").addEventListener("click", () => void saveReply("Draft"));
    $("submit-approval").addEventListener("click", () => void saveReply("Pending Approval"));
    $("reject-reply").addEventListener("click", () => void saveReply("Rejected"));
    $("approve-reply").addEventListener("click", () => void saveReply("Approved"));
    $("issue-reply").addEventListener("click", () => void saveReply("Issued"));
    $("create-revision").addEventListener("click", () => {
      ($("reply-status") as HTMLSelectElement).value = "Draft";
      ($("ai-eligible") as HTMLInputElement).checked = false;
      enforceRules();
      markDirty();
      toast("A revised draft is ready. Edit the reply and save when complete.");
      ($("final-reply") as HTMLTextAreaElement).focus();
    });
    $("copy-reply").addEventListener("click", async () => {
      const text = ($("final-reply") as HTMLTextAreaElement).value;
      if (!text) { toast("There is no reply text to copy.", true); return; }
      try { await navigator.clipboard.writeText(text); toast("Reply copied."); }
      catch { ($("final-reply") as HTMLTextAreaElement).select(); document.execCommand("copy"); toast("Reply copied."); }
    });
    $("copy-revision").addEventListener("click", async () => {
      if (!selectedRevisionText) { toast("This archived revision has no text.", true); return; }
      try { await navigator.clipboard.writeText(selectedRevisionText); toast("Archived reply copied."); closeDialog("revision-dialog"); }
      catch { toast("The browser could not copy this revision.", true); }
    });
    $("compare-replies").addEventListener("click", () => openDialog("reply-conflict-dialog"));
    $("use-helpdesk-reply").addEventListener("click", () => {
      if (!data) return;
      ($("final-reply") as HTMLTextAreaElement).value = String(data.reply.remote_final_reply || "");
      $("reply-character-count").textContent = String(($("final-reply") as HTMLTextAreaElement).value.length);
      markDirty();
      closeDialog("reply-conflict-dialog");
      toast("Helpdesk text loaded into the editor. Save to confirm this choice.");
    });
    $("read-full-complaint").addEventListener("click", () => openDialog("full-complaint-dialog"));
    document.querySelectorAll<HTMLButtonElement>("[data-context-tab]").forEach((node) => node.addEventListener("click", () => switchContext(node.dataset.contextTab || "complaint")));
    window.addEventListener("beforeunload", (event) => {
      if (dirty && !saving) { event.preventDefault(); event.returnValue = ""; }
    });

    void load();
  </script>
</CrmLayout>
