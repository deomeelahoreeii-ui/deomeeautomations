---
import CrmLayout from "../../../../../layouts/CrmLayout.astro";
import DataTable from "../../../../../components/DataTable.astro";
import ModalDialog from "../../../../../components/ui/ModalDialog.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Bulk Reply Records" description="Review reply-eligible complaints, actionable work, imported replies and generated letters in focused tables." page="replies">
  <a class="btn btn-sm" href="/crm/replies/bulk/" slot="actions">← Bulk Operations</a>
  <main id="bulk-records-page" data-api-base={apiBase} class="crm32-page bulk-records-page">
    <nav class="reply-mode-tabs" aria-label="Reply workspace modes"><a href="/crm/replies/">Reply Queue</a><a class="active" href="/crm/replies/bulk/">Bulk Operations</a><a href="/crm/replies/official-letters/">Official Letters</a><a href="/crm/dispatch/">Dispatch</a></nav>
    <section class="master-card bulk-records-header">
      <header class="crm-card-heading"><div><p class="eyebrow">Complaint records</p><h2 id="records-title">Reply-eligible complaints</h2><p id="records-description">Complaint-level status across the bulk reply workflow.</p></div><button id="refresh-records" class="btn btn-sm" type="button">↻ Refresh</button></header>
      <div class="bulk-record-view-tabs"><a data-view="eligible" href="?view=eligible">Reply eligible</a><a data-view="actionable" href="?view=actionable">Actionable</a><a data-view="awaiting" href="?view=awaiting">Awaiting reply</a><a data-view="imported" href="?view=imported">Imported replies</a><a data-view="generated" href="?view=generated">Letters generated</a></div>
      <label class="crm-field reply-search-filter"><span>Search</span><input id="record-search" class="input input-bordered" placeholder="Complaint number, complaint text or reply…" /></label>
    </section>
    <section class="master-card bulk-records-table-card"><DataTable id="bulk-records-table" pageSize={25} pageSizeOptions={[25,50,100]} emptyText="No complaint records match this view." ariaLabel="Bulk reply complaint records" class="bulk-records-table" /></section>
  </main>
  <ModalDialog id="record-preview-dialog" title="Complaint and reply" eyebrow="Record preview" description="Review the complete complaint and current imported reply." size="xl">
    <div id="record-preview-loading" class="crm-empty-state compact">Loading record…</div>
    <div id="record-preview-content" class="record-preview-content" hidden><section><h3>Complaint</h3><article id="record-complaint-text" class="complaint-preview-text"></article></section><section><h3>Current reply</h3><article id="record-reply-text" class="complaint-preview-text"></article></section></div>
    <Fragment slot="footer"><button class="btn" type="button" data-dialog-close>Close</button><a id="record-open-case" class="btn" href="#">Open case</a><a id="record-open-editor" class="btn btn-primary" href="#">Open reply editor</a></Fragment>
  </ModalDialog>
  <script>
    import { badge, stack } from "../../../../../scripts/table-cells"; import { openDialog, wireDialogs } from "../../../../../scripts/dialogs";
    type Row={case_id:string;complaint_number:string;complaint_remarks:string;paperless_document_id?:number|null;reply?:string|null;reply_status?:string;reply_actionable?:boolean;awaiting_reply?:boolean;reply_version?:number|null;source_filename?:string|null;imported_at?:string|null;generated_at?:string|null};
    const root=document.getElementById("bulk-records-page") as HTMLElement,API=root.dataset.apiBase||"",$=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T,table=$("bulk-records-table") as any,query=new URLSearchParams(location.search);let view=query.get("view")||"eligible";if(!["eligible","actionable","awaiting","imported","generated"].includes(view))view="eligible";const config:any={eligible:["Reply-eligible complaints","Accepted complaints in the reply lifecycle, including cases awaiting Paperless publication."],actionable:["Actionable replies","Complaints that still require drafting, approval, synchronization or revision."],awaiting:["Complaints awaiting reply","Accepted complaints for which no reply has been prepared."],imported:["Imported replies","Complaints with a current local reply and its source/version details."],generated:["Letters generated","Complaints included in at least one formal-letter package."]};$("records-title").textContent=config[view][0];$("records-description").textContent=config[view][1];document.querySelectorAll<HTMLAnchorElement>("[data-view]").forEach(a=>a.classList.toggle("active",a.dataset.view===view));const dt=(v?:string|null)=>v?new Date(v).toLocaleString():"—";
    async function api(path:string){const r=await fetch(`${API}${path}`),b=await r.json().catch(()=>({}));if(!r.ok)throw new Error(b.detail||r.statusText);return b}
    async function preview(row:Row){$("record-preview-loading").hidden=false;$("record-preview-content").hidden=true;$("record-open-case").setAttribute("href",`/crm/cases/${row.case_id}/`);$("record-open-editor").setAttribute("href",`/crm/replies/${row.case_id}/?return_to=${encodeURIComponent(location.pathname+location.search)}`);openDialog("record-preview-dialog");try{const d=await api(`/api/v1/crm/reply-workspace/cases/${row.case_id}`);$("record-complaint-text").textContent=d.case.complaint_text||row.complaint_remarks||"No complaint text is stored.";$("record-reply-text").textContent=d.reply.final_reply||row.reply||"No reply has been prepared.";$("record-preview-loading").hidden=true;$("record-preview-content").hidden=false}catch(e){$("record-preview-loading").textContent=e instanceof Error?e.message:String(e)}}
    async function configure(){await table.configure({columns:[
      {accessorKey:"complaint_number",header:"Complaint No.",meta:{minWidth:"145px"},cell:(c:any)=>{const r=c.row.original as Row,a=document.createElement("a");a.className="table-primary-link";a.href=`/crm/replies/${r.case_id}/?return_to=${encodeURIComponent(location.pathname+location.search)}`;a.textContent=r.complaint_number||r.case_id;return a}},
      {accessorKey:"complaint_remarks",header:"Complaint",meta:{minWidth:"300px",maxWidth:"540px"},cell:(c:any)=>{const r=c.row.original as Row,w=document.createElement("div");w.className="table-preview-cell";const s=document.createElement("span");s.textContent=r.complaint_remarks||"No complaint remarks";const b=document.createElement("button");b.className="btn btn-xs";b.type="button";b.textContent="View";b.addEventListener("click",()=>void preview(r));w.append(s,b);return w}},
      {id:"reply_status",header:"Reply status",meta:{minWidth:"145px"},cell:(c:any)=>{const r=c.row.original as Row,label=r.generated_at?"Letter generated":r.reply_status||"Not Prepared";return badge(label,r.awaiting_reply?"warning":r.reply_actionable?"info":"success")}},
      {id:"reply_source",header:"Reply source",meta:{minWidth:"180px"},cell:(c:any)=>{const r=c.row.original as Row;return stack(r.source_filename||"—",r.reply_version?`Version ${r.reply_version}`:"")}},
      {accessorKey:"imported_at",header:"Imported",meta:{minWidth:"160px"},cell:(c:any)=>dt(c.getValue())},
      {accessorKey:"generated_at",header:"Letter generated",meta:{minWidth:"160px"},cell:(c:any)=>dt(c.getValue())}
    ],manualPagination:true,getRowId:(r:Row)=>r.case_id,loadPage:async(i:number,s:number)=>{const p=new URLSearchParams({view,page:String(i+1),page_size:String(s)}),search=($("record-search") as HTMLInputElement).value.trim();if(search)p.set("search",search);history.replaceState(null,"",`${location.pathname}?${p}`);const d=await api(`/api/v1/crm/replies?${p}`);return{rows:d.items||[],total:d.total||0}}})}
    let timer:number|undefined;($("record-search") as HTMLInputElement).value=query.get("search")||"";$("record-search").addEventListener("input",()=>{clearTimeout(timer);timer=window.setTimeout(()=>void table.refresh(true),250)});$("refresh-records").addEventListener("click",()=>void table.refresh(false));wireDialogs();void configure();
  </script>
</CrmLayout>
