---
import CrmIntakeNav from "../../../components/CrmIntakeNav.astro";
import CrmLayout from "../../../layouts/CrmLayout.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="CRM Replies & Formal Letters" description="Export published complaint remarks, import reviewed replies, and generate native DEO Report packages." page="cases">
  <a class="btn btn-sm" href="/crm/knowledge/" slot="actions">AI Reply Archive</a>
  <a class="btn btn-sm" href="/crm/intake/review" slot="actions">← Review queue</a>
  <CrmIntakeNav active="packages" />

  <section class="crm-reply-hero" id="reply-root" data-api-base={apiBase}>
    <div><p class="eyebrow">Post-publication workflow</p><h2>Complaint replies and formal letters</h2><p>The complaint number is the durable key through every stage. Export published CRM Pending complaints, import the reviewed two-column reply CSV, then download one DEO Report ODT per complaint.</p></div>
    <div class="crm-reply-hero-badge"><strong>3 → 4 → 5</strong><span>Export · Import · Generate</span></div>
  </section>

  <section class="inbound-summary-grid crm-reply-summary">
    <article class="master-card"><span>Published complaints</span><strong id="reply-published">—</strong><small>Available from CRM Pending</small></article>
    <article class="master-card"><span>Awaiting reply</span><strong id="reply-awaiting">—</strong><small>Included in the default CSV</small></article>
    <article class="master-card"><span>Replies imported</span><strong id="reply-imported">—</strong><small>Durably stored here</small></article>
    <article class="master-card"><span>Letters generated</span><strong id="reply-generated">—</strong><small>Included in a downloaded package</small></article>
  </section>

  <section class="crm-reply-steps">
    <article class="master-card crm-reply-step"><span class="crm-step-number">3</span><div><p class="eyebrow">Prepare for ChatGPT</p><h2>Export complaint remarks</h2><p>Downloads exactly two UTF-8 columns: <b>Complaint Number</b> and <b>Complaint Remarks</b>.</p><div class="crm-step-actions"><a class="btn btn-primary" id="download-awaiting" href="#">Download complaints awaiting replies</a><a class="btn btn-sm" id="download-all" href="#">Download all published</a></div></div></article>
    <article class="master-card crm-reply-step"><span class="crm-step-number">4</span><div><p class="eyebrow">Bring reviewed replies back</p><h2>Import ChatGPT reply CSV</h2><p>The file must have exactly two columns: <b>Complaint Number</b> and <b>Reply</b>. Every complaint must already be published.</p><form id="reply-import-form"><input class="file-input file-input-bordered" id="reply-file" type="file" accept=".csv,text/csv" required/><button class="btn btn-primary" id="import-replies" type="submit">Validate and import replies</button></form><div id="reply-import-result" class="crm-reply-message" hidden></div></div></article>
    <article class="master-card crm-reply-step"><span class="crm-step-number">5</span><div><p class="eyebrow">Native formal documents</p><h2>Generate DEO Report package</h2><p>Creates a ZIP containing one complaint folder and formal ODT letter per imported reply, plus a traceable manifest.</p><div class="crm-step-actions"><button class="btn btn-primary" id="download-letters" type="button">Generate and download letters</button></div></div></article>
  </section>

  <section class="master-card crm-reply-register">
    <div class="inbound-card-heading"><div><p class="eyebrow">Reply register</p><h2>Published complaint coverage</h2><p>See which CRM Pending complaints still need a reply and which letters have been generated.</p></div><button class="btn btn-sm" id="refresh-replies">↻ Refresh</button></div>
    <div class="crm-reply-list" id="reply-list"><div class="crm-intake-empty"><h3>Loading reply register…</h3></div></div>
  </section>

  <style>
    .crm-reply-hero{display:flex;align-items:center;justify-content:space-between;gap:2rem;margin:1rem 0;border:1px solid #9bcdd4;border-left:5px solid #16879a;border-radius:.9rem;background:linear-gradient(120deg,#effafb,#fff);padding:1.25rem 1.4rem}.crm-reply-hero h2{margin:.15rem 0 .35rem}.crm-reply-hero p{max-width:62rem;margin:0;color:#64748b}.crm-reply-hero-badge{display:grid;min-width:10rem;text-align:center;padding:.8rem;border-radius:.7rem;background:#16879a;color:#fff}.crm-reply-hero-badge strong{font-size:1.4rem}.crm-reply-hero-badge span{font-size:.65rem}.crm-reply-summary{margin:1rem 0}.crm-reply-summary small{display:block;color:#718096}.crm-reply-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.crm-reply-step{display:flex;align-items:flex-start;gap:1rem;min-height:18rem}.crm-step-number{display:grid;place-items:center;flex:0 0 auto;width:2rem;height:2rem;border-radius:50%;background:#16879a;color:#fff;font-weight:850}.crm-reply-step h2{margin:.15rem 0 .45rem}.crm-reply-step p{color:#64748b;line-height:1.55}.crm-step-actions,#reply-import-form{display:flex;align-items:stretch;gap:.55rem;flex-wrap:wrap;margin-top:1rem}.crm-reply-message{margin-top:.8rem;border-radius:.6rem;background:#e9f8f2;color:#176b57;padding:.7rem}.crm-reply-message.error{background:#fff0f1;color:#a52630}.crm-reply-register{margin-top:1rem}.crm-reply-list{display:grid;gap:.55rem;margin-top:.8rem}.crm-reply-row{display:grid;grid-template-columns:minmax(10rem,.7fr) minmax(16rem,1.8fr) auto;gap:1rem;align-items:center;border:1px solid #e0e8ee;border-radius:.65rem;padding:.75rem .85rem}.crm-reply-row strong,.crm-reply-row small{display:block}.crm-reply-row small{color:#718096}.crm-reply-state{padding:.3rem .55rem;border-radius:1rem;background:#fff3dc;color:#925b05;font-size:.68rem;font-weight:750}.crm-reply-state.ready{background:#e7f8f1;color:#176b57}@media(max-width:1050px){.crm-reply-steps{grid-template-columns:1fr}.crm-reply-step{min-height:0}}@media(max-width:700px){.crm-reply-hero{align-items:flex-start;flex-direction:column}.crm-reply-row{grid-template-columns:1fr}}
  </style>

  <script>
    const root=document.getElementById("reply-root") as HTMLElement,API=root.dataset.apiBase||"";const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;const esc=(v:any)=>String(v??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;");const format=(v:any)=>v?new Date(v).toLocaleString():"—";
    el<HTMLAnchorElement>("download-awaiting").href=`${API}/api/v1/crm/replies/complaints.csv?scope=awaiting`;el<HTMLAnchorElement>("download-all").href=`${API}/api/v1/crm/replies/complaints.csv?scope=all`;
    async function json(path:string,init?:RequestInit){const response=await fetch(`${API}${path}`,init),body=await response.json().catch(()=>({}));if(!response.ok){const detail=body.detail;throw new Error(typeof detail==="string"?detail:detail?.message||detail?.errors?.join(" · ")||response.statusText)}return body}
    async function load(){const [stats,data]=await Promise.all([json("/api/v1/crm/replies/statistics"),json("/api/v1/crm/replies")]);el("reply-published").textContent=String(stats.published_cases);el("reply-awaiting").textContent=String(stats.awaiting_reply);el("reply-imported").textContent=String(stats.replies_imported);el("reply-generated").textContent=String(stats.letters_generated);const items=data.items||[];el("reply-list").innerHTML=items.length?items.map((x:any)=>`<article class="crm-reply-row"><div><strong>${esc(x.complaint_number)}</strong><small>Paperless #${esc(x.paperless_document_id||"—")}</small></div><div><strong>${x.reply?"Reply imported":"Awaiting reply"}</strong><small>${x.reply?`${esc(x.source_filename)} · version ${esc(x.reply_version)} · ${esc(format(x.imported_at))}`:"Export this complaint in the awaiting-replies CSV"}</small></div><span class="crm-reply-state ${x.reply?"ready":""}">${x.generated_at?"Letter generated":x.reply?"Ready for letter":"Needs reply"}</span></article>`).join(""):`<div class="crm-intake-empty"><h3>No published complaints yet</h3><p>Publish approved complaints to Paperless before drafting replies.</p></div>`}
    el<HTMLFormElement>("reply-import-form").addEventListener("submit",async event=>{event.preventDefault();const input=el<HTMLInputElement>("reply-file"),file=input.files?.[0],button=el<HTMLButtonElement>("import-replies"),message=el("reply-import-result");if(!file)return;button.disabled=true;button.textContent="Validating and importing…";message.hidden=true;const body=new FormData();body.append("file",file);try{const result=await json("/api/v1/crm/replies/imports",{method:"POST",body});message.className="crm-reply-message";message.textContent=`Imported ${result.imported}, updated ${result.updated}; ${result.letters_ready} formal letter(s) ready.`;message.hidden=false;input.value="";await load()}catch(error){message.className="crm-reply-message error";message.textContent=error instanceof Error?error.message:String(error);message.hidden=false}finally{button.disabled=false;button.textContent="Validate and import replies"}});el<HTMLButtonElement>("download-letters").addEventListener("click",async()=>{const button=el<HTMLButtonElement>("download-letters");button.disabled=true;button.textContent="Generating package…";try{const response=await fetch(`${API}/api/v1/crm/replies/letter-packages`,{method:"POST"});if(!response.ok){const body=await response.json().catch(()=>({}));throw new Error(typeof body.detail==="string"?body.detail:body.detail?.message||response.statusText)}const blob=await response.blob(),disposition=response.headers.get("content-disposition")||"",match=disposition.match(/filename="?([^";]+)"?/),link=document.createElement("a");link.href=URL.createObjectURL(blob);link.download=match?.[1]||"crm-deo-reply-letters.zip";link.click();URL.revokeObjectURL(link.href);await load()}catch(error){alert(error instanceof Error?error.message:String(error))}finally{button.disabled=false;button.textContent="Generate and download letters"}});el("refresh-replies").addEventListener("click",()=>void load());void load();
  </script>
</CrmLayout>
