---
import CrmLayout from "../../../../layouts/CrmLayout.astro";
import DataTable from "../../../../components/DataTable.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="Sent Compliances" description="Review higher-office compliance submissions grouped by the exact batch that was sent." page="dispatch">
  <a class="btn btn-sm" href="/crm/dispatch/" slot="actions">← Send Compliance</a>
  <main id="crm-sent-compliances" class="crm32-page crm-dispatch-page" data-api-base={apiBase}>
    <nav class="dispatch-tabs" aria-label="CRM dispatch pages"><a href="/crm/dispatch/">Dispatch Queue</a><a href="/crm/dispatch/batches/">Batches</a><a class="active" href="/crm/dispatch/sent/">Sent Compliances</a><a href="/crm/dispatch/routing/">Routing</a><a href="/crm/dispatch/deliveries/">Delivery History</a></nav>
    <section class="master-card dispatch-history-card">
      <header class="crm-card-heading"><div><p class="eyebrow">Higher-office register</p><h2>Sent compliance batches</h2><p>Each row is one immutable submission batch. Expand its packets to review complaints, destinations and delivery outcomes.</p></div><button id="refresh-submissions" class="btn btn-sm" type="button">↻ Refresh</button></header>
      <div class="dispatch-history-toolbar">
        <label class="crm-field"><span>Search</span><input id="submission-search" class="input input-bordered" placeholder="Batch, complaint or letter number…" /></label>
        <label class="crm-field"><span>Register view</span><select id="submission-phase" class="select select-bordered"><option value="sent">Sent / attempted</option><option value="in_progress">In progress</option><option value="attention">Needs attention</option><option value="all">All active submissions</option></select></label>
        <div class="crm-field"><span>Result</span><strong id="submission-count">Loading…</strong></div>
      </div>
      <DataTable id="sent-compliances-table" pageSize={25} pageSizeOptions={[10,25,50,100]} emptyText="No compliance submission batches match this view." ariaLabel="Sent compliance batches" />
    </section>
    <div id="submission-toast" class="crm-toast" role="status" hidden></div>
  </main>
  <script>
    const root=document.getElementById('crm-sent-compliances') as HTMLElement,API=root.dataset.apiBase||'',table=document.getElementById('sent-compliances-table') as any,$=(id:string)=>document.getElementById(id) as any;
    const dt=(value?:string|null)=>value?new Date(value).toLocaleString():'—';
    function toast(message:string){const node=$('submission-toast');node.textContent=message;node.className='crm-toast error';node.hidden=false}
    async function api(path:string){const response=await fetch(`${API}${path}`);const body=await response.json().catch(()=>({}));if(!response.ok)throw new Error(typeof body.detail==='string'?body.detail:response.statusText);return body}
    function stack(top:string,bottom:string){const node=document.createElement('div');node.className='table-stack';const strong=document.createElement('strong');strong.textContent=top;const small=document.createElement('small');small.textContent=bottom;node.append(strong,small);return node}
    function badge(value:string){const node=document.createElement('span');node.className=`crm-status-badge ${['completed','delivered','submitted'].includes(value)?'success':['failed','completed_with_errors','timed_out'].includes(value)?'danger':'warning'}`;node.textContent=(value||'unknown').replaceAll('_',' ');return node}
    function packets(row:any){const details=document.createElement('details');details.className='dispatch-batch-packets';const summary=document.createElement('summary');summary.textContent=`${row.packet_count} packet${row.packet_count===1?'':'s'}`;const list=document.createElement('div');list.className='dispatch-batch-packet-list';for(const packet of row.packets||[]){const item=document.createElement('div');item.className='configuration-row';const copy=stack(packet.complaint_number,`${packet.letter_number||'No letter'} · ${(packet.compliance_status||'unknown').replaceAll('_',' ')}`);const statuses=(packet.destinations||[]).map((target:any)=>`${target.profile_name}: ${target.status.replaceAll('_',' ')}`).join(' · ')||'No destination';copy.append(Object.assign(document.createElement('small'),{textContent:statuses}));item.append(copy);if(packet.packet_download_url){const link=document.createElement('a');link.className='btn btn-xs';link.href=`${API}${packet.packet_download_url}`;link.textContent='Packet PDF';item.append(link)}list.append(item)}details.append(summary,list);return details}
    async function loadPage(pageIndex:number,pageSize:number){const query=new URLSearchParams({page:String(pageIndex+1),page_size:String(pageSize),search:$('submission-search').value||'',phase:$('submission-phase').value});const result=await api(`/api/v1/crm/dispatch/submissions?${query}`);$('submission-count').textContent=`${result.total} batch${result.total===1?'':'es'}`;return{rows:result.items||[],total:Number(result.total||0)}}
    async function configure(){await table.configure({manualPagination:true,loadPage,columns:[{header:'Batch',accessorKey:'batch_number',cell:(cell:any)=>stack(cell.getValue(),`Created ${dt(cell.row.original.created_at)} · sent ${dt(cell.row.original.sent_at||cell.row.original.completed_at)}`)},{header:'Status',accessorKey:'status',cell:(cell:any)=>badge(cell.getValue())},{header:'Packets',id:'packets',cell:(cell:any)=>packets(cell.row.original),enableSorting:false},{header:'Delivery',id:'delivery',cell:(cell:any)=>{const row=cell.row.original,counts=row.target_counts||{};return stack(`${counts.delivered||0} delivered · ${counts.sent_pending_confirmation||0} pending`,`${counts.failed||0} failed · ${counts.timed_out||0} timed out`)}},{header:'Operator',accessorKey:'created_by',cell:(cell:any)=>stack(cell.getValue()||'—',cell.row.original.approved_by?`Approved by ${cell.row.original.approved_by}`:'Approval not recorded')},{header:'Actions',id:'actions',cell:(cell:any)=>{const link=document.createElement('a');link.className='btn btn-primary btn-sm';link.href=cell.row.original.detail_url;link.textContent=['failed','completed_with_errors'].includes(cell.row.original.status)?'Review / Retry':'Open batch';return link},meta:{align:'right',width:'130px'}}]})}
    $('refresh-submissions').addEventListener('click',()=>void table.reload());let timer=0;$('submission-search').addEventListener('input',()=>{clearTimeout(timer);timer=window.setTimeout(()=>void table.setPageIndex(0),250)});$('submission-phase').addEventListener('change',()=>void table.setPageIndex(0));configure().catch(error=>toast(error instanceof Error?error.message:String(error)));
  </script>
</CrmLayout>
