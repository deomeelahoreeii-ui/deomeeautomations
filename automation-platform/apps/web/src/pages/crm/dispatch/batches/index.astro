---
import CrmLayout from "../../../../layouts/CrmLayout.astro";
import DataTable from "../../../../components/DataTable.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="CRM Dispatch Batches" description="Review every compliance request and submission batch with route, approval and delivery progress." page="dispatch">
  <a class="btn btn-sm" href="/crm/dispatch/" slot="actions">← Dispatch Queue</a>
  <a class="btn btn-primary btn-sm" href="/crm/dispatch/routing/" slot="actions">Manage Routing</a>
  <main id="crm-dispatch-batches" class="crm32-page crm-dispatch-page" data-api-base={apiBase}>
    <nav class="dispatch-tabs" aria-label="CRM dispatch pages"><a href="/crm/dispatch/">Dispatch Queue</a><a class="active" href="/crm/dispatch/batches/">Batches</a><a href="/crm/dispatch/routing/">Routing</a><a href="/crm/dispatch/deliveries/">Delivery History</a></nav>
    <section class="master-card dispatch-history-card">
      <header class="crm-card-heading"><div><p class="eyebrow">Dispatch register</p><h2>Compliance dispatch batches</h2><p>Every downward request and upward submission remains traceable from routing through delivery.</p></div><button id="refresh-batches" class="btn btn-sm" type="button">↻ Refresh</button></header>
      <div class="dispatch-history-toolbar"><label class="crm-field"><span>Search</span><input id="batch-search" class="input input-bordered" placeholder="Batch number or purpose…" /></label><label class="crm-field"><span>Direction</span><select id="batch-direction" class="select select-bordered"><option value="">Both directions</option><option value="downward">Request compliance</option><option value="upward">Submit compliance</option></select></label><label class="crm-field"><span>Status</span><select id="batch-status" class="select select-bordered"><option value="">All statuses</option><option value="review_required">Needs routing/review</option><option value="ready">Awaiting approval</option><option value="sending">Sending</option><option value="completed">Completed</option><option value="completed_with_errors">Completed with errors</option><option value="failed">Failed</option></select></label></div>
      <DataTable id="dispatch-batches-table" pageSize={25} pageSizeOptions={[25,50,100]} emptyText="No dispatch batches match the filters." ariaLabel="CRM dispatch batches" />
    </section>
    <div id="batch-toast" class="crm-toast" role="status" hidden></div>
  </main>
  <script>
    const root=document.getElementById('crm-dispatch-batches') as HTMLElement;const API=root.dataset.apiBase||'';const table=document.getElementById('dispatch-batches-table') as any;const $=(id:string)=>document.getElementById(id) as any;
    function toast(message:string){const n=$('batch-toast');n.textContent=message;n.className='crm-toast error';n.hidden=false}
    async function api(path:string){const r=await fetch(`${API}${path}`);const b=await r.json().catch(()=>({}));if(!r.ok)throw new Error(typeof b.detail==='string'?b.detail:r.statusText);return b}
    const stack=(a:string,b:string)=>{const d=document.createElement('div');d.className='table-stack';const x=document.createElement('strong');x.textContent=a;const y=document.createElement('small');y.textContent=b;d.append(x,y);return d};
    const badge=(value:string)=>{const s=document.createElement('span');s.className=`crm-status-badge ${['completed'].includes(value)?'success':['failed','completed_with_errors'].includes(value)?'danger':'warning'}`;s.textContent=(value||'unknown').replaceAll('_',' ');return s};
    async function loadPage(pageIndex:number,pageSize:number){const q=new URLSearchParams({page:String(pageIndex+1),page_size:String(pageSize),search:$('batch-search').value||'',status:$('batch-status').value||'',direction:$('batch-direction').value||''});const r=await api(`/api/v1/crm/dispatch/batches?${q}`);return{rows:r.items||[],total:Number(r.total||0)}}
    async function configure(){await table.configure({manualPagination:true,loadPage,columns:[{header:'Batch',accessorKey:'batch_number',cell:(c:any)=>stack(c.getValue(),new Date(c.row.original.created_at).toLocaleString())},{header:'Workflow',id:'workflow',cell:(c:any)=>stack(c.row.original.direction==='downward'?'Request compliance':'Submit compliance',(c.row.original.purpose||'').replaceAll('_',' '))},{header:'Status',accessorKey:'status',cell:(c:any)=>badge(c.getValue())},{header:'Progress',id:'progress',cell:(c:any)=>stack(`${c.row.original.ready_items}/${c.row.original.total_items} ready`,`${c.row.original.queued_items} queued · ${c.row.original.successful_items} delivered · ${c.row.original.failed_items} failed`)},{header:'Actions',id:'actions',cell:(c:any)=>{const a=document.createElement('a');a.className='btn btn-primary btn-sm';a.href=c.row.original.detail_url;a.textContent='Review';return a},meta:{width:'100px',align:'right'}}]})}
    $('refresh-batches').addEventListener('click',()=>void table.reload());let timer=0;$('batch-search').addEventListener('input',()=>{clearTimeout(timer);timer=window.setTimeout(()=>void table.setPageIndex(0),250)});$('batch-status').addEventListener('change',()=>void table.setPageIndex(0));$('batch-direction').addEventListener('change',()=>void table.setPageIndex(0));configure().catch(e=>toast(e instanceof Error?e.message:String(e)));
  </script>
</CrmLayout>
