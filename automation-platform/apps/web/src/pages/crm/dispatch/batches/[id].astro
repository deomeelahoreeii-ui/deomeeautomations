---
import CrmLayout from "../../../../layouts/CrmLayout.astro";
const { id } = Astro.params;
if (!id) return Astro.redirect('/crm/dispatch/');
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="CRM Dispatch Batch" description="Review downward compliance requests and upward compliance submissions with exact routes, packets, approval and delivery history." page="dispatch">
  <a class="btn btn-sm" href="/crm/dispatch/" slot="actions">← Dispatch Queue</a>
  <a class="btn btn-sm" href="/crm/dispatch/routing/" slot="actions">Manage Routing</a>
  <main id="dispatch-batch" class="crm32-page dispatch-batch-page" data-api-base={apiBase} data-batch-id={id}>
    <nav class="dispatch-tabs" aria-label="CRM dispatch pages"><a href="/crm/dispatch/">Dispatch Queue</a><a class="active" href="/crm/dispatch/batches/">Batches</a><a href="/crm/dispatch/routing/">Routing</a><a href="/crm/dispatch/deliveries/">Delivery History</a></nav>
    <section class="master-card dispatch-batch-header"><header class="crm-card-heading"><div><p class="eyebrow" id="batch-direction-label">Traceable complaint dispatch</p><h2 id="batch-number">Loading batch…</h2><p id="batch-purpose"></p></div><span id="batch-status" class="crm-status-badge warning">Loading</span></header><div class="dispatch-batch-actions"><button id="resolve-routes" class="btn" type="button">Resolve Routes</button><button id="compile-previews" class="btn btn-primary" type="button">Freeze Exact Preview</button><button id="approve-previews" class="btn btn-primary" type="button" hidden>Approve and Queue</button><button id="refresh-batch" class="btn" type="button">↻ Reconcile status</button></div></section>
    <section class="crm-metric-grid dispatch-batch-metrics"><article class="crm-metric-card"><span>Complaints</span><strong id="metric-total">—</strong><small id="metric-ready">— ready</small></article><article class="crm-metric-card"><span>Needs decision</span><strong id="metric-blocked">—</strong><small>Unmatched, conflict or blocked</small></article><article class="crm-metric-card"><span>Excluded</span><strong id="metric-excluded">—</strong><small>Intentionally not sent</small></article><article class="crm-metric-card"><span>Delivered</span><strong id="metric-delivered">—</strong><small id="metric-failed">— failed</small></article></section>

    <section class="master-card dispatch-items-card"><header class="crm-card-heading"><div><p class="eyebrow">Route review</p><h2 id="route-review-title">Complaint packets and destination profiles</h2><p id="route-review-copy">Resolve only exceptions. Exact recipients and messages appear after the preview is frozen.</p></div></header><div id="dispatch-items" class="dispatch-item-list"><p class="crm-empty-state compact">Loading complaint packets…</p></div></section>

    <section id="preview-section" class="master-card dispatch-preview-card" hidden><header class="crm-card-heading"><div><p class="eyebrow">Immutable preview</p><h2>Exact recipients, messages and packet checksums</h2><p>Any profile, audience, template or frozen file change makes the preview stale and prevents approval.</p></div></header><div id="preview-list" class="dispatch-preview-list"></div></section>

    <section id="delivery-results" class="master-card dispatch-delivery-card"><header class="crm-card-heading"><div><p class="eyebrow">Delivery audit</p><h2>WhatsApp delivery results</h2><p>CRM status is derived from the existing WhatsApp approval, outbox, NATS and gateway acknowledgement records.</p></div></header><div id="delivery-list" class="dispatch-delivery-list"><p class="crm-empty-state compact">No approved deliveries yet.</p></div></section>

    <dialog id="route-dialog" class="crm-modal"><form method="dialog" class="crm-modal-shell"><header class="crm-modal-header"><div><p class="eyebrow">MANUAL ROUTING OVERRIDE</p><h2 id="route-title">Choose destination profiles</h2></div><button id="close-route" type="button">×</button></header><div class="crm-modal-body"><input id="route-item-id" type="hidden" /><div id="route-options" class="routing-profile-options"></div><label class="crm-field"><span>Reason for manual override</span><textarea id="route-reason" class="textarea textarea-bordered" rows="3" placeholder="Required for audit clarity when overriding automatic routing."></textarea></label><p id="route-message" class="form-message"></p></div><footer class="crm-modal-footer"><button id="cancel-route" class="btn" type="button">Cancel</button><button id="save-route" class="btn btn-primary" type="button">Apply Route</button></footer></form></dialog>
    <dialog id="approval-dialog" class="crm-modal"><form method="dialog" class="crm-modal-shell dispatch-approval-dialog"><header class="crm-modal-header"><div><p class="eyebrow">IRREVERSIBLE APPROVAL</p><h2>Approve exact WhatsApp deliveries</h2></div><button id="close-approval" type="button">×</button></header><div class="crm-modal-body"><p id="approval-summary"></p><label class="crm-check-row"><input id="ack-warnings" class="checkbox" type="checkbox" /><span><strong>Acknowledge preview warnings</strong><small>I reviewed all warning-level destinations and message details.</small></span></label><label class="crm-check-row"><input id="ack-exclusions" class="checkbox" type="checkbox" /><span><strong>Acknowledge exclusions</strong><small>Blocked and duplicate deliveries will remain unsent.</small></span></label><label class="crm-field"><span>Approved by</span><input id="approved-by" class="input input-bordered" value="web-operator" /></label><p id="approval-message" class="form-message"></p></div><footer class="crm-modal-footer"><button id="cancel-approval" class="btn" type="button">Cancel</button><button id="confirm-approval" class="btn btn-primary" type="button">Approve and Queue Real Messages</button></footer></form></dialog>
    <div id="batch-toast" class="crm-toast" role="status" hidden></div>
  </main>
  <script>
    const root=document.getElementById('dispatch-batch') as HTMLElement;const API=root.dataset.apiBase||'';const batchId=root.dataset.batchId||'';const $=(id:string)=>document.getElementById(id) as any;let data:any=null;
    function toast(m:string,e=false){const n=$('batch-toast');n.textContent=m;n.className=`crm-toast${e?' error':''}`;n.hidden=false;window.setTimeout(()=>n.hidden=true,6000)}
    async function api(path:string,init?:RequestInit){const h=new Headers(init?.headers||{});if(init?.body)h.set('Content-Type','application/json');const r=await fetch(`${API}${path}`,{...init,headers:h});const b=await r.json().catch(()=>({}));if(!r.ok)throw new Error(typeof b.detail==='string'?b.detail:b.detail?.message||r.statusText);return b}
    const badge=(v:string)=>{const s=document.createElement('span');s.className=`crm-status-badge ${['ready','delivered','completed','submitted','succeeded'].includes(v)?'success':['blocked','conflict','failed','timed_out','completed_with_errors'].includes(v)?'danger':'warning'}`;s.textContent=v.replaceAll('_',' ');return s};
    const paperlessSummary=(item:any)=>{const sync=item.paperless_sync||{};if(data.batch.direction!=='upward')return'';if(sync.state==='succeeded')return`Paperless #${sync.document_id} · ${sync.status_after||sync.intended_status} · synchronized`;if(sync.state==='failed'||sync.state==='blocked')return`Paperless #${sync.document_id||'—'} · sync ${sync.state}${sync.error?` · ${sync.error}`:''}`;if(item.compliance_status==='submitted')return`Paperless #${sync.document_id||'—'} · synchronization pending`;return`Paperless #${sync.document_id||'—'} · awaiting confirmed delivery`};
    const button=(label:string,handler:()=>void,primary=false)=>{const b=document.createElement('button');b.type='button';b.className=primary?'btn btn-primary btn-sm':'btn btn-sm';b.textContent=label;b.addEventListener('click',handler);return b};
    function render(){const b=data.batch;const downward=b.direction==='downward';$('batch-direction-label').textContent=downward?'DOWNWARD COMPLIANCE REQUEST':'UPWARD COMPLIANCE SUBMISSION';$('route-review-title').textContent=downward?'Pending complaints and lower-office destinations':'Finalized compliance packets and higher-office destinations';$('route-review-copy').textContent=downward?'Send complaint records for report, reply and evidence. Open the Reply Editor from an item to upload received compliance files.':'Submit the official letter, approved DEO reply, original complaint and accepted reports/evidence.';$('batch-number').textContent=b.batch_number;$('batch-purpose').textContent=`${downward?'Request compliance':'Submit compliance'} · ${b.purpose.replaceAll('_',' ')} · created ${new Date(b.created_at).toLocaleString()}${b.response_due_at?` · response due ${new Date(b.response_due_at).toLocaleString()}`:''}`;$('batch-status').replaceWith(Object.assign(badge(b.status),{id:'batch-status'}));$('metric-total').textContent=b.total_items;$('metric-ready').textContent=`${b.ready_items} ready`;$('metric-blocked').textContent=b.blocked_items;$('metric-excluded').textContent=b.excluded_items;$('metric-delivered').textContent=b.successful_items;$('metric-failed').textContent=`${b.failed_items} failed`;
      const pending=(data.previews||[]).filter((p:any)=>!p.approval);const eligible=pending.reduce((n:number,p:any)=>n+p.deliveries.filter((d:any)=>['ready','warning'].includes(d.status)).length,0);$('compile-previews').disabled=b.blocked_items>0||b.ready_items===0||['sending','completed'].includes(b.status);$('approve-previews').hidden=!pending.length||eligible===0;$('approve-previews').textContent=eligible?`Approve and Queue ${eligible}`:'No Eligible Deliveries';renderItems();renderPreviews();renderDelivery()}
    function renderItems(){const nodes=data.items.map((item:any)=>{const a=document.createElement('article');a.className=`dispatch-item-card ${item.route_status}`;const h=document.createElement('header');const identity=document.createElement('div');const source=data.batch.direction==='downward'?`Complaint assignment packet · ${item.compliance_status.replaceAll('_',' ')}`:`Official letter ${item.letter_number||'—'} · ${item.compliance_status.replaceAll('_',' ')}`;identity.innerHTML=`<strong>${item.complaint_number}</strong><small>${source} · ${item.packet_page_count} pages · ${(item.packet_size_bytes/1024/1024).toFixed(1)} MB</small>${data.batch.direction==='upward'?`<small>${paperlessSummary(item)}</small>`:''}`;h.append(identity,badge(item.paperless_sync?.state==='failed'||item.paperless_sync?.state==='blocked'?item.paperless_sync.state:item.route_status));const route=document.createElement('div');route.className='dispatch-item-route';if(item.targets.length){for(const target of item.targets){const row=document.createElement('div');row.className='dispatch-target-row';const copy=document.createElement('div');copy.innerHTML=`<strong>${target.profile?.name||'Missing profile'}</strong><small>${target.selection_source.replaceAll('_',' ')} · ${target.business_status.replaceAll('_',' ')}${target.error?` · ${target.error}`:''}</small>`;row.append(copy,badge(target.business_status));route.append(row)}}else{route.innerHTML=`<p>${item.route_summary?.reason||'No destination selected.'}</p>`}const footer=document.createElement('footer');const packet=document.createElement('a');packet.className='btn btn-sm';packet.href=`${API}${item.packet_download_url}`;packet.textContent=data.batch.direction==='downward'?'View Complaint Packet':'View Complete Compliance PDF';const editor=document.createElement('a');editor.className='btn btn-sm';editor.href=`/crm/replies/${item.complaint_case_id}/?dispatch_batch_id=${data.batch.id}&dispatch_item_id=${item.id}&return=${encodeURIComponent(location.pathname)}`;editor.textContent=data.batch.direction==='downward'?'Upload / Review Compliance':'Open Reply Editor';const manual=button(item.targets.length?'Change Route':'Choose Route',()=>openRoute(item),item.route_status!=='ready');const exclude=button(item.excluded?'Include':'Exclude',async()=>{const reason=item.excluded?'':prompt('Reason for excluding this complaint from dispatch:')||'';if(!item.excluded&&!reason)return;data=await api(`/api/v1/crm/dispatch/items/${item.id}/excluded`,{method:'PUT',body:JSON.stringify({excluded:!item.excluded,reason})});render()});footer.append(packet,editor,manual,exclude);a.append(h,route,footer);return a});$('dispatch-items').replaceChildren(...nodes)}
    function renderPreviews(){const previews=data.previews||[];$('preview-section').hidden=!previews.length;const nodes=previews.map((p:any)=>{const a=document.createElement('article');a.className='dispatch-preview-profile';const h=document.createElement('header');const identity=document.createElement('div');identity.innerHTML=`<strong>${p.profile_name}</strong><small>${p.preview_key} · SHA-256 ${p.content_sha256?p.content_sha256.slice(0,16)+'…':'unavailable'}</small>`;const actions=document.createElement('div');actions.className='table-actions';const review=document.createElement('a');review.className='btn btn-sm';review.href=`/whatsapp/previews/${p.id}`;review.textContent='Review Frozen Preview';actions.append(review,badge(p.approval?.status||p.status));h.append(identity,actions);const deliveries=document.createElement('div');deliveries.className='dispatch-preview-deliveries';for(const d of p.deliveries){const row=document.createElement('details');row.className=`dispatch-preview-delivery ${d.status}`;const summary=document.createElement('summary');summary.innerHTML=`<span><strong>${d.target_name}</strong><small>${d.target_jid}</small></span>`;summary.append(badge(d.status));const message=document.createElement('pre');message.textContent=d.message;row.append(summary,message);if(d.issues?.length){const ul=document.createElement('ul');for(const issue of d.issues){const li=document.createElement('li');li.textContent=issue.message;ul.append(li)}row.append(ul)}deliveries.append(row)}a.append(h,deliveries);return a});$('preview-list').replaceChildren(...nodes)}
    function renderDelivery(){const rows=data.items.flatMap((item:any)=>item.targets.filter((x:any)=>x.whatsapp_delivery_ids?.length||!['planned','blocked'].includes(x.business_status)).map((x:any)=>({item,target:x})));if(!rows.length){$('delivery-list').innerHTML='<p class="crm-empty-state compact">No approved deliveries yet.</p>';return}const nodes=rows.map(({item,target}:any)=>{const a=document.createElement('article');a.className='dispatch-delivery-row';const d=document.createElement('div');d.innerHTML=`<strong>${item.complaint_number} → ${target.profile?.name||'Destination'}</strong><small>${target.recipients?.map((x:any)=>x.name).join(', ')||'Recipients frozen in preview'}${target.error?` · ${target.error}`:''}</small>`;a.append(d,badge(target.business_status));return a});$('delivery-list').replaceChildren(...nodes)}
    function openRoute(item:any){$('route-item-id').value=item.id;$('route-title').textContent=`Route complaint ${item.complaint_number}`;$('route-reason').value='';$('route-message').textContent='';const current=new Set(item.targets.map((x:any)=>x.dispatch_profile_id));const nodes=data.profiles.filter((p:any)=>(p.allowed_directions||[]).includes(data.batch.direction)).map((p:any)=>{const label=document.createElement('label');label.className='routing-profile-option';const input=document.createElement('input');input.type='checkbox';input.className='checkbox checkbox-sm';input.value=p.id;input.dataset.routeProfile='1';input.checked=current.has(p.id);const copy=document.createElement('span');copy.innerHTML=`<strong>${p.name}</strong><small>${p.targets.length} recipient${p.targets.length===1?'':'s'} · ${(p.office_level||'both').replaceAll('_',' ')} · ${p.packet_policy.replaceAll('_',' ')}</small>`;label.append(input,copy);return label});$('route-options').replaceChildren(...nodes);$('route-dialog').showModal()}
    $('close-route').addEventListener('click',()=>$('route-dialog').close());$('cancel-route').addEventListener('click',()=>$('route-dialog').close());$('save-route').addEventListener('click',async()=>{const ids=Array.from(document.querySelectorAll<HTMLInputElement>('[data-route-profile]:checked')).map(x=>x.value);try{data=await api(`/api/v1/crm/dispatch/items/${$('route-item-id').value}/route`,{method:'PUT',body:JSON.stringify({profile_ids:ids,reason:$('route-reason').value})});$('route-dialog').close();render();toast('Manual route applied.')}catch(e){$('route-message').textContent=e instanceof Error?e.message:String(e)}});
    $('resolve-routes').addEventListener('click',async()=>{try{data=await api(`/api/v1/crm/dispatch/batches/${batchId}/resolve`,{method:'POST'});render();toast('Routing rules evaluated.')}catch(e){toast(e instanceof Error?e.message:String(e),true)}});$('compile-previews').addEventListener('click',async()=>{const b=$('compile-previews');b.disabled=true;try{data=await api(`/api/v1/crm/dispatch/batches/${batchId}/compile`,{method:'POST',body:JSON.stringify({actor:'web-operator'})});render();toast('Exact recipients, messages and PDFs are frozen for approval.')}catch(e){toast(e instanceof Error?e.message:String(e),true)}finally{b.disabled=false}});
    $('approve-previews').addEventListener('click',()=>{const pending=data.previews.filter((p:any)=>!p.approval);const deliveries=pending.reduce((n:number,p:any)=>n+p.deliveries.filter((d:any)=>['ready','warning'].includes(d.status)).length,0);const excluded=pending.reduce((n:number,p:any)=>n+p.deliveries.filter((d:any)=>['blocked','skipped'].includes(d.status)).length,0);$('approval-summary').textContent=`You are approving ${deliveries} exact WhatsApp deliveries across ${pending.length} destination profile preview(s). ${excluded} blocked or duplicate deliveries will remain unsent. This action queues real messages and cannot be undone.`;$('ack-warnings').checked=false;$('ack-exclusions').checked=excluded===0;$('approval-message').textContent='';$('approval-dialog').showModal()});$('close-approval').addEventListener('click',()=>$('approval-dialog').close());$('cancel-approval').addEventListener('click',()=>$('approval-dialog').close());
    $('confirm-approval').addEventListener('click',async()=>{const btn=$('confirm-approval');btn.disabled=true;try{const result=await api(`/api/v1/crm/dispatch/batches/${batchId}/approve`,{method:'POST',body:JSON.stringify({approved_by:$('approved-by').value||'web-operator',acknowledge_warnings:$('ack-warnings').checked,acknowledge_exclusions:$('ack-exclusions').checked})});$('approval-dialog').close();data=result.batch;render();toast(result.message||`${result.queued} real WhatsApp delivery queued.`)}catch(e){$('approval-message').textContent=e instanceof Error?e.message:String(e)}finally{btn.disabled=false}});
    $('refresh-batch').addEventListener('click',async()=>{try{data=await api(`/api/v1/crm/dispatch/batches/${batchId}/refresh`,{method:'POST'});render();const r=data.reconciliation||{};toast(r.failed?`${r.failed} Paperless synchronization${r.failed===1?'':'s'} need attention.`:r.synchronized?`${r.synchronized} Paperless record${r.synchronized===1?'':'s'} synchronized.`:'Dispatch and Paperless states are current.',Boolean(r.failed))}catch(e){toast(e instanceof Error?e.message:String(e),true)}});
    api(`/api/v1/crm/dispatch/batches/${batchId}`).then((r:any)=>{data=r;render()}).catch(e=>toast(e instanceof Error?e.message:String(e),true));
  </script>
</CrmLayout>
