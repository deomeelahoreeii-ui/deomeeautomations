---
import CrmLayout from "../../../../layouts/CrmLayout.astro";
import DataTable from "../../../../components/DataTable.astro";
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
---
<CrmLayout title="CRM Delivery History" description="Inspect real WhatsApp queue and delivery outcomes for CRM complaint dispatches." page="dispatch">
  <a class="btn btn-sm" href="/crm/dispatch/" slot="actions">← Dispatch Queue</a>
  <a class="btn btn-primary btn-sm" href="/whatsapp/deliveries" slot="actions">WhatsApp Deliveries</a>
  <main id="crm-delivery-history" class="crm32-page crm-dispatch-page" data-api-base={apiBase}>
    <nav class="dispatch-tabs" aria-label="CRM dispatch pages"><a href="/crm/dispatch/">Dispatch Queue</a><a href="/crm/dispatch/batches/">Batches</a><a href="/crm/dispatch/routing/">Routing</a><a class="active" href="/crm/dispatch/deliveries/">Delivery History</a></nav>
    <section class="master-card dispatch-history-card"><header class="crm-card-heading"><div><p class="eyebrow">Transport audit</p><h2>CRM WhatsApp delivery history</h2><p>Statuses are derived from the canonical WhatsApp approval, task outbox and delivery records.</p></div><button id="refresh-deliveries" class="btn btn-sm" type="button">↻ Refresh</button></header>
      <div class="dispatch-history-toolbar"><label class="crm-field"><span>Search</span><input id="delivery-search" class="input input-bordered" placeholder="Complaint, batch or recipient…" /></label><label class="crm-field"><span>Direction</span><select id="delivery-direction" class="select select-bordered"><option value="">Both directions</option><option value="downward">Request compliance</option><option value="upward">Submit compliance</option></select></label><label class="crm-field"><span>Status</span><select id="delivery-status" class="select select-bordered"><option value="">All statuses</option><option value="blocked">Blocked / not queued</option><option value="queued">Queued</option><option value="sent_pending_confirmation">Sent pending confirmation</option><option value="delivered">Delivered</option><option value="failed">Failed</option><option value="timed_out">Timed out</option></select></label></div>
      <DataTable id="crm-delivery-table" pageSize={25} pageSizeOptions={[25,50,100]} emptyText="No CRM delivery records match the filters." ariaLabel="CRM WhatsApp delivery history" />
    </section><div id="delivery-toast" class="crm-toast" role="status" hidden></div>
  </main>
  <script>
    const root=document.getElementById('crm-delivery-history') as HTMLElement;const API=root.dataset.apiBase||'';const table=document.getElementById('crm-delivery-table') as any;const $=(id:string)=>document.getElementById(id) as any;
    function toast(message:string){const n=$('delivery-toast');n.textContent=message;n.className='crm-toast error';n.hidden=false}
    async function api(path:string){const r=await fetch(`${API}${path}`);const b=await r.json().catch(()=>({}));if(!r.ok)throw new Error(typeof b.detail==='string'?b.detail:r.statusText);return b}
    const stack=(a:string,b:string)=>{const d=document.createElement('div');d.className='table-stack';const x=document.createElement('strong');x.textContent=a;const y=document.createElement('small');y.textContent=b;d.append(x,y);return d};
    const badge=(value:string)=>{const s=document.createElement('span');s.className=`crm-status-badge ${value==='delivered'?'success':['failed','timed_out','blocked'].includes(value)?'danger':'warning'}`;s.textContent=(value||'unknown').replaceAll('_',' ');return s};
    async function loadPage(pageIndex:number,pageSize:number){const q=new URLSearchParams({page:String(pageIndex+1),page_size:String(pageSize),search:$('delivery-search').value||'',status:$('delivery-status').value||'',direction:$('delivery-direction').value||''});const r=await api(`/api/v1/crm/dispatch/deliveries?${q}`);return{rows:r.items||[],total:Number(r.total||0)}}
    async function configure(){await table.configure({manualPagination:true,loadPage,columns:[{header:'Complaint',accessorKey:'complaint_number',cell:(c:any)=>stack(c.getValue(),c.row.original.batch_number)},{header:'Workflow',id:'workflow',cell:(c:any)=>stack(c.row.original.direction==='downward'?'Request compliance':'Submit compliance',(c.row.original.purpose||'').replaceAll('_',' '))},{header:'Destination',id:'destination',cell:(c:any)=>stack(c.row.original.profile_name,`${c.row.original.recipient_name} · ${c.row.original.target}`)},{header:'Status',accessorKey:'status',cell:(c:any)=>badge(c.getValue())},{header:'Activity',id:'activity',cell:(c:any)=>stack(c.row.original.completed_at?new Date(c.row.original.completed_at).toLocaleString():c.row.original.queued_at?new Date(c.row.original.queued_at).toLocaleString():'Not queued',c.row.original.error||'No transport error')},{header:'Actions',id:'actions',cell:(c:any)=>{const a=document.createElement('a');a.className='btn btn-primary btn-sm';a.href=c.row.original.detail_url;a.textContent='Open batch';return a}}]})}
    $('refresh-deliveries').addEventListener('click',()=>void table.reload());let timer=0;$('delivery-search').addEventListener('input',()=>{clearTimeout(timer);timer=window.setTimeout(()=>void table.setPageIndex(0),250)});$('delivery-status').addEventListener('change',()=>void table.setPageIndex(0));$('delivery-direction').addEventListener('change',()=>void table.setPageIndex(0));configure().catch(e=>toast(e instanceof Error?e.message:String(e)));
  </script>
</CrmLayout>
