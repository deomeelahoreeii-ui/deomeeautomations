---
import DataTable from "../../../components/DataTable.astro";
import WhatsAppRoutingNav from "../../../components/WhatsAppRoutingNav.astro";
import WhatsAppLayout from "../../../layouts/WhatsAppLayout.astro";
const audienceId = Astro.params.id || "";
---

<WhatsAppLayout title="Audience Targets" description="Explicit targets and dynamic Master Data sources authorized for one module audience." page="routing">
  <div class="page-actions" slot="actions"><button class="btn btn-sm" id="add-source">＋ Master Data source</button><button class="btn btn-sm btn-primary" id="add-target">＋ Add target</button></div>
  <WhatsAppRoutingNav active="audiences" />
  <a class="directory-back" href="/whatsapp/audiences">← Back to audiences</a>
  <section class="wa-panel group-detail-header" id="audience-details"><h2>Loading audience…</h2></section>
  <article class="master-card" style="margin-top:14px"><DataTable id="audience-members-table" pageSize={10} emptyText="No targets are assigned to this audience." /></article>

  <dialog class="modal" id="source-dialog"><div class="modal-box master-modal">
    <div class="modal-title"><h2>Add dynamic Master Data source</h2><button type="button" id="close-source">×</button></div>
    <form class="master-form" id="source-form">
      <label><span>Officer role *</span><select class="select select-bordered select-sm" id="source-role"><option value="aeo">AEO</option><option value="ddeo">DDEO</option></select></label>
      <label><span>Wing *</span><select class="select select-bordered select-sm" id="source-wing"></select></label>
      <label><span>Jurisdiction scope</span><input class="input input-bordered input-sm" id="source-scope" value="Markaz" readonly /></label>
      <label class="full"><input class="checkbox checkbox-sm" type="checkbox" id="source-aggregate" checked /> <span style="display:inline;margin-left:6px">Combine multiple jurisdictions into one message per officer</span></label>
      <div class="notice full">Recipients, personal numbers and schools are resolved from active Master Data whenever a preview is created.</div>
      <div class="form-actions"><button class="btn btn-sm" type="button" id="cancel-source">Cancel</button><button class="btn btn-sm btn-primary" type="submit">Add dynamic source</button></div>
    </form>
  </div><form method="dialog" class="modal-backdrop"><button>close</button></form></dialog>

  <dialog class="modal" id="target-dialog"><div class="modal-box master-modal">
    <div class="modal-title"><h2>Add audience target</h2><button type="button" id="close-target">×</button></div>
    <form class="master-form" id="target-form">
      <label><span>Target type</span><select class="select select-bordered select-sm" id="target-type"><option value="group">WhatsApp group</option><option value="contact">Individual contact</option></select></label>
      <div class="full group-picker"><label for="target-search"><span>Search synchronized directory *</span></label><input class="input input-bordered input-sm" id="target-search" autocomplete="off" placeholder="Search name, JID or LID…" /><div class="group-picker-results static-picker-results" id="target-results" hidden></div><div class="selected-group" id="selected-target" hidden></div></div>
      <label class="route-binding"><span>Authorized wing *</span><select class="select select-bordered select-sm" id="target-wing"></select></label>
      <label class="route-binding"><span>Hierarchy level *</span><select class="select select-bordered select-sm" id="target-scope"><option value="district">District</option><option value="wing">Wing</option><option value="tehsil" selected>Tehsil</option><option value="markaz">Markaz</option></select></label>
      <label class="route-binding"><span>Area represented by this group *</span><select class="select select-bordered select-sm" id="target-area"></select></label>
      <div class="form-actions"><button class="btn btn-sm" type="button" id="cancel-target">Cancel</button><button class="btn btn-sm btn-primary" id="save-target" type="submit">Add target</button></div>
    </form>
  </div><form method="dialog" class="modal-backdrop"><button>close</button></form></dialog>

  <script define:vars={{ audienceId }}>window.whatsappAudienceId=audienceId;</script>
  <script>
    import { actions } from "astro:actions";
    import { actionButtons, badge, stack } from "../../../scripts/table-cells";
    import { confirmAction, showError, showSuccess } from "../../../scripts/alerts";
    declare global { interface Window { whatsappAudienceId: string } }
    await customElements.whenDefined("astro-data-table");
    const id=window.whatsappAudienceId; const table=document.getElementById("audience-members-table") as any; const dialog=document.getElementById("target-dialog") as HTMLDialogElement; const sourceDialog=document.getElementById("source-dialog") as HTMLDialogElement; const el=<T extends HTMLElement>(key:string)=>document.getElementById(key) as T;
    let selected:any=null; let editingMember:any=null; let options:any={route_areas:[]}; let timer:number|undefined;
    async function loadAudience(){const result=await actions.whatsapp.audience({id});if(result.error)throw result.error;const item=result.data as any;const panel=el("audience-details");panel.replaceChildren();const copy=document.createElement("div");const eyebrow=document.createElement("span");eyebrow.className="eyebrow";eyebrow.textContent=item.application_name;const title=document.createElement("h2");title.textContent=item.name;const description=document.createElement("p");description.textContent=item.description||item.key;copy.append(eyebrow,title,description);const facts=document.createElement("div");facts.className="group-detail-facts";facts.innerHTML=`<span><strong>${item.group_count}</strong> active groups</span><span><strong>${item.contact_count}</strong> active individuals</span><span><strong>${item.source_count||0}</strong> dynamic sources</span><span><strong>${item.profile_count}</strong> dispatch profiles</span>`;panel.append(copy,facts);}
    async function loadPage(pageIndex:number,pageSize:number){const result=await actions.whatsapp.audienceMembers({id,page:pageIndex+1,pageSize});if(result.error)throw result.error;const data=result.data as any;return{rows:data.items,total:data.total};}
    async function refresh(){await loadAudience();await table.refresh(true);}
    function fillWings(){const html=(options.wings||[]).map((item:any)=>`<option value="${item.id}">${item.name}</option>`).join("");el<HTMLSelectElement>("target-wing").innerHTML=html;el<HTMLSelectElement>("source-wing").innerHTML=html;const mee=(options.wings||[]).find((item:any)=>item.code==="DEO MEE"||item.name==="DEO MEE");if(mee)el<HTMLSelectElement>("source-wing").value=mee.id;}
    function updateRouteFields(){const group=el<HTMLSelectElement>("target-type").value==="group";document.querySelectorAll<HTMLElement>(".route-binding").forEach(item=>item.hidden=!group);if(!group)return;const wingId=el<HTMLSelectElement>("target-wing").value;const wing=(options.wings||[]).find((item:any)=>item.id===wingId);const scope=el<HTMLSelectElement>("target-scope").value;const areas=(options.route_areas||[]).filter((item:any)=>item.scope_key===scope&&(scope==="district"?item.value===wing?.district_id:scope==="wing"?item.value===wingId:scope==="tehsil"?item.district_id===wing?.district_id:item.wing_id===wingId));el<HTMLSelectElement>("target-area").innerHTML=areas.length?areas.map((item:any)=>`<option value="${item.value}">${item.label}</option>`).join(""):'<option value="">No areas available</option>';}
    function choose(item:any){selected=item;el<HTMLInputElement>("target-search").value=item.name;const card=el("selected-target");card.replaceChildren();const strong=document.createElement("strong");strong.textContent=item.name;const small=document.createElement("small");small.textContent=item.identifier;card.append(strong,small);card.hidden=false;el("target-results").hidden=true;}
    async function search(){const query=el<HTMLInputElement>("target-search").value;const type=el<HTMLSelectElement>("target-type").value;const result=type==="group"?await actions.whatsapp.directoryGroups({search:query,availability:"available",page:1,pageSize:20}):await actions.whatsapp.directoryContacts({search:query,tokenStatus:"",page:1,pageSize:20});if(result.error){await showError(result.error);return;}const records=(result.data as any).items;const list=el("target-results");list.replaceChildren();for(const item of records){const option=document.createElement("button");option.type="button";const strong=document.createElement("strong");strong.textContent=item.name||item.display_name||"Unnamed contact";const small=document.createElement("small");small.textContent=item.jid||item.phone_jid||item.primary_lid_jid||"No identifier";option.append(strong,small);option.addEventListener("click",()=>choose({id:item.id,name:strong.textContent,identifier:small.textContent}));list.append(option);}if(!records.length){const empty=document.createElement("div");empty.className="group-picker-empty";empty.textContent="No directory targets found.";list.append(empty);}list.hidden=false;}
    function editRoute(item:any){editingMember=item;selected={id:item.target_id,name:item.name,identifier:item.identifier};el<HTMLSelectElement>("target-type").value=item.target_type;el<HTMLSelectElement>("target-type").disabled=true;el<HTMLInputElement>("target-search").value=item.name;el<HTMLInputElement>("target-search").disabled=true;choose(selected);el<HTMLSelectElement>("target-wing").value=item.wing_id||(options.wings?.[0]?.id||"");el<HTMLSelectElement>("target-scope").value=item.route_scope_key||"tehsil";updateRouteFields();el<HTMLSelectElement>("target-area").value=item.route_scope_value||"";el("save-target").textContent="Save route";dialog.showModal();}
    function enabledToggle(item:any){const wrap=document.createElement("label");wrap.className="target-enabled-toggle";const input=document.createElement("input");input.type="checkbox";input.className="toggle toggle-primary toggle-sm";input.checked=item.enabled;input.setAttribute("aria-label",`${item.enabled?"Disable":"Enable"} ${item.name}`);const text=document.createElement("span");text.textContent=item.enabled?"Enabled":"Disabled";input.addEventListener("change",async()=>{const desired=input.checked;input.disabled=true;const result=await actions.whatsapp.setAudienceMemberEnabled({audienceId:id,memberId:item.id,enabled:desired});if(result.error){input.checked=!desired;input.disabled=false;await showError(result.error);return;}text.textContent=desired?"Enabled":"Disabled";await Promise.all([loadAudience(),table.refresh(false)]);});wrap.append(input,text);return wrap;}
    try{const config=await actions.whatsapp.configurationOptions();if(config.error)throw config.error;options=config.data;fillWings();updateRouteFields();await loadAudience();await table.configure({manualPagination:true,loadPage,columns:[{accessorKey:"name",header:"Target",enableSorting:false,cell:({row}:any)=>stack(row.original.name,row.original.identifier)},{accessorKey:"target_type",header:"Type",enableSorting:false,cell:({row}:any)=>badge(row.original.dynamic?"dynamic contact":row.original.target_type)},{id:"route",header:"Authorized route",enableSorting:false,cell:({row}:any)=>row.original.dynamic?stack(row.original.route_scope_label,`Active Master Data · ${row.original.detail}`):row.original.target_type==="group"?stack(row.original.route_scope_label||"Not configured",`${row.original.wing_name||"Wing required"} · ${row.original.route_scope_key||"Route required"}`):"Master-data link"},{accessorKey:"available",header:"Destination",enableSorting:false,cell:({row}:any)=>badge(row.original.available?"Ready":"Unavailable",row.original.available?"":"warning")},{id:"enabled",header:"Dispatch",enableSorting:false,cell:({row}:any)=>row.original.dynamic?badge("Auto-resolved"):enabledToggle(row.original)},{id:"actions",header:"",enableSorting:false,cell:({row}:any)=>row.original.dynamic?"":actionButtons([...(row.original.target_type==="group"?[{label:"Edit route",onClick:()=>editRoute(row.original)}]:[]),{label:"Remove",tone:"danger",onClick:async()=>{if(!await confirmAction("Remove this target?","Existing delivery history will remain unchanged.","Remove target"))return;const result=await actions.whatsapp.removeAudienceMember({audienceId:id,memberId:row.original.id});if(result.error)await showError(result.error);else{await showSuccess("Target removed","Future profile previews will exclude it.");await refresh();}}}])}]});}catch(error){await showError(error);}
    el("add-target").addEventListener("click",()=>{editingMember=null;selected=null;el<HTMLFormElement>("target-form").reset();el<HTMLSelectElement>("target-type").disabled=false;el<HTMLInputElement>("target-search").disabled=false;el("save-target").textContent="Add target";el("selected-target").hidden=true;updateRouteFields();dialog.showModal();window.setTimeout(()=>{el<HTMLInputElement>("target-search").focus();void search();},0);});
    el("close-target").addEventListener("click",()=>dialog.close());el("cancel-target").addEventListener("click",()=>dialog.close());
    el("target-type").addEventListener("change",()=>{selected=null;el("selected-target").hidden=true;updateRouteFields();void search();});el("target-wing").addEventListener("change",updateRouteFields);el("target-scope").addEventListener("change",updateRouteFields);el("target-search").addEventListener("input",()=>{selected=null;el("selected-target").hidden=true;window.clearTimeout(timer);timer=window.setTimeout(()=>void search(),200);});
    el("target-form").addEventListener("submit",async(event)=>{event.preventDefault();try{if(!selected)throw new Error("Select a directory target.");const type=el<HTMLSelectElement>("target-type").value as "group"|"contact";const area=el<HTMLSelectElement>("target-area");if(type==="group"&&!area.value)throw new Error("Select an area represented by this group.");const route={wing_id:type==="group"?el<HTMLSelectElement>("target-wing").value:undefined,route_scope_key:type==="group"?el<HTMLSelectElement>("target-scope").value:"",route_scope_value:type==="group"?area.value:"",route_scope_label:type==="group"?area.selectedOptions[0]?.textContent||"":""};const result=editingMember?await actions.whatsapp.updateAudienceMember({audienceId:id,memberId:editingMember.id,target_type:type,target_id:selected.id,...route}):await actions.whatsapp.addAudienceMember({id,target_type:type,target_id:selected.id,...route});if(result.error)throw result.error;dialog.close();await showSuccess(editingMember?"Route updated":"Target added","The wing authorization and hierarchy binding will drive future dispatch previews.");await refresh();}catch(error){await showError(error);}});
    el("add-source").addEventListener("click",()=>sourceDialog.showModal());el("close-source").addEventListener("click",()=>sourceDialog.close());el("cancel-source").addEventListener("click",()=>sourceDialog.close());el("source-role").addEventListener("change",()=>{el<HTMLInputElement>("source-scope").value=el<HTMLSelectElement>("source-role").value==="aeo"?"Markaz":"Tehsil";});el("source-form").addEventListener("submit",async(event)=>{event.preventDefault();try{const role=el<HTMLSelectElement>("source-role").value as "aeo"|"ddeo";const result=await actions.whatsapp.addAudienceSource({id,source_type:"master_data_jurisdictions",recipient_role:role,wing_id:el<HTMLSelectElement>("source-wing").value,route_scope_key:role==="aeo"?"markaz":"tehsil",aggregate_by_recipient:el<HTMLInputElement>("source-aggregate").checked,enabled:true});if(result.error)throw result.error;const data=result.data as any;sourceDialog.close();await showSuccess("Dynamic source added",`${data.resolved_recipient_count} recipients across ${data.resolved_scope_count} jurisdictions are now resolved automatically.`);await refresh();}catch(error){await showError(error);}});
  </script>
</WhatsAppLayout>
