---
import DataTable from "../../../../components/DataTable.astro";
import DispatchPreviewNav from "../../../../components/DispatchPreviewNav.astro";
import WhatsAppLayout from "../../../../layouts/WhatsAppLayout.astro";

const { id = "" } = Astro.params;
---

<WhatsAppLayout title="Planned Deliveries" description="Exact recipient, route, message and attachment payloads in this frozen preview." page="previews">
  <div slot="actions" class="preview-next-actions"><button class="btn btn-sm btn-primary" id="approve-preview" type="button" hidden>Approve & queue</button><a class="btn btn-sm" href="/whatsapp/previews">← All previews</a></div>
  <span id="preview-context" data-preview-id={id} hidden></span>
  <div class="preview-identity compact"><div><span>Frozen batch</span><strong id="preview-key">Loading…</strong></div><span class="preview-state" id="preview-state">Loading</span></div>
  <DispatchPreviewNav id={id} active="deliveries" />
  <div class="toolbar directory-toolbar">
    <input class="input input-bordered input-sm search-input" id="delivery-search" placeholder="Search recipient, JID or route scope…" />
    <select class="select select-bordered select-sm" id="delivery-status"><option value="">All delivery states</option><option value="ready">Ready</option><option value="warning">Warning</option><option value="blocked">Blocked</option><option value="skipped">Skipped</option></select>
    <span class="toolbar-status" id="delivery-total">Loading…</span>
  </div>
  <article class="master-card"><DataTable id="preview-deliveries-table" pageSize={10} emptyText="This preview has no planned deliveries." /></article>

  <dialog class="modal" id="delivery-dialog"><div class="modal-box master-modal preview-delivery-modal">
    <div class="modal-title"><div><p class="eyebrow">Exact frozen payload</p><h2 id="delivery-title">Planned delivery</h2></div><button type="button" id="close-delivery">×</button></div>
    <div class="delivery-inspector">
      <aside>
        <dl class="preview-facts compact-facts">
          <div><dt>Recipient</dt><dd id="detail-recipient">—</dd></div>
          <div><dt>WhatsApp ID</dt><dd><code id="detail-target">—</code></dd></div>
          <div><dt>Target type</dt><dd id="detail-type">—</dd></div>
          <div><dt>Wing</dt><dd id="detail-wing">—</dd></div>
          <div><dt>Route</dt><dd id="detail-route">—</dd></div>
          <div><dt>State</dt><dd id="detail-status">—</dd></div>
        </dl>
        <section class="attachment-inspector"><h3>Attachments</h3><div id="detail-attachments"></div></section>
        <section class="issue-inspector"><h3>Validation</h3><div id="detail-issues"></div></section>
      </aside>
      <section class="message-inspector"><span>Rendered WhatsApp message</span><div class="whatsapp-message" id="detail-message"></div><small>This is the exact frozen message—not a regenerated example.</small></section>
    </div>
  </div><form method="dialog" class="modal-backdrop"><button>close</button></form></dialog>

  <script>
    import { actions } from "astro:actions";
    import { actionButtons, badge, stack } from "../../../../scripts/table-cells";
    import { confirmAction, showError, showSuccess } from "../../../../scripts/alerts";
    const id = document.getElementById("preview-context")!.dataset.previewId!;
    await customElements.whenDefined("astro-data-table");
    const table = document.getElementById("preview-deliveries-table");
    const dialog = document.getElementById("delivery-dialog");
    const el = (key) => document.getElementById(key);
    let timer;
    const tone = (status) => status === "blocked" ? "warning" : status === "warning" || status === "skipped" ? "inactive" : "";
    const formatBytes = (bytes) => bytes < 1024 ? `${bytes} B` : bytes < 1048576 ? `${(bytes / 1024).toFixed(1)} KB` : `${(bytes / 1048576).toFixed(1)} MB`;
    function openDelivery(item) {
      el("delivery-title").textContent = item.target_name || "Planned delivery";
      for (const [key, value] of [["detail-recipient", item.target_name], ["detail-target", item.target_jid], ["detail-type", item.target_type], ["detail-wing", item.wing_name], ["detail-route", `${item.route_kind || "route"} · ${item.route_scope || "configured scope"}`], ["detail-status", item.status]]) el(key).textContent = value || "—";
      el("detail-message").textContent = item.message;
      const attachments = el("detail-attachments"); attachments.replaceChildren();
      if (!item.attachments.length) attachments.innerHTML = '<p class="empty-state">Message only—no attachments.</p>';
      for (const file of item.attachments) { const link = document.createElement("a"); link.className = "preview-attachment"; link.href = `${(import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020")}/api/v1/whatsapp/previews/${id}/artifacts/${file.id}/download`; link.target = "_blank"; link.innerHTML = `<strong></strong><small>${formatBytes(file.size_bytes)} · ${file.checksum_sha256.slice(0, 12)}…</small>`; link.querySelector("strong").textContent = file.name; attachments.append(link); }
      const issues = el("detail-issues"); issues.replaceChildren();
      if (!item.issues.length) issues.innerHTML = '<span class="validation-ok">✓ All checks passed</span>';
      for (const issue of item.issues) { const row = document.createElement("div"); row.className = `validation-row ${issue.severity}`; row.innerHTML = `<strong>${issue.code.replaceAll("_", " ")}</strong><span></span>`; row.querySelector("span").textContent = issue.message; issues.append(row); }
      dialog.showModal();
    }
    async function loadPage(pageIndex, pageSize) { const result = await actions.whatsapp.previewDeliveries({ id, search: el("delivery-search").value, status: el("delivery-status").value, page: pageIndex + 1, pageSize }); if (result.error) throw result.error; const data = result.data; el("delivery-total").textContent = `${data.total} planned`; return { rows: data.items, total: data.total }; }
    try {
      const detail = await actions.whatsapp.preview({ id }); if (detail.error) throw detail.error; const preview = detail.data; el("preview-key").textContent = preview.preview_key; el("preview-state").textContent = (preview.display_status || preview.status).replaceAll("_", " "); el("preview-state").className = `preview-state ${(preview.display_status || preview.status).replaceAll("_", "-")}`;
      const approve = el("approve-preview");
      if (!preview.approval && preview.status === "ready" && !preview.stale && preview.delivery_count > 0) {
        approve.hidden = false;
        approve.textContent = `Approve & queue ${preview.eligible_delivery_count}${preview.blocked_count ? ` · exclude ${preview.blocked_count}` : ""}`;
        approve.addEventListener("click", async () => {
          const approvalText = `Queue ${preview.eligible_delivery_count} exact eligible messages inspected in this frozen preview?${preview.blocked_count ? ` ${preview.blocked_count} blocked messages will be excluded.` : ""} This cannot be undone.`;
          if (!await confirmAction("Approve live WhatsApp dispatch?", approvalText, "Approve & queue")) return;
          approve.disabled = true;
          try {
            const result = await actions.whatsapp.approvePreview({ id, acknowledge_warnings: preview.warning_issue_count > 0, acknowledge_exclusions: preview.blocked_count > 0, approved_by: "web-operator" });
            if (result.error) throw result.error;
            await showSuccess("Dispatch approved", "The exact frozen payloads were queued for delivery.");
            window.location.href = "/whatsapp/deliveries";
          } catch (error) { approve.disabled = false; await showError(error); }
        });
      }
      await table.configure({ manualPagination: true, loadPage, columns: [
        { accessorKey: "sequence", header: "#", enableSorting: false },
        { accessorKey: "target_name", header: "Recipient", enableSorting: false, cell: ({row}) => stack(row.original.target_name, row.original.target_jid) },
        { accessorKey: "route_scope", header: "Route", enableSorting: false, cell: ({row}) => stack(row.original.route_scope || "Configured scope", `${row.original.route_kind || "route"} · ${row.original.wing_name}`) },
        { accessorKey: "message", header: "Message", enableSorting: false, cell: ({row}) => String(row.original.message || "").replaceAll("\n", " ").slice(0, 82) },
        { accessorKey: "attachments", header: "Files", enableSorting: false, cell: ({row}) => `${row.original.attachments.length} file${row.original.attachments.length === 1 ? "" : "s"}` },
        { accessorKey: "status", header: "State", enableSorting: false, cell: ({row}) => badge(row.original.status, tone(row.original.status)) },
        { id: "actions", header: "", enableSorting: false, cell: ({row}) => actionButtons([{ label: "Inspect", onClick: () => openDelivery(row.original) }]) },
      ]});
    } catch (error) { await showError(error); }
    el("close-delivery").addEventListener("click", () => dialog.close());
    el("delivery-status").addEventListener("change", () => table.refresh(true));
    el("delivery-search").addEventListener("input", () => { clearTimeout(timer); timer = setTimeout(() => table.refresh(true), 250); });
  </script>
</WhatsAppLayout>
