---
import DataTable from "../../../../components/DataTable.astro";
import DispatchPreviewNav from "../../../../components/DispatchPreviewNav.astro";
import WhatsAppLayout from "../../../../layouts/WhatsAppLayout.astro";

const { id = "" } = Astro.params;
---

<WhatsAppLayout title="Validation Issues" description="Actionable warnings and blockers found while compiling this frozen dispatch preview." page="previews">
  <a class="btn btn-sm" href="/whatsapp/previews" slot="actions">← All previews</a>
  <span id="preview-context" data-preview-id={id} hidden></span>
  <div class="preview-identity compact"><div><span>Frozen batch</span><strong id="preview-key">Loading…</strong></div><span class="preview-state" id="preview-state">Loading</span></div>
  <DispatchPreviewNav id={id} active="issues" />
  <div class="notice">Batch-level blockers prevent approval. Delivery-level blockers exclude only the affected frozen deliveries; clean deliveries can still be approved after explicit acknowledgement.</div>
  <div class="toolbar directory-toolbar">
    <select class="select select-bordered select-sm" id="issue-severity"><option value="">All actionable</option><option value="blocked">Blocked</option><option value="warning">Warning</option></select>
    <span class="toolbar-status" id="issue-total">Loading…</span>
  </div>
  <article class="master-card"><DataTable id="preview-issues-table" pageSize={10} emptyText="No validation issues—every check passed." /></article>

  <script>
    import { actions } from "astro:actions";
    import { badge, stack } from "../../../../scripts/table-cells";
    import { showError } from "../../../../scripts/alerts";
    await customElements.whenDefined("astro-data-table");
    const id = document.getElementById("preview-context")!.dataset.previewId!;
    const table = document.getElementById("preview-issues-table") as any;
    const el = <T extends HTMLElement>(key: string) => document.getElementById(key) as T;
    const tone = (severity: string) => severity === "blocked" ? "warning" : "inactive";
    async function loadPage(pageIndex: number, pageSize: number) { const result = await actions.whatsapp.previewIssues({ id, severity: el<HTMLSelectElement>("issue-severity").value, page: pageIndex + 1, pageSize }); if (result.error) throw result.error; const data = result.data as any; el("issue-total").textContent = `${data.total} unique issue${data.total === 1 ? "" : "s"}${data.affected_total ? ` · ${data.affected_total} affected` : ""}`; return { rows: data.items, total: data.total }; }
    try {
      const detail = await actions.whatsapp.preview({ id }); if (detail.error) throw detail.error; const preview = detail.data as any; el("preview-key").textContent = preview.preview_key; el("preview-state").textContent = (preview.display_status || preview.status).replaceAll("_", " "); el("preview-state").className = `preview-state ${(preview.display_status || preview.status).replaceAll("_", "-")}`;
      await table.configure({ manualPagination: true, loadPage, columns: [
        { accessorKey: "severity", header: "Severity", enableSorting: false, cell: ({row}: any) => badge(row.original.severity, tone(row.original.severity)) },
        { accessorKey: "code", header: "Check", enableSorting: false, cell: ({row}: any) => String(row.original.code).replaceAll("_", " ") },
        { accessorKey: "message", header: "Explanation", enableSorting: false },
        { accessorKey: "occurrence_count", header: "Occurrences", enableSorting: false, cell: ({row}: any) => String(row.original.occurrence_count || 1) },
        { accessorKey: "source_name", header: "Affected item", enableSorting: false, cell: ({row}: any) => stack(row.original.source_name, `${row.original.source_type}${row.original.source_detail ? ` · ${row.original.source_detail}` : ""}`) },
      ]});
    } catch (error) { await showError(error); }
    el("issue-severity").addEventListener("change", () => void table.refresh(true));
  </script>
</WhatsAppLayout>
