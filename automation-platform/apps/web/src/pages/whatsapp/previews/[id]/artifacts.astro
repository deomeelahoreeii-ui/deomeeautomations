---
import DataTable from "../../../../components/DataTable.astro";
import DispatchPreviewNav from "../../../../components/DispatchPreviewNav.astro";
import WhatsAppLayout from "../../../../layouts/WhatsAppLayout.astro";

const { id = "" } = Astro.params;
---

<WhatsAppLayout title="Preview Attachments" description="Only files used by the audience deliveries in this frozen preview." page="previews">
  <a class="btn btn-sm" href="/whatsapp/previews" slot="actions">← All previews</a>
  <span id="preview-context" data-preview-id={id} hidden></span>
  <div class="preview-identity compact"><div><span>Frozen batch</span><strong id="preview-key">Loading…</strong></div><span class="preview-state" id="preview-state">Loading</span></div>
  <DispatchPreviewNav id={id} active="artifacts" />
  <div class="notice">Delivery files are hashed when the preview is created. A changed or missing file makes the preview stale.</div>
  <div class="toolbar directory-toolbar">
    <select class="select select-bordered select-sm" id="artifact-role"><option value="">All attachment roles</option><option value="delivery">Delivery attachments</option><option value="manifest">Run manifests</option><option value="audit">Audit files</option><option value="supporting">Supporting reports</option></select>
    <span class="toolbar-status" id="artifact-total">Loading…</span>
  </div>
  <article class="master-card"><DataTable id="preview-artifacts-table" pageSize={10} emptyText="This preview has no file attachments." /></article>

  <script>
    import { actions } from "astro:actions";
    import { actionButtons, badge, stack } from "../../../../scripts/table-cells";
    import { showError } from "../../../../scripts/alerts";
    await customElements.whenDefined("astro-data-table");
    const id = document.getElementById("preview-context")!.dataset.previewId!;
    const API_BASE = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8020";
    const table = document.getElementById("preview-artifacts-table") as any;
    const el = <T extends HTMLElement>(key: string) => document.getElementById(key) as T;
    const formatBytes = (bytes: number) => bytes < 1024 ? `${bytes} B` : bytes < 1048576 ? `${(bytes / 1024).toFixed(1)} KB` : `${(bytes / 1048576).toFixed(1)} MB`;
    async function loadPage(pageIndex: number, pageSize: number) { const result = await actions.whatsapp.previewArtifacts({ id, role: el<HTMLSelectElement>("artifact-role").value, page: pageIndex + 1, pageSize }); if (result.error) throw result.error; const data = result.data as any; el("artifact-total").textContent = `${data.total} file${data.total === 1 ? "" : "s"}`; return { rows: data.items, total: data.total }; }
    try {
      const detail = await actions.whatsapp.preview({ id }); if (detail.error) throw detail.error; const preview = detail.data as any; el("preview-key").textContent = preview.preview_key; el("preview-state").textContent = preview.status; el("preview-state").className = `preview-state ${preview.status}`;
      await table.configure({ manualPagination: true, loadPage, columns: [
        { accessorKey: "name", header: "Attachment", enableSorting: false, cell: ({row}: any) => stack(row.original.name, row.original.mime_type) },
        { accessorKey: "role", header: "Role", enableSorting: false, cell: ({row}: any) => badge(row.original.role, row.original.role === "delivery" ? "" : "inactive") },
        { accessorKey: "size_bytes", header: "Size", enableSorting: false, cell: ({row}: any) => formatBytes(row.original.size_bytes) },
        { accessorKey: "checksum_sha256", header: "SHA-256", enableSorting: false, cell: ({row}: any) => row.original.checksum_sha256 ? `${row.original.checksum_sha256.slice(0, 16)}…` : "Missing" },
        { accessorKey: "status", header: "State", enableSorting: false, cell: ({row}: any) => badge(row.original.status, row.original.status === "blocked" ? "warning" : "") },
        { id: "actions", header: "", enableSorting: false, cell: ({row}: any) => actionButtons([{ label: "Open", onClick: () => window.open(`${API_BASE}/api/v1/whatsapp/previews/${id}/artifacts/${row.original.id}/download`, "_blank") }]) },
      ]});
    } catch (error) { await showError(error); }
    el("artifact-role").addEventListener("change", () => void table.refresh(true));
  </script>
</WhatsAppLayout>
