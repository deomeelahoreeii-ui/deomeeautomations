---
import DataTable from "../../components/DataTable.astro";
import WhatsAppRoutingNav from "../../components/WhatsAppRoutingNav.astro";
import WhatsAppLayout from "../../layouts/WhatsAppLayout.astro";
---

<WhatsAppLayout title="Dispatch Profiles" description="Explicitly connect a module report to an audience, WhatsApp connection and delivery policy." page="routing">
  <div class="page-actions" slot="actions"><button class="btn btn-sm btn-primary" id="setup-route">＋ Setup reporting route</button><button class="btn btn-sm" id="add-profile">Advanced: add profile</button></div>
  <WhatsAppRoutingNav active="profiles" />
  <div class="notice">A profile is configuration—not a send command. Live runs will freeze and validate a versioned profile before any jobs are queued.</div>
  <div class="toolbar directory-toolbar"><input class="input input-bordered input-sm search-input" id="profile-search" placeholder="Search profile name or key…" /><select class="select select-bordered select-sm" id="profile-application"><option value="">All modules</option></select><span class="toolbar-status" id="profile-total">Loading…</span></div>
  <article class="master-card"><DataTable id="profiles-table" pageSize={10} emptyText="No dispatch profiles are configured." /></article>

  <dialog class="modal" id="setup-dialog"><div class="modal-box master-modal wide-modal setup-modal">
    <div class="modal-title"><div><span class="eyebrow">GUIDED SETUP</span><h2>Setup reporting route</h2></div><button type="button" id="close-setup">×</button></div>
    <div class="setup-progress" id="setup-progress"><span>1. Report</span><span>2. Scope</span><span>3. Group</span><span>4. Message</span><span>5. Review</span></div>
    <form id="setup-form">
      <section class="setup-step" data-step="0"><h3>What are you configuring?</h3><p>Create a complete setup, or safely add another group to an existing one.</p>
        <label><span>Setup mode</span><select class="select select-bordered" id="setup-mode"><option value="new">Create a new reporting setup</option><option value="existing">Add a group to an existing setup</option></select></label>
        <label id="setup-existing-field" hidden><span>Existing reporting setup *</span><select class="select select-bordered" id="setup-existing"></select></label>
        <div class="setup-grid" id="setup-new-report"><label><span>Module *</span><select class="select select-bordered" id="setup-module"></select></label><label><span>Report type *</span><select class="select select-bordered" id="setup-report"></select></label></div>
      </section>
      <section class="setup-step" data-step="1" hidden><h3>Which organizational scope?</h3><p>The wing and hierarchy area become hard routing boundaries.</p><div class="setup-grid"><label><span>Wing *</span><select class="select select-bordered" id="setup-wing"></select></label><label><span>Destination level *</span><select class="select select-bordered" id="setup-scope"></select></label></div><label><span>Area represented by the group *</span><select class="select select-bordered" id="setup-area"></select></label></section>
      <section class="setup-step" data-step="2" hidden><h3>Which detected WhatsApp group?</h3><p>Choose from the synchronized directory. Its exact JID is stored automatically.</p><button class="btn" type="button" id="setup-choose-group">Choose detected group</button><div class="setup-selection" id="setup-group-selection" hidden><strong id="setup-group-name"></strong><small id="setup-group-jid"></small><button type="button" class="btn btn-xs" id="setup-group-change">Change</button></div><input type="hidden" id="setup-group-id"/></section>
      <section class="setup-step" data-step="3" hidden><h3>Message and report format</h3><p>Choose what recipients read in WhatsApp and which report files they receive.</p><div id="setup-new-message"><label><span>Message template *</span><select class="select select-bordered" id="setup-template"></select></label><div class="setup-grid"><label><span>WhatsApp message</span><select class="select select-bordered" id="setup-message-style"><option value="summary">Concise summary</option><option value="detailed">Detailed school list</option></select></label><label><span>Attachments</span><select class="select select-bordered" id="setup-attachment-mode"><option value="image_excel">Readable image + Excel workbook</option><option value="image">Readable image only</option><option value="excel">Excel workbook only</option><option value="none">Message only</option></select></label><label><span>Image content</span><select class="select select-bordered" id="setup-image-content"><option value="details">School details</option><option value="summary">Summary dashboard</option></select></label></div><div class="setup-grid"><label><span>Audience name <small>(optional)</small></span><input class="input input-bordered" id="setup-audience-name" placeholder="Generated automatically"/></label><label><span>Profile name <small>(optional)</small></span><input class="input input-bordered" id="setup-profile-name" placeholder="Generated automatically"/></label></div></div><label><span>WhatsApp connection *</span><select class="select select-bordered" id="setup-account"></select></label><details><summary>Advanced delivery settings</summary><div class="setup-grid"><label><span>Maximum retries</span><input class="input input-bordered" type="number" min="0" max="10" value="5" id="setup-retries"/></label><label><span>Messages per minute</span><input class="input input-bordered" type="number" min="1" max="120" value="20" id="setup-rate"/></label></div></details></section>
      <section class="setup-step" data-step="4" hidden><h3>Review the complete route</h3><p>Everything below will be saved together. If validation fails, nothing is created.</p><div class="setup-review" id="setup-review"></div><label class="setup-check"><input type="checkbox" id="setup-approval" checked/> Require preview and approval before live delivery</label></section>
      <div class="setup-actions"><button class="btn" type="button" id="setup-back" hidden>Back</button><span></span><button class="btn" type="button" id="setup-cancel">Cancel</button><button class="btn btn-primary" type="button" id="setup-next">Continue</button><button class="btn btn-primary" type="submit" id="setup-save" hidden>Create setup</button></div>
    </form>
  </div><form method="dialog" class="modal-backdrop"><button>close</button></form></dialog>

  <dialog class="modal" id="group-picker-dialog"><div class="modal-box master-modal group-picker-modal"><div class="modal-title"><div><span class="eyebrow">WHATSAPP DIRECTORY</span><h2>Choose detected group</h2></div><button type="button" id="close-group-picker">×</button></div><div class="group-picker-body"><label><span>Search synchronized groups</span><input class="input input-bordered" id="group-picker-search" placeholder="Type part of the group name…" autocomplete="off" /></label><p class="group-picker-help">Available groups appear as you type. You can also select from the initial list.</p><div class="group-picker-results" id="group-picker-results"><div class="group-picker-empty">Loading available groups…</div></div></div><div class="form-actions"><button class="btn" type="button" id="cancel-group-picker">Cancel</button></div></div><form method="dialog" class="modal-backdrop"><button>close</button></form></dialog>

  <dialog class="modal" id="profile-dialog"><div class="modal-box master-modal wide-modal"><div class="modal-title"><h2 id="profile-title">Add dispatch profile</h2><button type="button" id="close-profile">×</button></div><form class="master-form" id="profile-form">
    <input type="hidden" id="profile-id" />
    <label><span>Platform module *</span><select class="select select-bordered select-sm" id="profile-module" required></select></label><label><span>Status</span><select class="select select-bordered select-sm" id="profile-enabled"><option value="true">Enabled</option><option value="false">Draft / archived</option></select></label>
    <label><span>Name *</span><input class="input input-bordered input-sm" id="profile-name" required /></label><label><span>Stable key *</span><input class="input input-bordered input-sm" id="profile-key" pattern="[a-z0-9_]+" required /></label>
    <label><span>Report type *</span><select class="select select-bordered select-sm" id="profile-report" required></select></label><label><span>Recipient channel *</span><select class="select select-bordered select-sm" id="profile-channel" required><option value="individual">Individual</option><option value="group">Group</option></select></label>
    <label><span>Recipient role / scope *</span><select class="select select-bordered select-sm" id="profile-scope" required></select></label><label><span>Audience *</span><select class="select select-bordered select-sm" id="profile-audience" required></select></label>
    <label><span>WhatsApp connection *</span><select class="select select-bordered select-sm" id="profile-account" required></select></label><label><span>Message template</span><select class="select select-bordered select-sm" id="profile-template"><option value="">No template</option></select></label>
    <label id="profile-wing-field"><span>AntiDengue wing *</span><select class="select select-bordered select-sm" id="profile-wing"><option value="">Select wing</option></select></label>
    <label><span>WhatsApp message</span><select class="select select-bordered select-sm" id="profile-message-style"><option value="summary">Concise summary</option><option value="detailed">Detailed school list</option></select></label>
    <label><span>Attachments</span><select class="select select-bordered select-sm" id="profile-attachment-mode"><option value="image_excel">Readable image + Excel workbook</option><option value="image">Readable image only</option><option value="excel">Excel workbook only</option><option value="none">Message only</option></select></label>
    <label><span>Image content</span><select class="select select-bordered select-sm" id="profile-image-content"><option value="details">School details</option><option value="summary">Summary dashboard</option></select></label>
    <label><span>Approval</span><select class="select select-bordered select-sm" id="profile-approval"><option value="true">Preview and approval required</option><option value="false">No manual approval</option></select></label><label><span>Fallback policy</span><select class="select select-bordered select-sm" id="profile-fallback"><option value="none">No fallback</option><option value="same_scope">Explicit same-scope fallback</option></select></label>
    <label><span>Maximum retries</span><input class="input input-bordered input-sm" id="profile-retries" type="number" min="0" max="10" value="5" /></label><label><span>Rate limit / minute</span><input class="input input-bordered input-sm" id="profile-rate" type="number" min="1" max="120" value="20" /></label>
    <label class="full"><span>Notes</span><textarea class="textarea textarea-bordered textarea-sm" id="profile-notes" rows="3"></textarea></label>
    <div class="form-actions"><button class="btn btn-sm" type="button" id="cancel-profile">Cancel</button><button class="btn btn-sm btn-primary" type="submit">Save profile</button></div>
  </form></div><form method="dialog" class="modal-backdrop"><button>close</button></form></dialog>

  <script>
    import { actions } from "astro:actions";import{actionButtons,badge,stack}from"../../scripts/table-cells";import{confirmAction,showError,showSuccess}from"../../scripts/alerts";
    await customElements.whenDefined("astro-data-table");const table=document.getElementById("profiles-table") as any;const dialog=document.getElementById("profile-dialog") as HTMLDialogElement;const setupDialog=document.getElementById("setup-dialog") as HTMLDialogElement;const groupPickerDialog=document.getElementById("group-picker-dialog") as HTMLDialogElement;const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;let options:any;let timer:number|undefined;let groupSearchTimer:number|undefined;let setupProfiles:any[]=[];let setupStep=0;
    function optionHtml(items:any[],label:(item:any)=>string){return items.map((item:any)=>`<option value="${item.id}">${label(item)}</option>`).join("");}
    function populateBase(){const apps=options.applications.filter((item:any)=>item.enabled);const appHtml=optionHtml(apps,(item)=>item.name);el<HTMLSelectElement>("profile-module").innerHTML=appHtml;el<HTMLSelectElement>("profile-application").innerHTML=`<option value="">All modules</option>${appHtml}`;el<HTMLSelectElement>("profile-account").innerHTML=optionHtml(options.accounts,(item)=>item.name);el<HTMLSelectElement>("profile-wing").innerHTML=`<option value="">Select wing</option>${optionHtml(options.wings,(item)=>item.name)}`;}
    function populateTemplate(selected=""){const applicationId=el<HTMLSelectElement>("profile-module").value;const reportId=el<HTMLSelectElement>("profile-report").value;const channel=el<HTMLSelectElement>("profile-channel").value;const scopeId=el<HTMLSelectElement>("profile-scope").value;const templates=options.templates.filter((item:any)=>item.enabled&&item.category==="report"&&item.application_id===applicationId&&item.report_type_id===reportId&&(item.recipient_channel==="any"||item.recipient_channel===channel)&&(!item.recipient_scope_id||item.recipient_scope_id===scopeId));el<HTMLSelectElement>("profile-template").innerHTML=`<option value="">Select report template</option>${optionHtml(templates,(item)=>`${item.name} · ${item.recipient_scope_name}`)}`;el<HTMLSelectElement>("profile-template").value=selected;}
    function populateScope(selected=""){const applicationId=el<HTMLSelectElement>("profile-module").value;const channel=el<HTMLSelectElement>("profile-channel").value;const scopes=options.recipient_scopes.filter((item:any)=>item.application_id===applicationId&&item.channel===channel);el<HTMLSelectElement>("profile-scope").innerHTML=optionHtml(scopes,(item)=>item.name);el<HTMLSelectElement>("profile-scope").value=selected||scopes[0]?.id||"";}
    function populateScoped(selected:any={}){const applicationId=el<HTMLSelectElement>("profile-module").value;const application=options.applications.find((item:any)=>item.id===applicationId);const reports=options.report_types.filter((item:any)=>item.application_id===applicationId);const audiences=options.audiences.filter((item:any)=>item.application_id===applicationId);el<HTMLSelectElement>("profile-report").innerHTML=optionHtml(reports,(item)=>item.name);el<HTMLSelectElement>("profile-audience").innerHTML=optionHtml(audiences,(item)=>item.name);el<HTMLSelectElement>("profile-report").value=selected.report_type_id||reports[0]?.id||"";el<HTMLSelectElement>("profile-channel").value=selected.recipient_channel||(selected.delivery_mode==="individuals"?"individual":"group");populateScope(selected.recipient_scope_id||"");el<HTMLSelectElement>("profile-audience").value=selected.audience_id||audiences[0]?.id||"";populateTemplate(selected.template_id||"");const isAntiDengue=application?.key==="antidengue";el("profile-wing-field").toggleAttribute("hidden",!isAntiDengue);el<HTMLSelectElement>("profile-wing").required=isAntiDengue;if(!isAntiDengue)el<HTMLSelectElement>("profile-wing").value="";}
    function openForm(item?:any){el<HTMLFormElement>("profile-form").reset();el("profile-title").textContent=item?"Edit dispatch profile":"Add dispatch profile";el<HTMLInputElement>("profile-id").value=item?.id||"";el<HTMLSelectElement>("profile-module").value=item?.application_id||options.applications[0]?.id||"";el<HTMLSelectElement>("profile-module").disabled=Boolean(item);populateScoped(item);el<HTMLInputElement>("profile-name").value=item?.name||"";el<HTMLInputElement>("profile-key").value=item?.key||"";el<HTMLSelectElement>("profile-account").value=item?.account_id||options.accounts[0]?.id||"";el<HTMLSelectElement>("profile-wing").value=item?.wing_id||"";const policy=item?.presentation_policy||{};el<HTMLSelectElement>("profile-message-style").value=policy.message_style||"summary";el<HTMLSelectElement>("profile-attachment-mode").value=policy.attachment_mode||"image_excel";el<HTMLSelectElement>("profile-image-content").value=policy.image_content||"details";el<HTMLSelectElement>("profile-approval").value=String(item?.require_approval??true);el<HTMLSelectElement>("profile-fallback").value=item?.fallback_policy||"none";el<HTMLInputElement>("profile-retries").value=String(item?.max_retries??5);el<HTMLInputElement>("profile-rate").value=String(item?.messages_per_minute??20);el<HTMLSelectElement>("profile-enabled").value=String(item?.enabled??true);el<HTMLTextAreaElement>("profile-notes").value=item?.notes||"";dialog.showModal();}
    async function loadPage(pageIndex:number,pageSize:number){const result=await actions.whatsapp.dispatchProfiles({applicationId:el<HTMLSelectElement>("profile-application").value,search:el<HTMLInputElement>("profile-search").value,page:pageIndex+1,pageSize});if(result.error)throw result.error;const data=result.data as any;el("profile-total").textContent=`${data.total} profiles`;return{rows:data.items,total:data.total};}
    try{const result=await actions.whatsapp.configurationOptions();if(result.error)throw result.error;options=result.data;populateBase();await table.configure({manualPagination:true,loadPage,columns:[{accessorKey:"name",header:"Dispatch profile",enableSorting:false,cell:({row}:any)=>stack(row.original.name,`${row.original.key} · v${row.original.version}`)},{accessorKey:"application_name",header:"Module",enableSorting:false},{accessorKey:"report_type_name",header:"Report",enableSorting:false},{accessorKey:"recipient_channel",header:"Recipients",enableSorting:false,cell:({row}:any)=>stack(row.original.recipient_channel,row.original.recipient_scope_name)},{accessorKey:"audience_name",header:"Audience",enableSorting:false,cell:({row}:any)=>stack(row.original.audience_name,row.original.wing_name||"All module scope")},{accessorKey:"enabled",header:"Status",enableSorting:false,cell:({row}:any)=>badge(row.original.enabled?"Enabled":"Draft",row.original.enabled?"":"inactive")},{id:"actions",header:"",enableSorting:false,cell:({row}:any)=>actionButtons([{label:"Edit",onClick:()=>openForm(row.original)},...(row.original.enabled?[{label:"Archive",tone:"danger",onClick:async()=>{if(!await confirmAction("Archive this dispatch profile?","No new run may select it after archival.","Archive profile"))return;const result=await actions.whatsapp.archiveDispatchProfile({id:row.original.id});if(result.error)await showError(result.error);else{await showSuccess("Profile archived","Historical delivery records remain unchanged.");await table.refresh(true);}}}]:[]),{label:row.original.guided_setup?"Delete setup":"Delete permanently",tone:"danger",onClick:async()=>{const guided=Boolean(row.original.guided_setup);if(!await confirmAction(guided?"Delete this complete reporting setup?":"Permanently delete this profile?",guided?"The profile, wizard-owned audience, template, frozen previews and managed attachment copies will be removed. Shared directory groups remain available.":"Its frozen previews and managed attachments will also be deleted.",guided?"Delete setup":"Delete permanently"))return;const result=await actions.whatsapp.hardDeleteDispatchProfile({id:row.original.id});if(result.error)await showError(result.error);else{await showSuccess(guided?"Reporting setup deleted":"Profile deleted",guided?"Wizard-owned configuration and previews were removed.":"Dependent previews were removed.");await table.refresh(true);}}}])}]});}catch(error){await showError(error);}
    el("profile-module").addEventListener("change",()=>populateScoped());el("profile-report").addEventListener("change",()=>populateTemplate());el("profile-channel").addEventListener("change",()=>{populateScope();populateTemplate();});el("profile-scope").addEventListener("change",()=>populateTemplate());el("profile-application").addEventListener("change",()=>void table.refresh(true));el("profile-search").addEventListener("input",()=>{window.clearTimeout(timer);timer=window.setTimeout(()=>void table.refresh(true),250);});el("add-profile").addEventListener("click",()=>openForm());el("close-profile").addEventListener("click",()=>dialog.close());el("cancel-profile").addEventListener("click",()=>dialog.close());
    el("profile-form").addEventListener("submit",async(event)=>{event.preventDefault();try{const id=el<HTMLInputElement>("profile-id").value;const template=el<HTMLSelectElement>("profile-template").value;const wing=el<HTMLSelectElement>("profile-wing").value;const channel=el<HTMLSelectElement>("profile-channel").value as "individual"|"group";const scope=el<HTMLSelectElement>("profile-scope").value;const result=await actions.whatsapp.saveDispatchProfile({id:id||undefined,application_id:el<HTMLSelectElement>("profile-module").value,key:el<HTMLInputElement>("profile-key").value,name:el<HTMLInputElement>("profile-name").value,report_type_id:el<HTMLSelectElement>("profile-report").value,audience_id:el<HTMLSelectElement>("profile-audience").value,account_id:el<HTMLSelectElement>("profile-account").value,template_id:template||undefined,recipient_channel:channel,recipient_scope_id:scope||undefined,wing_id:wing||undefined,delivery_mode:channel==="group"?"groups":"individuals",require_approval:el<HTMLSelectElement>("profile-approval").value==="true",fallback_policy:el<HTMLSelectElement>("profile-fallback").value as any,max_retries:Number(el<HTMLInputElement>("profile-retries").value),messages_per_minute:Number(el<HTMLInputElement>("profile-rate").value),message_style:el<HTMLSelectElement>("profile-message-style").value as any,attachment_mode:el<HTMLSelectElement>("profile-attachment-mode").value as any,image_content:el<HTMLSelectElement>("profile-image-content").value as any,enabled:el<HTMLSelectElement>("profile-enabled").value==="true",notes:el<HTMLTextAreaElement>("profile-notes").value});if(result.error)throw result.error;dialog.close();await showSuccess("Dispatch profile saved",`Configuration version ${(result.data as any).version} is ready for validated previews.`);const refreshed=await actions.whatsapp.configurationOptions();if(!refreshed.error)options=refreshed.data;await table.refresh(true);}catch(error){await showError(error);}});

    const setupValue=(id:string)=>el<HTMLSelectElement>(id).value;const selectedText=(id:string)=>el<HTMLSelectElement>(id).selectedOptions[0]?.textContent||"—";
    function populateSetupReports(){const app=setupValue("setup-module");const reports=options.report_types.filter((item:any)=>item.application_id===app&&item.enabled);el<HTMLSelectElement>("setup-report").innerHTML=optionHtml(reports,(item)=>item.name);}
    function populateSetupScopes(){const app=setupValue("setup-module");const scopes=options.recipient_scopes.filter((item:any)=>item.application_id===app&&item.channel==="group"&&item.enabled);el<HTMLSelectElement>("setup-scope").innerHTML=optionHtml(scopes,(item)=>item.name);populateSetupAreas();}
    function populateSetupAreas(){const wing=options.wings.find((item:any)=>item.id===setupValue("setup-wing"));const scope=options.recipient_scopes.find((item:any)=>item.id===setupValue("setup-scope"));if(!wing||!scope)return;const areas=options.route_areas.filter((item:any)=>item.scope_key===scope.key&&(scope.key==="district"?item.district_id===wing.district_id:scope.key==="wing"?item.wing_id===wing.id:scope.key==="tehsil"?item.district_id===wing.district_id:item.wing_id===wing.id));el<HTMLSelectElement>("setup-area").innerHTML=areas.map((item:any)=>`<option value="${item.value}">${item.label}</option>`).join("");}
    function populateSetupTemplates(){const app=setupValue("setup-module"),report=setupValue("setup-report"),scope=setupValue("setup-scope");const templates=options.templates.filter((item:any)=>item.enabled&&item.category==="report"&&item.application_id===app&&item.report_type_id===report&&(item.recipient_channel==="group"||item.recipient_channel==="any")&&(!item.recipient_scope_id||item.recipient_scope_id===scope));el<HTMLSelectElement>("setup-template").innerHTML=`<option value="__create__">Create recommended template automatically</option>${optionHtml(templates,(item)=>item.name)}`;}
    function applyExistingSetup(){const existing=setupValue("setup-mode")==="existing";el("setup-existing-field").hidden=!existing;el("setup-new-report").hidden=existing;el("setup-new-message").hidden=existing;const profile=setupProfiles.find(item=>item.id===setupValue("setup-existing"));for(const id of ["setup-module","setup-report","setup-wing","setup-scope","setup-account"])el<HTMLSelectElement>(id).disabled=existing;if(existing&&profile){el<HTMLSelectElement>("setup-module").value=profile.application_id;populateSetupReports();el<HTMLSelectElement>("setup-report").value=profile.report_type_id;el<HTMLSelectElement>("setup-wing").value=profile.wing_id;populateSetupScopes();el<HTMLSelectElement>("setup-scope").value=profile.recipient_scope_id;populateSetupAreas();el<HTMLSelectElement>("setup-account").value=profile.account_id;}else{populateSetupReports();populateSetupScopes();populateSetupTemplates();}}
    function showSetupStep(step:number){setupStep=step;document.querySelectorAll<HTMLElement>(".setup-step").forEach(item=>item.hidden=Number(item.dataset.step)!==step);document.querySelectorAll<HTMLElement>("#setup-progress span").forEach((item,index)=>item.classList.toggle("active",index===step));el("setup-back").hidden=step===0;el("setup-next").hidden=step===4;el("setup-save").hidden=step!==4;if(step===4){renderSetupReview();el("setup-save").textContent=setupValue("setup-mode")==="existing"?"Add group":"Create setup";}}
    function validateSetupStep(){if(setupStep===0&&setupValue("setup-mode")==="existing"&&!setupValue("setup-existing"))return "Select an existing reporting setup.";if(setupStep===0&&setupValue("setup-mode")==="new"&&(!setupValue("setup-module")||!setupValue("setup-report")))return "Select the module and report type.";if(setupStep===1&&(!setupValue("setup-wing")||!setupValue("setup-scope")||!setupValue("setup-area")))return "Select the wing, destination level and area.";if(setupStep===2&&!el<HTMLInputElement>("setup-group-id").value)return "Search for and select a detected WhatsApp group.";if(setupStep===3&&(!setupValue("setup-account")||(setupValue("setup-mode")==="new"&&!setupValue("setup-template"))))return "Select the connection and message template.";return "";}
    function renderSetupReview(){const existing=setupProfiles.find(item=>item.id===setupValue("setup-existing"));const report=setupValue("setup-mode")==="existing"?existing?.report_type_name:selectedText("setup-report");const existingTemplate=existing?options.templates.find((item:any)=>item.id===existing.template_id):null;const template=existing?(existingTemplate?.name||"Existing profile template"):(setupValue("setup-template")==="__create__"?"Recommended template (will be created)":selectedText("setup-template"));const policy=existing?.presentation_policy||{};const presentation=existing?`${policy.message_style||"summary"} message · ${policy.attachment_mode||"message only"}`:`${selectedText("setup-message-style")} · ${selectedText("setup-attachment-mode")}`;el("setup-review").innerHTML=`<div><span>Action</span><strong>${existing?"Add group to existing setup":"Create complete reporting setup"}</strong></div><div><span>Report</span><strong>${report}</strong></div><div><span>Scope</span><strong>${selectedText("setup-wing")} → ${selectedText("setup-scope")} → ${selectedText("setup-area")}</strong></div><div><span>Recipient</span><strong>${el("setup-group-name").textContent}</strong></div><div><span>Output</span><strong>${presentation}</strong></div><div><span>Template</span><strong>${template}</strong></div><div><span>Connection</span><strong>${selectedText("setup-account")}</strong></div>`;}
    async function searchSetupGroups(){const list=el("group-picker-results");list.innerHTML='<div class="group-picker-empty">Searching available groups…</div>';const result=await actions.whatsapp.directoryGroups({search:el<HTMLInputElement>("group-picker-search").value.trim(),availability:"available",page:1,pageSize:20});if(result.error){list.innerHTML='<div class="group-picker-empty">Could not load the synchronized directory.</div>';await showError(result.error);return;}const records=(result.data as any).items;list.replaceChildren();for(const item of records){const button=document.createElement("button");button.type="button";const strong=document.createElement("strong");strong.textContent=item.name;const small=document.createElement("small");small.textContent=item.jid;button.append(strong,small);button.addEventListener("click",()=>{el<HTMLInputElement>("setup-group-id").value=item.id;el("setup-group-name").textContent=item.name;el("setup-group-jid").textContent=item.jid;el("setup-group-selection").hidden=false;groupPickerDialog.close();});list.append(button);}if(!records.length){const empty=document.createElement("div");empty.className="group-picker-empty";empty.textContent=el<HTMLInputElement>("group-picker-search").value.trim()?"No matching available groups. Check the spelling or clear the search.":"No available synchronized groups were found.";list.append(empty);}}
    async function openGroupPicker(){el<HTMLInputElement>("group-picker-search").value="";groupPickerDialog.showModal();await searchSetupGroups();el<HTMLInputElement>("group-picker-search").focus();}
    async function openSetup(){el<HTMLFormElement>("setup-form").reset();el<HTMLInputElement>("setup-group-id").value="";el("setup-group-selection").hidden=true;const profilesResult=await actions.whatsapp.dispatchProfiles({applicationId:"",search:"",page:1,pageSize:100});if(profilesResult.error){await showError(profilesResult.error);return;}setupProfiles=(profilesResult.data as any).items.filter((item:any)=>item.enabled&&item.recipient_channel==="group");el<HTMLSelectElement>("setup-existing").innerHTML=optionHtml(setupProfiles,(item)=>`${item.name} · ${item.wing_name} · ${item.recipient_scope_name}`);const anti=options.applications.find((item:any)=>item.key==="antidengue");el<HTMLSelectElement>("setup-module").innerHTML=optionHtml(options.applications.filter((item:any)=>item.key==="antidengue"),(item)=>item.name);el<HTMLSelectElement>("setup-module").value=anti?.id||"";el<HTMLSelectElement>("setup-wing").innerHTML=optionHtml(options.wings,(item)=>item.name);el<HTMLSelectElement>("setup-account").innerHTML=optionHtml(options.accounts.filter((item:any)=>item.enabled),(item)=>item.name);applyExistingSetup();showSetupStep(0);setupDialog.showModal();}
    el("setup-route").addEventListener("click",()=>void openSetup());el("close-setup").addEventListener("click",()=>setupDialog.close());el("setup-cancel").addEventListener("click",()=>setupDialog.close());el("setup-mode").addEventListener("change",applyExistingSetup);el("setup-existing").addEventListener("change",applyExistingSetup);el("setup-module").addEventListener("change",()=>{populateSetupReports();populateSetupScopes();});el("setup-report").addEventListener("change",populateSetupTemplates);el("setup-wing").addEventListener("change",populateSetupAreas);el("setup-scope").addEventListener("change",()=>{populateSetupAreas();populateSetupTemplates();});el("setup-choose-group").addEventListener("click",()=>void openGroupPicker());el("setup-group-change").addEventListener("click",()=>void openGroupPicker());el("close-group-picker").addEventListener("click",()=>groupPickerDialog.close());el("cancel-group-picker").addEventListener("click",()=>groupPickerDialog.close());el("group-picker-search").addEventListener("input",()=>{window.clearTimeout(groupSearchTimer);groupSearchTimer=window.setTimeout(()=>void searchSetupGroups(),180);});el("setup-next").addEventListener("click",async()=>{const error=validateSetupStep();if(error){await showError(error);return;}showSetupStep(setupStep+1);});el("setup-back").addEventListener("click",()=>showSetupStep(setupStep-1));
    el("setup-form").addEventListener("submit",async event=>{event.preventDefault();const error=validateSetupStep();if(error){await showError(error);return;}try{const existing=setupValue("setup-mode")==="existing";const area=options.route_areas.find((item:any)=>item.value===setupValue("setup-area"));const template=setupValue("setup-template");const result=await actions.whatsapp.setupReportingRoute({profile_id:existing?setupValue("setup-existing"):undefined,application_id:existing?undefined:setupValue("setup-module"),report_type_id:existing?undefined:setupValue("setup-report"),wing_id:setupValue("setup-wing"),recipient_scope_id:setupValue("setup-scope"),account_id:setupValue("setup-account"),directory_group_id:el<HTMLInputElement>("setup-group-id").value,route_scope_value:setupValue("setup-area"),route_scope_label:area?.label||selectedText("setup-area"),template_id:!existing&&template!=="__create__"?template:undefined,create_recommended_template:!existing&&template==="__create__",audience_name:el<HTMLInputElement>("setup-audience-name").value,profile_name:el<HTMLInputElement>("setup-profile-name").value,template_name:"",template_body:"{{report_body}}",require_approval:el<HTMLInputElement>("setup-approval").checked,max_retries:Number(el<HTMLInputElement>("setup-retries").value),messages_per_minute:Number(el<HTMLInputElement>("setup-rate").value),message_style:setupValue("setup-message-style") as any,attachment_mode:setupValue("setup-attachment-mode") as any,image_content:setupValue("setup-image-content") as any});if(result.error)throw result.error;setupDialog.close();await showSuccess(existing?"Group added":"Reporting setup created",`${(result.data as any).group_name} is routed through ${(result.data as any).profile.name}.`);const refreshed=await actions.whatsapp.configurationOptions();if(!refreshed.error)options=refreshed.data;await table.refresh(true);}catch(error){await showError(error);}});
  </script>
  <style>
    .setup-modal{max-width:900px}.setup-progress{display:grid;grid-template-columns:repeat(5,1fr);gap:.4rem;padding:1rem 1.5rem;border-bottom:1px solid var(--line,#dce3ec)}.setup-progress span{padding:.55rem;border-radius:.45rem;background:#f3f6fa;color:#7a879b;font-size:.72rem;font-weight:700;text-align:center}.setup-progress span.active{background:#dff3f5;color:#087487}.setup-step{padding:1.5rem}.setup-step h3{font-size:1.2rem;margin:0 0 .25rem}.setup-step>p{color:#718096;margin:0 0 1.25rem}.setup-step label{display:grid;gap:.35rem;margin-bottom:1rem}.setup-step label>span{font-size:.78rem;font-weight:700;color:#536177}.setup-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.setup-actions{display:grid;grid-template-columns:auto 1fr auto auto;gap:.6rem;padding:1rem 1.5rem;border-top:1px solid var(--line,#dce3ec)}.group-picker-modal{display:flex;flex-direction:column;width:min(760px,calc(100vw - 32px));max-width:760px;max-height:min(720px,calc(100vh - 48px));overflow:hidden}.group-picker-body{display:grid;grid-template-rows:auto auto minmax(180px,1fr);min-height:0;padding:1.25rem 1.5rem}.group-picker-body label{display:grid;gap:.4rem}.group-picker-body label span{font-size:.78rem;font-weight:700;color:#536177}.group-picker-help{color:#718096;font-size:.82rem;margin:.65rem 0}.group-picker-modal .group-picker-results{position:static;inset:auto;z-index:auto;min-width:0;max-height:none;overflow-x:hidden;overflow-y:auto;margin:0;padding:0;border:1px solid #d7e0ea;border-radius:.5rem;box-shadow:none;background:#fff}.group-picker-modal .group-picker-results button{display:grid;gap:.15rem;width:100%;text-align:left;padding:.85rem 1rem;border:0;border-bottom:1px solid #edf1f5;background:white;cursor:pointer}.group-picker-modal .group-picker-results button:hover,.group-picker-modal .group-picker-results button:focus{background:#eefafb}.group-picker-results small,.setup-selection small{color:#8491a5}.group-picker-empty{padding:1.25rem;text-align:center;color:#8491a5}.setup-selection{display:grid;grid-template-columns:1fr auto;gap:.2rem 1rem;padding:1rem;margin-top:.75rem;border:1px solid #89cbd3;background:#eefafb;border-radius:.5rem}.setup-selection small{grid-column:1}.setup-selection button{grid-column:2;grid-row:1/3}.setup-review{display:grid;gap:.65rem;background:#f7f9fc;border:1px solid #dce3ec;border-radius:.6rem;padding:1rem;margin-bottom:1rem}.setup-review div{display:grid;grid-template-columns:140px minmax(0,1fr);gap:1rem}.setup-review span{color:#718096}.setup-check{display:flex!important;align-items:center;grid-template-columns:auto 1fr!important}.setup-step details{margin-top:1rem}.setup-step summary{cursor:pointer;font-weight:700;color:#536177;margin-bottom:1rem}@media(max-width:700px){.setup-grid{grid-template-columns:1fr}.setup-progress{grid-template-columns:1fr}.setup-progress span:not(.active){display:none}}
  </style>
