---
import WhatsAppLayout from "../../layouts/WhatsAppLayout.astro";
---

<WhatsAppLayout title="WhatsApp Settings" description="Global safety controls, pacing, retries, and acknowledgement policy." page="settings">
  <section class="wa-connection-grid"><article class="wa-panel"><h2>Delivery policy</h2><p>These controls apply before any producer can publish live jobs.</p><form id="settings-form" class="wa-form-grid">
    <label><span>Delay between sends (ms)</span><input class="input input-bordered input-sm" type="number" min="0" max="60000" id="send-delay" required /></label><label><span>Acknowledgement timeout (seconds)</span><input class="input input-bordered input-sm" type="number" min="5" max="180" id="ack-timeout" required /></label><label><span>Maximum worker retries</span><input class="input input-bordered input-sm" type="number" min="1" max="10" id="max-retries" required /></label><div></div>
    <div class="full"><div class="wa-switch-row"><div><strong>Require dispatch preview</strong><small>Users must inspect a frozen recipient plan before live publishing.</small></div><input class="toggle toggle-sm" type="checkbox" id="require-preview" /></div><div class="wa-switch-row"><div><strong>Enable live delivery</strong><small>Global kill switch. Keep disabled while building and validating routes.</small></div><input class="toggle toggle-sm toggle-error" type="checkbox" id="live-delivery" /></div></div>
    <div class="wa-panel-actions full"><button class="btn btn-sm btn-primary" type="submit">Save settings</button></div>
  </form></article><aside class="wa-panel"><h2>Safety model</h2><div class="wa-detail-list"><div class="wa-detail-row"><span>Dry run/report generation</span><strong>No delivery</strong></div><div class="wa-detail-row"><span>Officer mapping</span><strong>Validate selected routes only</strong></div><div class="wa-detail-row"><span>Wing routing</span><strong>Exact match required</strong></div><div class="wa-detail-row"><span>Unmapped schools</span><strong>Quarantine</strong></div></div></aside></section>
  <script>
    import { actions } from "astro:actions"; import { confirmAction, showError, showSuccess } from "../../scripts/alerts"; const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T; let initialLive=false;
    async function load(){try{const result=await actions.whatsapp.settings();if(result.error)throw result.error;const data=(result.data as any).settings;el<HTMLInputElement>("send-delay").value=String(data.send_delay_ms);el<HTMLInputElement>("ack-timeout").value=String(data.acknowledgement_timeout_seconds);el<HTMLInputElement>("max-retries").value=String(data.max_retries);el<HTMLInputElement>("require-preview").checked=data.require_preview;el<HTMLInputElement>("live-delivery").checked=data.live_delivery_enabled;initialLive=data.live_delivery_enabled;}catch(error){await showError(error);}}
    el("settings-form").addEventListener("submit",async(event)=>{event.preventDefault();const enabling=!initialLive&&el<HTMLInputElement>("live-delivery").checked;if(enabling&&!await confirmAction("Enable live WhatsApp delivery?","This permits approved actions to publish real messages. Preview and wing validation still apply.","Enable live delivery"))return;try{const result=await actions.whatsapp.updateSettings({send_delay_ms:Number(el<HTMLInputElement>("send-delay").value),acknowledgement_timeout_seconds:Number(el<HTMLInputElement>("ack-timeout").value),max_retries:Number(el<HTMLInputElement>("max-retries").value),require_preview:el<HTMLInputElement>("require-preview").checked,live_delivery_enabled:el<HTMLInputElement>("live-delivery").checked});if(result.error)throw result.error;initialLive=(result.data as any).live_delivery_enabled;await showSuccess("Settings saved","WhatsApp delivery policy has been updated.");}catch(error){await showError(error);}});void load();
  </script>
</WhatsAppLayout>
