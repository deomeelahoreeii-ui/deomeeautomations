---
import DataTable from "../../components/DataTable.astro";
import WhatsAppRoutingNav from "../../components/WhatsAppRoutingNav.astro";
import WhatsAppLayout from "../../layouts/WhatsAppLayout.astro";
---

<WhatsAppLayout title="Report Types" description="Module-specific report contracts used by dispatch profiles and templates." page="routing">
  <button class="btn btn-sm btn-primary" id="add-report-type" slot="actions">＋ Add report type</button>
  <WhatsAppRoutingNav active="report-types" />
  <div class="toolbar"><select class="select select-bordered select-sm" id="report-application"><option value="">All modules</option></select><span class="toolbar-status" id="report-total">Loading…</span></div>
  <article class="master-card"><DataTable id="report-types-table" pageSize={10} emptyText="No report types are configured." /></article>
  <dialog class="modal" id="report-dialog"><div class="modal-box master-modal"><div class="modal-title"><h2 id="report-title">Add report type</h2><button type="button" id="close-report">×</button></div><form class="master-form" id="report-form">
    <input type="hidden" id="report-id" /><label><span>Platform module *</span><select class="select select-bordered select-sm" id="report-module" required></select></label><label><span>Status</span><select class="select select-bordered select-sm" id="report-enabled"><option value="true">Enabled</option><option value="false">Archived</option></select></label><label><span>Name *</span><input class="input input-bordered input-sm" id="report-name" required /></label><label><span>Stable key *</span><input class="input input-bordered input-sm" id="report-key" pattern="[a-z0-9_]+" required /></label><label><span>Artifact kind</span><select class="select select-bordered select-sm" id="report-artifact"><option value="document">Document</option><option value="workbook">Workbook</option><option value="pdf">PDF</option><option value="message">Message only</option></select></label><label class="full"><span>Description</span><textarea class="textarea textarea-bordered textarea-sm" id="report-description" rows="4"></textarea></label><div class="form-actions"><button class="btn btn-sm" type="button" id="cancel-report">Cancel</button><button class="btn btn-sm btn-primary" type="submit">Save report type</button></div>
  </form></div><form method="dialog" class="modal-backdrop"><button>close</button></form></dialog>
  <script>
    import { actions } from "astro:actions";import{actionButtons,badge,stack}from"../../scripts/table-cells";import{confirmAction,showError,showSuccess}from"../../scripts/alerts";
    await customElements.whenDefined("astro-data-table");const table=document.getElementById("report-types-table") as any;const dialog=document.getElementById("report-dialog") as HTMLDialogElement;const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T;let options:any;let records:any[]=[];
    function populate(){const html=options.applications.filter((item:any)=>item.enabled).map((item:any)=>`<option value="${item.id}">${item.name}</option>`).join("");el<HTMLSelectElement>("report-module").innerHTML=html;el<HTMLSelectElement>("report-application").innerHTML=`<option value="">All modules</option>${html}`;}
    async function load(){const result=await actions.whatsapp.reportTypes({applicationId:el<HTMLSelectElement>("report-application").value});if(result.error)throw result.error;records=result.data as any[];el("report-total").textContent=`${records.length} report types`;return records;}async function refresh(){await table.setData(await load());}
    function openForm(item?:any){el<HTMLFormElement>("report-form").reset();el("report-title").textContent=item?"Edit report type":"Add report type";el<HTMLInputElement>("report-id").value=item?.id||"";el<HTMLSelectElement>("report-module").value=item?.application_id||options.applications[0]?.id||"";el<HTMLSelectElement>("report-module").disabled=Boolean(item);el<HTMLInputElement>("report-name").value=item?.name||"";el<HTMLInputElement>("report-key").value=item?.key||"";el<HTMLSelectElement>("report-artifact").value=item?.artifact_kind||"document";el<HTMLTextAreaElement>("report-description").value=item?.description||"";el<HTMLSelectElement>("report-enabled").value=String(item?.enabled??true);dialog.showModal();}
    try{const result=await actions.whatsapp.configurationOptions();if(result.error)throw result.error;options=result.data;populate();await table.configure({data:await load(),columns:[{accessorKey:"name",header:"Report type",cell:({row}:any)=>stack(row.original.name,row.original.key)},{accessorKey:"application_name",header:"Module"},{accessorKey:"artifact_kind",header:"Artifact"},{accessorKey:"template_count",header:"Templates",cell:({row}:any)=>stack(`${row.original.template_count} variants`,`${row.original.individual_template_count} individual · ${row.original.group_template_count} group`)},{accessorKey:"description",header:"Description",cell:({row}:any)=>String(row.original.description||"—").slice(0,80)},{accessorKey:"enabled",header:"Status",cell:({row}:any)=>badge(row.original.enabled?"Enabled":"Archived",row.original.enabled?"":"inactive")},{id:"actions",header:"",cell:({row}:any)=>actionButtons([{label:"Edit",onClick:()=>openForm(row.original)},{label:"Delete permanently",tone:"danger",onClick:async()=>{if(!await confirmAction("Permanently delete this report type?","Templates, profiles and previews using it will also be permanently deleted.","Delete permanently"))return;const result=await actions.whatsapp.hardDeleteReportType({id:row.original.id});if(result.error)await showError(result.error);else{await showSuccess("Report type deleted","Dependent routing configuration was removed.");await refresh();}}}])}]});}catch(error){await showError(error);}
    el("report-application").addEventListener("change",()=>void refresh());el("add-report-type").addEventListener("click",()=>openForm());el("close-report").addEventListener("click",()=>dialog.close());el("cancel-report").addEventListener("click",()=>dialog.close());el("report-form").addEventListener("submit",async(event)=>{event.preventDefault();try{const id=el<HTMLInputElement>("report-id").value;const result=await actions.whatsapp.saveReportType({id:id||undefined,application_id:el<HTMLSelectElement>("report-module").value,key:el<HTMLInputElement>("report-key").value,name:el<HTMLInputElement>("report-name").value,description:el<HTMLTextAreaElement>("report-description").value,artifact_kind:el<HTMLSelectElement>("report-artifact").value,enabled:el<HTMLSelectElement>("report-enabled").value==="true"});if(result.error)throw result.error;dialog.close();await showSuccess("Report type saved","It is now available to module-specific dispatch profiles.");await refresh();}catch(error){await showError(error);}});
  </script>
</WhatsAppLayout>
