---
import DataTable from "../../components/DataTable.astro";
import WhatsAppRoutingNav from "../../components/WhatsAppRoutingNav.astro";
import WhatsAppLayout from "../../layouts/WhatsAppLayout.astro";
---

<WhatsAppLayout title="Message Templates" description="Report messages and deterministic once-daily acknowledgement pools." page="routing">
  <button class="btn btn-sm btn-primary" id="add-template" slot="actions">＋ Add template</button>
  <WhatsAppRoutingNav active="templates" />
  <div class="notice"><strong>Zero-result acknowledgement pool</strong><br />Every enabled acknowledgement template matching the same module, report type, channel and optional scope becomes a daily variant. The platform deterministically rotates variants and sends at most once per group and scope each Asia/Karachi business day. Supported variables: <code>&#123;&#123;tehsil&#125;&#125;</code>, <code>&#123;&#123;wing&#125;&#125;</code>, <code>&#123;&#123;report_date&#125;&#125;</code>, <code>&#123;&#123;checked_at&#125;&#125;</code>, <code>&#123;&#123;group_name&#125;&#125;</code>, and <code>&#123;&#123;submission_deadline&#125;&#125;</code>.</div>
  <article class="master-card"><DataTable id="templates-table" pageSize={10} emptyText="No message templates are configured." /></article>
  <dialog class="modal" id="template-dialog"><div class="modal-box master-modal"><div class="modal-title"><h2 id="template-title">Add template</h2><button type="button" id="close-template">×</button></div><form class="master-form" id="template-form">
    <input type="hidden" id="template-id" /><label><span>Platform module</span><select class="select select-bordered select-sm" id="template-module"><option value="">Shared across modules</option></select></label><label><span>Report type</span><select class="select select-bordered select-sm" id="template-report"><option value="">All report types</option></select></label><label><span>Recipient channel</span><select class="select select-bordered select-sm" id="template-channel"><option value="individual">Individual</option><option value="group">Group</option><option value="any">Any (system templates)</option></select></label><label><span>Role / hierarchy scope</span><select class="select select-bordered select-sm" id="template-scope"><option value="">All roles / scopes in channel</option></select></label><label><span>Name *</span><input class="input input-bordered input-sm" id="template-name" required /></label><label><span>Key *</span><input class="input input-bordered input-sm" id="template-key" placeholder="antidengue_report" required /></label><label><span>Category</span><select class="select select-bordered select-sm" id="template-category"><option value="report">Report</option><option value="zero_result_acknowledgement">Zero-result acknowledgement</option><option value="system">System</option><option value="escalation">Escalation</option></select></label><label><span>Status</span><select class="select select-bordered select-sm" id="template-enabled"><option value="true">Enabled</option><option value="false">Archived</option></select></label><label class="full"><span>Message body *</span><textarea class="textarea textarea-bordered textarea-sm" rows="8" id="template-body" required></textarea></label><div class="form-actions"><button class="btn btn-sm" type="button" id="cancel-template">Cancel</button><button class="btn btn-sm btn-primary" type="submit">Save template</button></div>
  </form></div><form method="dialog" class="modal-backdrop"><button>close</button></form></dialog>
  <script>
    import { actions } from "astro:actions"; import { actionButtons, badge, stack } from "../../scripts/table-cells"; import { confirmAction, showError, showSuccess } from "../../scripts/alerts";
    await customElements.whenDefined("astro-data-table"); const table=document.getElementById("templates-table") as any; const dialog=document.getElementById("template-dialog") as HTMLDialogElement; const el=<T extends HTMLElement>(id:string)=>document.getElementById(id) as T; let options:any;
    async function load(){const result=await actions.whatsapp.templates();if(result.error)throw result.error;return result.data as any[];} async function refresh(){try{await table.setData(await load());}catch(error){await showError(error);}}
    function populateReports(selected=""){const applicationId=el<HTMLSelectElement>("template-module").value;const reports=options.report_types.filter((item:any)=>item.application_id===applicationId);el<HTMLSelectElement>("template-report").innerHTML=`<option value="">All report types</option>${reports.map((item:any)=>`<option value="${item.id}">${item.name}</option>`).join("")}`;el<HTMLSelectElement>("template-report").value=selected;}
    function populateScopes(selected=""){const applicationId=el<HTMLSelectElement>("template-module").value;const channel=el<HTMLSelectElement>("template-channel").value;const scopes=options.recipient_scopes.filter((item:any)=>item.application_id===applicationId&&item.channel===channel);el<HTMLSelectElement>("template-scope").innerHTML=`<option value="">All roles / scopes in channel</option>${scopes.map((item:any)=>`<option value="${item.id}">${item.name}</option>`).join("")}`;el<HTMLSelectElement>("template-scope").value=selected;el<HTMLSelectElement>("template-scope").disabled=channel==="any";}
    function openForm(item?:any){el<HTMLFormElement>("template-form").reset();el("template-title").textContent=item?"Edit template":"Add template";el<HTMLInputElement>("template-id").value=item?.id||"";el<HTMLSelectElement>("template-module").value=item?.application_id||"";el<HTMLSelectElement>("template-channel").value=item?.recipient_channel||(item?.category==="system"?"any":"group");populateReports(item?.report_type_id||"");populateScopes(item?.recipient_scope_id||"");el<HTMLInputElement>("template-name").value=item?.name||"";el<HTMLInputElement>("template-key").value=item?.key||"";el<HTMLSelectElement>("template-category").value=item?.category||"report";el<HTMLSelectElement>("template-enabled").value=String(item?.enabled??true);el<HTMLTextAreaElement>("template-body").value=item?.body||"";dialog.showModal();}
    const optionsResult=await actions.whatsapp.configurationOptions();if(optionsResult.error)await showError(optionsResult.error);else{options=optionsResult.data;el<HTMLSelectElement>("template-module").innerHTML=`<option value="">Shared across modules</option>${options.applications.map((item:any)=>`<option value="${item.id}">${item.name}</option>`).join("")}`;}el("template-module").addEventListener("change",()=>{populateReports();populateScopes();});el("template-channel").addEventListener("change",()=>populateScopes());
    await table.configure({data:await load(),columns:[{accessorKey:"name",header:"Template",cell:({row}:any)=>stack(row.original.name,row.original.key)},{accessorKey:"application_name",header:"Module / report",cell:({row}:any)=>stack(row.original.application_name,row.original.report_type_name)},{accessorKey:"recipient_channel",header:"Recipients",cell:({row}:any)=>stack(row.original.recipient_channel,row.original.recipient_scope_name)},{accessorKey:"category",header:"Category"},{accessorKey:"body",header:"Preview",cell:({row}:any)=>String(row.original.body).slice(0,90)},{accessorKey:"enabled",header:"Status",cell:({row}:any)=>badge(row.original.enabled?"Enabled":"Archived",row.original.enabled?"":"inactive")},{id:"actions",header:"",cell:({row}:any)=>actionButtons([{label:"Edit",onClick:()=>openForm(row.original)},{label:"Delete permanently",tone:"danger",onClick:async()=>{if(!await confirmAction("Permanently delete this template?","Profiles using it will be disabled.","Delete permanently"))return;const result=await actions.whatsapp.hardDeleteTemplate({id:row.original.id});if(result.error)await showError(result.error);else{await showSuccess("Template deleted","Dependent profiles were disabled.");await refresh();}}}])}]});
    el("add-template").addEventListener("click",()=>openForm());el("close-template").addEventListener("click",()=>dialog.close());el("cancel-template").addEventListener("click",()=>dialog.close());el("template-form").addEventListener("submit",async(event)=>{event.preventDefault();try{const id=el<HTMLInputElement>("template-id").value;const application=el<HTMLSelectElement>("template-module").value;const report=el<HTMLSelectElement>("template-report").value;const scope=el<HTMLSelectElement>("template-scope").value;const result=await actions.whatsapp.saveTemplate({id:id||undefined,application_id:application||undefined,report_type_id:report||undefined,recipient_channel:el<HTMLSelectElement>("template-channel").value as any,recipient_scope_id:scope||undefined,key:el<HTMLInputElement>("template-key").value,name:el<HTMLInputElement>("template-name").value,category:el<HTMLSelectElement>("template-category").value,body:el<HTMLTextAreaElement>("template-body").value,enabled:el<HTMLSelectElement>("template-enabled").value==="true"});if(result.error)throw result.error;dialog.close();await showSuccess("Template saved","The message content is scoped to its report, channel and optional recipient role.");const configured=await actions.whatsapp.configurationOptions();if(!configured.error)options=configured.data;await refresh();}catch(error){await showError(error);}});
  </script>
</WhatsAppLayout>
