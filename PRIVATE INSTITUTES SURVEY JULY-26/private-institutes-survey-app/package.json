{
  "name": "private-institutes-survey-app",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:production": "bun scripts/build-production.ts",
    "deploy:production": "bun scripts/build-production.ts && bun scripts/patch-production-wrangler.ts && bun x wrangler deploy --config dist/server/wrangler.json",
    "db:local:apply": "wrangler d1 execute private_institutes_survey_production_db --local --file schema.sql",
    "db:production:apply": "wrangler d1 execute private_institutes_survey_production_db --remote --file schema.sql",
    "db:production:migrate": "wrangler d1 execute private_institutes_survey_production_db --remote --file migrations/20260701_add_location_wing_fields.sql",
    "db:production:migrate:20260702": "wrangler d1 execute private_institutes_survey_production_db --remote --file migrations/20260702_split_uc_quran_add_zonal_heads.sql",
    "db:production:migrate:20260703": "wrangler d1 execute private_institutes_survey_production_db --remote --file migrations/20260703_add_se_submission_flow_fields.sql",
    "db:production:reset-clean": "wrangler d1 execute private_institutes_survey_production_db --remote --file migrations/20260702_reset_clean_schema.sql",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@clerk/astro": "^3.4.11",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^6.4.8",
    "daisyui": "^5.6.6",
    "sweetalert2": "^11.26.25",
    "tailwindcss": "^4.3.2",
    "wrangler": "^4.106.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
