---
import type { SurveyField } from "../../config/survey";

type Props = {
  field: SurveyField;
};

const { field } = Astro.props;
---

<label class="survey-field xl:col-span-2">
  <span class="survey-label">{field.label} {field.required && <span>*</span>}</span>
  <input
    class="survey-file-input"
    accept="image/png,image/jpeg,image/webp"
    data-image-upload
    data-image-field={field.name}
    name={`${field.name}_file`}
    required={field.required}
    type="file"
  />
  <span class="text-xs font-semibold text-slate-500">
    Select from gallery. JPG, PNG, or WEBP only. Maximum 2 MB.
  </span>
</label>
