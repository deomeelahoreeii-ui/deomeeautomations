---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { isAuthEnabled, requireApprovedAdmin } from "../../lib/admin-auth";
import { buildAeoRecordsUrl, getAeoDistribution } from "../../lib/admin-aeo-distribution";
import { getDb } from "../../lib/d1";

export const prerender = false;

const adminAuth = await requireApprovedAdmin(Astro);
if (!adminAuth.authorized) {
  return adminAuth.response;
}

const authEnabled = isAuthEnabled();
const db = getDb(Astro);

function displayValue(value: unknown): string {
  const cleaned = String(value ?? "").trim();
  return cleaned.length > 0 ? cleaned : "Not available";
}

function formatNumber(value: unknown): string {
  const number = Number(value ?? 0);
  return new Intl.NumberFormat("en-PK").format(Number.isFinite(number) ? number : 0);
}

function formatPercent(value: number): string {
  return `${Number.isFinite(value) ? value.toFixed(1) : "0.0"}%`;
}

const distribution = await getAeoDistribution(db);
const totalAeoSubmissions = distribution.reduce((sum, row) => sum + Number(row.total ?? 0), 0);
const assignedAeoGroups = distribution.filter((row) => displayValue(row.aeo_name) !== "Not assigned").length;
const attentionRecords = distribution.reduce((sum, row) => sum + Number(row.attention_records ?? 0), 0);
const facilityGapRecords = distribution.reduce((sum, row) => sum + Number(row.facility_gap_records ?? 0), 0);
---

<Layout>
  <main class="min-h-screen bg-[#f3f6fb] px-4 py-5 text-slate-950 sm:px-6 lg:px-8">
    <section class="mx-auto w-full max-w-7xl space-y-5">
      <header class="overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm">
        <div class="grid gap-0 xl:grid-cols-[1fr_auto]">
          <div class="px-5 py-6 sm:px-7">
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-full bg-sky-100 px-3 py-1 text-xs font-black uppercase tracking-wide text-sky-800">Admin</span>
              <span class="rounded-full bg-indigo-100 px-3 py-1 text-xs font-black uppercase tracking-wide text-indigo-800">AEO Wise</span>
              {!authEnabled && (
                <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-black uppercase tracking-wide text-amber-800">Auth disabled</span>
              )}
            </div>
            <h1 class="mt-4 text-3xl font-black tracking-normal text-slate-950 sm:text-4xl">
              AEO Submission Distribution
            </h1>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600 sm:text-base">
              Track submitted private institute records by AEO, reporting wing, tehsil coverage, and data quality signals.
            </p>
          </div>
          <div class="flex flex-wrap items-end gap-2 border-t border-slate-200 bg-slate-950 px-5 py-5 xl:border-l xl:border-t-0 xl:px-6">
            <a class="btn min-h-11 rounded-xl border-white/10 bg-white/10 text-white hover:bg-white/20" href="/admin">
              Back to Dashboard
            </a>
            <a class="btn min-h-11 rounded-xl border-0 bg-sky-500 text-white hover:bg-sky-600" href="/api/admin/aeo-distribution?format=csv">
              Download CSV
            </a>
          </div>
        </div>
      </header>

      <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-[1.25rem] border border-slate-200 bg-white p-5 shadow-sm">
          <div class="text-sm font-bold text-slate-500">AEO-tracked Records</div>
          <div class="mt-3 text-4xl font-black text-slate-950">{formatNumber(totalAeoSubmissions)}</div>
        </div>
        <div class="rounded-[1.25rem] border border-slate-200 bg-white p-5 shadow-sm">
          <div class="text-sm font-bold text-slate-500">AEO Groups</div>
          <div class="mt-3 text-4xl font-black text-sky-700">{formatNumber(assignedAeoGroups)}</div>
        </div>
        <div class="rounded-[1.25rem] border border-amber-200 bg-amber-50 p-5 shadow-sm">
          <div class="text-sm font-bold text-amber-700">Registration Attention</div>
          <div class="mt-3 text-4xl font-black text-amber-900">{formatNumber(attentionRecords)}</div>
        </div>
        <div class="rounded-[1.25rem] border border-rose-200 bg-rose-50 p-5 shadow-sm">
          <div class="text-sm font-bold text-rose-700">Facility Gap Records</div>
          <div class="mt-3 text-4xl font-black text-rose-900">{formatNumber(facilityGapRecords)}</div>
        </div>
      </section>

      <section class="rounded-[1.25rem] border border-slate-200 bg-white shadow-sm">
        <div class="flex flex-col gap-3 border-b border-slate-200 p-5 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-xs font-black uppercase tracking-wide text-sky-700">Distribution</p>
            <h2 class="mt-1 text-2xl font-black tracking-normal">AEO-wise Submission Ownership</h2>
          </div>
          <a class="btn min-h-11 rounded-xl border-slate-300 bg-white px-4 text-slate-700 hover:bg-slate-100" href="/api/admin/aeo-distribution?format=csv">
            Download table
          </a>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full min-w-[980px] text-left text-sm">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50 text-xs font-black uppercase tracking-wide text-slate-500">
                <th class="px-5 py-3">#</th>
                <th class="px-3 py-3">AEO</th>
                <th class="px-3 py-3">Wing</th>
                <th class="px-3 py-3">Submitted</th>
                <th class="px-3 py-3">Share</th>
                <th class="px-3 py-3">Students</th>
                <th class="px-3 py-3">Teachers</th>
                <th class="px-3 py-3">Registered</th>
                <th class="px-3 py-3">Issues</th>
                <th class="px-5 py-3">Tehsils</th>
              </tr>
            </thead>
            <tbody>
              {distribution.length === 0 ? (
                <tr>
                  <td class="px-5 py-8 text-slate-500" colspan="10">No AEO-linked records are available yet.</td>
                </tr>
              ) : (
                distribution.map((row, index) => {
                  const share = totalAeoSubmissions > 0 ? (row.total / totalAeoSubmissions) * 100 : 0;
                  const issues = Number(row.attention_records ?? 0) + Number(row.facility_gap_records ?? 0);
                  const recordsUrl = buildAeoRecordsUrl("/admin/aeo-records", {
                    aeoName: displayValue(row.aeo_name),
                    reportingWing: displayValue(row.reporting_wing),
                  });
                  return (
                    <tr class="border-b border-slate-100 align-top last:border-0">
                      <th class="px-5 py-4 text-slate-500">{index + 1}</th>
                      <td class="min-w-72 px-3 py-4">
                        <div class="flex items-center gap-3">
                          <a
                            class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-sky-200 bg-sky-50 text-sky-700 shadow-sm hover:border-sky-300 hover:bg-sky-100"
                            href={recordsUrl}
                            aria-label={`Open institute records for ${displayValue(row.aeo_name)}`}
                            title="Open institute records"
                          >
                            <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M8 6h13" />
                              <path d="M8 12h13" />
                              <path d="M8 18h13" />
                              <path d="M3 6h.01" />
                              <path d="M3 12h.01" />
                              <path d="M3 18h.01" />
                            </svg>
                          </a>
                          <div class="font-black leading-snug text-slate-950">{displayValue(row.aeo_name)}</div>
                        </div>
                      </td>
                      <td class="px-3 py-4">
                        <span class="rounded-full bg-indigo-100 px-2.5 py-1 text-xs font-black text-indigo-800">
                          {displayValue(row.reporting_wing)}
                        </span>
                      </td>
                      <td class="px-3 py-4 font-black">{formatNumber(row.total)}</td>
                      <td class="min-w-44 px-3 py-4">
                        <div class="flex items-center gap-3">
                          <div class="h-2 flex-1 overflow-hidden rounded-full bg-slate-100">
                            <div class="h-full rounded-full bg-sky-500" style={`width: ${Math.max(2, share)}%`}></div>
                          </div>
                          <span class="w-14 text-right text-xs font-black text-slate-600">{formatPercent(share)}</span>
                        </div>
                      </td>
                      <td class="px-3 py-4 text-slate-600">{formatNumber(row.students)}</td>
                      <td class="px-3 py-4 text-slate-600">{formatNumber(row.teachers)}</td>
                      <td class="px-3 py-4">
                        <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-black text-emerald-800">
                          {formatNumber(row.registered)}
                        </span>
                      </td>
                      <td class="px-3 py-4">
                        <span class:list={[
                          "rounded-full px-2.5 py-1 text-xs font-black",
                          issues > 0 ? "bg-rose-100 text-rose-800" : "bg-slate-100 text-slate-600",
                        ]}>
                          {formatNumber(issues)}
                        </span>
                      </td>
                      <td class="min-w-72 px-5 py-4 text-xs font-semibold leading-5 text-slate-500">
                        {displayValue(row.tehsils)}
                      </td>
                    </tr>
                  );
                })
              )}
            </tbody>
          </table>
        </div>
      </section>
    </section>
  </main>
</Layout>
