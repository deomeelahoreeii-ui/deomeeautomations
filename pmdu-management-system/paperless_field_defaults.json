{
  "defaults": {
    "Complaint Number": "{complaint_code}",
    "Revision": "{version}",
    "Source": "{source_label}",
    "Direction": "Incoming"
  },
  "main_complaint": {
    "Document Role": "Main Complaint",
    "Status": "Pending",
    "Complainant Name": "{identity.citizen_name}",
    "Complainant Mobile Number": "{identity.citizen_contact}",
    "Complainant CNIC": "{identity.citizen_cnic}",
    "Complainant Address": "{identity.address}",
    "District": "{identity.district}",
    "Tehsil": "{identity.tehsil}",
    "Department": "School Education Department",
    "Complaint Category": null,
    "Complaint Sub-Category": null,
    "Complaint Attachments": null,
    "Remarks": "{complaint_remarks}"
  },
  "attachment": {
    "Document Role": "Complaint Details",
    "Parent Case": "{parent_document_id}"
  },
  "clear_fields": {
    "main_complaint": ["Parent Case"],
    "attachment": ["Status", "Complaint Attachments"]
  },
  "filters": {
    "roles": ["main_complaint", "attachment"],
    "paperless_added_date": null,
    "paperless_created_date": null,
    "complaint_codes": []
  },
  "field_mappings": {
    "Tehsil": {
      "Lahore City": "City",
      "Lahore Cantt": "Cantt"
    }
  }
}
