NATS_URL=nats://localhost:4222
NATS_STREAM=pending_stream
NATS_SUBJECT=whatsapp.pending
NATS_CONSUMER_NAME=whatsapp_worker_1
NATS_DEAD_LETTER_STREAM=whatsapp_dead_stream
NATS_DEAD_LETTER_SUBJECT=whatsapp.dead
NATS_ACK_WAIT_MS=120000
NATS_MAX_DELIVER=5
NATS_NAK_DELAY_MS=5000

WA_AUTH_DIR=auth_info_baileys
WA_ENABLE_GROUP_DISCOVERY=true
WA_GROUPS_FILE=data/discovered-groups.csv
WA_GROUP_METADATA_FAILURE_COOLDOWN_MS=60000
WA_GROUP_METADATA_MIN_INTERVAL_MS=1500
WA_GROUP_METADATA_RATELIMIT_COOLDOWN_MS=300000
WA_RECONNECT_DELAY_MS=5000
WA_STARTUP_DELAY_MS=5000
WA_SEND_DELAY_MS=1500
WA_BROWSER_PLATFORM=Windows
WA_BROWSER_NAME=Chrome
WA_BROWSER_VERSION=122.0.0.0
LOG_LEVEL=info
