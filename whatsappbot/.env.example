NATS_URL=nats://localhost:4222
NATS_STREAM=pending_stream
NATS_SUBJECT=whatsapp.pending
NATS_HEALTH_SUBJECT=whatsapp.worker.health
NATS_GROUP_MEMBERS_SUBJECT=whatsapp.worker.group-members
NATS_CONSUMER_NAME=whatsapp_worker_1
NATS_DEAD_LETTER_STREAM=whatsapp_dead_stream
NATS_DEAD_LETTER_SUBJECT=whatsapp.dead
NATS_ACK_WAIT_MS=120000
NATS_MAX_DELIVER=5
NATS_NAK_DELAY_MS=5000

WA_AUTH_DIR=auth_info_baileys
WA_WORKER_ID=default
WA_ALLOW_DIRECT_GROUP_ADDS=false
WA_WORKER_LOCK_FILE=data/worker.lock
WA_ENABLE_GROUP_DISCOVERY=true
WA_GROUPS_FILE=data/discovered-groups.csv
WA_QR_IMAGE_PATH=data/whatsapp-login-qr.png
WA_GROUP_METADATA_FAILURE_COOLDOWN_MS=60000
WA_GROUP_METADATA_MIN_INTERVAL_MS=1500
WA_GROUP_METADATA_RATELIMIT_COOLDOWN_MS=300000
WA_RECONNECT_DELAY_MS=5000
WA_STARTUP_DELAY_MS=5000
WA_SEND_DELAY_MS=1500
WA_BROWSER_PLATFORM=Windows
WA_BROWSER_NAME=Chrome
LOG_LEVEL=info

# Durable inbound message capture foundation
WA_ENABLE_INBOUND_CAPTURE=true
WA_INBOUND_STORE_PATH=data/whatsapp-inbound-default.sqlite
WA_PLATFORM_URL=http://127.0.0.1:8020
WA_PLATFORM_INGEST_TOKEN=replace-with-the-same-long-random-secret
WA_PLATFORM_TIMEOUT_MS=10000
WA_INBOUND_OUTBOX_FLUSH_MS=5000
WA_INBOUND_OUTBOX_BATCH_SIZE=100
# On-demand media export requests from the platform.
WA_INBOUND_MEDIA_SUBJECT=whatsapp.worker.inbound.media
WA_INBOUND_MEDIA_MAX_BYTES=78643200
WA_INBOUND_MEDIA_UPLOAD_TIMEOUT_MS=180000
# Controlled on-demand history sync. Each request is capped to protect the linked account.
WA_INBOUND_HISTORY_SUBJECT=whatsapp.worker.inbound.history
WA_INBOUND_HISTORY_MAX_COUNT=200
