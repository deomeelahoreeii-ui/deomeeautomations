# Must match whatsapp_accounts.worker_key and the Baileys worker id.
WWEBJS_WORKER_ID=default
NATS_URL=nats://127.0.0.1:4222
WWEBJS_HISTORY_SUBJECT=whatsapp.web.inbound.history

# Normal historical retrieval mode. whatsapp-web.js launches and owns one Brave
# page from a private snapshot of the real profile where the files are visible.
# Before first use, close normal Brave and run:
#   ./scripts/launch-brave-debug.sh
WWEBJS_MODE=visible_profile
WWEBJS_VISIBLE_USER_DATA_DIR=~/.local/share/deomee-wwebjs-brave-visible
# Usually discovered automatically by the snapshot script (for example Profile 1).
WWEBJS_VISIBLE_PROFILE_DIRECTORY=
WWEBJS_VISIBLE_PROFILE_METADATA=data/visible-profile.json
WWEBJS_BROWSER_EXECUTABLE=/usr/bin/brave
WWEBJS_HEADLESS=false

# Preserved experimental modes. Both are blocked for history unless explicitly
# allowed because they do not guarantee the visible-profile history contract.
WWEBJS_ALLOW_LOCAL_AUTH_HISTORY=false
WWEBJS_ALLOW_BROWSER_URL_HISTORY=false
WWEBJS_BROWSER_URL=http://127.0.0.1:9222
WWEBJS_AUTH_PATH=data/auth
WWEBJS_QR_PATH=data/login-qr.png
WWEBJS_STATE_PATH=data/history-state.json
WWEBJS_LOCK_PATH=data/bridge.lock
WWEBJS_CLIENT_ID=deomee-default

WWEBJS_MAX_HISTORY_COUNT=5000
WWEBJS_MAX_MESSAGES_SCANNED=5000
WWEBJS_REQUEST_TIMEOUT_MS=600000
WWEBJS_FETCH_ATTEMPT_TIMEOUT_MS=120000
WWEBJS_PAGE_RECOVERY_TIMEOUT_MS=30000
WWEBJS_SYNC_HISTORY=true
WWEBJS_SYNC_HISTORY_TIMEOUT_MS=30000
WWEBJS_SYNC_SETTLE_MS=3500
WWEBJS_MEDIA_MAX_BYTES=78643200

# Same platform URL/token used by whatsappbot inbound capture.
WWEBJS_PLATFORM_URL=http://127.0.0.1:8020
WWEBJS_PLATFORM_TOKEN=change-me
WWEBJS_PLATFORM_TIMEOUT_MS=180000
LOG_LEVEL=info
