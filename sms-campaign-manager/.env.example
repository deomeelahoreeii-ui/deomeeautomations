# Never commit real credentials. Rotate any password exposed in screenshots/chat.
# Private server URLs require /api. If the sender runs on the same host as
# the SMSGate server, prefer localhost over the Tailscale hostname.
SMS_GATE_BASE_URL=http://127.0.0.1:3000/api
SMS_GATE_USERNAME=your-username
SMS_GATE_PASSWORD=your-password
SMS_GATE_DEVICE_ID=your-device-id
SMS_GATE_DATABASE=data/sms-campaigns.sqlite3
SMS_GATE_DEVICE_MAX_AGE_SECONDS=120
SMS_GATE_DEVICE_ONLINE_TIMEOUT_SECONDS=900
